oc:kn_2386685d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting long documents to audio" ;
    oc:directiveContent "gTTS has a character limit of approximately 5000 characters per API request. Long text must be split into chunks at sentence boundaries." ;
    oc:hasRationale "Exceeding the character limit causes API errors; sentence-boundary splitting preserves natural speech flow" ;
    oc:severityLevel "HIGH" .

oc:kn_981bd058 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When chunking text for TTS processing" ;
    oc:directiveContent "Never split text at arbitrary character boundaries. Always split at sentence boundaries using regex like (?<=[.!?])\\s+ to avoid cutting words mid-sentence." ;
    oc:hasRationale "Splitting mid-sentence produces unnatural pauses and broken speech output" ;
    oc:severityLevel "HIGH" .

oc:kn_a339f1d4 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When executing TTS conversion" ;
    oc:directiveContent "gTTS requires an active internet connection and may have rate limits for heavy usage. Handle network errors gracefully." ;
    oc:hasRationale "Since gTTS uses Google's servers, network failures will halt processing mid-conversion" ;
    oc:severityLevel "HIGH" .

oc:kn_b9c18b43 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When generating speech output" ;
    oc:directiveContent "Use slow=False for natural speech speed. Add brief pauses between chapters or sections for better listening experience." ;
    oc:hasRationale "Default slow speed sounds unnatural; pauses improve comprehension in long-form audio" ;
    oc:severityLevel "MEDIUM" .

oc:kn_dae0b8bd a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When processing long text with chunking" ;
    oc:directiveContent "Creates temporary MP3 files during chunk processing that must be cleaned up after concatenation." ;
    oc:hasRationale "Temp files consume disk space and can accumulate if not properly deleted" ;
    oc:severityLevel "MEDIUM" .

oc:kn_e8d098a3 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before first use" ;
    oc:directiveContent "Install gtts and pydub via: pip install gtts pydub. pydub is needed for audio segment concatenation." ;
    oc:hasRationale "gtts handles TTS generation; pydub handles audio file manipulation and concatenation" .

