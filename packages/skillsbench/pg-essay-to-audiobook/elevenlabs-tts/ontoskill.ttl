oc:kn_0bcd53c9 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When authenticating with the ElevenLabs API" ;
    oc:directiveContent "The ELEVENLABS_API_KEY must be kept secure and passed via the xi-api-key header, never hardcoded." ;
    oc:hasRationale "Exposed API keys can lead to unauthorized usage and credit exhaustion" ;
    oc:severityLevel "HIGH" .

oc:kn_2b35176d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When synthesizing text longer than ~5000 characters" ;
    oc:directiveContent "ElevenLabs has a ~5000 character limit per request. Text exceeding this must be split into chunks at sentence boundaries." ;
    oc:hasRationale "Exceeding the character limit causes API errors; splitting at sentence boundaries avoids cutting words mid-speech" ;
    oc:severityLevel "CRITICAL" .

oc:kn_d25b0de7 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "On every text-to-speech API call" ;
    oc:directiveContent "Each API call consumes ElevenLabs API credits and produces an MP3 audio file on disk." ;
    oc:hasRationale "Agents should be aware of credit consumption and disk space usage to avoid unexpected costs" .

oc:kn_d59bd769 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When making repeated TTS requests" ;
    oc:directiveContent "Cache generated audio to avoid redundant API calls. Rate limits vary by subscription tier." ;
    oc:hasRationale "Caching reduces API costs and avoids hitting rate limits that vary by subscription tier" ;
    oc:severityLevel "MEDIUM" .

oc:kn_d67da6e5 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When handling long documents for TTS conversion" ;
    oc:directiveContent "Split long text at sentence boundaries, generate audio per chunk, then concatenate with ffmpeg or pydub." ;
    oc:hasRationale "Sentence-boundary splitting preserves natural speech cadence and avoids garbled audio at chunk boundaries" ;
    oc:severityLevel "HIGH" .

