oc:kn_471aa603 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When retrying or regenerating audio" ;
    oc:directiveContent "TTS generation is NOT idempotent — repeated calls with same input may produce slightly different audio output." ;
    oc:hasRationale "Neural TTS models can produce slight variations between calls" ;
    oc:severityLevel "LOW" .

oc:kn_5fa5f89b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When wanting to control speech tone or style" ;
    oc:directiveContent "The instructions parameter for tone/style control is only available with the gpt-4o-mini-tts model." ;
    oc:hasRationale "Older models (tts-1, tts-1-hd) do not support the instructions parameter" ;
    oc:severityLevel "HIGH" .

oc:kn_6a92022e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting long text to audio" ;
    oc:directiveContent "For long documents, split text into chunks at sentence boundaries with a max of ~4000 characters per chunk, then concatenate audio segments using pydub." ;
    oc:hasRationale "The TTS API has input length limits; sentence-boundary splitting preserves natural speech cadence across chunk boundaries" ;
    oc:severityLevel "HIGH" .

oc:kn_8966f467 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting voice and model for TTS generation" ;
    oc:directiveContent "Use marin or cedar voices for best quality; use gpt-4o-mini-tts model for newest and most reliable results with tone/style support." ;
    oc:hasRationale "Voice and model selection directly impacts output quality and available features like tone control" ;
    oc:severityLevel "MEDIUM" .

oc:kn_bc81402d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using tts-1 or tts-1-hd models" ;
    oc:directiveContent "tts-1 and tts-1-hd models only support voices: alloy, ash, coral, echo, fable, onyx, nova, sage, shimmer. They do NOT support marin, cedar, ballad, or verse." ;
    oc:hasRationale "Using unsupported voices will cause API errors" ;
    oc:severityLevel "HIGH" .

