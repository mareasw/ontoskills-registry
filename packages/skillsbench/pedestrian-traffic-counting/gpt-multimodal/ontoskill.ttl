oc:kn_2d82a180 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When estimating costs for image analysis requests" ;
    oc:directiveContent "High-detail images are scaled to fit 2048×2048, divided into 512×512 tiles, each costing 170 tokens plus 85 base tokens. For batch video frame processing, use batch_size=5 with low detail." ;
    oc:hasRationale "Understanding token costs enables budget planning and optimization" .

oc:kn_60fb1238 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When crafting vision analysis prompts" ;
    oc:directiveContent "Be specific in prompts ('Count people wearing red shirts' vs 'Analyze this image'), request structured JSON output when appropriate, provide context about the image, and order images logically in multi-image requests." ;
    oc:hasRationale "Specific prompts yield more targeted and useful responses from vision models" .

oc:kn_77d06767 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring detail_level parameter" ;
    oc:directiveContent "Use detail='low' for video frames/color/shape detection, detail='high' for text extraction/fine-grained analysis, detail='auto' when unsure. Limit to 10-20 images per request for best results." ;
    oc:hasRationale "Balances token cost vs analysis quality based on task requirements" .

oc:kn_b90bf855 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When preparing image inputs for API calls" ;
    oc:directiveContent "Supported file formats are JPG, JPEG, PNG, WEBP, and non-animated GIF only. Maximum 500 images per request, 50MB total payload, 20MB per image recommended." ;
    oc:hasRationale "Exceeding format or size limits will cause API rejection or errors" ;
    oc:severityLevel "CRITICAL" .

oc:kn_b9eec5ec a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When interpreting results for tasks involving OCR, counting, or spatial precision" ;
    oc:directiveContent "Vision models struggle with rotated/upside-down text, text smaller than 10pt, non-Latin scripts, precise spatial reasoning, exact object counting, and panoramic/fisheye images." ;
    oc:hasRationale "Model limitations affect reliability; results should be validated for these use cases" ;
    oc:severityLevel "MEDIUM" .

oc:kn_d3d963c9 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When API calls fail due to rate limits or token limits" ;
    oc:directiveContent "On RateLimitError, implement exponential backoff with up to 3 retries (wait 1s, 2s, 4s). On token limit errors, reduce max_tokens or switch to low detail mode." ;
    oc:hasRationale "OpenAI enforces TPM limits; exponential backoff is the recommended recovery pattern" .

oc:kn_f5f780bf a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing multiple sequential frames or performing simple scene classification" ;
    oc:directiveContent "Do not use high detail mode for video frame batches or simple classification tasks. Use low detail (~85 tokens/image) instead." ;
    oc:hasRationale "High detail mode consumes significantly more tokens (85 base + 170 per tile) and adds latency without proportional benefit for temporal or simple tasks" ;
    oc:severityLevel "HIGH" .

oc:payload_fd03d0a5b2125661 a oc:ExecutionPayload ;
    oc:code """from openai import OpenAI
import base64
import json
import os
import time
from pathlib import Path

def analyze_image(image_path, prompt="What's in this image?", model="gpt-5", detail="high"):
    client = OpenAI(api_key=os.environ.get("OPENAI_API_KEY"))
    start_time = time.time()
    try:
        with open(image_path, "rb") as f:
            base64_image = base64.b64encode(f.read()).decode('utf-8')
        response = client.chat.completions.create(
            model=model,
            messages=[{"role": "user", "content": [
                {"type": "text", "text": prompt},
                {"type": "image_url", "image_url": {
                    "url": f"data:image/jpeg;base64,{base64_image}",
                    "detail": detail
                }}
            ]}],
            max_tokens=500
        )
        return {
            "success": True, "model": model,
            "analysis": response.choices[0].message.content,
            "metadata": {"tokens_used": response.usage.total_tokens, "processing_time_ms": int((time.time() - start_time) * 1000)}
        }
    except Exception as e:
        return {"success": False, "analysis": "", "warnings": [str(e)]}""" ;
    oc:executor "python" ;
    oc:timeout 60000 .

