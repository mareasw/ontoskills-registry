oc:kn_1625baee a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Standard frame extraction workflow" ;
    oc:directiveContent "1. Validate video file exists and is readable. 2. Create output directory. 3. Open video with cv2.VideoCapture and verify with cap.isOpened(). 4. Extract video metadata (total_frames, fps, width, height). 5. Seek to start_frame if specified. 6. Read frames in loop, saving every Nth frame (based on interval) with zero-padded filenames. 7. Release capture object. 8. Build and return JSON result conforming to output schema." ;
    oc:hasRationale "This ordered procedure ensures consistent, reliable frame extraction with proper resource management." ;
    oc:stepOrder 1 .

oc:kn_2d045046 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "Always, when extracting frames" ;
    oc:directiveContent "Frame extraction creates one image file per extracted frame in the output directory. A 10-second 30fps video at full extraction yields 300 image files. Disk space can be exhausted rapidly with high-resolution videos." ;
    oc:hasRationale "Uncompressed frame extraction from long or high-resolution videos can consume gigabytes of disk space unexpectedly." ;
    oc:severityLevel "MEDIUM" .

oc:kn_adce8fbd a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After extraction completes, before returning results" ;
    oc:directiveContent "Verify: output is valid JSON, all required fields present, output directory created, extracted frame count matches expected value based on interval, warnings array populated with any issues, frame filenames follow zero-padded numbering." ;
    oc:hasRationale "Quality self-check ensures output integrity and helps catch silent failures like partial extractions or malformed output." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b55238f4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When returning extraction results" ;
    oc:directiveContent "All extraction results must be returned as valid JSON conforming to the defined output schema with fields: success, source_video, output_directory, frames_extracted, extraction_params, video_metadata, output_files, warnings." ;
    oc:hasRationale "Structured JSON output enables downstream processing, validation, and consistent integration with other skills." ;
    oc:severityLevel "HIGH" .

oc:kn_bb613415 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting frame extraction loop" ;
    oc:directiveContent "Verify video can be opened with cap.isOpened() after creating VideoCapture, and check FPS is non-zero to confirm codec support before proceeding with extraction." ;
    oc:hasRationale "Early detection of unreadable videos or unsupported codecs prevents wasted computation and provides meaningful error messages." ;
    oc:severityLevel "HIGH" .

oc:kn_bcc51c62 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When using cap.set() for frame seeking, especially with MKV or VFR videos" ;
    oc:directiveContent "Seeking in variable frame rate videos may be inaccurate. Some container formats (MKV with certain codecs) may have seeking issues. OpenCV may not support all video codecs." ;
    oc:hasRationale "OpenCV's seeking relies on constant frame rate assumptions and codec keyframe indices that may not align with variable frame rate encodings." ;
    oc:severityLevel "MEDIUM" .

oc:kn_da33dafc a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, after any cv2.VideoCapture usage" ;
    oc:directiveContent "Never skip cap.release() after video processing — always release the VideoCapture object in a finally block or after the read loop." ;
    oc:hasRationale "Failing to release the capture object leaks file handles and may lock the video file, preventing subsequent access." ;
    oc:severityLevel "HIGH" .

oc:kn_e35683db a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before execution" ;
    oc:directiveContent "OpenCV (opencv-python) must be installed. Source video file must exist with read permissions. Output directory must be writable." ;
    oc:hasRationale "OpenCV is the core dependency for video decoding and frame capture. Without file access and write permissions, extraction cannot proceed." ;
    oc:severityLevel "CRITICAL" .

oc:kn_ec9cd57e a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "All frame extraction results" ;
    oc:directiveContent "{\"success\": bool, \"source_video\": str, \"output_directory\": str, \"frames_extracted\": int, \"extraction_params\": {\"interval\": int, \"start_frame\": int, \"end_frame\": int|null, \"output_format\": str}, \"video_metadata\": {\"total_frames\": int, \"fps\": float, \"duration_seconds\": float, \"resolution\": [int, int]}, \"output_files\": [str], \"warnings\": [str]}" ;
    oc:hasRationale "Standardized JSON schema enables validation and downstream consumption." ;
    oc:severityLevel "HIGH" ;
    oc:templateVariables "extraction_params",
        "frames_extracted",
        "output_directory",
        "output_files",
        "source_video",
        "success",
        "video_metadata",
        "warnings" .

