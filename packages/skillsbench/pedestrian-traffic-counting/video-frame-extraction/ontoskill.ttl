                                    oc:blockType "code_block" ;
                                    oc:codeContent """import cv2
import os

def extract_frames_at_interval(video_path, output_dir, interval=1):
    \"\"\"Extract frames at specified intervals.\"\"\"
    os.makedirs(output_dir, exist_ok=True)
    
    cap = cv2.VideoCapture(video_path)
    frame_index = 0
    saved_count = 0
    
    while True:
        ret, frame = cap.read()
        if not ret:
            break
        
        if frame_index % interval == 0:
            filename = os.path.join(output_dir, f"frame_{saved_count:06d}.jpg")
            cv2.imwrite(filename, frame)
            saved_count += 1
        
        frame_index += 1
    
    cap.release()
    return saved_count
""" ;
                                    oc:codeLanguage "python" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 115-141" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 10 ;
