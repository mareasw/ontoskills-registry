                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Upload processing stuck**: Use timeout logic and fail gracefully after max wait time" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Inconsistent counts**: Be very explicit in prompts about counting rules and exclusions" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Ambiguous responses**: Use structured output tags like `<answer></answer>` for reliable parsing" ],
