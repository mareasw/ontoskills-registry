oc:kn_03ccf84a a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When saving plans" ;
    oc:directiveContent "save-plan writes a text plan file to disk at the specified output_path, creating or overwriting the file." ;
    oc:hasRationale "Overwriting existing files can destroy prior work if paths are reused carelessly" ;
    oc:severityLevel "MEDIUM" .

oc:kn_077b0068 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating plans with OneshotPlanner" ;
    oc:directiveContent "Planning must terminate within timeout. If no plan exists, return an empty plan or explicit failure flag (None)." ;
    oc:hasRationale "Unbounded planning can hang indefinitely; explicit failure handling prevents silent errors" ;
    oc:severityLevel "HIGH" .

oc:kn_2bc76d99 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "After plan generation, before saving" ;
    oc:directiveContent "Always validate generated plans using SequentialPlanValidator to confirm goal satisfaction and action correctness before saving." ;
    oc:hasRationale "Validation ensures the plan actually solves the given problem; unvalidated plans may be incorrect" ;
    oc:severityLevel "HIGH" .

oc:kn_2d963c9b a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Complete end-to-end planning pipeline" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """problem = load_problem("domain.pddl", "task01.pddl")
plan = generate_plan(problem)
if not validate(problem, plan):
    raise ValueError("Generated plan is invalid")
save_plan(plan, "task01.plan")""" .

oc:kn_58d3a860 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Standard planning pipeline execution" ;
    oc:directiveContent "1. Load domain and problem via load_problem(domain_path, problem_path) → 2. Generate plan via generate_plan(problem_object) → 3. Validate plan via validate(problem_object, plan_object) → 4. If valid, save via save_plan(plan_object, output_path)" ;
    oc:hasRationale "This sequence ensures every generated plan is validated before being persisted, guaranteeing correctness" ;
    oc:stepOrder 1 .

oc:kn_94bf159b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When loading or generating PDDL files" ;
    oc:directiveContent "Domain files must follow PDDL standard syntax and problem files must reference the correct domain. Plans must be sequential classical plans." ;
    oc:hasRationale "Non-conforming PDDL files will cause parsing failures or incorrect plan synthesis" ;
    oc:severityLevel "CRITICAL" .

oc:kn_a6a987fd a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After save-plan execution" ;
    oc:directiveContent "After saving a plan, confirm the output file exists and is non-empty. Validate that plan correctness was confirmed before save." ;
    oc:hasRationale "Ensures the persisted artifact is usable and was verified correct" ;
    oc:severityLevel "LOW" .

oc:kn_e43c5dd6 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When re-running the pipeline" ;
    oc:directiveContent "load-problem is idempotent given same inputs. save-plan overwrites the output file. generate-plan may return different plans across runs depending on planner internals." ;
    oc:hasRationale "Understanding idempotency characteristics helps avoid stale file or non-deterministic plan issues" .

oc:kn_f76cd6b3 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "On parsing failure or unsolvable problems" ;
    oc:directiveContent "load-problem raises an error if PDDL parsing fails. generate-plan returns None if no plan exists." ;
    oc:hasRationale "Callers must handle both exception-based and None-return failure modes to avoid crashes" ;
    oc:severityLevel "MEDIUM" .

oc:kn_fcce7c6a a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before any PDDL skill execution" ;
    oc:directiveContent "unified_planning library must be installed. pyperplan is the default planner backend." ;
    oc:hasRationale "The entire skill set depends on the unified_planning framework for parsing, planning, and validation" .

oc:req_1cfb0831 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "PDDL syntax and planning concepts" .

oc:req_59ecb2ac a oc:RequirementTool ;
