oc:kn_3fb431bf a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting text from scanned/image-based PDFs" ;
    oc:directiveContent "For scanned PDFs, convert pages to images first using pdf2image, then apply pytesseract OCR — direct text extraction will return empty or garbage results." ;
    oc:hasRationale "Scanned PDFs contain images, not selectable text, so OCR is the only way to extract readable content" ;
    oc:severityLevel "HIGH" .

oc:kn_563e8dfa a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting a PDF library for any operation" ;
    oc:directiveContent "Use pdfplumber for text and table extraction, pypdf for merge/split/rotate/encrypt operations, and reportlab for PDF creation. Choose the right tool per task." ;
    oc:hasRationale "Each library has different strengths; using the wrong one leads to poor results or unnecessary complexity" ;
    oc:severityLevel "HIGH" .

oc:kn_5d10ba11 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting tables from any PDF" ;
    oc:directiveContent "Do not use pypdf's extract_text() for table extraction — it loses column structure. Always use pdfplumber's extract_tables() for tabular data." ;
    oc:hasRationale "pypdf's text extraction flattens table structure, making tabular data unusable" ;
    oc:severityLevel "CRITICAL" .

oc:kn_ac5d604d a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before executing PDF operations" ;
    oc:directiveContent "Required Python packages: pypdf, pdfplumber, reportlab. For OCR: pytesseract, pdf2image. CLI tools: poppler-utils (pdftotext, pdfimages), qpdf, pdftk." ;
    oc:hasRationale "Missing dependencies cause runtime failures; verify installation before starting" .

oc:kn_b685a44f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating PDFs with reportlab" ;
    oc:directiveContent "When creating multi-page PDFs with reportlab, use Platypus (SimpleDocTemplate + story list) instead of low-level canvas operations for anything beyond single-page documents." ;
    oc:hasRationale "Platypus handles page layout, flow, and page breaks automatically, reducing code complexity for multi-page documents" .

oc:kn_ca57c95c a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When performing any PDF file operation" ;
    oc:directiveContent "Always close/finish PDF operations properly — use context managers (with statements) for pdfplumber and call writer.write() before closing for pypdf PdfWriter." ;
    oc:hasRationale "Improper cleanup can result in corrupted or incomplete output files" ;
    oc:severityLevel "MEDIUM" .

