oc:kn_01f81f6e a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "LibreOffice must be installed for formula recalculation via recalc.py. The script auto-configures LibreOffice on first run." .

oc:kn_21ab463a a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "After saving any Excel file with formulas to recalculate and verify" ;
    oc:directiveContent "python recalc.py <excel_file> [timeout_seconds]" .

oc:kn_382e1c4b a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When editing existing Excel files while preserving formulas and formatting" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from openpyxl import load_workbook

wb = load_workbook('existing.xlsx')
sheet = wb.active
sheet['A1'] = 'New Value'
sheet.insert_rows(2)
sheet.delete_cols(3)
new_sheet = wb.create_sheet('NewSheet')
wb.save('modified.xlsx')""" .

oc:kn_41e06f9a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing between pandas and openpyxl for a task" ;
    oc:directiveContent "Use pandas for data analysis, bulk operations, and simple data export. Use openpyxl for complex formatting, formulas, and Excel-specific features." ;
    oc:hasRationale "Each library has distinct strengths; choosing the right one avoids unnecessary complexity and limitations." ;
    oc:severityLevel "MEDIUM" .

oc:kn_4a634661 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reading and analyzing Excel data" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """import pandas as pd

df = pd.read_excel('file.xlsx')
all_sheets = pd.read_excel('file.xlsx', sheet_name=None)
df.head()
df.info()
df.describe()
df.to_excel('output.xlsx', index=False)""" .

oc:kn_532eb752 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using openpyxl load_workbook" ;
    oc:directiveContent "Never open a workbook with data_only=True and then save it — this permanently replaces all formulas with their cached values." ;
    oc:hasRationale "Formula loss is irreversible and destroys the spreadsheet's computational integrity." ;
    oc:severityLevel "CRITICAL" .

oc:kn_608b40e9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before delivering any Excel file" ;
    oc:directiveContent "Every Excel model MUST be delivered with ZERO formula errors (#REF!, #DIV/0!, #VALUE!, #N/A, #NAME?)." ;
    oc:hasRationale "Formula errors indicate broken references or logic that undermine trust and usability." ;
    oc:severityLevel "CRITICAL" .

oc:kn_6742fba0 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formatting financial models unless overridden by existing template conventions" ;
    oc:directiveContent "Use industry-standard financial color coding: Blue=hardcoded inputs, Black=formulas/calculations, Green=cross-sheet links, Red=external file links, Yellow background=key assumptions needing attention." ;
    oc:hasRationale "Color coding communicates cell nature at a glance and is standard practice in financial modeling." ;
    oc:severityLevel "MEDIUM" .

oc:kn_6ec93ef8 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When editing an existing spreadsheet with established patterns" ;
    oc:directiveContent "Study and EXACTLY match existing format, style, and conventions when modifying files. Existing template conventions ALWAYS override default guidelines." ;
    oc:hasRationale "Consistency with existing conventions preserves readability and avoids confusing downstream consumers." ;
    oc:severityLevel "HIGH" .

oc:kn_7814d3ca a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building financial models or any formula-heavy spreadsheet" ;
    oc:directiveContent "Place ALL assumptions (growth rates, margins, multiples) in separate cells and reference them in formulas rather than hardcoding values. Example: use =B5*(1+$B$6) instead of =B5*1.05." ;
    oc:hasRationale "Centralized assumptions enable scenario analysis and prevent errors from scattered hardcoded values." ;
    oc:severityLevel "HIGH" .

oc:kn_891ed04f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any calculated value to an Excel cell" ;
    oc:directiveContent "Never hardcode calculated values in cells. Always use Excel formulas (=SUM(), =AVERAGE(), etc.) so the spreadsheet remains dynamic and recalculates when source data changes." ;
    oc:hasRationale "Hardcoded values break the spreadsheet's dynamic nature and silently become stale when source data changes." ;
    oc:severityLevel "CRITICAL" .

oc:kn_a45a0163 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When working with any Excel file" ;
    oc:directiveContent "1. Choose tool (pandas for data, openpyxl for formulas/formatting) → 2. Create new workbook or load existing file → 3. Add/edit data, formulas, and formatting → 4. Save to file → 5. Run recalc.py to recalculate formulas → 6. Verify output and fix any errors" ;
    oc:stepOrder 1 .

oc:kn_be4e8833 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "Parsing recalc.py JSON output to verify formula correctness" ;
    oc:directiveContent "{\"status\": \"{success|errors_found}\", \"total_errors\": {count}, \"total_formulas\": {count}, \"error_summary\": {\"{error_type}\": {\"count\": {n}, \"locations\": [\"{Sheet!Cell}\"]}}}" ;
    oc:templateVariables "error_summary",
        "status",
        "total_errors",
        "total_formulas" .

oc:kn_ca0404db a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing formulas in any spreadsheet" ;
    oc:directiveContent "Start small: test formulas on 2-3 cells before applying broadly. Verify all cell references exist and test edge cases (zero, negative, very large values)." ;
    oc:hasRationale "Catching formula errors early prevents cascading mistakes across large models." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d7c7384a a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before creating formulas in a new or modified spreadsheet" ;
    oc:directiveContent "Before building formulas at scale, verify 2-3 sample cell references pull correct values, confirm column mapping (e.g., column 64 = BL), and remember DataFrame row 5 = Excel row 6 due to 1-indexing." ;
    oc:hasRationale "Off-by-one errors and column mapping mistakes propagate across entire models and are costly to fix retroactively." ;
    oc:severityLevel "HIGH" .

oc:kn_db7d10ac a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When re-running Excel operations" ;
    oc:directiveContent "Editing an existing file and saving is NOT idempotent — always load from the original if re-running. Formula recalculation via recalc.py IS idempotent." ;
    oc:hasRationale "Overwriting an already-modified file can lose data or compound errors." .

oc:kn_dc9eae76 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After saving any xlsx file containing formulas" ;
    oc:directiveContent "After saving any Excel file with formulas, run recalc.py to recalculate all formulas and scan for errors. If status is 'errors_found', check error_summary for locations, fix, and recalculate again." ;
    oc:hasRationale "openpyxl writes formulas as strings without evaluating them; recalculation ensures cached values match formula results." ;
    oc:severityLevel "CRITICAL" .

oc:kn_e08acfde a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When formatting financial data in spreadsheets" ;
    oc:directiveContent "Number formatting rules: Years as text strings, Currency as $#,##0 with units in headers, Zeros displayed as '-', Percentages as 0.0%, Multiples as 0.0x, Negative numbers in parentheses." ;
    oc:hasRationale "Consistent number formatting follows industry conventions and improves readability." ;
    oc:severityLevel "MEDIUM" .

oc:kn_eec69240 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating new Excel files with formatting and formulas" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from openpyxl import Workbook
from openpyxl.styles import Font, PatternFill, Alignment

wb = Workbook()
sheet = wb.active
sheet['A1'] = 'Hello'
sheet['B1'] = 'World'
sheet['B2'] = '=SUM(A1:A10)'
sheet['A1'].font = Font(bold=True, color='FF0000')
sheet['A1'].fill = PatternFill('solid', start_color='FFFF00')
sheet['A1'].alignment = Alignment(horizontal='center')
sheet.column_dimensions['A'].width = 20
wb.save('output.xlsx')""" .

