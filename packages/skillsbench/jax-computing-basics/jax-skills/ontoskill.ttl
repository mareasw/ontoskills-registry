oc:kn_3b9ff976 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When evaluating functions multiple times with same-shape inputs" ;
    oc:directiveContent "Use JIT compilation (jit_run) for compute-heavy functions to speed up repeated calls; one-time calls may not benefit." ;
    oc:hasRationale "JIT compilation has upfront cost; benefits only materialize on repeated invocations with stable input shapes." ;
    oc:severityLevel "LOW" .

oc:kn_51424328 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Throughout all JAX workflows" ;
    oc:directiveContent "Prefer JAX arrays (jnp.array) for all operations; convert to NumPy only when saving to external formats." ;
    oc:hasRationale "Staying in JAX-native types preserves JIT compatibility, automatic differentiation, and GPU/TPU acceleration." ;
    oc:severityLevel "MEDIUM" .

oc:kn_84b15bbd a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using jit_run for JIT compilation" ;
    oc:directiveContent "JIT-compiled functions must receive inputs with consistent shapes across calls." ;
    oc:hasRationale "JAX JIT traces functions based on input shapes; changing shapes triggers recompilation and defeats performance gains." ;
    oc:severityLevel "HIGH" .

oc:kn_9b984f2e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using map_op, reduce_op, rnn_scan, or any JAX transformation" ;
    oc:directiveContent "Avoid side effects inside functions passed to vmap or scan; these functions must be pure." ;
    oc:hasRationale "JAX transformations (vmap, scan, jit) require pure functions; side effects break functional guarantees and cause undefined behavior." ;
    oc:severityLevel "CRITICAL" .

oc:kn_9e3b6107 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before calling map_op, reduce_op, rnn_scan, or logistic_grad" ;
    oc:directiveContent "Validate input types and shapes for all functions before execution; provide meaningful error messages for unsupported operations." ;
    oc:hasRationale "Shape mismatches in JAX often produce cryptic tracing errors rather than clear messages; early validation improves debugging." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a687e51e a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reasoning about reproducibility of JAX computations" ;
    oc:directiveContent "Array loading and saving operations are idempotent for the same data; gradient and scan operations are deterministic given identical inputs." ;
    oc:hasRationale "JAX operations are functional and deterministic by default, supporting reproducible scientific computing." ;
    oc:severityLevel "LOW" .

oc:kn_b3876c97 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating, loading, or saving any array" ;
    oc:directiveContent "All arrays MUST be JAX-compatible (jnp.array) or convertible from Python lists; use .npy, .npz, JSON, or pickle for serialization." ;
    oc:hasRationale "JAX operations require JAX-native arrays; mixing NumPy arrays can cause silent errors or performance degradation." ;
    oc:severityLevel "CRITICAL" .

