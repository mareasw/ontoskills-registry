oc:kn_077b0068 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating plans" ;
    oc:directiveContent "Planning must terminate within timeout. If no plan exists, return an empty plan or explicit failure flag (None)." ;
    oc:hasRationale "Prevents infinite hangs and ensures graceful handling of unsolvable problems" ;
    oc:severityLevel "HIGH" .

oc:kn_1f4debf7 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "After completing the full workflow" ;
    oc:directiveContent "A valid pipeline run produces: a Problem object from load_problem, a non-None plan from generate_plan, True from validate, and a written .plan file from save_plan." .

oc:kn_7c9ddb62 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, when building planning pipelines" ;
    oc:directiveContent "Use the unified_planning framework consistently for loading (PDDLReader), planning (OneshotPlanner), validation (SequentialPlanValidator), and saving (PDDLWriter) to maintain reproducibility." ;
    oc:hasRationale "Ensures compatibility across all pipeline stages and reproducible results" .

oc:kn_8a8e69a6 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running pipelines multiple times" ;
    oc:directiveContent "Plan saving is idempotent for the same plan and path; plan generation is deterministic for a given problem with the same planner." .

oc:kn_98b5c214 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When loading or creating any PDDL files" ;
    oc:directiveContent "Domain files must follow PDDL standard syntax; problem files must reference the correct domain; plans must be sequential classical plans." ;
    oc:hasRationale "Non-conforming PDDL files will cause parse errors or invalid planning results" ;
    oc:severityLevel "CRITICAL" .

oc:kn_9a311730 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "After generating a plan" ;
    oc:directiveContent "Never save or use a plan without validating it first." ;
    oc:hasRationale "Unvalidated plans may not achieve the goal state and could lead to incorrect automated actions" ;
    oc:severityLevel "CRITICAL" .

oc:kn_fa60299c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "After plan generation, before saving" ;
    oc:directiveContent "Validation must confirm goal satisfaction and action correctness before a plan is accepted." ;
    oc:hasRationale "Ensures plans actually solve the stated problem and are executable" ;
    oc:severityLevel "HIGH" .

