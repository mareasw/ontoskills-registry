oc:kn_0f32b90b a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running formula recalculation" ;
    oc:directiveContent "Running recalc.py multiple times on the same file is safe — it recalculates all formulas and re-scans for errors each time." ;
    oc:hasRationale "Ensures iterative fix-and-verify workflows don't corrupt the file." ;
    oc:severityLevel "LOW" .

oc:kn_16ef0d09 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using openpyxl load_workbook with data_only=True" ;
    oc:directiveContent "If opened with data_only=True and saved, formulas are permanently replaced with their cached values. Never save a workbook opened with data_only=True if formulas must be preserved." ;
    oc:hasRationale "This is an irreversible data loss — the formula text is discarded and only the last-calculated value remains." ;
    oc:severityLevel "CRITICAL" .

oc:kn_1e3c3544 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When constructing formulas that divide or reference other sheets" ;
    oc:directiveContent "Check for division by zero (#DIV/0!) by guarding denominators; handle NaN values with pd.notna(); verify cross-sheet references use Sheet1!A1 format." ;
    oc:hasRationale "These are the most frequent preventable formula errors in generated spreadsheets." ;
    oc:severityLevel "HIGH" .

oc:kn_3b5830b6 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After saving any Excel file containing formulas" ;
    oc:directiveContent "After creating or modifying an xlsx with formulas, run recalc.py and verify the JSON output has status 'success' and total_errors: 0. If errors_found, check error_summary for locations and types." ;
    oc:hasRationale "openpyxl does not evaluate formulas — recalc.py ensures computed values are populated and error-free." ;
    oc:severityLevel "CRITICAL" .

oc:kn_608b40e9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before final delivery of any spreadsheet" ;
    oc:directiveContent "Every Excel model MUST be delivered with ZERO formula errors (#REF!, #DIV/0!, #VALUE!, #N/A, #NAME?)." ;
    oc:hasRationale "Formula errors indicate broken logic and erode trust in the model." ;
    oc:severityLevel "CRITICAL" .

oc:kn_6159900a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building financial models unless user or existing template specifies otherwise" ;
    oc:directiveContent "Use financial color coding: Blue (0,0,255) for hardcoded inputs, Black (0,0,0) for formulas, Green (0,128,0) for cross-sheet links, Red (255,0,0) for external links, Yellow background (255,255,0) for key assumptions." ;
    oc:hasRationale "Industry-standard color coding allows auditors and users to instantly distinguish inputs from calculations." ;
    oc:severityLevel "MEDIUM" .

oc:kn_72422343 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing a Python library for spreadsheet work" ;
    oc:directiveContent "Use pandas for data analysis and bulk operations; use openpyxl for complex formatting, formulas, and Excel-specific features." ;
    oc:hasRationale "Each library has different strengths — pandas excels at data manipulation, openpyxl at Excel fidelity." ;
    oc:severityLevel "MEDIUM" .

oc:kn_78f37697 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When editing an existing spreadsheet that has established patterns" ;
    oc:directiveContent "When modifying existing templates, study and EXACTLY match existing format, style, and conventions. Existing template conventions ALWAYS override these guidelines." ;
    oc:hasRationale "Consistency within a document is more important than applying a universal standard." ;
    oc:severityLevel "HIGH" .

oc:kn_8f7f8015 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any cell that derives from other data" ;
    oc:directiveContent "Never hardcode calculated values in cells. Always use Excel formulas (e.g., '=SUM(B2:B9)') so the spreadsheet remains dynamic and recalculates when source data changes." ;
    oc:hasRationale "Hardcoded values destroy spreadsheet integrity — changing source data won't propagate, making models unreliable." ;
    oc:severityLevel "CRITICAL" .

oc:kn_a7145d7f a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When working with externally sourced Excel files" ;
    oc:directiveContent "Never open untrusted xlsx files with data_only=False and then save — macros and external links may persist. Use read_only=True for inspection of unknown files." ;
    oc:hasRationale "Excel files can contain embedded macros, external data connections, and other security risks." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c4c1f2ac a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before writing formulas to cells" ;
    oc:directiveContent "Before building formulas: test 2-3 sample cell references for correct values, confirm column mapping (e.g., column 64 = BL), and account for 1-indexed Excel rows vs 0-indexed DataFrame rows." ;
    oc:hasRationale "Off-by-one errors and column mis-mapping are the most common formula bugs." ;
    oc:severityLevel "HIGH" .

oc:kn_d440a743 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When constructing financial model formulas" ;
    oc:directiveContent "Place ALL assumptions (growth rates, margins, multiples) in separate assumption cells and reference them via cell references in formulas (e.g., =B5*(1+$B$6) not =B5*1.05)." ;
    oc:hasRationale "Centralized assumptions enable scenario analysis and make the model auditable." ;
    oc:severityLevel "HIGH" .

