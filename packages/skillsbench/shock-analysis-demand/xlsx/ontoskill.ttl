                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "This applies to ALL calculations - totals, percentages, ratios, differences, etc. The spreadsheet should be able to recalculate when source data changes." ] ;
                    oc:hasSubsection [ a oc:Section ;
