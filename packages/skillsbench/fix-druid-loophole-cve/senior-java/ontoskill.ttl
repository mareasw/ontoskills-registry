oc:kn_06383d69 a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When optimizing JPA/Hibernate query performance" ;
    oc:directiveContent "Use entity graphs or fetch joins for relationship loading; configure Hibernate second-level cache with Hazelcast or Redis for repeated queries" ;
    oc:hasRationale "Proper fetch strategies prevent N+1 queries; caching reduces database load for frequently accessed data" .

oc:kn_708cc2de a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing list/query endpoints with potentially large result sets" ;
    oc:directiveContent "Use Spring Data Slice or Page for large datasets rather than loading full collections" ;
    oc:hasRationale "Pagination prevents memory exhaustion and reduces response times for large datasets" .

oc:kn_73d315c1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing service layer methods" ;
    oc:directiveContent "Always annotate service methods modifying data with @Transactional" ;
    oc:hasRationale "Missing transaction boundaries can lead to partial data saves and inconsistent state" ;
    oc:severityLevel "CRITICAL" .

oc:kn_76c802e7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring Spring Boot applications" ;
    oc:directiveContent "Use externalized configuration with Spring profiles (dev, staging, prod) instead of hardcoded values" ;
    oc:hasRationale "Externalized configuration enables environment-specific settings without code changes, supporting 12-factor app principles" ;
    oc:severityLevel "HIGH" .

oc:kn_79124b59 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When sizing and benchmarking Spring Boot microservices" ;
    oc:directiveContent "Target < 512MB heap for typical microservice; > 1000 RPS per instance; scaffolding < 30 min; entity generation < 5 min per entity" ;
    oc:hasRationale "These targets represent production-grade efficiency for cloud-native Java services" .

oc:kn_92f99cf7 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring JPA/Hibernate in Spring Boot applications" ;
    oc:directiveContent "Disable Open Session in View (OSIV) anti-pattern in production" ;
    oc:hasRationale "OSIV keeps database sessions open during view rendering, causing unpredictable query execution, hidden N+1 issues, and connection pool exhaustion" ;
    oc:severityLevel "HIGH" .

oc:kn_abeb4f49 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing REST controllers" ;
    oc:directiveContent "Always validate input at the controller layer using Jakarta validation annotations" ;
    oc:hasRationale "Missing validation allows invalid data into the system, causing downstream errors and security vulnerabilities" ;
    oc:severityLevel "HIGH" .

oc:kn_adcfb4b1 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When measuring quality of generated Spring Boot applications" ;
    oc:directiveContent "Target 80%+ code coverage for business logic, 60%+ overall; P99 latency < 200ms for CRUD; zero critical/high security vulnerabilities" ;
    oc:hasRationale "These thresholds ensure production-ready quality with adequate test coverage, responsive APIs, and secure code" .

oc:kn_e1020416 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing JPA/Hibernate data access layers" ;
    oc:directiveContent "Never use N+1 queries — always employ entity graphs or fetch joins for relationships" ;
    oc:hasRationale "N+1 queries cause severe performance degradation by issuing one SQL query per entity in a collection" ;
    oc:severityLevel "CRITICAL" .

oc:kn_e9d6836f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When developing reactive services with Spring WebFlux" ;
    oc:directiveContent "Never use blocking calls in reactive WebFlux pipelines" ;
    oc:hasRationale "Blocking calls defeat the purpose of reactive programming and can starve the limited event loop threads" ;
    oc:severityLevel "CRITICAL" .

