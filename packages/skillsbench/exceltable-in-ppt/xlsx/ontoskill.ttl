                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "[ ] **Division by zero**: Check denominators before using `/` in formulas (#DIV/0!)" ],
