oc:kn_1aaf2f6f a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When choosing a library for an Excel task" ;
    oc:directiveContent "Use pandas for data analysis/bulk operations; use openpyxl for formulas, formatting, and Excel-specific features." ;
    oc:hasRationale "Each library has distinct strengths; using the wrong one leads to unnecessary complexity or lost capabilities." ;
    oc:severityLevel "MEDIUM" .

oc:kn_35f7d383 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When editing any existing spreadsheet with established patterns" ;
    oc:directiveContent "When modifying existing templates, study and EXACTLY match existing format, style, and conventions. Existing template conventions ALWAYS override these guidelines." ;
    oc:hasRationale "Imposing new formatting on established templates breaks visual consistency and user expectations." ;
    oc:severityLevel "HIGH" .

oc:kn_521126c3 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating financial models without user-specified or existing color conventions" ;
    oc:directiveContent "Use financial color coding: Blue (0,0,255) for hardcoded inputs, Black (0,0,0) for formulas, Green (0,128,0) for cross-sheet links, Red (255,0,0) for external links, Yellow background (255,255,0) for key assumptions." ;
    oc:hasRationale "Industry-standard color coding allows auditors and users to instantly distinguish inputs from calculations." ;
    oc:severityLevel "MEDIUM" .

oc:kn_608b40e9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before delivering any Excel file" ;
    oc:directiveContent "Every Excel model MUST be delivered with ZERO formula errors (#REF!, #DIV/0!, #VALUE!, #N/A, #NAME?)." ;
    oc:hasRationale "Formula errors indicate broken logic and render the spreadsheet unreliable for decision-making." ;
    oc:severityLevel "CRITICAL" .

oc:kn_8186a009 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When formula recalculation detects errors" ;
    oc:directiveContent "If recalc.py returns status 'errors_found', check error_summary for specific error types (#REF!, #DIV/0!, #VALUE!, #NAME?) and locations, fix the identified errors, then recalculate again." ;
    oc:hasRationale "Iterative fix-and-recalc ensures the final spreadsheet is error-free." ;
    oc:severityLevel "HIGH" .

oc:kn_8bd302b5 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any calculated value to a spreadsheet cell" ;
    oc:directiveContent "Never hardcode calculated values in cells — always use Excel formulas (e.g., '=SUM(B2:B9)') so the spreadsheet remains dynamic and updateable." ;
    oc:hasRationale "Hardcoded values break spreadsheet integrity; formulas ensure recalculability when source data changes." ;
    oc:severityLevel "CRITICAL" .

oc:kn_dd4e44f4 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When working with large Excel files" ;
    oc:directiveContent "For large files: use openpyxl read_only=True for reading or write_only=True for writing; use pandas usecols to read only needed columns." ;
    oc:hasRationale "Loading entire large files into memory causes performance degradation and potential failures." ;
    oc:severityLevel "LOW" .

oc:kn_e78e22e8 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before writing formulas to a spreadsheet" ;
    oc:directiveContent "Before building formulas broadly: (1) Test 2-3 sample references, (2) Confirm column mapping (e.g., column 64 = BL), (3) Remember Excel rows are 1-indexed (DataFrame row 5 = Excel row 6)." ;
    oc:hasRationale "Off-by-one and column mapping errors are the most common formula bugs and are costly to fix at scale." ;
    oc:severityLevel "HIGH" .

oc:kn_e88c6ba8 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When entering any hardcoded value into a financial model" ;
    oc:directiveContent "Document all hardcoded values with source attribution: 'Source: [System/Document], [Date], [Specific Reference], [URL if applicable]'." ;
    oc:hasRationale "Traceability to authoritative sources is essential for audit compliance and model validation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f5a651d3 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reading calculated values with openpyxl" ;
    oc:directiveContent "Never open a workbook with data_only=True and then save it — formulas will be permanently replaced with their cached values." ;
    oc:hasRationale "This is an irreversible data loss that destroys the spreadsheet's computational model." ;
    oc:severityLevel "CRITICAL" .

oc:kn_f95904c3 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When building financial models or any projection-based spreadsheet" ;
    oc:directiveContent "Place ALL assumptions (growth rates, margins, multiples) in separate assumption cells and reference them via cell references, not hardcoded values in formulas. Example: =B5*(1+$B$6) not =B5*1.05." ;
    oc:hasRationale "Centralized assumptions enable scenario analysis and reduce error risk from scattered hardcoded values." ;
    oc:severityLevel "HIGH" .

