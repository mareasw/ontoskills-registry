oc:kn_15d26c27 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing any security-relevant code or reviewing application security" ;
    oc:directiveContent "Always validate all inputs, use parameterized queries, implement proper authentication, and keep dependencies updated as baseline security practices." ;
    oc:hasRationale "These four practices prevent the most common vulnerability classes: injection, broken authentication, and known vulnerability exploitation" ;
    oc:severityLevel "CRITICAL" .

oc:kn_213fe58d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running security audits or building security tooling" ;
    oc:directiveContent "Do not optimize security tooling performance before measuring baseline metrics; do not skip comprehensive testing for security controls." ;
    oc:hasRationale "Premature optimization of security tooling can miss critical findings; untested security controls provide false confidence" ;
    oc:severityLevel "HIGH" .

oc:kn_2a323297 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing security architecture for any application" ;
    oc:directiveContent "Follow established security architecture patterns, document security decisions, and review them regularly against evolving threats." ;
    oc:hasRationale "Security architecture must evolve with the threat landscape; documented decisions enable consistent review and improvement" .

oc:kn_b1f4aa26 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When security tooling fails or produces unexpected results" ;
    oc:directiveContent "Check reference documentation in references/cryptography_implementation.md for troubleshooting, review script output messages, and consult error logs for diagnosis." ;
    oc:hasRationale "Structured troubleshooting paths reduce time to resolution and prevent compounding errors during security assessments" .

oc:kn_bc32d16d a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When conducting a comprehensive security assessment" ;
    oc:directiveContent "Run threat modeling first to identify attack surfaces, then security auditing to find vulnerabilities, then penetration testing to validate exploitable weaknesses." ;
    oc:hasRationale "This sequence ensures testing is targeted and prioritized by actual risk rather than theoretical vulnerability" .

oc:kn_eba23a77 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before executing any security assessment workflow" ;
    oc:directiveContent "Ensure Python runtime is available for running security scripts (threat_modeler.py, security_auditor.py, pentest_automator.py) and that npm dependencies are installed if auditing Node.js projects." ;
    oc:hasRationale "Missing runtime dependencies cause silent failures or incomplete security assessments" ;
    oc:severityLevel "HIGH" .

