        oc:kn_56222657,
        oc:kn_90c241f7,
        oc:kn_c5081a63,
        oc:kn_ca6eb5c8 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:SystemAuthenticated ;
    oc:resolvesIntent "audit code for vulnerabilities",
        "find bugs in code changes",
        "review local branch diff for issues",
        "security review of branch changes" ;
    oc:yieldsState oc:BugReportGenerated .

oc:kn_05dbc4af a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When filtering and ranking findings for output" ;
    oc:directiveContent "Skip stylistic and formatting issues entirely. Prioritize: security vulnerabilities > bugs > code quality." ;
    oc:hasRationale "Review focus must remain on substantive issues that affect correctness and security" ;
    oc:severityLevel "HIGH" .

oc:kn_1a31c72f a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Phase 3 systematic security review" ;
    oc:directiveContent "Security checklist items to check for EVERY file: Injection, XSS, Authentication, Authorization/IDOR, CSRF, Race conditions (TOCTOU), Session, Cryptography, Information disclosure, DoS, Business logic" ;
    oc:stepOrder 3 .

oc:kn_362eb867 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "Phase 5 pre-conclusion audit" ;
    oc:directiveContent "Before finalizing: list every file reviewed, every checklist item with status, areas that could not be verified, and only then produce final findings." ;
    oc:hasRationale "Systematic audit trail prevents premature conclusion and ensures completeness of the review" ;
    oc:severityLevel "HIGH" .

oc:kn_3b8d6d09 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "After gathering full diff, before security analysis" ;
    oc:directiveContent "Map attack surfaces first (user inputs, DB queries, auth checks, session ops, external calls, crypto) before running the security checklist." ;
    oc:hasRationale "Attack surface mapping focuses the security checklist on relevant areas rather than mechanically scanning everything without context" .

oc:kn_49d5f04b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Phase 4 verification of every potential finding" ;
    oc:directiveContent "Never report an issue without verifying it against surrounding context, existing mitigations in changed code, and existing test coverage." ;
    oc:hasRationale "False positives erode trust and waste developer time; verification ensures only real, actionable issues are reported" ;
    oc:severityLevel "CRITICAL" .

oc:kn_55c7a164 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning any analysis" ;
    oc:directiveContent "Must obtain the complete diff (git diff master...HEAD) and read every changed line, even if truncated output requires reading files individually." ;
    oc:hasRationale "Incomplete diff review means potential vulnerabilities in unseen code are missed entirely" ;
    oc:severityLevel "CRITICAL" .

oc:kn_56222657 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When reporting findings" ;
    oc:directiveContent """For each issue:
* **{File}:{Line}** - {Brief description}
* **Severity**: Critical/High/Medium/Low
* **Problem**: {What's wrong}
* **Evidence**: {Why this is real}
* **Fix**: {Concrete suggestion}
* **References**: {OWASP, RFCs, or standards}""" ;
    oc:templateVariables "Brief description",
        "Concrete suggestion",
        "File",
        "Line",
        "OWASP/RFCs/standards",
        "What's wrong",
        "Why this is real" .

oc:kn_90c241f7 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, especially when findings are sparse" ;
    oc:directiveContent "Never invent issues to justify the review. If no significant issues are found, explicitly say so." ;
    oc:hasRationale "Fabricated issues undermine credibility and cause developers to ignore genuine findings in future reviews" ;
    oc:severityLevel "HIGH" .

oc:kn_c5081a63 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always during execution of this skill" ;
    oc:directiveContent "Do not make changes to code — only report findings. The user decides what to address." ;
    oc:hasRationale "This is an audit/review skill, not a remediation skill; maintaining separation preserves user autonomy" ;
    oc:severityLevel "CRITICAL" .

oc:kn_ca6eb5c8 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "1. Get full diff (git diff master...HEAD), handle truncation by reading files individually 2. List all modified files 3. Map attack surfaces per file 4. Apply 11-item security checklist to every file 5. Verify each potential issue against surrounding code and tests 6. Audit completeness: list files reviewed, checklist items covered, unverifiable areas 7. Output prioritized findings" ;
    oc:stepOrder 1 .

_:ref_279a232bb529c97e a oc:WorkflowStep ;
    dcterms:description "Get the FULL diff: `git diff master...HEAD`" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_3d15c3b263af2ec3 a oc:WorkflowStep ;
    dcterms:description "If output is truncated, read each changed file individually until you have seen every changed line" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_402475fa40e4eb4a a oc:WorkflowStep ;
    dcterms:description "Only then provide your final findings" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_7c3b65b30f890702 a oc:WorkflowStep ;
    dcterms:description "List any areas you could NOT fully verify and why" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_87e9ee944fb5c350 a oc:WorkflowStep ;
    dcterms:description "List every checklist item and note whether you found issues or confirmed it's clean" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_b1fc5bc1d7ed0ce0 a oc:WorkflowStep ;
    dcterms:description "List every file you reviewed and confirm you read it completely" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_bc0b55d3891d0c07 a oc:WorkflowStep ;
    dcterms:description "List all files modified in this branch before proceeding" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

