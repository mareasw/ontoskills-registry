oc:kn_095d8a74 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When naming Erlang nodes" ;
    oc:directiveContent "Use short names (sname) for local clusters and long names for internet-wide distribution." ;
    oc:hasRationale "Short names use local hostname resolution and are simpler for same-network clusters; long names use FQDNs needed for WAN deployment." ;
    oc:severityLevel "MEDIUM" .

oc:kn_14afe3e4 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing inter-node communication pattern" ;
    oc:directiveContent "Prefer direct message passing over RPC for complex distributed protocols; use RPC only for simple request-response calls." ;
    oc:hasRationale "Message passing provides better control over failure modes, backpressure, and protocol complexity than synchronous RPC." ;
    oc:severityLevel "MEDIUM" .

oc:kn_18b71208 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing process registration strategy" ;
    oc:directiveContent "Never use the global registry everywhere — it creates a single point of failure and coordination bottleneck in distributed clusters." ;
    oc:hasRationale "Global registration requires cluster-wide consensus on every registration change, degrading performance as cluster size grows." ;
    oc:severityLevel "HIGH" .

oc:kn_5de71077 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring node connectivity" ;
    oc:directiveContent "All nodes in a trusted cluster must share the same magic cookie for authentication." ;
    oc:hasRationale "Mismatched cookies prevent nodes from connecting, causing silent failures that are difficult to diagnose." ;
    oc:severityLevel "CRITICAL" .

oc:kn_b7641828 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When cluster connectivity changes" ;
    oc:directiveContent "Implement partition detection with missing node comparison and healing with global:sync() after reconnection." ;
    oc:hasRationale "Automatic partition healing restores cluster consistency without manual intervention." .

oc:kn_cc4593d7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When architecting distributed state management" ;
    oc:directiveContent "Design for eventual consistency in distributed systems, accepting CAP theorem limitations rather than requiring strict consistency." ;
    oc:hasRationale "During network partitions, you cannot maintain both consistency and availability — choose based on application requirements." ;
    oc:severityLevel "HIGH" .

oc:kn_ce19b9cb a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When registering processes globally" ;
    oc:directiveContent "Global registration adds coordination overhead — use it sparingly and only when location-independent process discovery is essential." ;
    oc:hasRationale "Every global registration change requires cluster-wide consensus, impacting latency and throughput." .

oc:kn_ceae386d a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When building production distributed systems" ;
    oc:directiveContent "Monitor node connections via net_kernel:monitor_nodes/1 to detect and handle network partitions proactively." ;
    oc:hasRationale "Early partition detection enables automatic healing strategies and prevents stale state propagation." ;
    oc:severityLevel "HIGH" .

oc:kn_d2320eac a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When deploying distributed Erlang systems" ;
    oc:directiveContent "The Erlang distribution cookie is the sole authentication mechanism between nodes — protect it as a shared secret." ;
    oc:hasRationale "Any process with the correct cookie can fully control the cluster, making cookie leakage a critical security risk." ;
    oc:severityLevel "CRITICAL" .

oc:kn_eeb78510 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When healing from network partitions" ;
    oc:directiveContent "Forgetting to call global:sync() after a network partition heals can leave the global registry in an inconsistent state." ;
    oc:hasRationale "The global registry may have diverged during the partition and must be explicitly synchronized to resolve conflicts." ;
    oc:severityLevel "HIGH" .

oc:kn_fb2b8996 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When making remote calls or sending messages to remote nodes" ;
    oc:directiveContent "Never assume network reliability — always implement proper timeouts on distributed RPC calls and handle node disconnections explicitly." ;
    oc:hasRationale "Network partitions and slow networks will occur in production; unhandled disconnections cause processes to hang indefinitely." ;
    oc:severityLevel "CRITICAL" .

