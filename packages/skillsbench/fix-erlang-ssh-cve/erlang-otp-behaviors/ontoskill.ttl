oc:kn_026779bb a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When supervisor detects and restarts a crashed child" ;
    oc:directiveContent "Supervisor restarting children is a visible side effect—linked processes receive EXIT signals and logs are generated for each restart cycle." ;
    oc:hasRationale "Restart cascades can affect dependent processes and generate log noise, requiring monitoring of restart intensity." .

oc:kn_0ecc6517 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When structuring nested supervisor trees" ;
    oc:directiveContent "Circular dependencies in supervisor trees cause startup failures—ensure child start_link functions never depend on processes defined later in the same supervisor." ;
    oc:hasRationale "Circular startup ordering prevents any process from initializing, deadlocking the entire application." ;
    oc:severityLevel "HIGH" .

oc:kn_1a6acd90 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scaffolding a new gen_server module" ;
    oc:codeLanguage "erlang" ;
    oc:directiveContent """-module(MODULE).
-behaviour(gen_server).
-export([start_link/0]).
-export([init/1, handle_call/3, handle_cast/2, handle_info/2, terminate/2, code_change/3]).

init([]) -> {ok, #state{}}.
handle_call(Request, _From, State) -> {reply, ok, State}.
handle_cast(_Msg, State) -> {noreply, State}.
handle_info(_Info, State) -> {noreply, State}.
terminate(_Reason, _State) -> ok.
code_change(_OldVsn, State, _Extra) -> {ok, State}.""" .

oc:kn_26ae8413 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining supervisor child specifications" ;
    oc:codeLanguage "erlang" ;
    oc:directiveContent """init([]) ->
    SupFlags = #{strategy => one_for_one, intensity => 5, period => 60},
    ChildSpecs = [
        #{id => worker1, start => {worker1, start_link, []}, restart => permanent, shutdown => 5000, type => worker}
    ],
    {ok, {SupFlags, ChildSpecs}}.""" .

oc:kn_2b4aa7f4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any gen_server module" ;
    oc:directiveContent "All six gen_server callbacks must be implemented: init/1, handle_call/3, handle_cast/2, handle_info/2, terminate/2, code_change/3—even if they return default values." ;
    oc:hasRationale "OTP behavior contracts require all callbacks; missing ones cause compilation warnings and runtime crashes." ;
    oc:severityLevel "HIGH" .

oc:kn_504c82a1 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "After starting OTP behavior processes" ;
    oc:directiveContent "A gen_server or gen_statem is successfully started when start_link returns {ok, Pid}; a supervisor is healthy when supervisor:count_children/1 shows expected active counts." .

oc:kn_57d78795 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before implementing OTP behaviors" ;
    oc:directiveContent "Erlang/OTP runtime must be installed and the application must include OTP as a dependency in its .app file." .

oc:kn_6686b3f0 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining child specs in supervisor init/1" ;
    oc:directiveContent "Do not use temporary restart strategy for critical processes—permanent or transient restart ensures automatic recovery." ;
    oc:hasRationale "Temporary restart means the supervisor won't restart a crashed child, allowing permanent loss of critical services." ;
    oc:severityLevel "HIGH" .

oc:kn_67715256 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing gen_server state structures" ;
    oc:directiveContent "Avoid storing large state in gen_server records—state is copied on every message handling cycle." ;
    oc:hasRationale "Large state causes excessive memory copying and GC pressure, degrading system performance." ;
    oc:severityLevel "MEDIUM" .

oc:kn_691d697d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing gen_server handle_call/3 callbacks" ;
    oc:directiveContent "Never perform blocking operations inside handle_call as this prevents the gen_server from processing other messages, leading to deadlock." ;
    oc:hasRationale "handle_call runs in the server process; blocking it blocks all other callers, creating cascading timeouts and system stalls." ;
    oc:severityLevel "CRITICAL" .

oc:kn_8479a7f5 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When supervisor restarts children" ;
    oc:directiveContent "Supervisor restart strategies make process recovery idempotent—restarting a child that's already dead simply starts a new one; restarting one that's alive is a no-op." ;
    oc:hasRationale "Supervisors track child state via pid references, ensuring restart operations are safe to repeat." .

oc:kn_965e7438 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing which OTP behavior to implement" ;
    oc:directiveContent "Use gen_server for stateful processes, gen_statem for complex state machines with explicit transitions, supervisors for fault tolerance, and gen_event for event distribution." ;
    oc:hasRationale "Each behavior provides specialized infrastructure for its pattern—message passing, state transitions, lifecycle management, or event handling—reducing boilerplate and error-prone manual implementation." ;
    oc:severityLevel "HIGH" .

oc:kn_a6269873 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing gen_server handle_call/3 callbacks" ;
    oc:directiveContent "Never forget to reply in handle_call—unreplied calls leave the caller waiting indefinitely." ;
    oc:hasRationale "The caller blocks until it receives a reply or times out; missing replies cause resource leaks and hung processes." ;
    oc:severityLevel "CRITICAL" .

oc:kn_b48b1f4a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing supervisor hierarchies" ;
    oc:directiveContent "Match supervision strategy to child dependency relationships: one_for_one for independent children, rest_for_one for sequential dependencies, one_for_all when all children must be consistent." ;
    oc:hasRationale "Wrong strategy causes unnecessary restarts of healthy processes or leaves dependent processes in inconsistent states." ;
    oc:severityLevel "MEDIUM" .

oc:kn_bc140660 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating a supervisor" ;
    oc:directiveContent "1. Define module with -behaviour(supervisor) 2. Implement init/1 returning {ok, {SupFlags, ChildSpecs}} 3. Set strategy (one_for_one, one_for_all, rest_for_one) 4. Set intensity and period for restart limits 5. Define child specs with id, start, restart, shutdown, type 6. Build nested trees with supervisor-type children for complex apps" ;
    oc:stepOrder 3 .

oc:kn_cb919fd8 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When defining supervisor child specifications" ;
    oc:directiveContent """%% Child spec map:
#{
    id => atom(),
    start => {Module, Function, Args},
    restart => permanent | transient | temporary,
    shutdown => integer() | infinity,
    type => worker | supervisor,
    modules => [Module] | dynamic
}""" ;
    oc:templateVariables "id",
        "modules",
        "restart",
        "shutdown",
        "start",
        "type" .

oc:kn_cf5225be a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating a new gen_server" ;
    oc:directiveContent "1. Define module with -behaviour(gen_server) declaration 2. Export API functions wrapping gen_server:call/2 and gen_server:cast/2 3. Export all 6 callbacks 4. Implement init/1 returning {ok, State} 5. Implement handle_call/3 for synchronous ops 6. Implement handle_cast/2 for async ops 7. Implement handle_info/2 for non-OTP messages 8. Implement terminate/2 for cleanup 9. Implement code_change/3 for hot upgrades" ;
    oc:stepOrder 1 .

oc:kn_d3011d32 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing gen_statem state functions" ;
    oc:codeLanguage "erlang" ;
    oc:directiveContent """%% State function in gen_statem
locked(call, {unlock, Code}, Data) when Code =:= ?CODE ->
    {next_state, unlocked, Data, [{reply, ok}]};
locked(call, _Event, Data) ->
    {keep_state, Data, [{reply, {error, denied}}]}.""" .

oc:kn_db9ca0bf a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating a new gen_statem state machine" ;
    oc:directiveContent "1. Define module with -behaviour(gen_statem) 2. Export state functions named after each state 3. Implement callback_mode/0 returning state_functions 4. Each state function handles EventType, EventContent, Data 5. Return {next_state, NewState, NewData} for transitions 6. Return {keep_state, NewData} to stay in current state 7. Optionally add state_enter for entry actions" ;
    oc:stepOrder 2 .

oc:kn_eb34f81c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any gen_statem module" ;
    oc:directiveContent "Always implement callback_mode/0 in gen_statem returning state_functions or handle_event_function to define the callback mode." ;
    oc:hasRationale "gen_statem requires explicit callback mode selection to dispatch state transition events to the correct functions." ;
    oc:severityLevel "CRITICAL" .

oc:kn_f5519340 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing gen_server processes that manage external resources" ;
    oc:directiveContent "Set process_flag(trap_exit, true) in init/1 when the process must perform cleanup in terminate/2, such as closing sockets or releasing resources." ;
    oc:hasRationale "Without trapping exits, terminate/2 is not called on parent shutdown, leaking resources like sockets and file handles." ;
    oc:severityLevel "MEDIUM" .

oc:kn_fbee4ca4 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before deploying any OTP behavior module" ;
    oc:directiveContent "Verify all behaviour callbacks are exported and implemented before starting the process—missing exports cause runtime crashes." ;
    oc:severityLevel "HIGH" .

