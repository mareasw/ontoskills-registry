                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "When creating a new Word document from scratch, use **docx-js**, which allows you to create Word documents using JavaScript/TypeScript." ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent _:ref_1c9ccb8953df64b1 ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Workflow" ] ;
