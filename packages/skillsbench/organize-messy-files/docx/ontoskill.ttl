oc:kn_0fc9ad2d a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "pandoc, docx (npm), LibreOffice, poppler-utils, and defusedxml must be installed" .

oc:kn_12a503c2 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Creating a new Word document from scratch" ;
    oc:directiveContent "1. Read docx-js.md fully 2. Create JS/TS file with Document, Paragraph, TextRun 3. Export via Packer.toBuffer()" ;
    oc:stepOrder 1 .

oc:kn_1ab55a54 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "Converting DOCX to images for visual analysis" ;
    oc:directiveContent "soffice --headless --convert-to pdf document.docx && pdftoppm -jpeg -r 150 document.pdf page" .

oc:kn_1e1ac9b7 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing tracked changes in redlining workflow" ;
    oc:directiveContent "Never replace entire sentences when only specific words change. Use minimal tracked changes: [unchanged text] + [deletion] + [insertion] + [unchanged text], preserving original RSID for unchanged runs." ;
    oc:hasRationale "Replacing entire sentences with tracked changes makes edits harder to review and appears unprofessional; precise edits show exactly what changed." ;
    oc:severityLevel "CRITICAL" .

oc:kn_37c52f95 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing which workflow to apply for a document task" ;
    oc:directiveContent "Use docx-js (JavaScript) for creating new documents from scratch; use the Document library (Python/OOXML) for editing existing documents; use redlining workflow for reviewing others' documents." ;
    oc:hasRationale "Each approach is optimized for its use case: docx-js for clean creation, Document library for structural editing, redlining for collaborative review." ;
    oc:severityLevel "HIGH" .

oc:kn_3b270cc6 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After completing all tracked change batches" ;
    oc:directiveContent "After all tracked changes, convert final document to markdown with pandoc and grep for both original (should NOT find) and replacement phrases (should find) to verify correctness." ;
    oc:hasRationale "Comprehensive verification catches missed changes, unintended modifications, and ensures document integrity." ;
    oc:severityLevel "HIGH" .

oc:kn_3d50adc5 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Editing an existing Word document" ;
    oc:directiveContent "1. Read ooxml.md fully 2. Unpack docx 3. Create/run Python script using Document library 4. Pack back to docx" ;
    oc:stepOrder 1 .

oc:kn_40e08815 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Redlining workflow for document review with tracked changes" ;
    oc:directiveContent "1. Get markdown with pandoc --track-changes=all 2. Identify and group changes into batches of 3-10 3. Read ooxml.md and unpack document 4. Implement changes in batches (grep XML, script, save) 5. Pack document 6. Final verification with pandoc + grep" ;
    oc:stepOrder 1 .

oc:kn_61216b15 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before any document creation or editing operation" ;
    oc:directiveContent "MANDATORY: Always read the full reference file (docx-js.md for creation, ooxml.md for editing) without range limits before generating any code." ;
    oc:hasRationale "These reference files contain critical syntax rules, formatting patterns, and API details that are essential for correct document generation." ;
    oc:severityLevel "CRITICAL" .

oc:kn_755aafca a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When locating changes in tracked changes workflow" ;
    oc:directiveContent "DO NOT use markdown line numbers to locate text in XML — they do not map to XML structure. Use section numbers, heading identifiers, or grep patterns instead." ;
    oc:hasRationale "Markdown line numbers are a linear representation that does not correspond to the hierarchical XML structure inside .docx files." ;
    oc:severityLevel "HIGH" .

oc:kn_7bc191de a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When editing an existing .docx file via OOXML" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """python ooxml/scripts/unpack.py <office_file> <output_directory>
# Edit XML or use Document library
python ooxml/scripts/pack.py <input_directory> <office_file>""" .

oc:kn_b03ab231 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing tracked changes on a document" ;
    oc:directiveContent "Group related tracked changes into batches of 3-10 changes. Organize by section, type, complexity, or proximity. Test each batch before moving to the next." ;
    oc:hasRationale "Batches of 3-10 changes balance debugging ease with efficiency; too few is slow, too many makes isolating errors difficult." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e80ec84f a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "During batch implementation of tracked changes" ;
    oc:directiveContent "Always grep word/document.xml immediately before writing a script to get current line numbers and verify text content. Line numbers change after each script run." ;
    oc:hasRationale "Each script run modifies the XML file, shifting line numbers and potentially splitting text runs differently." ;
    oc:severityLevel "HIGH" .

oc:kn_e9e824a0 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When editing documents from regulated or professional domains" ;
    oc:directiveContent "For legal, academic, business, or government documents, always use the redlining workflow regardless of document ownership." ;
    oc:hasRationale "These domains require auditable change tracking; direct edits without tracked changes are inappropriate." ;
    oc:severityLevel "HIGH" .

oc:kn_eb240fb8 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting text or analyzing document content with tracked changes" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "pandoc --track-changes=all path-to-file.docx -o output.md" .

oc:kn_fdffca06 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When parsing or manipulating OOXML content" ;
    oc:directiveContent "Use defusedxml for XML parsing to prevent XML-based attacks when working with .docx files." ;
    oc:hasRationale "Standard XML parsers are vulnerable to entity expansion and other XML attacks; defusedxml mitigates these risks." ;
    oc:severityLevel "MEDIUM" .

