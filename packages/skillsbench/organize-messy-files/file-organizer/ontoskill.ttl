_:ref_32176017deb9d707 a oc:CodeExample ;
    oc:blockType "code_block" ;
    oc:codeContent """# Get overview of current structure
ls -la [target_directory]

# Check file types and sizes
find [target_directory] -type f -exec file {} \\; | head -20

# Identify largest files
du -sh [target_directory]/* | sort -rh | head -20

# Count file types
find [target_directory] -type f | sed 's/.*\\.//' | sort | uniq -c | sort -rn
""" ;
    oc:codeLanguage "bash" ;
    oc:contentOrder 2 ;
    oc:sourceLocation "lines 84-96" .

_:ref_3848375effcd5107 a oc:CodeExample ;
