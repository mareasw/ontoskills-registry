oc:kn_1e0c3eca a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "During execution phase" ;
    oc:directiveContent "File moves, renames, and deletions alter the filesystem. Log all moves for potential undo. Preserve original modification dates." ;
    oc:hasRationale "Logging enables recovery; preserving dates maintains temporal provenance of files" ;
    oc:severityLevel "HIGH" .

oc:kn_4509dd98 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When user is new to file organization" ;
    oc:directiveContent "Start with one small messy folder (like Downloads) to build trust before tackling larger reorganizations." ;
    oc:hasRationale "Incremental wins build confidence and let the user validate the approach before larger changes" .

oc:kn_5f0703f0 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When executing file moves, renames, or deletions" ;
    oc:directiveContent "Never delete files without explicit user confirmation. Always ask before any destructive operation." ;
    oc:hasRationale "Irreversible data loss can occur; user must retain agency over all destructive actions" ;
    oc:severityLevel "CRITICAL" .

oc:kn_86b5dd95 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before executing any file moves, creates, or deletes" ;
    oc:directiveContent "Always present a full organization plan and get explicit approval before making any filesystem changes." ;
    oc:hasRationale "Preview-and-confirm prevents unwanted reorganization and builds user trust" ;
    oc:severityLevel "HIGH" .

oc:kn_aae358d9 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining logical groupings for organization" ;
    oc:directiveContent "Group files by type (documents, images, videos, archives, code), by purpose (work/personal, active/archive), and by date (current/old)." ;
    oc:hasRationale "Multiple grouping dimensions provide flexible organization that matches how people actually search for files" .

oc:kn_afbef8f2 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When renaming files or creating folders" ;
    oc:directiveContent "Use consistent file naming: 'YYYY-MM-DD - Description.ext'. Use clear folder names with hyphens. Avoid spaces. Use prefixes for ordering: '01-current', '02-archive'." ;
    oc:hasRationale "Consistent naming makes files sortable, searchable, and predictable" .

oc:kn_cb06dad0 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning any organization task" ;
    oc:directiveContent "Verify target directory exists and is writable. Check for any files or folders the user wants to exclude. Clarify scope (which directory, how aggressive)." ;
    oc:hasRationale "Scope clarity prevents unintended changes to sensitive or active project files" .

oc:kn_db1a5866 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "After execution phase" ;
    oc:directiveContent "Organization is complete when: new folders created, files moved to logical locations, duplicates resolved, and a summary with maintenance tips is provided." ;
    oc:hasRationale "Comprehensive closure ensures the user understands what changed and how to maintain it" .

oc:kn_df47daa3 a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When file classification is ambiguous" ;
    oc:directiveContent "If uncertain about a file's destination, place it in a ToSort/ folder rather than guessing. Stop and ask the user about unexpected situations." ;
    oc:hasRationale "Ambiguity handled by deferral is safer than misclassification" .

