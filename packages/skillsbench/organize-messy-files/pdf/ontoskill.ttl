oc:kn_13a6a189 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When performing any PDF manipulation" ;
    oc:directiveContent "PDF merge, split, watermark, and encryption operations create new files — the original PDFs are never modified in place." ;
    oc:hasRationale "pypdf and reportlab always write to a new output stream, preserving source files as a safety net." .

oc:kn_1700d7ba a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When PDF contains scanned images instead of selectable text" ;
    oc:directiveContent "For scanned PDFs, convert pages to images first with pdf2image, then run pytesseract OCR on each image." ;
    oc:hasRationale "Scanned PDFs have no text layer; OCR is the only way to extract textual content." .

oc:kn_3b907c89 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When considering re-running PDF operations" ;
    oc:directiveContent "PDF read and extract operations are idempotent and can be safely re-run. Write operations create new files each time." ;
    oc:hasRationale "Read operations have no side effects; write operations produce deterministic output given identical input." .

oc:kn_41738bee a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing a library for a PDF task" ;
    oc:directiveContent "Use pdfplumber for text and table extraction (better layout fidelity), pypdf for merge/split/rotate/encrypt operations, and reportlab for PDF creation." ;
    oc:hasRationale "Each library has different strengths; using the wrong one leads to poor results or unnecessary complexity." ;
    oc:severityLevel "HIGH" .

oc:kn_881a82f6 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When adding password protection to PDFs" ;
    oc:directiveContent "When encrypting PDFs, always set both user password and owner password for proper access control." ;
    oc:hasRationale "User password controls who can open the file; owner password controls permissions (print, copy, etc.)." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b17b4f5c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting text from PDFs with tables or complex formatting" ;
    oc:directiveContent "Do not use pypdf's extract_text() for complex layouts or tables — use pdfplumber instead." ;
    oc:hasRationale "pypdf's text extraction is basic and loses layout information; pdfplumber preserves spatial relationships." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e427921f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating new PDF documents" ;
    oc:directiveContent "Use reportlab's Platypus (SimpleDocTemplate) for multi-page documents with flowing content, and Canvas for simple single-page or drawing-heavy PDFs." ;
    oc:hasRationale "Platypus handles page breaks, styles, and flowing layout automatically; Canvas requires manual positioning." .

