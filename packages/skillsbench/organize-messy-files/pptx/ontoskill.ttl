oc:kn_19c3ef8f a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before any PPTX operation" ;
    oc:directiveContent "Node.js global packages required: pptxgenjs, playwright, sharp, react-icons, react, react-dom. Python packages required: markitdown[pptx], defusedxml. System packages: LibreOffice, poppler-utils." .

oc:kn_1a6d6ba6 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before any presentation creation or editing operation" ;
    oc:directiveContent "Mandatory: Read html2pptx.md completely before creating new presentations. Read ooxml.md completely before editing existing presentations. NEVER set range limits when reading these reference files." ;
    oc:hasRationale "These reference files contain critical syntax rules and formatting requirements that are essential for correct output" ;
    oc:severityLevel "CRITICAL" .

oc:kn_1b96c44d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, before creating any new presentation" ;
    oc:directiveContent "Before creating any presentation, analyze content subject matter and choose colors/design that match the topic. State design approach BEFORE writing code. Select 3-5 colors that work together with good text-background contrast." ;
    oc:hasRationale "Content-informed design produces more effective and visually coherent presentations" ;
    oc:severityLevel "HIGH" .

oc:kn_289454f5 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting text content from a presentation for reading/analysis" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "python -m markitdown path-to-file.pptx" .

oc:kn_3cc22409 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "After generating any presentation" ;
    oc:directiveContent "Visual validation via thumbnail grids is mandatory. Check for: text cutoff by header bars/shapes/edges, text overlap, content too close to boundaries, insufficient contrast. Regenerate until all issues resolved." ;
    oc:hasRationale "HTML-to-PPTX conversion can introduce subtle layout issues invisible in code but obvious visually" ;
    oc:severityLevel "HIGH" .

oc:kn_48751bf4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any code for PPTX operations" ;
    oc:directiveContent "Write concise code. Avoid verbose variable names, redundant operations, and unnecessary print statements when generating PPTX operation code." ;
    oc:hasRationale "Cleaner code is easier to debug and maintain for presentation generation tasks" ;
    oc:severityLevel "LOW" .

oc:kn_565fa2c9 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When editing OOXML XML files" ;
    oc:directiveContent "After each XML edit of an existing presentation, validate immediately using validate.py and fix any errors before proceeding. Do not batch edits without intermediate validation." ;
    oc:hasRationale "XML errors compound and become harder to diagnose if not caught early" ;
    oc:severityLevel "HIGH" .

oc:kn_5bdeed87 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating slides containing charts or tables" ;
    oc:directiveContent "Never vertically stack charts/tables below text in a single column. Use two-column layout (text + chart side-by-side) or full-slide layout for featured content." ;
    oc:hasRationale "Vertical stacking causes poor readability and layout issues" ;
    oc:severityLevel "HIGH" .

oc:kn_659127ed a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When generating thumbnail grids for large presentations" ;
    oc:directiveContent "Thumbnail grids have limits based on columns: 3 cols = 12 slides/grid, 4 cols = 20, 5 cols = 30, 6 cols = 42. Large decks create multiple grid files (thumbnails-1.jpg, thumbnails-2.jpg)." ;
    oc:hasRationale "Knowing grid limits helps set appropriate column counts and anticipate output files" ;
    oc:severityLevel "LOW" .

oc:kn_67f6763d a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When editing an existing PowerPoint presentation" ;
    oc:directiveContent "1. Read ooxml.md fully → 2. Unpack pptx: python ooxml/scripts/unpack.py <file> <dir> → 3. Edit XML files → 4. Validate after EACH edit: python ooxml/scripts/validate.py <dir> --original <file> → 5. Repack: python ooxml/scripts/pack.py <dir> <file>" ;
    oc:stepOrder 2 .

oc:kn_6f42528b a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When duplicating and reordering template slides (0-indexed)" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "python scripts/rearrange.py template.pptx working.pptx 0,34,34,50,54" .

oc:kn_718f6593 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting slides to individual JPEG images for detailed visual analysis" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "soffice --headless --convert-to pdf template.pptx && pdftoppm -jpeg -r 150 template.pdf slide" .

oc:kn_7f22f11b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating presentations from scratch via html2pptx" ;
    oc:directiveContent "Use only web-safe fonts: Arial, Helvetica, Times New Roman, Georgia, Courier New, Verdana, Tahoma, Trebuchet MS, Impact. Rasterize gradients and icons as PNG images using Sharp BEFORE referencing them in HTML." ;
    oc:hasRationale "Non-web-safe fonts will not render correctly in PowerPoint; gradients and icons cannot be directly converted from HTML to PPTX" ;
    oc:severityLevel "CRITICAL" .

oc:kn_81f1d1e8 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating a new presentation without a template" ;
    oc:directiveContent "1. Read html2pptx.md fully → 2. Create HTML file per slide (720pt×405pt for 16:9) → 3. Run JS using html2pptx.js to convert → 4. Generate thumbnails and validate visually → 5. Fix issues and regenerate if needed" ;
    oc:stepOrder 1 .

oc:kn_854e8da1 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating visual thumbnail grids for validation" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "python scripts/thumbnail.py output.pptx workspace/thumbnails --cols 4" .

oc:kn_926f0600 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "Output format of inventory.py - text inventory JSON structure for template-based workflows" ;
    oc:directiveContent """{
  "slide-{N}": {
    "shape-{N}": {
      "placeholder_type": "TITLE|BODY|SUBTITLE|CENTER_TITLE|OBJECT|null",
      "left": 1.5,
      "top": 2.0,
      "width": 7.5,
      "height": 1.2,
      "default_font_size": 14.0,
      "paragraphs": [
        {"text": "...", "bold": true, "alignment": "CENTER", "font_size": 14.0, "bullet": true, "level": 0, "color": "FF0000"}
      ]
    }
  }
}""" ;
    oc:templateVariables "paragraphs",
        "placeholder_type",
        "shape-N",
        "slide-N" .

oc:kn_998b53e6 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating replacement-text.json for template workflows" ;
    oc:directiveContent "When creating replacement JSON for template-based presentations: never include bullet symbols (•, -, *) in text when bullet:true (they're auto-added). Include paragraph properties from original inventory, not just text. Shapes without 'paragraphs' field are automatically cleared." ;
    oc:hasRationale "The replace.py script adds bullets automatically; missing formatting properties lose original styling; unmentioned shapes get cleared" ;
    oc:severityLevel "CRITICAL" .

oc:kn_bac45592 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting template layouts for content" ;
    oc:directiveContent "Match layout structure to actual content: 2 items → 2-column layout only, 3 items → 3-column layout only, image+text layouts only with actual images, quote layouts only for attributed quotes. Never use layouts with more placeholders than content." ;
    oc:hasRationale "Mismatched layouts with empty placeholders look unprofessional and confusing" ;
    oc:severityLevel "HIGH" .

oc:kn_cc25bd5c a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating a presentation using an existing template" ;
    oc:directiveContent "1. Extract text + create thumbnails → 2. Analyze template, save inventory to template-inventory.md → 3. Create outline with template mapping (0-indexed) → 4. Rearrange: python scripts/rearrange.py template.pptx working.pptx indices → 5. Extract inventory: python scripts/inventory.py working.pptx text-inventory.json → 6. Generate replacement-text.json (shapes without paragraphs are auto-cleared) → 7. Apply: python scripts/replace.py working.pptx replacement-text.json output.pptx" ;
    oc:stepOrder 3 .

oc:kn_f5066f54 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When given an example presentation to emulate" ;
    oc:directiveContent "When emulating an existing design, analyze typography and colors first: read ppt/theme/theme1.xml for color scheme and fonts, examine actual slide XML for font usage, grep for color and font patterns across all XML files." ;
    oc:hasRationale "Theme files define intended design but actual slides may override; both must be analyzed for accurate reproduction" ;
    oc:severityLevel "MEDIUM" .

