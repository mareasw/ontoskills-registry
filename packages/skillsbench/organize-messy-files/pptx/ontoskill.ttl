                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Raw XML access" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "If you just need to read the text contents of a presentation, you should convert the document to markdown:" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """# Convert document to markdown
python -m markitdown path-to-file.pptx
""" ;
                                    oc:codeLanguage "bash" ;
                                    oc:contentOrder 2 ;
