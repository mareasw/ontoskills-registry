        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: planning-with-files
description: Implements Manus-style file-based planning for complex tasks. Creates task_plan.md, findings.md, and progress.md. Use when starting complex multi-step tasks, research projects, or any task requiring >5 tool calls.
allowed-tools:
  - Read
  - Write
  - Edit
  - Bash
  - Glob
  - Grep
  - WebFetch
  - WebSearch
metadata:
  version: "2.1.2"
  user-invocable: true
  hooks:
    SessionStart:
      - hooks:
          - type: command
            command: "echo '[planning-with-files] Ready. Auto-activates for complex tasks, or invoke manually with /planning-with-files'"
    PreToolUse:
      - matcher: "Write|Edit|Bash"
        hooks:
          - type: command
            command: "cat task_plan.md 2>/dev/null | head -30 || true"
    PostToolUse:
      - matcher: "Write|Edit"
        hooks:
          - type: command
            command: "echo '[planning-with-files] File updated. If this completes a phase, update task_plan.md status.'"
    Stop:
      - hooks:
          - type: command
            command: "${CLAUDE_PLUGIN_ROOT}/scripts/check-complete.sh"
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
    oc:hasWorkflow _:ref_06d4b4167911848f,
        [ a oc:Workflow ;
            dcterms:description "Core workflow for managing complex tasks using file-based planning" ;
            oc:hasStep _:ref_56515b4734a11680,
                _:ref_6060a3540f62f5d0,
                _:ref_6dd79cb8e6f83830,
                _:ref_865b3579639a5403,
                [ a oc:WorkflowStep ;
                    dcterms:description "Run check-complete.sh to verify all phases complete and no unresolved errors" ;
                    oc:expectedOutcome "All phases marked complete, no blocking errors" ;
                    oc:stepDependsOn _:ref_56515b4734a11680 ;
                    oc:stepId "verify-complete" ],
                _:ref_f51b2086563cd7d6 ;
            oc:workflowId "plan-execute-track" ;
            oc:workflowName "Plan-Execute-Track Cycle" ] ;
    oc:impartsKnowledge oc:kn_06455661,
        oc:kn_0e47ef86,
        oc:kn_5a9d4f2b,
        oc:kn_62a9957d,
        oc:kn_65bd3be0,
        oc:kn_65be7768,
        oc:kn_aa6e5edc,
        oc:kn_e0a8e967,
        oc:kn_e31943a7,
        oc:kn_f7f82738 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:DirectoryWritable ;
    oc:resolvesIntent "maintain working memory across sessions",
        "manage research findings",
        "organize multi-step work",
        "plan complex tasks",
        "track task progress" ;
    oc:yieldsState oc:PlanCreated,
        oc:ProgressTracking .

oc:kn_06455661 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When initializing a planning session" ;
    oc:directiveContent "Creates three planning files (task_plan.md, findings.md, progress.md) in the project directory. These files persist after the session ends." ;
    oc:hasRationale "These files serve as the persistent memory store and will exist in the user's project directory." ;
    oc:severityLevel "LOW" .

oc:kn_0e47ef86 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before creating planning files" ;
    oc:directiveContent "Verify the project directory is writable and does not already contain conflicting planning files from a different task." ;
    oc:hasRationale "Overwriting an existing plan from another task could destroy valuable state." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5a9d4f2b a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When any action fails repeatedly" ;
    oc:directiveContent "Follow the 3-strike protocol: Attempt 1 diagnose & fix, Attempt 2 try alternative approach, Attempt 3 broader rethink. After 3 failures, escalate to user." ;
    oc:hasRationale "Systematic escalation prevents infinite loops and ensures the agent doesn't repeat failing actions." ;
    oc:severityLevel "HIGH" .

oc:kn_62a9957d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "During research or browsing operations" ;
    oc:directiveContent "After every 2 view/browser/search operations, IMMEDIATELY save key findings to text files." ;
    oc:hasRationale "Visual and multimodal information degrades rapidly in context; writing to disk preserves it." ;
    oc:severityLevel "HIGH" .

oc:kn_65bd3be0 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always during task execution" ;
    oc:directiveContent "Treat the filesystem as persistent disk and context window as volatile RAM. Write anything important to disk immediately." ;
    oc:hasRationale "Context windows have hard limits and information gets evicted; files persist across the entire session." ;
    oc:severityLevel "MEDIUM" .

oc:kn_65be7768 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When an action fails" ;
    oc:directiveContent "Never repeat the exact same failing action. Track what was tried and mutate the approach." ;
    oc:hasRationale "Repeating failed actions wastes tokens and time; mutations are needed to find a working path." ;
    oc:severityLevel "CRITICAL" .

oc:kn_aa6e5edc a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating planning files" ;
    oc:directiveContent "Planning files (task_plan.md, findings.md, progress.md) must be created in the project working directory, NOT in the skill installation directory." ;
    oc:hasRationale "Planning files belong alongside the project code so they are visible and version-controlled with the project." ;
    oc:severityLevel "HIGH" .

oc:kn_e0a8e967 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "When finishing a planned task" ;
    oc:directiveContent "Run check-complete.sh to verify all phases are marked complete and no errors remain unresolved." ;
    oc:hasRationale "Ensures nothing was missed and all planned work items have been addressed." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e31943a7 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "Before making any significant decision during task execution" ;
    oc:directiveContent "Before major decisions, re-read the plan file to refresh goals in the attention window." ;
    oc:hasRationale "Context windows are limited and goals stated early may have been evicted by new information." ;
    oc:severityLevel "HIGH" .

oc:kn_f7f82738 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before beginning any multi-step task" ;
    oc:directiveContent "Never start a complex task without creating task_plan.md first. This is non-negotiable." ;
    oc:hasRationale "Without a plan file, goals and progress exist only in volatile context memory and will be lost." ;
    oc:severityLevel "CRITICAL" .

