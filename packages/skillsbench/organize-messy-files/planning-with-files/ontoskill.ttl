                                    oc:itemText "`scripts/init-session.sh` — Initialize all planning files" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "`scripts/check-complete.sh` — Verify all phases complete" ] ] ;
