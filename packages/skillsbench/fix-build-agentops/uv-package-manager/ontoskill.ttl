oc:kn_09c69f26 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before running any uv commands" ;
    oc:directiveContent "Verify uv is installed with `uv --version` before attempting project setup commands." ;
    oc:hasRationale "uv must be available on PATH; if missing, install via curl/pip/brew first" .

oc:kn_41db4e29 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "On cache corruption or inexplicable installation failures" ;
    oc:directiveContent "Clear the global cache with `uv cache clean` when encountering corrupted or stale package data." ;
    oc:hasRationale "uv's global cache can occasionally hold corrupted artifacts; clearing resolves mysterious install failures" .

oc:kn_76903044 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When evaluating tool choice for dependency management" ;
    oc:directiveContent "uv is 10-100x faster than pip due to Rust implementation, parallel installation, and global disk cache." ;
    oc:hasRationale "Performance gains are most dramatic in CI/CD and cold-start scenarios" .

oc:kn_82114aae a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When managing project dependencies" ;
    oc:directiveContent "Always commit uv.lock to version control for reproducible builds across environments." ;
    oc:hasRationale "Lockfiles ensure exact version reproduction in CI/CD and across developer machines" ;
    oc:severityLevel "HIGH" .

oc:kn_882b0b79 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When optimizing Docker images for production" ;
    oc:directiveContent "For Docker builds, use multi-stage builds with uv sync --frozen --no-dev --no-editable, then copy .venv to a slim runtime image." ;
    oc:hasRationale "Multi-stage builds minimize final image size while maintaining reproducible dependencies" .

oc:kn_9de9a88b a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When running uv sync in CI/CD environments" ;
    oc:directiveContent "Use --frozen flag in CI pipelines to prevent unexpected dependency resolution." ;
    oc:hasRationale "Frozen installs guarantee the lockfile is respected exactly, avoiding surprise upgrades in production" ;
    oc:severityLevel "CRITICAL" .

oc:kn_a43357f3 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When managing project dependencies" ;
    oc:directiveContent "Do not mix pip and uv commands on the same virtual environment." ;
    oc:hasRationale "Mixing package managers can cause inconsistent state, broken metadata, and resolution conflicts" ;
    oc:severityLevel "HIGH" .

oc:kn_c9077783 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When re-running CI or reprovisioning environments" ;
    oc:directiveContent "uv sync is idempotent — running it multiple times produces the same environment state as defined by uv.lock." ;
    oc:hasRationale "Safe to run repeatedly without side effects, enabling reliable automated workflows" .

oc:kn_dca07037 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up a new project" ;
    oc:directiveContent "Pin Python version with .python-version file via `uv python pin <version>` at project initialization." ;
    oc:hasRationale "Ensures consistent interpreter version across all developers and CI environments" .

oc:kn_e2822d98 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "After manually editing pyproject.toml" ;
    oc:directiveContent "Lockfile out-of-sync errors occur when pyproject.toml is modified without running uv lock." ;
    oc:hasRationale "The lockfile must be regenerated whenever dependency specifications change to stay consistent" ;
    oc:severityLevel "MEDIUM" .

oc:kn_ee0d431f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running Python scripts or tools in a project" ;
    oc:directiveContent "Use `uv run` instead of manually activating virtual environments." ;
    oc:hasRationale "uv run auto-activates the project venv, reducing errors from forgotten activation and simplifying workflows" ;
    oc:severityLevel "MEDIUM" .

oc:req_6a683cce a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "bash" .

oc:req_89f0378e a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "uv" .

