oc:kn_01ed7e13 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any Temporal workflow test" ;
    oc:directiveContent "Do not test workflows without mocking activities or without using time-skipping. Never skip replay testing when deploying workflow changes to production." ;
    oc:hasRationale "Without mocking, tests become non-deterministic and slow. Without replay testing, workflow changes may break in production due to non-deterministic execution" ;
    oc:severityLevel "CRITICAL" .

oc:kn_259bf9ee a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When writing Temporal workflow tests from scratch" ;
    oc:directiveContent "1. Identify testing scenario (unit/integration/replay/local-setup) 2. Load corresponding resource file 3. Create async pytest fixture with WorkflowEnvironment.start_time_skipping() 4. Write test using Worker and client.execute_workflow 5. Assert results against expected values 6. Run with pytest-asyncio and verify ≥80% coverage" ;
    oc:stepOrder 1 .

oc:kn_45e3dbaf a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning test strategy for Temporal workflows" ;
    oc:directiveContent "Write the majority of Temporal tests as integration tests with mocked activities, not end-to-end tests. Use unit tests with time-skipping for fast feedback, and reserve end-to-end tests sparingly." ;
    oc:hasRationale "Integration tests balance confidence and speed; end-to-end tests are slow and flaky, while pure unit tests may miss interaction bugs" ;
    oc:severityLevel "HIGH" .

oc:kn_a80addef a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When testing long-running workflows or individual activities" ;
    oc:directiveContent "Use WorkflowEnvironment.start_time_skipping() to compress month-long workflow executions into seconds. Use ActivityEnvironment for isolated activity unit tests." ;
    oc:hasRationale "Time-skipping is Temporal's key testing advantage — it enables testing complex time-dependent logic without real waits" ;
    oc:severityLevel "MEDIUM" .

oc:kn_daf176f5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When measuring test coverage for production Temporal workflows" ;
    oc:directiveContent "Target ≥80% logic coverage for both workflows and activities. All workflow versions must pass replay testing before deployment." ;
    oc:hasRationale "Temporal workflows are long-running distributed computations where bugs are costly; high coverage and determinism validation prevent production failures" ;
    oc:severityLevel "HIGH" .

oc:kn_ed6143b8 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When the agent encounters a specific Temporal testing need" ;
    oc:directiveContent "Load progressive disclosure resources based on testing scenario: unit-testing.md for isolated tests, integration-testing.md for mocked dependencies, replay-testing.md for determinism, local-setup.md for environment setup." ;
    oc:hasRationale "Temporal testing is broad; progressive disclosure prevents information overload while ensuring depth when needed" ;
    oc:severityLevel "MEDIUM" .

