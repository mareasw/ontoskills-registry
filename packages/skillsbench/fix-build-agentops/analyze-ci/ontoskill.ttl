                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**GitHub Token**: Auto-detected via `gh auth token`, or set `GITHUB_TOKEN` env var" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Prerequisites" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Analyze CI Failures" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Fetch and analyze failed GitHub Action jobs for a pull request or specific job URLs" ;
            oc:hasStep _:ref_2a69462d2c3cf450,
