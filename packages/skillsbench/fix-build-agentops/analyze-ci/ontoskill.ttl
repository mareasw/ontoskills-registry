    oc:contentHash "d8e86df9dcbb6325f68e2bbcb0ac608299588ebcfdf04abcff4a7d4e20810b9e" ;
    oc:differentia "analyzes failed GitHub Action jobs using Claude to produce concise failure summaries with root cause identification" ;
    oc:handlesFailure oc:InvalidInput,
        oc:NetworkTimeout,
        oc:PermissionDenied ;
    oc:hasAllowedTool "Bash" ;
    oc:hasArgumentHint "<pr_url> or <job_url> [job_url ...] [--debug]" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Analyze failed GitHub Action jobs for a pull request." ;
    oc:hasName "analyze-ci" ;
    oc:hasRequirement oc:req_0eafac1e,
