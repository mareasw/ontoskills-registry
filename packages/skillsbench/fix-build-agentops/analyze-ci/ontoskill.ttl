oc:kn_54feaf6b a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "1. Accept PR URL or job URL(s) as input 2. Fetch GitHub Action logs via gh API 3. Analyze logs using Claude 4. Output concise failure summary with root cause, error messages, test names, log snippets" ;
    oc:stepOrder 1 .

oc:kn_5bb0be3a a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When processing CI logs" ;
    oc:directiveContent "CI logs may contain secrets, tokens, or sensitive environment variables; avoid logging or persisting raw log output" ;
    oc:severityLevel "HIGH" .

oc:kn_60006ab1 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before any CI analysis execution" ;
    oc:directiveContent "GitHub authentication required: auto-detected via `gh auth token` or set `GITHUB_TOKEN` env var" .

oc:kn_a5ec4916 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "always" ;
    oc:directiveContent "Concise failure summary with: root cause, error messages, test names, relevant log snippets" ;
    oc:templateVariables "error_messages",
        "log_snippets",
        "root_cause",
        "test_names" .

oc:kn_ad275b06 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When re-running analysis" ;
    oc:directiveContent "Running multiple times produces same analysis for unchanged CI logs; re-running on updated PR may yield different results if new failures occurred" .

oc:kn_dd0aa32a a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When analyzing CI failures" ;
    oc:directiveContent """uv run skills analyze-ci <pr_url>
uv run skills analyze-ci <job_url> [job_url ...]
uv run skills analyze-ci <pr_url> --debug""" .

oc:kn_df5ad39f a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before execution" ;
    oc:directiveContent "Verify gh auth token is available or GITHUB_TOKEN env var is set before running analysis" .

oc:req_0eafac1e a oc:RequirementAPI ;
    oc:isOptional true ;
    oc:requirementValue "GITHUB_TOKEN (auto-detected via gh auth token)" .

oc:req_333cda1a a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "gh CLI (GitHub CLI)" .

oc:req_4d830aa1 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "uv package manager" .

_:ref_2a69462d2c3cf450 a oc:WorkflowStep ;
    dcterms:description "Verify GitHub authentication via gh auth token or GITHUB_TOKEN env var" ;
    oc:expectedOutcome "Valid GitHub credentials confirmed" ;
    oc:stepId "authenticate" .

_:ref_de6021faf70bfaeb a oc:WorkflowStep ;
    dcterms:description "Fetch failed job logs from GitHub Actions API using the provided PR URL or job URLs" ;
    oc:expectedOutcome "Raw CI log data retrieved for all failed jobs" ;
    oc:stepDependsOn _:ref_2a69462d2c3cf450 ;
    oc:stepId "fetch-logs" .

