                                    oc:textContent "Pass FastMCP servers directly to clients:" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "Only use HTTP transport when explicitly testing network features." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Use in-memory transport for testing" ],
