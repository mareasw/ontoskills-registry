oc:kn_46ad17dc a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding what to mock" ;
    oc:directiveContent "Mock at the boundary — mock external services and dependencies, not internal classes. Test your own code with real implementations when possible." ;
    oc:hasRationale "Mocking internal classes hides real bugs; mocking external boundaries isolates your system from flaky or unavailable dependencies." ;
    oc:severityLevel "HIGH" .

oc:kn_78871329 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any test function" ;
    oc:directiveContent "Never write a test that verifies multiple unrelated behaviors. Each test should be atomic, self-contained, and test a single functionality." ;
    oc:hasRationale "Tests that assert multiple unrelated behaviors are harder to debug and maintain when they fail." ;
    oc:severityLevel "CRITICAL" .

oc:kn_86016c2f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing async tests in this project" ;
    oc:directiveContent "Do not use @pytest.mark.asyncio decorators. The project uses asyncio_mode = \"auto\" globally." ;
    oc:hasRationale "The auto mode means async test functions are automatically recognized; adding the decorator is redundant and against project convention." ;
    oc:severityLevel "HIGH" .

oc:kn_b0809e73 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When testing MCP/fastmcp server code" ;
    oc:directiveContent "Use in-memory transport (pass FastMCP servers directly to clients) for testing. Only use HTTP transport when explicitly testing network features." ;
    oc:hasRationale "In-memory transport is faster, more reliable, and avoids network flakiness in tests." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b9084762 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before finalizing any test file" ;
    oc:directiveContent "Before submitting tests verify: each test tests one thing, no @pytest.mark.asyncio decorators, imports at module level, descriptive test names, in-memory transport used, parameterization for variations, separate tests for different behaviors." ;
    oc:hasRationale "The checklist catches the most common violations of project test conventions." ;
    oc:severityLevel "MEDIUM" .

oc:kn_bde5fbbf a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When organizing imports in test files" ;
    oc:directiveContent "Put ALL imports at the top of the file at module level. Never use local imports inside test functions." ;
    oc:hasRationale "Module-level imports improve readability, avoid import-time side effects per test, and follow project conventions." ;
    oc:severityLevel "HIGH" .

oc:kn_cb15df0f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When multiple test inputs exercise the same code path" ;
    oc:directiveContent "Use parameterization for variations of the same concept/behavior. Write separate tests for fundamentally different behaviors." ;
    oc:hasRationale "Parameterized tests reduce duplication while keeping related assertions grouped; separate tests maintain atomicity for unrelated behaviors." ;
    oc:severityLevel "MEDIUM" .

oc:kn_df3ca6aa a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When naming test functions" ;
    oc:directiveContent "Test names must describe the scenario and tell you what is broken when they fail. Use patterns like test_<action>_<condition/expected>." ;
    oc:hasRationale "Descriptive names provide immediate diagnostic value in CI output and test reports without reading the test body." ;
    oc:severityLevel "MEDIUM" .

_:ref_248f1723aa8aa2bc a oc:WorkflowStep ;
    dcterms:description "Add all necessary imports at the top of the test module." ;
    oc:expectedOutcome "Module-level imports with no local imports in test bodies." ;
    oc:stepId "setup-imports" .

_:ref_7672fb95b46d4d8f a oc:WorkflowStep ;
    dcterms:description "Write assertions verifying the single behavior. Use pytest.raises for error cases, parameterization for input variations." ;
    oc:expectedOutcome "Assertions that verify exactly one behavior per test." ;
    oc:stepDependsOn _:ref_f118eb9c90003eee ;
    oc:stepId "write-assertions" .

_:ref_cbda36a4e194095e a oc:WorkflowStep ;
    dcterms:description "Run tests with 'uv run pytest -n auto -x' to execute in parallel and stop on first failure." ;
    oc:expectedOutcome "All tests pass; if not, debug the failing test." ;
    oc:stepDependsOn _:ref_248f1723aa8aa2bc,
        _:ref_7672fb95b46d4d8f ;
    oc:stepId "run-tests" .

_:ref_f118eb9c90003eee a oc:WorkflowStep ;
    dcterms:description "Identify the single behavior to test and write a descriptive test name (e.g., test_action_condition)." ;
    oc:expectedOutcome "A clear, named test function that communicates what it verifies." ;
    oc:stepId "choose-scope" .

