oc:kn_0fcd4848 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When setting up any parallel computation" ;
    oc:directiveContent "1. Define a pure function for a single item 2. Pre-compute any shared data once outside Parallel 3. Wrap calls with delayed() 4. Set n_jobs=-1 for all cores or specific number 5. Filter None results after collection" ;
    oc:stepOrder 1 .

oc:kn_1e99ad72 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running parallel grid search over hyperparameters" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from joblib import Parallel, delayed
from itertools import product
params = list(product(param_a_values, param_b_values))
results = Parallel(n_jobs=-1, verbose=10)(delayed(evaluate)(a, b) for a, b in params)
best = max(results, key=lambda x: x['score'])""" .

oc:kn_71a83dd2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When passing large datasets to Parallel()" ;
    oc:directiveContent "Each worker gets its own copy of data — watch memory usage when passing large objects to parallel tasks." ;
    oc:hasRationale "Joblib serializes arguments to each worker independently, multiplying memory consumption by n_jobs." .

oc:kn_77580c48 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When all tasks need the same reference data" ;
    oc:directiveContent "Do not compute shared data inside the worker function — pre-compute it once and pass it as an argument." ;
    oc:hasRationale "Recomputing shared data per worker wastes CPU and memory; pre-computing once avoids redundant work." ;
    oc:severityLevel "HIGH" .

oc:kn_7f174489 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding whether to use Parallel()" ;
    oc:directiveContent "Only parallelize tasks where each item takes >0.1s; otherwise the process spawning overhead exceeds the benefit." ;
    oc:hasRationale "Joblib worker processes have startup and serialization overhead that negates gains for trivially fast items." .

oc:kn_e28c8041 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When parallelizing any function over an iterable" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from joblib import Parallel, delayed
results = Parallel(n_jobs=-1)(delayed(func)(arg) for arg in iterable)""" .

oc:kn_f09fff5a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting the joblib backend" ;
    oc:directiveContent "Use backend='loky' (default) for CPU-bound tasks and backend='threading' for I/O-bound tasks." ;
    oc:hasRationale "Loky uses separate processes to bypass the GIL for CPU work; threading allows concurrent I/O without process overhead." .

oc:req_abc92cd8 a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "Python multiprocessing concepts (GIL, processes vs threads)" .

oc:req_b9d4feff a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "joblib" .

