oc:kn_e4b0a681 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When using custom metrics on large datasets" ;
    oc:directiveContent "Custom Python distance functions are significantly slower than built-in metrics. For large datasets, vectorize operations or pre-compute distance matrices when doing multiple lookups." ;
    oc:hasRationale "Python-level function call overhead per pair of points makes custom metrics orders of magnitude slower than C-optimized built-in metrics" ;
    oc:severityLevel "MEDIUM" .

oc:kn_efaf9462 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a distance metric needs configurable parameters (weights, scales, thresholds)" ;
    oc:directiveContent "Use a factory/closure pattern to create parameterized distance functions: outer function takes parameters, inner function captures them via closure and computes distance." ;
    oc:hasRationale "sklearn's metric parameter accepts a callable(u, v) -> float only; closures provide a clean way to inject parameters without global state" .

