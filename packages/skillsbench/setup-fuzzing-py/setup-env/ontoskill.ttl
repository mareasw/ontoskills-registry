        "run Python scripts in isolated environment",
        "set up Python virtual environment" ;
    oc:yieldsState oc:EnvironmentReady .

oc:kn_091b692b a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "always" ;
    oc:directiveContent "uv must be installed and available on PATH before this skill can execute." ;
    oc:hasRationale "All commands in this skill depend on the uv tool." ;
    oc:severityLevel "CRITICAL" .

oc:kn_419b3873 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before any environment setup" ;
    oc:directiveContent "Select workflow by detecting project files: if pyproject.toml exists use project workflow (uv sync, uv run); else if requirements.txt exists use pip workflow (uv venv, uv pip install, .venv/bin/python); else error out." ;
    oc:hasRationale "Choosing the wrong workflow leads to missing dependencies or broken environments." ;
    oc:severityLevel "CRITICAL" .

oc:kn_4e553577 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "After completing environment setup" ;
    oc:directiveContent "Verify setup with: `test -x .venv/bin/python` and `uv pip list` to confirm the venv exists and packages are installed." ;
    oc:hasRationale "Silent failures in venv creation or package installation can cause confusing downstream errors." .

oc:kn_773d60da a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before environment setup begins" ;
    oc:directiveContent "The project must have either pyproject.toml or requirements.txt at the repo root. If neither exists, stop with an error." ;
    oc:hasRationale "Without a dependency manifest, there is no way to determine what to install." ;
    oc:severityLevel "HIGH" .

oc:kn_7ebdb242 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When executing any Python script or module" ;
    oc:directiveContent "Always run scripts inside the project environment using `uv run -- python <script.py>` for project workflow or `.venv/bin/python <script.py>` for pip workflow. Never activate the venv manually." ;
    oc:hasRationale "Direct activation is error-prone in automated agent contexts; explicit interpreter paths or uv run are more reliable." .

_:ref_0c5177de61a78e15 a oc:WorkflowStep ;
    dcterms:description "Run Python scripts/commands" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_48529fd4417681a0 a oc:WorkflowStep ;
    dcterms:description "Create a virtual environment" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_9fd4d453aea93003 a oc:WorkflowStep ;
    dcterms:description "Install dependencies" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_60f195b843936e09 a oc:WorkflowStep ;
    dcterms:description "Check for pyproject.toml in repo root" ;
    oc:expectedOutcome "pyproject.toml found, proceed with project workflow" ;
    oc:stepId "detect-project" .

_:ref_627a733ea24e31eb a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_0c5177de61a78e15,
        _:ref_48529fd4417681a0,
        _:ref_9fd4d453aea93003 ;
    oc:workflowId "procedure_1" ;
    oc:workflowName "Ordered Procedure" .

_:ref_7e3b74605aebd08f a oc:WorkflowStep ;
    dcterms:description "Run `uv venv` from repo root to create .venv" ;
    oc:expectedOutcome ".venv directory created" ;
    oc:stepDependsOn _:ref_a3dc6abe9c17f528 ;
    oc:stepId "create-venv" .

_:ref_a3dc6abe9c17f528 a oc:WorkflowStep ;
    dcterms:description "Check for requirements.txt in repo root" ;
    oc:expectedOutcome "requirements.txt found, proceed with pip workflow" ;
    oc:stepId "detect-requirements" .

_:ref_006e259f044de5f7 a oc:WorkflowStep ;
    dcterms:description "Run `uv sync` from repo root to create .venv and install all dependencies" ;
    oc:expectedOutcome ".venv directory created with all dependencies installed" ;
    oc:stepDependsOn _:ref_60f195b843936e09 ;
    oc:stepId "sync-deps" .

_:ref_de641e8b7b691d56 a oc:WorkflowStep ;
    dcterms:description "Run `uv pip install -r requirements.txt`" ;
    oc:expectedOutcome "All packages from requirements.txt installed into .venv" ;
    oc:stepDependsOn _:ref_7e3b74605aebd08f ;
    oc:stepId "install-deps" .

