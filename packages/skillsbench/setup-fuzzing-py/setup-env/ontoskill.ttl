                    oc:expectedOutcome "Script executes within the venv" ;
                    oc:stepDependsOn _:ref_de641e8b7b691d56 ;
                    oc:stepId "run-script-pip" ],
                _:ref_de641e8b7b691d56 ;
            oc:workflowId "setup-env-pip" ;
            oc:workflowName "Pip Workflow (requirements.txt)" ],
        [ a oc:Workflow ;
            dcterms:description "Set up environment and run scripts when pyproject.toml is present" ;
            oc:hasStep _:ref_006e259f044de5f7,
                [ a oc:WorkflowStep ;
                    dcterms:description "Run sanity checks: `test -x .venv/bin/python` and `uv pip list`" ;
                    oc:expectedOutcome "Venv exists and packages are listed" ;
                    oc:stepDependsOn _:ref_006e259f044de5f7 ;
                    oc:stepId "verify-setup" ],
                _:ref_60f195b843936e09,
