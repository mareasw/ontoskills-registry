                                    oc:itemText "Identify parsers, decoders, validators, or boundary code that is fuzz-worthy" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Produce a structured shortlist of fuzz targets with harness guidance" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Decide what to fuzz based on existing test coverage and API surface" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
