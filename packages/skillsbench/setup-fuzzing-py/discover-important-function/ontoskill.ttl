oc:skill_setup_fuzzing_py_discover_important_function a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "discover-important-function" ;
    skos:broader "Code analysis methodology" ;
    prov:wasDerivedFrom ".agents/skills/skillsbench/setup-fuzzing-py/discover-important-function" ;
    oc:contentHash "a2b24860a8f050f81db64941d27d88ebe9308be35c56c6f22de562e3b66cb1ca" ;
    oc:dependsOnSkill oc:skill_ontoskills_setup_env ;
    oc:differentia "Identifies and ranks high-value fuzz targets in Python repositories by combining static analysis, test inspection, and heuristic scoring" ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput ;
    oc:hasAllowedTool "Bash",
        "Glob",
        "Grep",
        "Read" ;
    oc:hasArgumentHint "path to Python repository root" ;
    oc:hasCategory "development" ;
    oc:hasDescription "When given a project codebase, this skill observes the important functions in the codebase for future action." ;
    oc:hasName "discover-important-function" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "At the end of the report, include a JSON object with:" ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 2 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "selected_futs: [{qualname, file, line_range, justification}]" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "test_summary: {test_map, inferred_oracles, gaps}" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "important_files: [{path, score, rationale, indicators_hit}]" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "important_functions: [{qualname, file, line_range, score, rationale, dependencies, harnessability}]" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 5 ;
                            oc:itemText "notes_to_self: [{target_qualname, note}]" ] ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 29 ;
            oc:sectionTitle "Final JSON block" ],
        [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Ranking functions" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Proposing seed corpus sources" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Designing input models and oracles" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Selecting FUTs" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Always inspect and incorporate existing tests in the repository when:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 21 ;
                    oc:sectionTitle "Hard requirement" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "test_map: module_under_test → tests → asserted behaviors" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "inferred_oracles: list of reusable invariants with the functions they apply to" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "gaps: ranked list of untested or weakly-tested candidates" ] ] ;
