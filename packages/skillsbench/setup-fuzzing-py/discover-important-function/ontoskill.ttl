                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent """Do not use this skill when the user primarily wants to fix a specific bug,
refactor code, or implement a harness immediately
(unless they explicitly ask for target selection first).""" ] ;
