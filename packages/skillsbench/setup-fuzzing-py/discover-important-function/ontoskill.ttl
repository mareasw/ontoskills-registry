oc:kn_08062b8f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When localizing important functions via Approach 1 (AST-based scan)" ;
    oc:directiveContent "Do not read full function bodies during the initial analysis pass. Use AST-based header/docstring scanning first, then targeted reading only for top candidates." ;
    oc:hasRationale "Reading all function bodies upfront wastes tokens and time; headers and docstrings contain enough signal to filter candidates." ;
    oc:severityLevel "MEDIUM" .

oc:kn_314652c7 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning file localization" ;
    oc:directiveContent "Use `tree` to get a fast high-signal view of repository structure. Fall back to recursive shell listing if tree is unavailable." ;
    oc:hasRationale "A structural overview is essential to orient the analysis and identify package layouts, test directories, and native bindings." ;
    oc:severityLevel "LOW" .

oc:kn_77b95de4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Throughout the entire analysis workflow" ;
    oc:directiveContent "Always inspect and incorporate existing tests when ranking functions, selecting FUTs, designing input models and oracles, and proposing seed corpus sources." ;
    oc:hasRationale "Existing tests reveal oracles, document expected behavior, and highlight coverage gaps that fuzzing should target." ;
    oc:severityLevel "CRITICAL" .

oc:kn_7c6d95dc a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When localizing important files" ;
    oc:directiveContent "Score files higher when they exhibit: public API exposure, input boundary keywords (parse/load/decode/validate), format handlers (json/yaml/xml), native boundaries (ctypes/cffi), high import fan-in, or heavy test references." ;
    oc:hasRationale "These indicators are strong predictors of fuzz-worthy logic and boundary code." ;
    oc:severityLevel "MEDIUM" .

oc:kn_93534c18 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When executing commands during analysis" ;
    oc:directiveContent "This skill is read-only analysis. Default to read-only commands and avoid any source code modifications." ;
    oc:hasRationale "Analysis should not alter the codebase; any changes require explicit user consent." ;
    oc:severityLevel "MEDIUM" .

oc:kn_eb05a528 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting fuzz targets and producing final output" ;
    oc:directiveContent "Keep the final FUT shortlist small (typically 1–5 functions). Do not modify source code unless explicitly requested." ;
    oc:hasRationale "A focused shortlist ensures the agent can produce high-quality harnesses rather than spreading effort across too many targets." ;
    oc:severityLevel "HIGH" .

oc:kn_f65aafca a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scoring and ranking function candidates for fuzzing" ;
    oc:directiveContent "Prioritize functions that accept bytes/str/file-like/dict payloads, convert between representations, perform validation/parsing/decoding, touch filesystem/network/protocol boundaries, or call into native extensions." ;
    oc:hasRationale "These characteristics correlate strongly with security-relevant attack surfaces where fuzzing has highest payoff." ;
    oc:severityLevel "HIGH" .

