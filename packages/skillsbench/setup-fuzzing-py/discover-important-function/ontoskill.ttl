                    oc:itemOrder 2 ;
                    oc:itemText "Input boundary keywords in file path or symbols: parse, load, dump, decode, encode, deserialize, serialize, validate, normalize, schema, protocol, message" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 4 ;
                    oc:itemText "Regex-heavy or templating-heavy code" ] ] ;
