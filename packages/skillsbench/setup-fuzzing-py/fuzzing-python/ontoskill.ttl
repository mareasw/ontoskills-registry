oc:kn_1fdc500f a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When fuzz target has side effects" ;
    oc:directiveContent "Ideally, fuzz targets should not modify global state. While not strictly required, modifying global state between iterations can cause unreliable results." ;
    oc:hasRationale "Global state changes persist across iterations in the same process, potentially causing false positives or missed bugs" ;
    oc:severityLevel "LOW" .

oc:kn_20d54c59 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When running fuzzers with coverage.py for visualization" ;
    oc:directiveContent "Use -atheris_runs=<number> instead of libFuzzer's -runs flag for graceful exit with coverage reports. No coverage report is generated on native code crashes or SIGINT." ;
    oc:hasRationale "Atheris needs to handle cleanup to produce coverage reports; only -atheris_runs guarantees graceful exit with report generation" ;
    oc:severityLevel "MEDIUM" .

oc:kn_6f459f6e a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When fuzzing C/C++ native extensions for CPython" ;
    oc:directiveContent "Atheris reports failures on uncaught exceptions. When fuzzing native extensions, combine with Address Sanitizer or Undefined Behavior Sanitizer for deeper bug detection." ;
    oc:hasRationale "Native code bugs (buffer overflows, use-after-free) are invisible to Python exception handling; sanitizers catch memory corruption bugs" ;
    oc:severityLevel "MEDIUM" .

oc:kn_841f268c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing fuzz target scope and complexity" ;
    oc:directiveContent "Fuzz targets must be fast — avoid cubic or greater complexity, excessive logging, or high memory consumption. Split targets handling multiple formats into separate fuzz targets per format." ;
    oc:hasRationale "Slow targets reduce iterations per second, dramatically decreasing the chance of finding bugs; narrow targets achieve higher coverage per target" ;
    oc:severityLevel "HIGH" .

oc:kn_9d16c5f2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any TestOneInput fuzz target function" ;
    oc:directiveContent "The fuzz target function must accept a single bytes argument, must not call exit(), must tolerate any input (empty, huge, malformed), and must be deterministic." ;
    oc:hasRationale "LibFuzzer executes the target many times in the same process; non-determinism or early exits make fuzzing ineffective or unstable" ;
    oc:severityLevel "CRITICAL" .

oc:kn_cdf4dea0 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting raw fuzz bytes into structured input types for the target function" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """fdp = atheris.FuzzedDataProvider(data)
value = fdp.ConsumeIntInRange(min_val, max_val)
items = fdp.ConsumeBytes(count)""" .

oc:kn_df657856 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When fuzz target parses structured or compressed input formats" ;
    oc:directiveContent "For code parsing complex data types (e.g., compressed data, serialized formats), use custom mutators via the custom_mutator parameter of atheris.Setup() to produce grammar-aware inputs." ;
    oc:hasRationale "Mutation-based fuzzing rarely produces valid structured inputs; custom mutators decompress/mutate/recompress to maintain format validity" ;
    oc:severityLevel "MEDIUM" .

oc:kn_e33f2f32 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When setting up any Atheris fuzz driver" ;
    oc:directiveContent "Import atheris first, then import all libraries to be fuzzed inside a `with atheris.instrument_imports():` block to enable coverage instrumentation." ;
    oc:hasRationale "Libraries imported outside the instrument_imports context will not have coverage instrumentation, reducing fuzzer effectiveness" ;
    oc:severityLevel "HIGH" .

oc:kn_f29bf67a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing fuzz targets with complex setup logic" ;
    oc:directiveContent "Do not add non-trivial logic before coverage instrumentation in TestOneInput; the first 2 calls must produce coverage events or you get 'no interesting inputs found' error." ;
    oc:hasRationale "Atheris requires coverage events from the first 2 invocations to initialize the fuzzer; nontrivial pre-processing can prevent this" ;
    oc:severityLevel "HIGH" .

oc:req_569ba2ed a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "atheris" .

oc:req_8ddfe0b2 a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "coverage-guided fuzzing" .

oc:req_b0a27d07 a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "libFuzzer" .

oc:req_c17bd76d a oc:RequirementTool ;
