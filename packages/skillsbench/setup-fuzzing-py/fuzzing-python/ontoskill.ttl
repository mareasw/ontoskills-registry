_:ref_738a5d58049218e1 a oc:WorkflowStep ;
    dcterms:description "Install Atheris: pip3 install atheris" ;
    oc:expectedOutcome "atheris package available for import" ;
    oc:stepId "install-atheris" .

_:ref_74f036b56fbbcb86 a oc:WorkflowStep ;
    dcterms:description "Write fuzz driver: import atheris, instrument target library imports, define TestOneInput(data) that exercises the target API, call Setup() and Fuzz()" ;
    oc:expectedOutcome "Complete fuzz driver Python script" ;
    oc:stepDependsOn _:ref_738a5d58049218e1,
        _:ref_d99b2cb07fce5671 ;
    oc:stepId "write-fuzz-driver" .

_:ref_c1bf77eb1f0bbef4 a oc:WorkflowStep ;
    dcterms:description "Add coverage instrumentation: use atheris.instrument_imports() for libraries, @atheris.instrument_func for individual functions, or atheris.instrument_all() for everything" ;
    oc:expectedOutcome "Coverage instrumentation active on target code paths" ;
    oc:stepDependsOn _:ref_74f036b56fbbcb86 ;
    oc:stepId "add-instrumentation" .

_:ref_d99b2cb07fce5671 a oc:WorkflowStep ;
    dcterms:description "Identify the function/API to fuzz from the target library (use discover-important-function skill)" ;
    oc:expectedOutcome "Specific function(s) selected as fuzz target entry point" ;
    oc:stepId "identify-target" .

