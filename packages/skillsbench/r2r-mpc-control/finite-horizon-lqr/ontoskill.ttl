oc:skill_r2r_mpc_control_finite_horizon_lqr a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "finite-horizon-lqr" ;
    skos:broader "Optimal control algorithm" ;
    prov:wasDerivedFrom ".agents/skills/skillsbench/r2r-mpc-control/finite-horizon-lqr" ;
    oc:contentHash "3b86d9a1ed1cf954d7b2d70050234c31552472c7ec0199b944c7fe85b127143c" ;
    oc:dependsOnSkill oc:skill_ontoskills_state_space_linearization ;
    oc:differentia "solves finite-horizon LQR via backward Riccati recursion for use in receding-horizon MPC" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasCategory "development" ;
    oc:hasDescription "Solving finite-horizon LQR via dynamic programming for MPC." ;
    oc:hasName "finite-horizon-lqr" ;
    oc:hasSection [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """J = Σ(k=0 to N-1) [x'Qx + u'Ru] + x_N' P x_N
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 11-13" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Minimize cost over horizon N:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Problem Formulation" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """u_k = -K_k @ x_k
x_{k+1} = A @ x_k + B @ u_k
""" ;
                            oc:codeLanguage "python" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 28-31" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Starting from x_0:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Forward Simulation" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "For k = N-1 down to 0:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """K_k = inv(R + B'P_{k+1}B) @ B'P_{k+1}A
P_k = Q + A'P_{k+1}(A - B @ K_k)
""" ;
                            oc:codeLanguage "python" ;
                            oc:contentOrder 3 ;
                            oc:sourceLocation "lines 20-23" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Initialize: P_N = Q (or LQR solution for stability)" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Backward Riccati Recursion" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "At each timestep:" ],
                        _:ref_b87dd5efdb438f43 ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "MPC Application" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """def finite_horizon_lqr(A, B, Q, R, N, x0):
    nx, nu = A.shape[0], B.shape[1]
    K = np.zeros((nu, nx, N))
    P = Q.copy()

    # Backward pass
    for k in range(N-1, -1, -1):
        K[:,:,k] = np.linalg.solve(R + B.T @ P @ B, B.T @ P @ A)
        P = Q + A.T @ P @ (A - B @ K[:,:,k])

    # Return first control
    return -K[:,:,0] @ x0
""" ;
                            oc:codeLanguage "python" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 35-48" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Python Implementation" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Finite-Horizon LQR for MPC" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: finite-horizon-lqr
description: Solving finite-horizon LQR via dynamic programming for MPC.
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
