oc:kn_1438be88 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When initializing the backward Riccati recursion" ;
    oc:directiveContent "Terminal cost P_N should be set to Q for a simple terminal penalty, or to the steady-state LQR solution for improved stability guarantees" ;
    oc:hasRationale "Proper terminal cost selection ensures closed-loop stability of the finite-horizon MPC scheme" ;
    oc:severityLevel "HIGH" .

oc:kn_47c4d9ff a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Receding-horizon MPC loop" ;
    oc:directiveContent "1. Measure current state x 2. Solve finite-horizon LQR from x 3. Apply first control u_0 4. Repeat next timestep" ;
    oc:stepOrder 2 .

oc:kn_5ad3cf8e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing the Riccati recursion in Python" ;
    oc:directiveContent "Use np.linalg.solve instead of explicit matrix inversion when computing the gain K_k = inv(R + B'P_{k+1}B) @ B'P_{k+1}A" ;
    oc:hasRationale "np.linalg.solve is numerically more stable and efficient than computing an explicit inverse" ;
    oc:severityLevel "MEDIUM" .

oc:kn_808772bb a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When solving finite-horizon LQR" ;
    oc:directiveContent "1. Initialize terminal cost P_N = Q (or steady-state LQR solution) 2. Backward pass: compute K_k and P_k for k=N-1 down to 0 via Riccati recursion 3. Return first control u_0 = -K_0 @ x_0" ;
    oc:stepOrder 1 .

oc:kn_b1aeba9f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing receding-horizon MPC" ;
    oc:directiveContent "Only the first control input u_0 is applied at each MPC timestep; the full horizon solution is recomputed at the next step" ;
    oc:hasRationale "Receding horizon handles disturbances and model mismatch by re-optimizing from the current measured state" .

oc:kn_f26e0f92 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Backward Riccati recursion step" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """K[:,:,k] = np.linalg.solve(R + B.T @ P @ B, B.T @ P @ A)
P = Q + A.T @ P @ (A - B @ K[:,:,k])""" .

