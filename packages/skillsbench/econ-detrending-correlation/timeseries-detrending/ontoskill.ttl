oc:kn_1ea958e8 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When reporting correlation of cyclical components" ;
    oc:directiveContent "Business cycle correlation: {correlation:.4f}" ;
    oc:templateVariables "correlation" .

oc:kn_202cfab9 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When detrending annual macroeconomic data" ;
    oc:directiveContent "Do not use λ=1600 (the quarterly default) for annual data — it produces an overly smooth trend that misses cyclical dynamics." ;
    oc:hasRationale "This is the most common mistake in applied macroeconomic detrending and silently produces misleading results." ;
    oc:severityLevel "HIGH" .

oc:kn_25bb7d1a a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before executing any detrending analysis" ;
    oc:directiveContent "Install required packages: pip install statsmodels pandas numpy" .

oc:kn_57e26fe1 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When preparing macroeconomic data for detrending" ;
    oc:directiveContent "Always convert nominal values to real (inflation-adjusted) terms before log transformation and filtering." ;
    oc:hasRationale "Nominal values conflate price level changes with real economic fluctuations, contaminating cyclical component extraction." ;
    oc:severityLevel "HIGH" .

oc:kn_795abaa3 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding whether to log-transform before filtering" ;
    oc:directiveContent "Do NOT apply log transformation to: series that can be negative (net exports, current account), series already expressed as rates or percentages, or series containing zeros." ;
    oc:hasRationale "Log of non-positive values is undefined or produces invalid results; rate series are already in comparable units." ;
    oc:severityLevel "HIGH" .

oc:kn_88845927 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Computing business cycle correlation between two detrended series" ;
    oc:codeLanguage "python" ;
    oc:directiveContent "correlation = np.corrcoef(cycle_c, cycle_i)[0, 1]" .

oc:kn_8ae46d31 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Complete detrending workflow" ;
    oc:directiveContent "1. Load and clean data (handle missing values, ensure time ordering) → 2. Convert to real terms (deflate using price index) → 3. Apply log transformation to positive level variables → 4. Apply HP filter with correct λ for data frequency → 5. Analyze cyclical component (correlations, volatilities)" ;
    oc:stepOrder 1 .

oc:kn_8b3f0cce a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Standard HP filter application to log-transformed annual data" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from statsmodels.tsa.filters.hp_filter import hpfilter
import numpy as np

log_series = np.log(real_series)
cycle, trend = hpfilter(log_series, lamb=100)  # λ=100 for annual data""" .

oc:kn_928c623f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying the HP filter to any time series" ;
    oc:directiveContent "The HP filter smoothing parameter λ must match data frequency: λ=100 for annual, λ=1600 for quarterly, λ=14400 for monthly data." ;
    oc:hasRationale "Using the wrong λ (e.g., quarterly default on annual data) produces an overly smooth trend that misses important cyclical dynamics." ;
    oc:severityLevel "CRITICAL" .

oc:kn_d79b6969 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When detrending growth series for business cycle analysis" ;
    oc:directiveContent "Apply natural logarithm to positive macroeconomic aggregates (GDP, consumption, investment) BEFORE HP filtering, never after." ;
    oc:hasRationale "Log transformation converts multiplicative relationships to additive, stabilizes variance, and makes the cyclical component interpretable as percentage deviations from trend." ;
    oc:severityLevel "HIGH" .

oc:kn_e061f981 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calling statsmodels hpfilter in Python" ;
    oc:directiveContent "The HP filter function parameter is `lamb` (not `lambda`) because `lambda` is a Python keyword." ;
    oc:hasRationale "Using `lambda` as parameter name causes a SyntaxError." ;
    oc:severityLevel "MEDIUM" .

