                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Important**: GLM `z` is height from lake bottom, not depth from surface." ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """# Convert to depth from surface
# Set LAKE_DEPTH based on lake_depth in &init_profiles section of glm3.nml
LAKE_DEPTH = <lake_depth_from_nml>
depth_from_surface = LAKE_DEPTH - z
""" ;
                            oc:codeLanguage "python" ;
