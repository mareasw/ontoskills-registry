oc:kn_516d11c9 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reading or analyzing GLM output variables" ;
    oc:directiveContent "Never use GLM z values directly as depth. z is height from lake bottom, not depth from surface. Convert using: depth = lake_depth - z." ;
    oc:hasRationale "Using z directly as depth produces inverted profiles and wildly incorrect RMSE values" ;
    oc:severityLevel "CRITICAL" .

oc:kn_84676382 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When merging simulated and observed dataframes" ;
    oc:directiveContent "Round depths to integers and group by (datetime, depth) when preparing data for comparison to ensure reliable matching between simulated and observed values." ;
    oc:hasRationale "Floating-point depth differences and duplicate layer records cause merge failures or inflated match counts" .

oc:kn_910719bc a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before converting z coordinates to depth" ;
    oc:directiveContent "The lake_depth value must be read from the &init_profiles section of glm3.nml to ensure correct coordinate conversion." ;
    oc:hasRationale "Using an incorrect lake_depth value shifts all depth calculations, making comparison with observations invalid" ;
    oc:severityLevel "HIGH" .

