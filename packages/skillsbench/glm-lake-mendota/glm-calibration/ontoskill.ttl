oc:kn_319a237e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When manual calibration has brought RMSE close to target" ;
    oc:directiveContent "Use optimization (e.g., Nelder-Mead) for fine-tuning after manual coarse adjustment of parameters. Limit maxiter to ~150." ;
    oc:hasRationale "Manual calibration provides good initial guesses; optimization then refines within the physical parameter space more efficiently than manual iteration alone" .

oc:kn_511af507 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Manual calibration of GLM water temperature" ;
    oc:directiveContent "1. Start with default parameters, run GLM, calculate RMSE. 2. Adjust one parameter at a time. 3. If surface too warm → increase wind_factor. 4. If deep water too warm → increase Kw. 5. If stratification too weak → decrease coef_mix_hyp. 6. Iterate until RMSE < 2.0°C." ;
    oc:hasRationale "One-at-a-time adjustment isolates the effect of each parameter on model output" ;
    oc:stepOrder 1 .

oc:kn_5982f7d6 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "All calibration runs" ;
    oc:directiveContent "Target RMSE < 2.0°C for good calibration. Keep all parameters within their physical ranges: Kw 0.1–0.5, coef_mix_hyp 0.3–0.7, wind_factor 0.7–1.3, lw_factor 0.7–1.3, ch 0.0005–0.002." ;
    oc:hasRationale "Parameters outside physical ranges produce unrealistic model behavior and invalidate results" ;
    oc:severityLevel "HIGH" .

oc:kn_641e4c08 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Automated GLM parameter optimization" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from scipy.optimize import minimize

def objective(x):
    Kw, coef_mix_hyp, wind_factor, lw_factor, ch = x
    params = {'Kw': round(Kw, 4), 'coef_mix_hyp': round(coef_mix_hyp, 4),
              'wind_factor': round(wind_factor, 4), 'lw_factor': round(lw_factor, 4),
              'ch': round(ch, 6)}
    modify_nml('glm3.nml', params)
    subprocess.run(['glm'], capture_output=True)
    rmse = calculate_rmse(sim_df, obs_df)
    return rmse

result = minimize(objective, x0=[0.3, 0.5, 1.0, 1.0, 0.0013], method='Nelder-Mead', options={'maxiter': 150})""" .

oc:kn_67bf3d93 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "Diagnosing calibration residuals" ;
    oc:directiveContent "Surface too warm → increase wind_factor. Deep water too warm → increase Kw. Weak stratification → decrease coef_mix_hyp. Overall warm bias → decrease lw_factor or ch." ;
    oc:hasRationale "Each symptom maps to a specific physical mechanism, enabling targeted parameter adjustment" .

oc:kn_6afafe9c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Manual calibration process" ;
    oc:directiveContent "Do not adjust multiple parameters simultaneously during manual calibration." ;
    oc:hasRationale "Simultaneous changes make it impossible to attribute RMSE improvement or regression to any single parameter" ;
    oc:severityLevel "HIGH" .

oc:kn_a6f0c189 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "After each calibration run or optimization iteration" ;
    oc:directiveContent "RMSE < 2.0°C between simulated and observed water temperatures indicates successful calibration." .

