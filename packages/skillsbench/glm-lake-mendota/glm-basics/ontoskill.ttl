oc:kn_013cc10d a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Running a GLM simulation from start to finish" ;
    oc:directiveContent "1. Prepare glm3.nml and bcs/*.csv files in working directory 2. Backup glm3.nml before any modifications 3. Run `glm` from /root 4. Check output/output.nc for results 5. Verify run succeeded after each parameter change" ;
    oc:stepOrder 1 .

oc:kn_66d341ad a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When GLM fails to start or produces no output" ;
    oc:directiveContent "Missing bcs/ directory or CSV files causes GLM to fail immediately; invalid namelist syntax prevents output generation; unrealistic parameters cause simulation crashes" ;
    oc:hasRationale "These are the three most common failure modes and should be checked first when debugging" .

oc:kn_98e76e31 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "After running GLM" ;
    oc:directiveContent "Successful GLM execution produces output/output.nc in the working directory" ;
    oc:hasRationale "The presence of the NetCDF output file confirms the simulation completed" .

oc:kn_c17636ab a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When interpreting or configuring model behavior" ;
    oc:directiveContent "GLM is a 1D vertical model — it simulates temperature and mixing along the depth axis only, not horizontal dynamics" ;
    oc:hasRationale "Understanding the 1D limitation is essential for selecting appropriate use cases and interpreting results correctly" .

oc:kn_c33a0a71 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Modifying numeric parameters in glm3.nml programmatically" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """import re

def modify_nml(nml_path, params):
    with open(nml_path, 'r') as f:
        content = f.read()
    for param, value in params.items():
        pattern = rf"({param}\\s*=\\s*)[\\d\\.\\-e]+"
        replacement = rf"\\g<1>{value}"
        content = re.sub(pattern, replacement, content)
    with open(nml_path, 'w') as f:
        f.write(content)""" .

oc:kn_d3ba9abe a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before any parameter modification" ;
    oc:directiveContent "Always backup glm3.nml before modifying it; the Fortran namelist format is fragile and invalid syntax causes simulation failure" ;
    oc:hasRationale "Invalid namelist syntax silently breaks the simulation or causes GLM to fail to start" ;
    oc:severityLevel "HIGH" .

oc:payload_5acb93c72d0b7b2e a oc:ExecutionPayload ;
    oc:code "cd /root && glm" ;
    oc:executor "shell" .

