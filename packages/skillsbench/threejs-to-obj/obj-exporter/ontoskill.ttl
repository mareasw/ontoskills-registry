@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_threejs_to_obj_obj_exporter a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "obj-exporter" ;
    skos:broader "Exporter utility" ;
    prov:wasDerivedFrom ".agents/skills/skillsbench/threejs-to-obj/obj-exporter" ;
    oc:contentHash "f30a9921e0eaef54eff372d03a16b83f6c9476d411df81d1d51cb7e3d6ad96b8" ;
    oc:differentia "converts Three.js 3D geometry to Wavefront OBJ text format for interoperability with external 3D software" ;
    oc:handlesFailure oc:ExportError,
        oc:InvalidGeometry ;
    oc:hasCategory "development" ;
    oc:hasDescription "Three.js OBJExporter utility for exporting 3D geometry to Wavefront OBJ format. Use when converting Three.js scenes, meshes, or geometries to OBJ files for use in other 3D software like Blender, Maya, or MeshLab." ;
    oc:hasName "obj-exporter" ;
    oc:hasSection [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "For running Three.js in Node.js:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """// package.json
{ "type": "module" }
""" ;
                            oc:codeLanguage "json" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 86-89" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """// script.js
import * as THREE from 'three';
import { OBJExporter } from 'three/examples/jsm/exporters/OBJExporter.js';
""" ;
                            oc:codeLanguage "javascript" ;
                            oc:contentOrder 3 ;
                            oc:sourceLocation "lines 91-95" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Node.js ES Module Setup" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """# Comment
v x y z        # Vertex position
vn x y z       # Vertex normal
f v1 v2 v3     # Face (triangle)
f v1/vt1/vn1 v2/vt2/vn2 v3/vt3/vn3  # Face with texture/normal indices
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 12-18" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "OBJ is a text-based 3D geometry format:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Example:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """# Cube
v 0 0 0
v 1 0 0
v 1 1 0
v 0 1 0
f 1 2 3
f 1 3 4
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 4 ;
                            oc:sourceLocation "lines 21-29" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Basic Structure" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "To export geometry in world coordinates:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """// Update world matrices first
root.updateMatrixWorld(true);

// Clone and transform geometry
const worldGeometry = mesh.geometry.clone();
worldGeometry.applyMatrix4(mesh.matrixWorld);

// Create new mesh for export
const exportMesh = new THREE.Mesh(worldGeometry);
const objData = exporter.parse(exportMesh);
""" ;
                            oc:codeLanguage "javascript" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 50-61" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Exporting with World Transforms" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """import { mergeGeometries } from 'three/examples/jsm/utils/BufferGeometryUtils.js';

const geometries = [];
root.traverse((obj) => {
  if (obj instanceof THREE.Mesh) {
    const geom = obj.geometry.clone();
    geom.applyMatrix4(obj.matrixWorld);
    geometries.push(geom);
  }
});

const merged = mergeGeometries(geometries);
const mergedMesh = new THREE.Mesh(merged);
const objData = exporter.parse(mergedMesh);
""" ;
                            oc:codeLanguage "javascript" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 65-80" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Merging Multiple Geometries" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Three.js provides `OBJExporter` in examples:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """import { OBJExporter } from 'three/examples/jsm/exporters/OBJExporter.js';

const exporter = new OBJExporter();
const objString = exporter.parse(object3D);

// Write to file (Node.js)
import fs from 'fs';
fs.writeFileSync('output.obj', objString);
""" ;
                            oc:codeLanguage "javascript" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 35-44" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Three.js OBJExporter" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "OBJExporter Guide" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: obj-exporter
description: Three.js OBJExporter utility for exporting 3D geometry to Wavefront OBJ format. Use when converting Three.js scenes, meshes, or geometries to OBJ files for use in other 3D software like Blender, Maya, or MeshLab.
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
    oc:impartsKnowledge oc:kn_1f78c18a,
        oc:kn_7c6db89f,
        oc:kn_a7ed2139,
        oc:kn_c82ad981,
        oc:kn_ceb77ffb,
        oc:kn_e14538f5,
        oc:kn_ecaab3a0,
        oc:kn_fe41621e ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:NodeJsEnvironment,
        oc:ThreeSceneLoaded ;
    oc:resolvesIntent "convert Three.js mesh to OBJ format",
        "export 3D geometry with world transforms to OBJ",
        "export Three.js scene to OBJ",
        "merge and export multiple geometries as OBJ" ;
    oc:yieldsState oc:OBJFileExported .

oc:kn_1f78c18a a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Basic OBJ export from any Three.js Object3D" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """import { OBJExporter } from 'three/examples/jsm/exporters/OBJExporter.js';
const exporter = new OBJExporter();
const objString = exporter.parse(object3D);""" .

oc:kn_7c6db89f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When exporting with world transforms" ;
    oc:directiveContent "Always call updateMatrixWorld(true) on the root object before exporting to ensure all child transforms are current." ;
    oc:hasRationale "Stale matrix data produces geometry in wrong positions relative to its scene hierarchy." ;
    oc:severityLevel "HIGH" .

oc:kn_a7ed2139 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When preparing geometry for export" ;
    oc:directiveContent "Never apply matrixWorld directly to the original geometry without cloning first." ;
    oc:hasRationale "Mutating the original geometry corrupts the live scene's vertex data." ;
    oc:severityLevel "CRITICAL" .

oc:kn_c82ad981 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When exporting individual meshes in world space" ;
    oc:directiveContent "To export with world coordinates: 1. Clone the geometry 2. Apply matrixWorld to the clone via applyMatrix4 3. Create a new Mesh with the transformed geometry 4. Pass to exporter.parse()." ;
    oc:hasRationale "OBJExporter.parse() uses the geometry as-is; transforms must be baked into vertex positions beforehand." ;
    oc:stepOrder 1 .

oc:kn_ceb77ffb a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always" ;
    oc:directiveContent "OBJ format only stores geometry (vertices, normals, faces, texture coordinates). Materials, lights, cameras, and animations are NOT exported." ;
    oc:hasRationale "OBJ is a geometry-only interchange format; use FBX or glTF for full scene export with materials." ;
    oc:severityLevel "HIGH" .

oc:kn_e14538f5 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When merging multiple scene geometries for unified export" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """import { mergeGeometries } from 'three/examples/jsm/utils/BufferGeometryUtils.js';
const geometries = [];
root.traverse((obj) => {
  if (obj instanceof THREE.Mesh) {
    const geom = obj.geometry.clone();
    geom.applyMatrix4(obj.matrixWorld);
    geometries.push(geom);
  }
});
const merged = mergeGeometries(geometries);""" .

oc:kn_ecaab3a0 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When exporting an entire scene or subtree as a single OBJ file" ;
    oc:directiveContent "To merge multiple geometries: 1. Traverse scene to collect all Mesh objects 2. Clone each geometry and apply its matrixWorld 3. Use mergeGeometries from BufferGeometryUtils 4. Create a single Mesh from merged geometry 5. Export with OBJExporter." ;
    oc:hasRationale "Merging produces a single coherent OBJ file rather than separate disconnected objects." ;
    oc:stepOrder 2 .

oc:kn_fe41621e a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "When running in Node.js environment" ;
    oc:directiveContent "Requires Three.js installed and package.json must include { \"type\": \"module\" } for ES module imports." ;
    oc:hasRationale "Three.js OBJExporter uses ES module syntax (import/export) which requires module mode in Node.js." .

