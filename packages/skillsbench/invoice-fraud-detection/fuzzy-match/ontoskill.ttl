oc:kn_217295e6 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring fuzzy matching similarity thresholds" ;
    oc:directiveContent "Set an appropriate cutoff threshold (e.g., 0.6 for get_close_matches) to balance precision vs recall for your use case." ;
    oc:hasRationale "Too low a threshold produces false positives; too high misses valid matches. 0.6 is a reasonable default starting point." .

oc:kn_8fc3493b a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "Before any fuzzy matching operation" ;
    oc:directiveContent "Always normalize strings (lowercase, remove special chars, normalize whitespace, expand/contract abbreviations) before comparing to improve matching accuracy." ;
    oc:hasRationale "Normalization reduces false negatives caused by formatting differences rather than genuine string differences." ;
    oc:severityLevel "HIGH" .

oc:kn_c7efa139 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When matching large datasets or performance matters" ;
    oc:directiveContent "Prefer rapidfuzz over difflib for production workloads due to significantly better performance." ;
    oc:hasRationale "rapidfuzz is C-optimized and offers more metrics (partial_ratio, token_sort_ratio) than difflib." .

oc:kn_cfec95b8 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing entity resolution against a clean database" ;
    oc:directiveContent "Use containment checks (substring matching) as a fast first pass before falling back to fuzzy matching." ;
    oc:hasRationale "Containment is O(n) and eliminates obvious matches quickly, reserving expensive fuzzy computation for ambiguous cases." .

oc:kn_fae84f79 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When processing large lists of strings" ;
    oc:directiveContent "difflib.SequenceMatcher is O(N*M) in the worst case for strings of length N and M. rapidfuzz is much faster for bulk operations." ;
    oc:hasRationale "Naive pairwise comparison scales quadratically; use process.extract or process.extractOne from rapidfuzz for efficient bulk matching." .

