oc:skill_edit_pdf_text_parser a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "text-parser" ;
    skos:broader "Parser" ;
    prov:wasDerivedFrom ".agents/skills/skillsbench/edit-pdf/text-parser" ;
    oc:contentHash "dcd91e88b9fd2ca435d43b65fc96af54e2662430e3e6cda9998632bbee04adff" ;
    oc:differentia "extracts key-value pairs from structured text input files for downstream consumption" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasCategory "document" ;
    oc:hasDescription "Guide for parsing structured text input files." ;
    oc:hasName "text-parser" ;
    oc:hasSection [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """def parse_input(text):
    \"\"\"Parse key-value pairs from text.\"\"\"
    data = {}
    for line in text.strip().split('\\n'):
        if ':' in line:
            # Remove leading dash/bullet if present
            line = line.lstrip('- ').strip()
            key, value = line.split(':', 1)
            data[key.strip()] = value.strip()
    return data

# Usage
with open("input.txt") as f:
    content = f.read()

data = parse_input(content)
# data["Name"] -> "John Smith"
# data["Email"] -> "john@example.com"
""" ;
                            oc:codeLanguage "python" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 14-33" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Key-Value Parsing" ],
