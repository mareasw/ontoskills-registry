oc:kn_06b04d82 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing parsing logic for structured text" ;
    oc:directiveContent "Handle both dash-prefixed and plain key-value formats to maximize input flexibility." ;
    oc:hasRationale "Users may provide input in slightly different formats; robust parsing reduces preprocessing errors." .

oc:kn_7e84f723 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "Always" ;
    oc:directiveContent "This skill reads files from the local filesystem but does not modify any files." ;
    oc:hasRationale "Parsing is a read-only operation; no external state is mutated." .

oc:kn_85d77246 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When parsing any structured text input" ;
    oc:directiveContent "Read the entire input file before parsing to ensure all key-value pairs are captured." ;
    oc:hasRationale "Partial reads may miss fields defined later in the file, leading to incomplete data extraction." ;
    oc:severityLevel "MEDIUM" .

oc:kn_aa6316b5 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When preparing parsed data for PDF filling" ;
    oc:directiveContent "Match parsed field names to target PDF labels to ensure correct form field population." ;
    oc:hasRationale "Mismatched field names cause silent failures where PDF fields remain empty or get wrong values." .

oc:kn_ce92e765 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When parsing input text" ;
    oc:directiveContent "Only lines containing a colon (:) delimiter are parsed as key-value pairs; all other lines are silently skipped." ;
    oc:hasRationale "The colon delimiter is the sole structural indicator for valid data lines. Lines without it are ignored." .

