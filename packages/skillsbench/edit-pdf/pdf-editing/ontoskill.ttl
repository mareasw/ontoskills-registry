    oc:appliesToContext "When redacting sensitive data near other content" ;
    oc:directiveContent "When using add_redact_annot for true redaction, create a TIGHT bounding box (e.g., adjust y0+8, y1-2) to avoid covering nearby labels or adjacent text." ;
