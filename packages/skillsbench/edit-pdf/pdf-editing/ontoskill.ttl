oc:kn_35088a03 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When replacing text in a PDF document" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """import fitz
doc = fitz.open("input.pdf")
page = doc[0]
rects = page.search_for("old_value")
if rects:
    rect = rects[0]
    page.draw_rect(rect, color=(1,1,1), fill=(1,1,1), width=0)
    page.insert_text((rect.x0, rect.y1), "new_value", fontsize=11, color=(0,0,0))
doc.save("output.pdf")""" .

oc:kn_38575ce7 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "True redaction of sensitive data (e.g., student IDs)" ;
    oc:directiveContent "1. Extract text to find the sensitive value 2. search_for(value) to get bounding rect 3. Create tight_rect (narrower than full rect) 4. add_redact_annot(tight_rect, fill=(1,1,1)) 5. apply_redactions() to remove from structure 6. insert_text(masked_value) at same position" ;
    oc:hasRationale "True redaction removes text from the PDF binary structure, not just visually covering it" ;
    oc:stepOrder 2 .

oc:kn_761f2aa7 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Standard text replacement workflow" ;
    oc:directiveContent "1. Open PDF with fitz.open() 2. Extract current text with page.get_text() 3. Compare with correct values from input source 4. For each changed value: search_for(old_value) → draw_rect(white fill) to cover → insert_text(new_value) at same position 5. Save output" ;
    oc:hasRationale "This read-first-compare-then-replace approach prevents unnecessary edits and ensures accuracy" ;
    oc:stepOrder 1 .

oc:kn_832ff535 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always when editing any PDF" ;
    oc:directiveContent "NEVER use strikethrough lines, rasterization (get_pixmap), PDF-to-image workflows, or black-fill redaction (add_redact_annot with fill=(0,0,0)). These destroy the text layer or produce poor results." ;
    oc:hasRationale "These approaches either destroy the extractable text layer or create visually ugly/suspicious black boxes" ;
    oc:severityLevel "CRITICAL" .

oc:kn_8b3ca8dd a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting any PDF edit" ;
    oc:directiveContent "Before editing: 1. Verify PyMuPDF is available (python3 -c 'import fitz') 2. Extract current PDF text to confirm content 3. Identify all values needing change by comparing with correct source" ;
    oc:severityLevel "HIGH" .

oc:kn_a6d28788 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When inserting new text into a PDF" ;
    oc:directiveContent "Always match the existing font size (typically 10-12pt for forms) and preserve all form labels when editing PDF documents." ;
    oc:hasRationale "Consistent font sizing and preserved labels maintain document professionalism and readability" ;
    oc:severityLevel "MEDIUM" .

oc:kn_a8be1ddb a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing a PDF editing library" ;
    oc:directiveContent "Use Python with PyMuPDF (fitz) over JavaScript pdf-lib. PyMuPDF preserves the text layer properly so text remains extractable after editing; pdf-lib may create text that tools like pypdf cannot extract." ;
    oc:hasRationale "PyMuPDF produces more compatible output that preserves text extractability across tools" ;
    oc:severityLevel "HIGH" .

oc:kn_ae16a01c a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before any edit operation" ;
    oc:directiveContent "PDF editing is NOT idempotent - running the same edit twice will add duplicate text layers. Always check current PDF content before making changes by extracting text first." ;
    oc:hasRationale "Repeated application of the same edit compounds visual artifacts and text layer corruption" ;
    oc:severityLevel "HIGH" .

oc:kn_bfa8387b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing between visual cover and structural redaction" ;
    oc:directiveContent "Use draw_rect() with white fill (1,1,1) and width=0 for simple text replacement. Use add_redact_annot() + apply_redactions() for TRUE redaction where text must be removed from PDF structure." ;
    oc:hasRationale "draw_rect only visually covers text (still machine-extractable); true redaction removes text from the PDF structure entirely" ;
    oc:severityLevel "HIGH" .

oc:kn_c2f5617e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When replacing existing text in a PDF" ;
    oc:directiveContent "NEVER add new text NEXT TO old values. Always REPLACE old text at the SAME position by covering with a white rectangle first." ;
    oc:hasRationale "Adding text beside old values leaves both visible, creating confusion and unprofessional output" ;
    oc:severityLevel "CRITICAL" .

oc:kn_f1b19a7a a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "Expected result of PDF text replacement" ;
    oc:directiveContent """Input: input.pdf with current values
Output: output.pdf with:
- Old text covered by white rectangles (invisible)
- New text inserted at same positions
- Text layer preserved (extractable)
- All labels intact""" ;
    oc:templateVariables "input.pdf",
        "output.pdf" .

