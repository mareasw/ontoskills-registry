    oc:resolvesIntent "download flood stage thresholds",
        "get flood levels for USGS stations",
        "match station IDs to NWS flood thresholds",
        "retrieve NWS gauge data" ;
    oc:yieldsState oc:FloodThresholdsLoaded .

oc:kn_5cae3af4 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When downloading and parsing the NWS bulk CSV" ;
    oc:directiveContent "Never use the NWS CSV data without truncating rows to 43 columns — the header has 43 columns but data rows have 44, causing pandas alignment errors." ;
    oc:hasRationale "This is a known upstream data inconsistency that will cause runtime errors if not handled." ;
    oc:severityLevel "CRITICAL" .

oc:kn_5cb3fc9c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When filtering and processing threshold data" ;
    oc:directiveContent "Filter out rows where threshold values equal -9999, as this sentinel indicates no threshold is defined for that station." ;
    oc:hasRationale "Using -9999 as a threshold would produce wildly incorrect flood detection results." ;
    oc:severityLevel "HIGH" .

oc:kn_8c39d683 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When loading the NWS CSV into a DataFrame" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """data = [row[:43] for row in reader]
nws_df = pd.DataFrame(data, columns=headers)
nws_df['flood stage'] = pd.to_numeric(nws_df['flood stage'], errors='coerce')""" .

oc:kn_938396ce a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When matching thresholds to USGS station IDs" ;
    oc:directiveContent "Some stations in the NWS CSV have empty 'usgs id' fields — these are NWS-only stations with no USGS counterpart. Filter by usgs id not null/empty." ;
    oc:hasRationale "Attempting to match empty USGS IDs will produce incorrect joins or lookups." ;
    oc:severityLevel "MEDIUM" .

oc:kn_97caf197 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When retrieving flood thresholds for any analysis" ;
    oc:directiveContent "1. Download CSV from NWS URL 2. Parse with csv.reader, skip header 3. Truncate rows to 43 columns 4. Build DataFrame 5. Convert threshold columns to numeric 6. Filter by state/station IDs 7. Exclude -9999 values and empty USGS IDs" ;
    oc:stepOrder 1 .

oc:kn_9c8099d7 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When filtering stations by state" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """state_stations = nws_df[
    (nws_df['state'] == '<STATE_CODE>') &
    (nws_df['usgs id'].notna()) &
    (nws_df['usgs id'] != '') &
    (nws_df['flood stage'].notna()) &
    (nws_df['flood stage'] != -9999)
]""" .

oc:kn_add67016 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When a requested station ID has no match in the NWS data" ;
    oc:directiveContent "If a station is missing from the NWS database, skip it or use an alternative data source rather than assuming no flood threshold." ;
    oc:hasRationale "Missing threshold data should not be interpreted as zero or infinite — it means the data is unavailable." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c47ba3cf a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before downloading NWS flood threshold data" ;
    oc:directiveContent "pandas and Python standard library (csv, urllib.request, io) must be available" .

oc:kn_d4021e6b a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building a threshold lookup dictionary for specific stations" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """thresholds = {}
for _, row in nws_df.iterrows():
    usgs_id = str(row['usgs id']).strip()
    if usgs_id in station_ids:
        thresholds[usgs_id] = {'name': row['location name'], 'flood': row['flood stage']}""" .

oc:kn_d9bc1b52 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining if flooding occurred at a station" ;
    oc:directiveContent "Use the 'flood stage' column as the primary threshold for general flood detection — it represents minor flooding with minimal property damage." ;
    oc:hasRationale "The 'flood stage' column is the standard NWS minor flood threshold and the most commonly used metric for binary flood detection." .

oc:kn_f65f9ce2 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "After loading the CSV into a DataFrame" ;
    oc:directiveContent "Always convert threshold columns from strings to numeric using pd.to_numeric with errors='coerce' before any comparison or filtering." ;
    oc:hasRationale "CSV data arrives as strings; numeric conversion is required for threshold comparisons against water level data." .

