oc:kn_21c549f1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating flood results for multiple stations" ;
    oc:directiveContent "Do not report all stations regardless of flood status. Only report stations with at least 1 flood day to keep output meaningful." ;
    oc:hasRationale "Including zero-flood stations in results creates noise and obscures actionable flood information." ;
    oc:severityLevel "MEDIUM" .

oc:kn_604f14a9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When validating flood detection results" ;
    oc:directiveContent "If all days show flooding, suspect threshold too low or data error (e.g., threshold in wrong units). If no floods detected, verify threshold values are not too high or check for dry periods." ;
    oc:hasRationale "Extreme results (all or none) typically indicate configuration errors rather than genuine hydrological conditions." ;
    oc:severityLevel "MEDIUM" .

oc:kn_61d686ba a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When detecting flood events from water level data" ;
    oc:directiveContent "1. Aggregate instantaneous data to daily maximum using resample('D').max() 2. Compare daily max against flood threshold 3. Count flood days with (daily_max >= threshold).sum() 4. Extract flood dates 5. Classify severity using action/minor/moderate/major thresholds 6. Sort results by severity or duration" ;
    oc:hasRationale "Structured procedure ensures consistent and accurate flood detection across all stations." ;
    oc:stepOrder 1 .

oc:kn_683b56ac a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When encountering NaN in aggregated daily data" ;
    oc:directiveContent "NaN values in daily_max indicate missing data for an entire day. Check data availability before running flood detection." ;
    oc:hasRationale "USGS gauges can have data gaps due to equipment failure or transmission issues; NaN propagates through comparisons silently." ;
    oc:severityLevel "HIGH" .

oc:kn_77540d12 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When aggregating instantaneous USGS data for flood detection" ;
    oc:directiveContent "Use daily maximum aggregation (resample('D').max()) for flood detection to capture peak water levels; never use mean or min as they may miss short flood peaks." ;
    oc:hasRationale "Mean and min aggregations can miss short-duration flood peaks that occur between measurement intervals, leading to false negatives." ;
    oc:severityLevel "CRITICAL" .

oc:kn_87ecf415 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When outputting flood detection results" ;
    oc:directiveContent """CSV: station_id,flood_days
JSON: {"flood_events": [{"station_id": "...", "flood_days": N}], "total_stations_with_flooding": N}""" ;
    oc:templateVariables "flood_days",
        "station_id",
        "total_stations_with_flooding" .

oc:kn_92bc0c8f a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When classifying flood severity with multiple threshold levels" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """def classify_flood(water_level, thresholds):
    if water_level >= thresholds['major']:
        return 'major'
    elif water_level >= thresholds['moderate']:
        return 'moderate'
    elif water_level >= thresholds['flood']:
        return 'minor'
    elif water_level >= thresholds['action']:
        return 'action'
    else:
        return 'normal'""" .

oc:kn_98211dff a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When detecting flood days from a DataFrame of water levels" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """daily_max = df[gage_col].resample('D').max()
flood_days = (daily_max >= flood_threshold).sum()
flood_dates = daily_max[daily_max >= flood_threshold].index.tolist()""" .

oc:kn_f459a437 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When comparing water levels against thresholds" ;
    oc:directiveContent "Ensure water level data and flood threshold use the same units (typically feet). Unit mismatch between feet and meters causes false positives or negatives." ;
    oc:hasRationale "NWS thresholds are in feet; USGS data may vary in units. Mismatched units silently produce incorrect results." ;
    oc:severityLevel "CRITICAL" .

