oc:kn_011d195c a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting the value column from a USGS DataFrame while excluding quality codes" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """gage_col = [c for c in df.columns if '00065' in str(c) and '_cd' not in str(c)]
if gage_col:
    water_levels = df[gage_col[0]]""" .

oc:kn_082bd8a1 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When downloading data spanning long time ranges or many stations" ;
    oc:directiveContent "Break up large requests into smaller time periods to avoid timeouts, and add delays between requests when downloading multiple stations to avoid rate limiting." ;
    oc:hasRationale "Large single requests to USGS can timeout; rapid sequential requests can trigger rate limiting." ;
    oc:severityLevel "LOW" .

oc:kn_7dd94330 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before any USGS data download" ;
    oc:directiveContent "dataretrieval Python package must be installed (pip install dataretrieval). Network access to USGS servers is required." .

oc:kn_85ec119c a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When encountering empty results or network failures" ;
    oc:directiveContent "If get_dv() returns empty for gage height, switch to get_iv() and aggregate manually. For connection errors, add retry logic with delays." ;
    oc:hasRationale "Daily gage height data is frequently unavailable; instantaneous data provides a reliable fallback that can be aggregated." ;
    oc:severityLevel "MEDIUM" .

oc:kn_8f4b5a06 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When downloading USGS water level data" ;
    oc:directiveContent "1. Install dataretrieval (pip install dataretrieval) 2. Import nwis module 3. Call nwis.get_iv() or nwis.get_dv() with site ID, date range, and parameterCd 4. Wrap call in try/except 5. Check len(df) > 0 6. Filter out _cd quality columns 7. Extract value column for analysis" ;
    oc:hasRationale "Provides the standard reliable workflow for acquiring and preparing USGS data." ;
    oc:stepOrder 1 .

oc:kn_99143641 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When specifying station IDs for any USGS API call" ;
    oc:directiveContent "USGS station IDs are 8-digit strings with leading zeros (e.g., '04119000'). Always preserve leading zeros." ;
    oc:hasRationale "Leading zeros are part of the station identifier; dropping them will result in invalid or incorrect station lookups." ;
    oc:severityLevel "CRITICAL" .

oc:kn_cfcc6f30 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When downloading gage height (parameter 00065) data" ;
    oc:directiveContent "Use get_iv() for gage height data rather than get_dv(), as daily gage height data is often unavailable." ;
    oc:hasRationale "Many USGS stations do not report daily gage height aggregates; instantaneous values at 15-minute intervals are more reliably available." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d173cce1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When downloading data from any USGS station" ;
    oc:directiveContent "Never make USGS API calls without wrapping them in try/except blocks." ;
    oc:hasRationale "Network failures, rate limiting, and missing data will crash the entire pipeline if unhandled." ;
    oc:severityLevel "HIGH" .

oc:kn_e0053464 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "After every data download, before processing or analysis" ;
    oc:directiveContent "Always check len(df) > 0 before processing downloaded data, and filter out quality code columns (ending in _cd)." ;
    oc:hasRationale "Empty DataFrames indicate no data for the requested range; quality code columns are not needed for analysis and add noise." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e1d3e3bb a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When re-running or retrying downloads" ;
    oc:directiveContent "USGS data downloads are read-only and idempotent — the same query always returns the same historical data." ;
    oc:hasRationale "Historical water level data does not change, so re-downloading is safe and produces consistent results." ;
    oc:severityLevel "LOW" .

oc:kn_e59bdafe a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When downloading instantaneous gage height data for a single station" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from dataretrieval import nwis

df, meta = nwis.get_iv(
    sites='<station_id>',
    start='<start_date>',
    end='<end_date>',
    parameterCd='00065'
)""" .

