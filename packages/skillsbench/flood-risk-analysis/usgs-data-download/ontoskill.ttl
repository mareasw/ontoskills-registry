                    oc:expectedOutcome "Clean Series of water level or discharge values" ;
                    oc:stepDependsOn _:ref_629992f2d9c18fe8 ;
                    oc:stepId "extract-column" ],
                _:ref_8cd2958bc02e24e9 ;
