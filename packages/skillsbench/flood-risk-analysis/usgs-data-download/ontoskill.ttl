    oc:isOptional false ;
    oc:requirementValue "dataretrieval Python package" .

oc:req_96b7c7a4 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "USGS parameter codes (00065 for gage height, 00060 for discharge)" .

oc:req_ccf0414d a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "USGS station IDs are 8-digit strings with leading zeros" .

