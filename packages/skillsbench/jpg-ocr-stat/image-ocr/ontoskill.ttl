oc:kn_0ce00abe a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before using this skill" ;
    oc:directiveContent "Tesseract OCR must be installed and accessible in PATH. pytesseract and Pillow Python packages must be available." .

oc:kn_294b567d a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After every OCR extraction before returning results" ;
    oc:directiveContent "Validate output JSON with json.loads(), confirm all required fields are present, text preserves reading order, confidence level reflects quality, and warnings array includes detected issues." ;
    oc:hasRationale "Ensures output integrity and provides consumers with reliable, complete results" .

oc:kn_4772c078 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When preparing any image for OCR extraction" ;
    oc:directiveContent "Always preprocess images before OCR: convert to grayscale, apply autocontrast, and sharpen. These three steps significantly improve character recognition accuracy." ;
    oc:hasRationale "Preprocessing reduces noise and enhances text edges, which are the primary factors in OCR accuracy" .

oc:kn_4cb6a974 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before running any OCR operation" ;
    oc:directiveContent "Verify Tesseract is installed and accessible by calling pytesseract.get_tesseract_version() before attempting OCR." ;
    oc:hasRationale "pytesseract will raise TesseractNotFoundError at runtime if Tesseract binary is not in PATH" ;
    oc:severityLevel "CRITICAL" .

oc:kn_4f5d0ebd a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Basic single-image text extraction" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """import pytesseract
from PIL import Image

def extract_text_from_image(image_path):
    img = Image.open(image_path)
    text = pytesseract.image_to_string(img)
    return text.strip()""" .

oc:kn_856c38f5 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calculating OCR confidence scores" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """data = pytesseract.image_to_data(img, output_type=pytesseract.Output.DICT)
confidences = [c for c in data['conf'] if c > 0]
avg_conf = sum(confidences) / len(confidences) if confidences else 0
confidence = "high" if avg_conf >= 80 else "medium" if avg_conf >= 50 else "low\"""" .

oc:kn_8951ce0e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When OCR confidence is low or image quality is suboptimal" ;
    oc:directiveContent "Never run a single OCR pass on challenging images without preprocessing or multi-pass strategies." ;
    oc:hasRationale "Single-pass OCR on difficult images (low contrast, faded text, complex layouts) misses significant text" ;
    oc:severityLevel "MEDIUM" .

oc:kn_89bb878d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When initial OCR results are poor or text extraction is incomplete" ;
    oc:directiveContent "For difficult images, use multi-pass OCR: try multiple PSM modes (--psm 6 for blocks, --psm 4 for columns, --psm 11 for sparse text) combined with preprocessing variants (grayscale+autocontrast, inverted, sharpened) and aggregate results." ;
    oc:hasRationale "Different PSM modes and preprocessing strategies capture different text regions; combining them maximizes extraction coverage" .

oc:kn_99ef2e56 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When performing OCR on any image" ;
    oc:directiveContent "1. Verify Tesseract is installed 2. Open image and preprocess (grayscale, autocontrast, sharpen) 3. Run pytesseract.image_to_data() for confidence data 4. Run pytesseract.image_to_string() for text 5. Calculate confidence level (>=80 high, >=50 medium, else low) 6. Assemble JSON output with metadata and warnings 7. Validate JSON output" ;
    oc:stepOrder 1 .

oc:kn_9a43e568 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When preprocessing images for better OCR accuracy" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from PIL import Image, ImageFilter, ImageOps
img = Image.open(image_path)
img = img.convert('L')  # grayscale
img = ImageOps.autocontrast(img)
img = img.filter(ImageFilter.SHARPEN)
text = pytesseract.image_to_string(img)""" .

oc:kn_c35fd6a8 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before processing any image" ;
    oc:directiveContent "Accepted image formats are JPG, JPEG, PNG, and WEBP only. Images should be under 5MB and at minimum 300 DPI for printed text." ;
    oc:hasRationale "Non-supported formats will cause errors; low-resolution images produce poor OCR results" ;
    oc:severityLevel "HIGH" .

oc:kn_dede1aa6 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When returning any OCR result" ;
    oc:directiveContent "All OCR results must conform to the JSON schema with fields: success (bool), filename (str), extracted_text (str), confidence (high|medium|low), metadata (object with language_detected, text_regions, has_tables, has_handwriting), warnings (array of strings)." ;
    oc:hasRationale "Consistent output schema enables downstream processing and error handling" ;
    oc:severityLevel "HIGH" ;
    oc:templateVariables "confidence",
        "extracted_text",
        "filename",
        "metadata",
        "success",
        "warnings" .

oc:kn_f43750a6 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When processing images with these characteristics" ;
    oc:directiveContent "Tesseract has limited handwriting recognition, struggles with decorative/artistic fonts, mathematical equations, and special notation. Redacted or watermarked text cannot be recovered." ;
    oc:hasRationale "These are fundamental limitations of the Tesseract engine; consider alternative approaches (e.g., vision models) for such content" ;
    oc:severityLevel "MEDIUM" .

