oc:kn_140baa3f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting text from scanned PDFs where pypdf/pdfplumber return empty or garbage text" ;
    oc:directiveContent "For scanned/image-based PDFs, convert pages to images first with pdf2image, then apply pytesseract OCR to extract text." ;
    oc:hasRationale "Scanned PDFs contain images, not selectable text, so standard text extraction methods fail. OCR bridges this gap." ;
    oc:severityLevel "HIGH" .

oc:kn_8162ef93 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When performing PDF manipulation operations" ;
    oc:directiveContent "Merging, splitting, and watermarking operations create new PDF files on disk. Encryption operations produce a new encrypted file separate from the original." ;
    oc:hasRationale "pypdf and CLI tools do not modify files in-place; they create new output files. Agents should inform users about output file paths." ;
    oc:severityLevel "LOW" .

oc:kn_bf161695 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When text extraction returns empty or poorly formatted results" ;
    oc:directiveContent "If pypdf fails to extract text from a PDF, fall back to pdfplumber for better layout preservation, or pdftotext CLI with -layout flag." ;
    oc:hasRationale "Different PDF libraries use different extraction engines and heuristics. A PDF that fails with one library often succeeds with another." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c48b1e74 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating PDF documents" ;
    oc:directiveContent "Use reportlab Platypus (SimpleDocTemplate) for multi-page PDFs with flowing content, and Canvas for simple single-page or precise-layout documents." ;
    oc:hasRationale "Platypus handles page breaks, styles, and flowing paragraphs automatically, while Canvas gives pixel-level control but requires manual layout management." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d22c93f9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the user needs to fill out an interactive PDF form" ;
    oc:directiveContent "PDF form filling requires special handling — consult forms.md for form-specific instructions rather than using general PDF operations." ;
    oc:hasRationale "PDF forms (AcroForms) have field names, types, and validation rules that require dedicated libraries like pdf-lib or pypdf form methods." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e9f48326 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting tables from PDFs" ;
    oc:directiveContent "Do not use pypdf for table extraction; use pdfplumber instead, which preserves table structure and layout." ;
    oc:hasRationale "pypdf's text extraction loses table structure while pdfplumber's extract_tables() preserves rows and columns." ;
    oc:severityLevel "HIGH" .

