oc:kn_18bc7ca3 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When processing MKV, WMV, or less common container formats" ;
    oc:directiveContent "OpenCV may not support all video codecs; if FPS reads as 0, the codec is likely unsupported" ;
    oc:hasRationale "Codec incompatibility is the most common failure mode and manifests as zero metadata values" ;
    oc:severityLevel "MEDIUM" .

oc:kn_1dfc7428 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Whenever using cv2.VideoCapture" ;
    oc:directiveContent "Always call cap.release() after video processing to free resources, even on error paths" ;
    oc:hasRationale "Failing to release the capture object leaks file handles and may lock the video file" ;
    oc:severityLevel "CRITICAL" .

oc:kn_1faf8014 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When extracting specific frames by index or seeking to a position" ;
    oc:directiveContent "Seeking (cap.set cv2.CAP_PROP_POS_FRAMES) in variable frame rate videos may be inaccurate; prefer sequential reads when frame accuracy matters" ;
    oc:hasRationale "VFR videos have non-uniform frame timing, making index-based seeking unreliable" ;
    oc:severityLevel "MEDIUM" .

oc:kn_22089aa4 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "Always, when extracting frames" ;
    oc:directiveContent "Extraction creates one image file per sampled frame in the output directory; a full extraction of a 5-min 30fps video creates 9000 files" ;
    oc:hasRationale "Massive file counts can overwhelm filesystems, file browsers, and downstream processing" ;
    oc:severityLevel "MEDIUM" .

oc:kn_264bb625 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When opening any video file" ;
    oc:directiveContent "Check cap.isOpened() immediately after creating VideoCapture and raise/return error if False" ;
    oc:hasRationale "Attempting to read frames from an unopened capture silently fails and can cause infinite loops" ;
    oc:severityLevel "HIGH" .

oc:kn_4a6f3d5b a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When re-running extraction to the same output directory" ;
    oc:directiveContent "Frame extraction with os.makedirs(exist_ok=True) is idempotent if output directory is clean; re-running overwrites existing frames with same names" ;
    oc:hasRationale "Repeated runs produce consistent results but partial overlaps from previous runs may leave stale frames" ;
    oc:severityLevel "LOW" .

oc:kn_55d7a86d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing long or high-frame-rate videos for analysis or ML training" ;
    oc:directiveContent "Use interval-based extraction (e.g., every 10th or 30th frame) rather than extracting all frames unless every frame is specifically needed" ;
    oc:hasRationale "Reduces disk usage, processing time, and redundancy in near-identical consecutive frames" ;
    oc:severityLevel "LOW" .

oc:kn_6b0ad26c a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before extracting frames from large videos or extracting all frames" ;
    oc:directiveContent "Verify sufficient disk space before extraction: a 10-min 1080p 30fps video yields ~18K uncompressed frames (~500MB+ as JPEG)" ;
    oc:hasRationale "Disk exhaustion mid-extraction produces partial results and wasted I/O" ;
    oc:severityLevel "HIGH" .

oc:kn_da197d11 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After completing any frame extraction operation" ;
    oc:directiveContent "After extraction, validate: output is valid JSON, required fields present, frame count matches expected based on interval, filenames use consistent zero-padded numbering" ;
    oc:hasRationale "Silent partial failures (corrupted frames, codec errors) can produce misleading results without validation" ;
    oc:severityLevel "MEDIUM" .

oc:kn_e875aff6 a oc:KnowledgeNode,
