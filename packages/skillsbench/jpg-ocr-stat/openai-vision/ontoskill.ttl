                            oc:contentOrder 1 ;
                            oc:textContent "The `detail` parameter controls image resolution and token usage:" ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """def get_recommended_detail(task_type):
    \"\"\"Recommend detail level based on task type.\"\"\"
    high_detail_tasks = {
        'ocr', 'text_extraction', 'document_analysis',
        'small_object_detection', 'detailed_comparison',
        'fine_grained_analysis'
    }
    
    low_detail_tasks = {
        'scene_classification', 'dominant_colors',
        'general_description', 'thumbnail_preview'
    }
    
    if task_type.lower() in high_detail_tasks:
        return "high"
    elif task_type.lower() in low_detail_tasks:
        return "low"
    else:
        return "auto"
""" ;
                                    oc:codeLanguage "python" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 420-440" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 16 ;
                            oc:sectionTitle "Choosing Detail Level" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 15 ;
                    oc:sectionTitle "Detail Level Configuration" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """from openai import OpenAI
import base64
import json
from pathlib import Path

client = OpenAI()

def process_image_directory(directory_path, output_file, prompt=None):
    \"\"\"Process all images in a directory and save results.\"\"\"
    if prompt is None:
        prompt = "Describe this image briefly, including any visible text."
    
    image_extensions = {'.jpg', '.jpeg', '.png', '.webp', '.gif'}
    results = []
    
    for file_path in sorted(Path(directory_path).iterdir()):
        if file_path.suffix.lower() in image_extensions:
            print(f"Processing: {file_path.name}")
            
            try:
                analysis = analyze_local_image(str(file_path), prompt)
                results.append({
                    "filename": file_path.name,
                    "success": True,
                    "analysis": analysis
                })
            except Exception as e:
                results.append({
                    "filename": file_path.name,
                    "success": False,
                    "error": str(e)
                })
    
    # Save results
    with open(output_file, 'w') as f:
        json.dump(results, f, indent=2)
    
    return results
""" ;
                                    oc:codeLanguage "python" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 358-397" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 14 ;
