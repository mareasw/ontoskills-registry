                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Non-Latin scripts**: Lower accuracy for complex scripts (CJK, Arabic, etc.)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 8 ;
                                    oc:itemText "**Graphs and charts**: May misinterpret line styles, legends, or data points" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 9 ;
                                    oc:itemText "**Metadata**: Cannot access EXIF data, camera info, or GPS coordinates from images" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "**Spatial precision**: Cannot provide pixel-accurate bounding boxes or measurements" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Medical imagery**: Not suitable for diagnostic analysis of CT scans, X-rays, or MRIs" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Rotated/skewed text**: Accuracy decreases with text rotation; pre-process if needed" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
