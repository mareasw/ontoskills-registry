oc:kn_655eaa28 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When requesting structured output from vision analysis" ;
    oc:directiveContent "For structured JSON output, instruct the model to 'Return ONLY valid JSON, no other text'. Strip markdown code blocks (```json```) from responses before parsing. Always wrap JSON parsing in try/except with fallback to raw response." ;
    oc:hasRationale "GPT models sometimes wrap JSON in markdown blocks or add explanatory text, causing parse failures" ;
    oc:severityLevel "MEDIUM" .

oc:kn_6cf4e5b9 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When estimating cost for large batches or high-resolution images" ;
    oc:directiveContent "Low detail uses fixed ~85 tokens per image. High detail uses 85 + 170 tokens per 512x512 tile (image scaled to fit 2048x2048, min 768 on shortest side). Batch processing directories incurs sequential API calls." ;
    oc:hasRationale "Token costs scale with image resolution and detail level; unmonitored batch processing can be expensive" ;
    oc:severityLevel "MEDIUM" .

oc:kn_703e4ce1 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Core pattern for sending any image to the vision API" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """response = client.chat.completions.create(
    model="gpt-4o",
    messages=[{
        "role": "user",
        "content": [
            {"type": "text", "text": prompt},
            {"type": "image_url", "image_url": {"url": f"data:{media_type};base64,{base64_image}", "detail": "high"}}
        ]
    }],
    max_tokens=1000
)""" .

oc:kn_80fdd0ca a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Requires openai Python package installed and OPENAI_API_KEY environment variable set with a valid API key." .

oc:kn_813e7d64 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When encoding local images for the API" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """base64_image = base64.standard_b64encode(open(image_path, 'rb').read()).decode('utf-8')
media_types = {'jpg':'image/jpeg','jpeg':'image/jpeg','png':'image/png','gif':'image/gif','webp':'image/webp'}""" .

oc:kn_8b8f7d2a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before sending any image to the API" ;
    oc:directiveContent "Maximum image size is 20MB per image; total request payload must be under 50MB. Supported formats: JPG, JPEG, PNG, WEBP, non-animated GIF. Up to 500 images per request." ;
    oc:hasRationale "Exceeding size or format limits causes API rejection or degraded performance" ;
    oc:severityLevel "HIGH" .

oc:kn_8cd7a9e0 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When API calls fail due to rate limits or payload size" ;
    oc:directiveContent "On RateLimitError, implement exponential backoff retry (2^attempt seconds). On image too large, iteratively resize by 50% with LANCZOS resampling until under 15MB, then re-encode as JPEG quality 85." ;
    oc:hasRationale "Rate limits are transient and recoverable; oversized images can be reduced without significant quality loss" ;
    oc:severityLevel "MEDIUM" .

oc:kn_98b8e9a5 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent "{\"success\": {bool}, \"images_analyzed\": {int}, \"analysis\": {\"description\": {str}, \"objects\": [{\"name\": {str}, \"color\": {str}, \"position\": {str}}], \"text_content\": {str}, \"colors\": [{str}], \"scene_type\": {str}}, \"comparison\": {\"differences\": [{str}], \"similarities\": [{str}]}, \"metadata\": {\"model_used\": {str}, \"detail_level\": {str}, \"token_usage\": {\"prompt\": {int}, \"completion\": {int}}}, \"warnings\": [{str}]}" ;
    oc:templateVariables "colors",
        "description",
        "detail_level",
        "differences",
        "images_analyzed",
        "model_used",
        "objects",
        "scene_type",
        "similarities",
        "success",
        "text_content",
        "token_usage",
        "warnings" .

oc:kn_9ae8c93f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring the detail parameter for any vision API call" ;
    oc:directiveContent "Use detail='high' for OCR, text extraction, small object detection, and detailed comparison. Use detail='low' for scene classification, dominant colors, and general descriptions (~85 tokens). Use detail='auto' when cost vs quality tradeoff is acceptable." ;
    oc:hasRationale "Detail level directly affects token cost and analysis quality; high detail can cost 85 + 170 per 512x512 tile" ;
    oc:severityLevel "MEDIUM" .

oc:kn_b4e54e31 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting this tool for a task" ;
    oc:directiveContent "Do not use vision models for medical imagery diagnostics, pixel-accurate measurements, bounding boxes, or EXIF/metadata extraction. Accuracy decreases for rotated/skewed text, non-Latin scripts (CJK, Arabic), and object counting." ;
    oc:hasRationale "The model has documented limitations in these domains that can produce misleading results" ;
    oc:severityLevel "HIGH" .

oc:kn_c8dde906 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before encoding and sending any local image" ;
    oc:directiveContent "Validate image existence, supported extension (.jpg/.jpeg/.png/.gif/.webp), and verify image integrity using PIL Image.open().verify() before encoding to base64." ;
    oc:hasRationale "Invalid or corrupted images waste API calls and produce errors" ;
    oc:severityLevel "LOW" .

oc:kn_d22a28d8 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After receiving analysis results" ;
    oc:directiveContent "After analysis, verify: API response received, output is valid JSON (if requested), all requested fields present, token usage within bounds, no error messages, and all images processed (for multi-image)." ;
    oc:hasRationale "Silent failures can return partial or malformed results that appear successful" ;
    oc:severityLevel "LOW" .

oc:kn_d4c0d51c a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "For any single image analysis" ;
    oc:directiveContent "1. Validate image file (exists, supported format, integrity check). 2. Determine detail level based on task type. 3. Encode local files to base64 with correct media type, or use URL directly. 4. Construct message with text prompt + image_url content blocks. 5. Call client.chat.completions.create() with model='gpt-4o'. 6. Parse response, stripping markdown code blocks if JSON expected. 7. Validate output against expected schema." ;
    oc:stepOrder 1 .

