oc:kn_22e6c54a a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "All keyframe extraction commands" ;
    oc:directiveContent "Always include -vsync vfr to prevent duplicate frames in output." ;
    oc:hasRationale "Without -vsync vfr, FFmpeg may produce duplicate frames when using select filters, inflating output." ;
    oc:severityLevel "HIGH" .

oc:kn_3d902e83 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When speed is priority and only keyframes are needed" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "ffmpeg -skip_frame nokey -i <input_video> -vsync vfr <output_pattern>" .

oc:kn_52668321 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Choosing between extraction methods" ;
    oc:directiveContent "Use -skip_frame nokey (Method 2) for faster extraction when you only need keyframes; use select filter (Method 1) when you need to combine with other filters." ;
    oc:hasRationale "Method 2 skips decoding non-keyframes entirely for performance; Method 1 allows filter chaining for more complex operations." ;
    oc:severityLevel "MEDIUM" .

oc:kn_543d8eff a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "High-quality JPEG keyframe extraction" ;
    oc:directiveContent "ffmpeg -i video.mp4 -skip_frame nokey -vsync vfr -q:v 2 keyframe_%03d.jpg" .

oc:kn_9a8a0dc9 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "Output file naming patterns" ;
    oc:directiveContent """keyframe_%03d.png → keyframe_001.png, keyframe_002.png, ...
keyframe_%03d.jpg → keyframe_001.jpg, keyframe_002.jpg, ...
keyframe_%d.bmp → keyframe_1.bmp, keyframe_2.bmp, ...""" ;
    oc:templateVariables "%03d",
        "%d" .

oc:kn_aad1cc53 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When expecting a specific number of output frames" ;
    oc:directiveContent "Keyframe frequency depends entirely on the video's encoding settings; there is no guaranteed minimum or maximum number of keyframes." ;
    oc:hasRationale "GOP (Group of Pictures) size is set at encoding time, so extraction yield varies per video." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b55fc92e a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before any keyframe extraction" ;
    oc:directiveContent "FFmpeg must be installed and available in PATH" ;
    oc:severityLevel "CRITICAL" .

oc:kn_c5a30e72 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "Basic PNG keyframe extraction" ;
    oc:directiveContent "ffmpeg -i video.mp4 -vf \"select='eq(pict_type,I)'\" -vsync vfr keyframe_%03d.png" .

oc:kn_d1b522e0 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When precise I-frame filtering is needed or combining with other filters" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "ffmpeg -i <input_video> -vf \"select='eq(pict_type,I)'\" -vsync vfr <output_pattern>" .

