                                            oc:itemOrder 1 ;
                                            oc:itemText "**AAC** (aac) - Universal" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Opus** (libopus) - Best quality/bitrate" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**FLAC** (flac) - Lossless" ],
                                        [ a oc:BulletItem ;
