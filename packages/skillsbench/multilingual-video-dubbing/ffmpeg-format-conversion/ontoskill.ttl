                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: FFmpeg Format Conversion
description: Convert media files between formats - video containers, audio formats, and codec transcoding
""" ] ;
            oc:sectionLevel 0 ;
