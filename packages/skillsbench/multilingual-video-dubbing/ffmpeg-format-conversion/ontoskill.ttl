                                            oc:itemText "**AV1** (libaom-av1) - Modern codec" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**H.264** (libx264) - Universal compatibility" ],
                                        [ a oc:BulletItem ;
