                    oc:stepId "cut-3" ] ;
            oc:workflowId "cut-video-segment" ;
            oc:workflowName "Cut Video Segment" ],
        [ a oc:Workflow ;
            dcterms:description "Divide a video into multiple segments" ;
            oc:hasStep [ a oc:WorkflowStep ;
                    dcterms:description "Run ffmpeg segment muxer or individual cut commands" ;
                    oc:expectedOutcome "Multiple output video parts created" ;
                    oc:stepDependsOn _:ref_cd7fe4d2a5d4cc33 ;
                    oc:stepId "split-2" ],
                _:ref_cd7fe4d2a5d4cc33 ;
            oc:workflowId "split-video" ;
            oc:workflowName "Split Video into Parts" ],
        [ a oc:Workflow ;
            dcterms:description "Join multiple video files into one" ;
            oc:hasStep _:ref_19b41c6ea6cc2a5e,
                [ a oc:WorkflowStep ;
                    dcterms:description "Run ffmpeg -f concat -safe 0 -i list.txt -c copy output.mp4" ;
                    oc:expectedOutcome "Concatenated output video created" ;
                    oc:stepDependsOn _:ref_b286a248162349ac ;
                    oc:stepId "concat-3" ],
                _:ref_b286a248162349ac ;
            oc:workflowId "concatenate-videos" ;
            oc:workflowName "Concatenate Videos" ] ;
    oc:impartsKnowledge oc:kn_0d06c167,
        oc:kn_36255c6f,
