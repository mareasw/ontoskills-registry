oc:kn_0d06c167 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When concatenating videos using the recommended file list method" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "ffmpeg -f concat -safe 0 -i list.txt -c copy output.mp4" .

oc:kn_36255c6f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When concatenating multiple video files" ;
    oc:directiveContent "Use the file list method (concat demuxer with -f concat -safe 0 -i list.txt) for concatenation; it is the most reliable approach." ;
    oc:hasRationale "The file list method handles varied inputs better than the pipe concat protocol." ;
    oc:severityLevel "MEDIUM" .

oc:kn_41aba6b5 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When cutting a specific time range from a video" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "ffmpeg -ss 00:00:10 -to 00:00:30 -i input.mp4 -c copy output.mp4" .

oc:kn_47c6e774 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When using -ss for time-based cutting" ;
    oc:directiveContent "Place -ss BEFORE -i for fast seeking (keyframe-level); place -ss AFTER -i for precise frame-accurate seeking." ;
    oc:hasRationale "Input seeking (-ss before -i) seeks to nearest keyframe; output seeking (-ss after -i) decodes from start for precision." ;
    oc:severityLevel "HIGH" .

oc:kn_7280bc7b a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before any video editing operation" ;
    oc:directiveContent "ffmpeg must be installed and available in PATH" .

oc:kn_7f74ea52 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When performing any video editing operation" ;
    oc:directiveContent "1. Identify operation (cut/trim/concat/split) 2. Determine if re-encoding is needed 3. Place -ss before -i for speed or after -i for precision 4. Use -c copy unless codec change required 5. Verify output duration matches expectation" ;
    oc:stepOrder 1 .

oc:kn_a17838da a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing any cutting, trimming, or concatenation operation" ;
    oc:directiveContent "Use -c copy for speed (no re-encoding); use re-encoding only when precision or codec change is needed." ;
    oc:hasRationale "Re-encoding is slow and degrades quality; stream copy is near-instant and lossless." ;
    oc:severityLevel "HIGH" .

oc:kn_b0b9f764 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When concatenating videos using -c copy or concat protocol" ;
    oc:directiveContent "Concatenation with -c copy requires all input files to have the same codec, resolution, and format." ;
    oc:hasRationale "Mismatched codecs/formats cause corruption or failure in the concatenated output." ;
    oc:severityLevel "CRITICAL" .

oc:kn_bd5a256e a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When cutting from the end of a video" ;
    oc:directiveContent "Using -sseof requires knowing the file duration beforehand; negative timestamps are relative to the end of file." ;
    oc:hasRationale "Without knowing duration, -sseof estimates may be inaccurate for some containers." ;
    oc:severityLevel "LOW" .

oc:kn_d2649fd3 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When splitting video into equal-duration segments" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "ffmpeg -i input.mp4 -c copy -f segment -segment_time 60 -reset_timestamps 1 output_%03d.mp4" .

_:ref_19b41c6ea6cc2a5e a oc:WorkflowStep ;
    dcterms:description "Verify all input videos have same codec/format (use ffmpeg-media-info)" ;
    oc:expectedOutcome "Codec compatibility confirmed" ;
    oc:stepId "concat-1" .

_:ref_b286a248162349ac a oc:WorkflowStep ;
    dcterms:description "Create file list (list.txt) with file references" ;
    oc:expectedOutcome "Concat list file created" ;
    oc:stepDependsOn _:ref_19b41c6ea6cc2a5e ;
    oc:stepId "concat-2" .

_:ref_bf52a855a83798d1 a oc:WorkflowStep ;
    dcterms:description "Decide precision level: -ss before -i (fast) or after -i (precise)" ;
    oc:expectedOutcome "Seeking strategy chosen" ;
    oc:stepDependsOn _:ref_dc8cbe8d0aa669ce ;
    oc:stepId "cut-2" .

_:ref_cd7fe4d2a5d4cc33 a oc:WorkflowStep ;
    dcterms:description "Determine segment duration or specific split timestamps" ;
    oc:expectedOutcome "Segment boundaries defined" ;
    oc:stepId "split-1" .

_:ref_dc8cbe8d0aa669ce a oc:WorkflowStep ;
    dcterms:description "Determine start time, end time/duration for the cut" ;
    oc:expectedOutcome "Time parameters identified" ;
    oc:stepId "cut-1" .

