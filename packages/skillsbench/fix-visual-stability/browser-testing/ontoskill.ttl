                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """{
  "url": "http://localhost:3000",
  "totalMs": 1523,
  "requests": [
    { "url": "http://localhost:3000/", "ms": 45.2 },
    { "url": "http://localhost:3000/api/products", "ms": 512.3 },
    { "url": "http://localhost:3000/api/featured", "ms": 301.1 }
  ],
  "metrics": {
    "JSHeapUsedSize": 4521984,
    "LayoutCount": 12,
    "ScriptDuration": 0.234
  }
}
""" ;
                            oc:codeLanguage "json" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 30-45" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "The script outputs JSON with:" ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 4 ;
                                    oc:tableCaption "### Key Metrics" ;
                                    oc:tableMarkdown """| Metric | What it means | Red flag |
|--------|---------------|----------|
| `totalMs` | Total page load time | > 1000ms |
| `JSHeapUsedSize` | Memory used by JS | Growing over time |
| `LayoutCount` | Layout recalculations | > 50 per page |
| `ScriptDuration` | Time in JS execution | > 0.5s |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Key Metrics" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """BAD (sequential - each waits for previous):
  /api/products    |████████|                        512ms
  /api/featured             |██████|                 301ms  (starts AFTER products)
  /api/categories                  |████|            201ms  (starts AFTER featured)
  Total: 1014ms

GOOD (parallel - all start together):
  /api/products    |████████|                        512ms
  /api/featured    |██████|                          301ms  (starts SAME TIME)
  /api/categories  |████|                            201ms  (starts SAME TIME)
  Total: 512ms (just the slowest one)
""" ;
                                    oc:codeLanguage "" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 51-63" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "The `requests` array shows network timing. Look for **sequential patterns**:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Reading the Waterfall" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Understanding the Output" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """async function measureAPI(url: string) {
  const start = Date.now();
  const response = await fetch(url);
  const elapsed = Date.now() - start;
  return { url, time_ms: elapsed, status: response.status };
}

// Example
const endpoints = [
  'http://localhost:3000/api/products',
  'http://localhost:3000/api/products?cache=false',
  'http://localhost:3000/api/checkout',
];

for (const endpoint of endpoints) {
  const result = await measureAPI(endpoint);
  console.log(`${endpoint}: ${result.time_ms}ms`);
}
""" ;
                            oc:codeLanguage "typescript" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 87-106" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "For quick API timing without browser overhead:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Measuring API Endpoints Directly" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 4 ;
                            oc:tableCaption "## What to Look For" ;
                            oc:tableMarkdown """| Symptom | Likely Cause | Fix |
|---------|--------------|-----|
| Requests in sequence | Sequential `await` statements | Use `Promise.all()` |
| Same URL requested twice | Fetch before cache check | Check cache first |
| Long time before response starts | Blocking operation before sending | Make it async/non-blocking |
| High LayoutCount | Components re-rendering | Add `React.memo`, `useMemo` |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "What to Look For" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "This gives you the same data as Chrome DevTools Network tab, but programmatically." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "The script uses Chrome DevTools Protocol (CDP) to intercept browser internals:" ],
                        _:ref_60d0e3a6f7605a17 ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "How the Measurement Script Works" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 7 ;
                                    oc:tableCaption "### Common CLS Causes" ;
                                    oc:tableMarkdown """| Shift Source | Likely Cause | Fix |
|--------------|--------------|-----|
| `<img>` elements | Missing width/height | Add dimensions or use `next/image` |
| Theme wrapper | Hydration flicker | Use inline script before React |
| Skeleton loaders | Size mismatch | Match skeleton to final content size |
| Dynamic banners | No reserved space | Add `min-height` to container |
| Late-loading sidebars | Content appears and pushes main content | Reserve space with CSS or show placeholder |
| Pagination/results bars | UI element appears after data loads | Show immediately with loading state |
| Font loading | Custom fonts cause text reflow | Use `font-display: swap` or preload fonts |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
                            oc:sectionTitle "Common CLS Causes" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 6 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Network conditions affect when content loads" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Viewport size affects what's \"in view\" during shifts" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "setTimeout delays vary slightly between runs" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Production vs development builds have different timing" ] ],
                                [ a oc:Paragraph ;
