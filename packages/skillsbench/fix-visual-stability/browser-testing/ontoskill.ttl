oc:kn_33f0e9bc a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always" ;
    oc:directiveContent "Measurement scripts are read-only and produce no side effects. They can be run multiple times safely. Results may vary slightly between runs." ;
    oc:hasRationale "Non-destructive measurement enables iterative before/after comparison" .

oc:kn_647f1135 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating CLS scores" ;
    oc:directiveContent "CLS score < 0.1 is Good (no action), 0.1-0.25 Needs Improvement (review sources), > 0.25 is Poor (fix immediately)." ;
    oc:hasRationale "Google's Core Web Vitals thresholds determine SEO and UX impact" ;
    oc:severityLevel "MEDIUM" .

oc:kn_741be530 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When reading measurement output metrics" ;
    oc:directiveContent "Key thresholds: totalMs > 1000ms is a red flag, LayoutCount > 50 per page indicates excessive reflows, ScriptDuration > 0.5s signals heavy JS execution, JSHeapUsedSize growing over time indicates memory leak." ;
    oc:hasRationale "These thresholds identify the most impactful performance regressions" .

oc:kn_747d367c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When analyzing network waterfall showing sequential patterns" ;
    oc:directiveContent "Sequential await statements cause network requests to run one after another instead of in parallel. Use Promise.all() to run independent requests concurrently." ;
    oc:hasRationale "Sequential fetches waste time; parallel fetches reduce total load time to the slowest single request" .

oc:kn_8f5e2138 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When fixing CLS issues identified by measurement" ;
    oc:directiveContent "Common CLS fixes: add width/height to images (or use next/image), use inline script before React for theme, match skeleton sizes to final content, add min-height to dynamic containers, use font-display: swap or preload fonts." ;
    oc:hasRationale "These address the most frequent causes of layout shift in modern web apps" .

oc:kn_c1797ed6 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When measuring CLS" ;
    oc:directiveContent "CLS only measures shifts within the viewport. Content below the fold doesn't contribute until scrolled. Use --scroll flag or manual scrolling sequence for accurate measurement." ;
    oc:hasRationale "Incomplete CLS measurements can give false confidence that layout is stable" ;
    oc:severityLevel "HIGH" .

oc:kn_dc584e3d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When interpreting CLS scores" ;
    oc:directiveContent "The relative difference (before/after fix) matters more than absolute CLS values. Measurements vary due to build mode, viewport size, setTimeout jitter, and network conditions." ;
    oc:hasRationale "Absolute CLS values are non-deterministic; comparative measurement isolates the actual impact of changes" .

