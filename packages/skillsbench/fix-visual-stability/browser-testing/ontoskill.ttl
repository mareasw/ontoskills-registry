                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Diagnose performance issues by measuring actual load times and network activity." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "**Playwright is pre-installed.** Just use the measurement script." ] ;
