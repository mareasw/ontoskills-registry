npx ts-node <path-to-this-skill>/measure-cls.ts http://localhost:3000

# With scrolling (catches more shifts)
npx ts-node <path-to-this-skill>/measure-cls.ts http://localhost:3000 --scroll
""" ;
                                    oc:codeLanguage "bash" ;
