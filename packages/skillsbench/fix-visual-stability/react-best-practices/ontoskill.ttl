oc:kn_06ae79ba a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any async data fetching code" ;
    oc:directiveContent "Always use Promise.all() for independent async operations; never await sequentially when operations don't depend on each other." ;
    oc:hasRationale "Sequential awaits create unnecessary waterfalls that compound latency." ;
    oc:severityLevel "HIGH" .

oc:kn_12ccde93 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When prioritizing which performance rules to apply" ;
    oc:directiveContent "Eliminating waterfalls and bundle size optimization are CRITICAL priority — apply these rules first before any other optimization." ;
    oc:hasRationale "These two categories have the highest user-perceived impact on application performance." ;
    oc:severityLevel "CRITICAL" .

oc:kn_22834a48 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing React hooks and state management" ;
    oc:directiveContent "Do not subscribe to state values that are only used inside callbacks; use refs or functional setState instead." ;
    oc:hasRationale "Subscribing to state only needed in callbacks triggers unnecessary re-renders." ;
    oc:severityLevel "MEDIUM" .

oc:kn_74ad81a2 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When organizing imports in any React/Next.js file" ;
    oc:directiveContent "Avoid barrel file imports (index.js re-exports) — import directly from the specific module path." ;
    oc:hasRationale "Barrel files prevent tree-shaking and force bundlers to include unused code." ;
    oc:severityLevel "HIGH" .

oc:kn_8ab94716 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing any specific rule from the 45-rule set" ;
    oc:directiveContent "The rule files in rules/ directory contain incorrect and correct code examples for each rule — always consult the specific rule file before applying changes." ;
    oc:hasRationale "Each rule has nuanced context about when it applies and edge cases to watch for." .

oc:kn_99f02f6c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When optimizing initial page load bundle size" ;
    oc:directiveContent "Use next/dynamic for heavy components, defer third-party scripts (analytics/logging) until after hydration, and preload on hover/focus." ;
    oc:hasRationale "Reducing the critical path JavaScript improves Time to Interactive." ;
    oc:severityLevel "HIGH" .

oc:kn_b88f0b28 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reading from localStorage or cookies in React components" ;
    oc:directiveContent "Use inline script blocks for client-only data (localStorage, cookies) to prevent hydration mismatches and FOUC." ;
    oc:hasRationale "Server-rendered HTML won't have client-only data, causing hydration mismatch flicker." ;
    oc:severityLevel "HIGH" .

oc:kn_c0f45504 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing server component data flow in Next.js" ;
    oc:directiveContent "Minimize data passed from server to client components; use React.cache() for per-request deduplication and LRU cache for cross-request caching." ;
    oc:hasRationale "Excessive server-to-client serialization increases payload size and hydration cost." ;
    oc:severityLevel "MEDIUM" .

_:ref_25e00abe859e5863 a oc:WorkflowStep ;
    dcterms:description "Fix hydration flicker, optimize SVGs, use content-visibility for long lists, use ternary conditionals" ;
    oc:expectedOutcome "No hydration mismatches or visual flickering" ;
    oc:stepDependsOn _:ref_ef837a1261d8fd62 ;
    oc:stepId "audit-rendering" .

_:ref_40d5a1d73da65651 a oc:WorkflowStep ;
    dcterms:description "Apply React.cache(), minimize server-to-client serialization, parallelize server fetches" ;
    oc:expectedOutcome "Server-side data fetching is deduplicated and parallelized" ;
    oc:stepDependsOn _:ref_eb193084ccdff2fb ;
    oc:stepId "audit-server" .

_:ref_5cadc11f503e40f6 a oc:WorkflowStep ;
    dcterms:description "Check for barrel imports, add dynamic imports for heavy components, defer third-party scripts" ;
    oc:expectedOutcome "Bundle size reduced, no unnecessary barrel file imports" ;
    oc:stepId "audit-bundle" .

_:ref_874302004a3068cd a oc:WorkflowStep ;
    dcterms:description "Implement SWR for client data fetching, deduplicate event listeners" ;
    oc:expectedOutcome "Client-side requests are deduplicated and cached" ;
    oc:stepDependsOn _:ref_5cadc11f503e40f6 ;
    oc:stepId "audit-client" .

_:ref_eb193084ccdff2fb a oc:WorkflowStep ;
    dcterms:description "Check for sequential awaits and apply async-parallel, async-defer-await rules" ;
    oc:expectedOutcome "All independent async operations run in parallel via Promise.all()" ;
    oc:stepId "audit-waterfalls" .

_:ref_ef837a1261d8fd62 a oc:WorkflowStep ;
    dcterms:description "Fix unnecessary subscriptions, add memoization, use primitive dependencies in effects" ;
    oc:expectedOutcome "Unnecessary re-renders eliminated" ;
    oc:stepDependsOn _:ref_40d5a1d73da65651,
        _:ref_874302004a3068cd ;
    oc:stepId "audit-rerender" .

