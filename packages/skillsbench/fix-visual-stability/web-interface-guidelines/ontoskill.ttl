oc:kn_0ae67ecd a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When building interactive UI components" ;
    oc:directiveContent "Interactive elements need visible focus (focus-visible:ring-*). Use :focus-visible over :focus. Never outline-none without focus replacement. Icon-only buttons need aria-label. Use <button> for actions, <a>/<Link> for navigation—never <div onClick>." ;
    oc:hasRationale "Keyboard and screen reader users depend on visible focus states and semantic HTML for navigation" ;
    oc:severityLevel "HIGH" .

oc:kn_317305b1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing CSS transitions or animations" ;
    oc:directiveContent "Animate only transform and opacity properties. Never use transition: all—list properties explicitly. Honor prefers-reduced-motion by providing reduced variants or disabling animation." ;
    oc:hasRationale "Only transform/opacity are compositor-friendly; animating layout properties causes jank. Reduced motion is an accessibility requirement." ;
    oc:severityLevel "HIGH" .

oc:kn_806a53fc a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or reviewing image elements" ;
    oc:directiveContent "All <img> elements need explicit width and height to prevent CLS. Below-fold images get loading='lazy'. Above-fold critical images get priority or fetchpriority='high'." ;
    oc:hasRationale "Images without dimensions cause Cumulative Layout Shift, a Core Web Vital metric" ;
    oc:severityLevel "CRITICAL" .

oc:kn_9c1023be a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When rendering large datasets or optimizing rendering performance" ;
    oc:directiveContent "Virtualize lists with >50 items using virtua or content-visibility: auto. Avoid layout reads (getBoundingClientRect, offsetHeight, offsetWidth, scrollTop) in the render path. Batch DOM reads/writes—never interleave them. Preconnect to CDN/asset domains." ;
    oc:hasRationale "Unvirtualized large lists cause excessive DOM nodes; layout reads in render force synchronous reflows" ;
    oc:severityLevel "HIGH" .

oc:kn_b8c5d552 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When building form controls" ;
    oc:directiveContent "Inputs need autocomplete and meaningful name attributes. Use correct type (email, tel, url, number) and inputmode. Never block paste. Labels must be clickable via htmlFor or wrapping the control." ;
    oc:hasRationale "Proper form semantics enable browser autofill, mobile keyboard selection, and accessibility" ;
    oc:severityLevel "MEDIUM" .

oc:kn_cd0279f0 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing any UI code" ;
    oc:directiveContent "Flag these anti-patterns on sight: user-scalable=no, transition: all, outline-none without focus-visible replacement, images without dimensions, large arrays .map() without virtualization, form inputs without labels, icon buttons without aria-label" ;
    oc:hasRationale "These are the most common and impactful violations that degrade accessibility and performance" ;
    oc:severityLevel "HIGH" .

oc:kn_ee13f506 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When building content-displaying components" ;
    oc:directiveContent "Text containers must handle long content using truncate, line-clamp-*, or break-words. Flex children need min-w-0 to allow text truncation. Handle empty states—never render broken UI for empty strings/arrays." ;
    oc:hasRationale "Overflow text breaks layout; empty data states cause visual glitches and confuse users" ;
    oc:severityLevel "MEDIUM" .

