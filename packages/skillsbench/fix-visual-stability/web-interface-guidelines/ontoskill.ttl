                            oc:sectionTitle "Accessibility" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Full Rules" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Web Interface Guidelines" ] ;
    oc:impartsKnowledge oc:kn_0ae67ecd,
