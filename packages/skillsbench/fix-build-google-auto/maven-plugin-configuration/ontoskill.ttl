oc:kn_01eeac60 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "CI/CD pipeline configuration" ;
    oc:directiveContent "Avoid skipping tests in CI via skip flags — tests accidentally skipped undermine code quality gates." ;
    oc:hasRationale "Skipped tests hide regressions and defects that quality plugins are meant to catch." ;
    oc:severityLevel "HIGH" .

oc:kn_1541fae0 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining custom plugin executions" ;
    oc:directiveContent "Use meaningful execution IDs and bind to appropriate lifecycle phases; ensure sufficient heap memory for plugins like surefire and shade." ;
    oc:hasRationale "Ambiguous execution IDs make debugging difficult; insufficient memory causes OOM failures during build." ;
    oc:severityLevel "MEDIUM" .

oc:kn_159c1a93 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When troubleshooting Maven plugin issues" ;
    oc:directiveContent "1. Check for missing plugin versions. 2. Verify correct phase binding. 3. Eliminate duplicate executions. 4. Ensure sufficient JVM heap. 5. Resolve plugin execution ordering conflicts. 6. Review unintended plugin inheritance. 7. Clarify fork behavior. 8. Confirm skip flags are not accidentally set in CI." ;
    oc:stepOrder 2 .

oc:kn_29779e1d a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring any Maven plugin with custom execution" ;
    oc:codeLanguage "xml" ;
    oc:directiveContent """<plugin>
    <groupId>org.apache.maven.plugins</groupId>
    <artifactId>maven-{PLUGIN_NAME}-plugin</artifactId>
    <version>{VERSION}</version>
    <configuration>
        <!-- plugin-specific config -->
    </configuration>
    <executions>
        <execution>
            <id>{execution-id}</id>
            <phase>{PHASE}</phase>
            <goals><goal>{GOAL}</goal></goals>
        </execution>
    </executions>
</plugin>""" .

oc:kn_3d6567d2 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining plugin executions" ;
    oc:directiveContent "Do not bind plugins to wrong lifecycle phases or create duplicate executions of the same goal." ;
    oc:hasRationale "Wrong phase binding causes unexpected execution order; duplicate executions waste time and can produce conflicting outputs." ;
    oc:severityLevel "HIGH" .

oc:kn_47b55006 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When setting up Maven plugin configuration" ;
    oc:directiveContent "1. Pin plugin versions in pluginManagement. 2. Use defaults where possible. 3. Add meaningful execution IDs. 4. Bind to correct lifecycle phases. 5. Provide skip properties. 6. Comment complex configs. 7. Use pluginManagement for multi-module inheritance. 8. Keep plugins updated. 9. Separate CI/release plugins into profiles. 10. Document non-obvious configuration decisions." ;
    oc:severityLevel "HIGH" ;
    oc:stepOrder 1 .

oc:kn_52abbabb a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "Multi-module Maven projects" ;
    oc:directiveContent "Centralize plugin versions and shared configuration in pluginManagement in the parent POM, then reference plugins without version in child modules." ;
    oc:hasRationale "Centralization ensures consistency across modules and simplifies version upgrades across the project." ;
    oc:severityLevel "HIGH" .

oc:kn_a4a5eef9 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When declaring any Maven plugin" ;
    oc:directiveContent "Always specify explicit plugin versions in pluginManagement or the plugin declaration; never rely on Maven's default plugin versions." ;
    oc:hasRationale "Default plugin versions can change between Maven releases, causing unpredictable builds and reproducibility failures." ;
    oc:severityLevel "CRITICAL" .

oc:kn_d3b10c7c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing a packaging plugin" ;
    oc:directiveContent "Use maven-shade-plugin for fat JARs with dependency relocation, maven-assembly-plugin for custom archive layouts, and spring-boot-maven-plugin for Spring Boot applications." ;
    oc:hasRationale "Each packaging plugin has different strengths — shade handles class relocation, assembly handles custom descriptors, Spring Boot handles layered JARs." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d59365f3 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing plugin configuration strategy" ;
    oc:directiveContent "Use minimal configuration — rely on sensible defaults where possible, provide skip properties for flexibility, and separate CI/release plugins into profiles." ;
    oc:hasRationale "Minimal configuration reduces maintenance burden and makes POMs readable; profiles prevent unnecessary plugin execution in dev builds." ;
    oc:severityLevel "MEDIUM" .

oc:kn_fbc81324 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring any Maven plugin" ;
    oc:directiveContent "Do not rely on default plugin versions or omit version tags — this leads to non-reproducible builds." ;
    oc:hasRationale "Missing versions cause builds to vary across environments and Maven versions, breaking CI/CD reliability." ;
    oc:severityLevel "CRITICAL" .

