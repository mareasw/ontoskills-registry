    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "configure maven build phases and goals",
        "configure test execution with surefire and failsafe",
        "create and activate maven build profiles",
        "customize maven build process for java projects",
        "debug maven build failures",
        "optimize maven multi-module builds",
        "set up maven CI/CD pipelines" .

oc:kn_160d5b4e a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining Maven build profiles with activation triggers" ;
    oc:codeLanguage "xml" ;
    oc:directiveContent """<profiles>
  <profile>
    <id>profile-id</id>
    <activation>
      <activeByDefault>false</activeByDefault>
      <property><name>env.VAR</name><value>value</value></property>
    </activation>
    <properties>
      <key>value</key>
    </properties>
  </profile>
</profiles>""" .

oc:kn_2c1a2e39 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running any Maven phase command" ;
    oc:directiveContent "Maven lifecycle phases execute sequentially — running `mvn package` executes all phases from validate through package." ;
    oc:hasRationale "Understanding phase ordering is essential to predict what happens during a build and to avoid phase confusion" ;
    oc:severityLevel "HIGH" .

oc:kn_2e9bd853 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating Maven build profiles" ;
    oc:directiveContent "1. Define profile in <profiles> section with unique id → 2. Set activation trigger (activeByDefault, JDK, OS, property, file) → 3. Configure profile-specific properties and plugins → 4. Activate via `-PprofileName` or rely on activation trigger" ;
    oc:stepOrder 2 .

oc:kn_4b15459b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring test plugins in pom.xml" ;
    oc:directiveContent "Use Surefire for unit tests (*Test.java, *Tests.java) and Failsafe for integration tests (*IT.java, *IntegrationTest.java) to keep test lifecycles separate." ;
    oc:hasRationale "Separation enables integration tests to run in the integration-test phase after packaging, when the application is fully assembled" ;
    oc:severityLevel "HIGH" .

oc:kn_52566a56 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Maven 3.x+ must be installed (mvn command available). Maven 4+ required for build cache feature." .

oc:kn_5743a7ef a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When working with multi-module Maven projects" ;
    oc:directiveContent "Use `-pl module-name -am` to build a specific module and its dependencies, `-amd` for dependents, and `-T 1C` for parallel builds in multi-module projects." ;
    oc:hasRationale "Targeted module builds save significant time in large projects; parallel builds utilize available CPU cores" ;
    oc:severityLevel "MEDIUM" .

oc:kn_753f9723 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Common Maven build commands for different scenarios" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """mvn clean install -Pproduction -DskipTests
mvn clean verify -Pci
mvn install -pl module-name -am -T 1C""" .

oc:kn_7def2879 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining Maven profiles" ;
    oc:directiveContent "Keep build profiles focused and isolated — each profile should address a single concern (environment, JDK version, CI) and not overlap with others." ;
    oc:hasRationale "Overlapping profile configurations cause unpredictable build behavior and make debugging difficult" ;
    oc:severityLevel "MEDIUM" .

oc:kn_8699ddca a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent "Lifecycle phases execute in order: validate → initialize → generate-sources → process-sources → generate-resources → process-resources → compile → process-classes → generate-test-sources → process-test-sources → generate-test-resources → process-test-resources → test-compile → process-test-classes → test → prepare-package → package → pre-integration-test → integration-test → post-integration-test → verify → install → deploy" .

oc:kn_90ff4aef a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When a Maven build fails" ;
    oc:directiveContent "For build failures: run `mvn install -X` for debug logs, `mvn install -e` for stack traces, and `mvn help:effective-pom` to inspect resolved configuration." ;
    oc:hasRationale "Debug flags and effective POM inspection are the primary diagnostic tools for Maven build issues" .

oc:kn_b040b898 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When configuring resource filtering in build/resources section" ;
    oc:directiveContent "Resource filtering enabled on binary files will corrupt them. Enable filtering only for text-based resources like .properties and .xml files." ;
    oc:hasRationale "Maven replaces ${...} placeholders in filtered resources — applying this to binary files (images, jars) corrupts their content" ;
    oc:severityLevel "CRITICAL" .

oc:kn_d0b5d98d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring CI/CD pipelines" ;
    oc:directiveContent "Never skip tests in CI pipelines; use -DskipTests only for local development or release builds where tests have already been verified." ;
    oc:hasRationale "Skipping tests in CI defeats the purpose of continuous integration and allows regressions to slip through" ;
    oc:severityLevel "CRITICAL" .

oc:kn_dca3347f a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When preparing release builds" ;
    oc:directiveContent "Always pin exact plugin versions in pom.xml and run `mvn clean` before releases to ensure reproducible builds." ;
    oc:hasRationale "Unpinned versions can cause non-deterministic builds; stale target files can cause subtle build inconsistencies" ;
    oc:severityLevel "HIGH" .

oc:kn_e9355178 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When performing a standard Maven build" ;
    oc:directiveContent "1. Run `mvn clean` to remove stale artifacts → 2. Execute desired phase (compile/test/package/install/deploy) → 3. Use `-X` for debug output if build fails → 4. Check effective POM with `mvn help:effective-pom` for configuration issues" ;
    oc:stepOrder 1 .

oc:kn_fcc1e79b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When needing to skip tests during builds" ;
    oc:directiveContent "Use `-DskipTests` to skip test execution but still compile tests; use `-Dmaven.test.skip=true` to skip both compilation and execution." ;
    oc:hasRationale "Understanding the difference prevents confusion when tests are or aren't compiled during rapid iteration" ;
    oc:severityLevel "MEDIUM" .

