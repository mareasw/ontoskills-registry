oc:kn_35607fbf a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When declaring dependency versions in pom.xml" ;
    oc:directiveContent "Never use LATEST or RELEASE version specifiers in production POMs; always pin exact versions for reproducible builds." ;
    oc:hasRationale "LATEST/RELEASE are resolved dynamically and can break builds non-deterministically at any time." ;
    oc:severityLevel "CRITICAL" .

oc:kn_39bb0c5c a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before releasing a project" ;
    oc:directiveContent "Run 'mvn dependency:analyze' before releases to identify unused declared dependencies and used undeclared dependencies." ;
    oc:hasRationale "Unused dependencies bloat the artifact; undeclared used dependencies can break at runtime when transitive paths change." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5389c3de a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When encountering dependency conflicts or ClassNotFoundException" ;
    oc:directiveContent "When dependency resolution fails, use 'mvn dependency:tree -Dverbose' to see conflict resolution details, then force the correct version via dependencyManagement." ;
    oc:hasRationale "Verbose tree output shows exactly which version was selected and why, enabling targeted fixes." ;
    oc:severityLevel "MEDIUM" .

oc:kn_53ccbef4 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When troubleshooting version conflicts in dependency tree" ;
    oc:directiveContent "Maven resolves version conflicts using 'nearest definition wins' — the dependency closest to the root in the dependency tree takes precedence, not the highest version." ;
    oc:hasRationale "Understanding this is essential for correctly diagnosing and fixing unexpected runtime behavior caused by wrong transitive versions." ;
    oc:severityLevel "HIGH" .

oc:kn_77ae58d2 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When declaring dependencies" ;
    oc:directiveContent "Never use system scope with hardcoded paths; it breaks portability across machines and CI environments." ;
    oc:hasRationale "System scope dependencies reference local file paths that won't exist on other machines or build servers." ;
    oc:severityLevel "HIGH" .

oc:kn_881fb749 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When managing framework or library ecosystem dependencies" ;
    oc:directiveContent "Use well-maintained BOMs (Bill of Materials) such as spring-boot-dependencies, jackson-bom, or junit-bom via import scope to manage compatible version sets." ;
    oc:hasRationale "BOMs ensure compatible versions across related artifacts without manually tracking each one." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a2fbc7af a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When using exclusion elements in dependency declarations" ;
    oc:directiveContent "Excluding a transitive dependency affects the entire dependency subtree for that artifact; adding an alternative must be done explicitly." ;
    oc:hasRationale "Exclusions don't just remove from one path — they remove the excluded artifact from all paths through that dependency." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e08bdf2c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up multi-module Maven projects" ;
    oc:directiveContent "Centralize all dependency versions in the dependencyManagement section of the parent POM, and omit version tags in child module dependencies." ;
    oc:hasRationale "Centralization prevents version drift, eliminates conflicts, and makes upgrading a single version change across all modules." ;
    oc:severityLevel "HIGH" .

oc:kn_edf0740f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When specifying dependency versions" ;
    oc:directiveContent "Avoid version ranges in dependency declarations; use exact pinned versions combined with dependencyManagement for centralization." ;
    oc:hasRationale "Version ranges introduce non-determinism and make builds non-reproducible across environments." ;
    oc:severityLevel "HIGH" .

oc:kn_f0f35b7b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring dependencies for release builds" ;
    oc:directiveContent "Never use SNAPSHOT versions in production releases; they are mutable and can change at any time, breaking reproducibility." ;
    oc:hasRationale "SNAPSHOT artifacts are development versions that can be overwritten, making production builds non-deterministic." ;
    oc:severityLevel "CRITICAL" .

