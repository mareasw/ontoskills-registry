                                    oc:contentOrder 1 ;
                                    oc:rowCount 6 ;
                                    oc:tableCaption "### Available Scopes" ;
                                    oc:tableMarkdown """| Scope | Compile CP | Test CP | Runtime CP | Transitive |
|-------|-----------|---------|------------|------------|
| compile | Yes | Yes | Yes | Yes |
| provided | Yes | Yes | No | No |
| runtime | No | Yes | Yes | Yes |
| test | No | Yes | No | No |
| system | Yes | Yes | No | No |
| import | N/A | N/A | N/A | N/A |
""" ] ;
                            oc:sectionLevel 3 ;
