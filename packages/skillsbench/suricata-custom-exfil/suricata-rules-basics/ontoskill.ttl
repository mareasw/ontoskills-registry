oc:kn_08fa51c6 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When composing multi-condition Suricata rules" ;
    oc:directiveContent "Start with strict conditions (method, path, header), then add body checks. Compose rules from focused, single-purpose match blocks rather than one monolithic pattern." ;
    oc:hasRationale "Layered constraints from specific to general reduce false positives and keep rules readable and maintainable." ;
    oc:severityLevel "HIGH" .

oc:kn_158c57ca a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing content matches containing special characters" ;
    oc:directiveContent "Represent special characters like colons as hex (e.g., |3a| for ':') in content matches to avoid formatting surprises." ;
    oc:hasRationale "Suricata rule parsing can misinterpret literal special characters; hex encoding is unambiguous." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5acf37c9 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing PCRE for body content matching" ;
    oc:directiveContent "Avoid overly generic Base64 regex patterns that are too permissive (false positives) or too strict (false negatives)." ;
    oc:hasRationale "A too-permissive regex fires on unrelated traffic; a too-strict one misses encoded payloads. Anchor patterns to parameter names like blob=." ;
    oc:severityLevel "MEDIUM" .

oc:kn_80733146 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any Suricata alert rule" ;
    oc:directiveContent "Every Suricata rule must have a unique sid (rule ID) and a rev (revision number). The msg field should be specific and descriptive." ;
    oc:hasRationale "sid uniqueness is required for rule management and updates; rev tracks rule evolution; specific msg aids alert triage." ;
    oc:severityLevel "CRITICAL" .

oc:kn_d19d11cd a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When building HTTP inspection rules" ;
    oc:directiveContent "Always prefer protocol-specific sticky buffers (http.method, http.uri, http.header, http_client_body) over raw content matching." ;
    oc:hasRationale "Sticky buffers scope matches to the correct protocol field, preventing accidental matches on unrelated bytes in the TCP stream." ;
    oc:severityLevel "HIGH" .

oc:kn_e9db2e33 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing HTTP content matches in Suricata rules" ;
    oc:directiveContent "Never use content:\"POST\"; without http.method; buffer — it will match the string 'POST' anywhere in the packet including the body." ;
    oc:hasRationale "Without protocol-aware sticky buffers, string matches scan the entire raw TCP stream causing false positives." ;
    oc:severityLevel "CRITICAL" .

oc:kn_f996e160 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When writing rules that inspect client-to-server traffic" ;
    oc:directiveContent "Use flow:established,to_server (or similar flow keywords) to constrain rule evaluation to specific direction and connection state." ;
    oc:hasRationale "Flow keywords prevent rules from firing on incomplete handshakes or return traffic, improving accuracy and performance." ;
    oc:severityLevel "MEDIUM" .

oc:req_80b4becb a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "Suricata IDS/IPS" .

oc:req_b30d1e1e a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Regular expressions (PCRE syntax)" .

oc:req_f15977d7 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "HTTP protocol structure (methods, headers, URIs, body)" .

_:ref_16e7717ccddcf40c a oc:WorkflowStep ;
    dcterms:description "Add HTTP method constraint using http.method sticky buffer with exact content match (e.g., POST)." ;
    oc:expectedOutcome "Rule only triggers on the specified HTTP method" ;
    oc:stepDependsOn _:ref_5cb136f051be9573 ;
    oc:stepId "add-method-constraint" .

_:ref_65ea39ed09829836 a oc:WorkflowStep ;
    dcterms:description "Add body parameter presence checks using http_client_body sticky buffer for each required parameter." ;
    oc:expectedOutcome "Rule verifies required POST body parameters exist" ;
    oc:stepDependsOn _:ref_5cb136f051be9573 ;
    oc:stepId "add-body-content-checks" .

_:ref_6f74c1eb9dbb3fa4 a oc:WorkflowStep ;
    dcterms:description "Add PCRE patterns anchored to parameter names (e.g., sig= with exactly 64 hex chars, blob= with Base64 min length 80) in http_client_body." ;
    oc:expectedOutcome "Rule enforces format and length constraints on body parameters" ;
    oc:stepDependsOn _:ref_65ea39ed09829836 ;
    oc:stepId "add-body-pcre-checks" .

_:ref_91fd80f1b67015fd a oc:WorkflowStep ;
    dcterms:description "Add header constraint using http.header sticky buffer, using hex encoding for special characters like colons." ;
    oc:expectedOutcome "Rule checks for required custom header presence" ;
    oc:stepDependsOn _:ref_5cb136f051be9573 ;
    oc:stepId "add-header-constraint" .

_:ref_d934b455ac30d4b4 a oc:WorkflowStep ;
    dcterms:description "Add URI/path constraint using http.uri sticky buffer with exact content match for the target endpoint." ;
    oc:expectedOutcome "Rule scoped to specific API path" ;
    oc:stepDependsOn _:ref_5cb136f051be9573 ;
    oc:stepId "add-uri-constraint" .

_:ref_5cb136f051be9573 a oc:WorkflowStep ;
    dcterms:description "Define the rule header: protocol (http), source/destination (any any -> any any), and flow direction (flow:established,to_server)." ;
    oc:expectedOutcome "Rule header with correct protocol and flow constraints set" ;
    oc:stepId "define-rule-header" .

