@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_scheduling_email_assistant_constraint_parser a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "constraint-parser" ;
    skos:broader "Parser" ;
    prov:wasDerivedFrom ".agents/skills/skillsbench/scheduling-email-assistant/constraint-parser" ;
    oc:contentHash "3cbf5d113edc45fee8bed53562b1218bca2d7b9f967759bbfe84d90b45909b05" ;
    oc:dependsOnSkill oc:skill_ontoskills_gmail_skill ;
    oc:differentia "that extracts scheduling constraints from raw email text" ;
    oc:handlesFailure oc:InvalidInput,
        oc:NoConstraintsFound ;
    oc:hasArgumentHint "raw email text containing a meeting scheduling request" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Parse scheduling constraints from a email text." ;
    oc:hasName "constraint-parser" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "This skill parses the constraints from raw email text containing a meeting scheduling request." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """{
  "constraints": [
    "Jan 5-7th 9:00am to 12:00pm",
    "not available from 11:00am to 11:30am on Jan 6th"
  ]
}
""" ;
                            oc:codeLanguage "json" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 18-25" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Example Output" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Raw email text containing a meeting scheduling request." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Input" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """Given the email text, extract the scheduling constraints: times or conditions that must or must not be met
(e.g., specific time windows, unavailable days).""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Instruction" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Constraint Parser" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: constraint-parser
description: Parse scheduling constraints from a email text.
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Extract scheduling constraints from raw email text" ;
            oc:hasStep [ a oc:WorkflowStep ;
                    dcterms:description "Format extracted constraints as JSON output" ;
                    oc:expectedOutcome "JSON object with constraints array" ;
                    oc:stepDependsOn _:ref_da69d989553b0cc3 ;
                    oc:stepId "format-output" ],
                _:ref_c42629fe91b6ea37,
                _:ref_da69d989553b0cc3 ;
            oc:workflowId "parse-constraints" ;
            oc:workflowName "Parse Scheduling Constraints" ] ;
    oc:impartsKnowledge oc:kn_23f906dd,
        oc:kn_7ef346ca,
        oc:kn_856d04db,
        oc:kn_a850fb44,
        oc:kn_bf9a7d0d ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EmailTextAvailable ;
    oc:resolvesIntent "extract meeting time requirements from email text",
        "identify availability constraints from scheduling requests",
        "parse scheduling constraints from email" ;
    oc:yieldsState oc:ConstraintsParsed .

oc:kn_23f906dd a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before parsing" ;
    oc:directiveContent "Assumes the input email text contains a meeting scheduling request; may produce unreliable results for unrelated emails" ;
    oc:hasRationale "The parser is specialized for scheduling language and is not a general-purpose email parser" ;
    oc:severityLevel "MEDIUM" .

oc:kn_7ef346ca a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When parsing email text" ;
    oc:directiveContent "Extract only scheduling-related constraints (times, conditions that must or must not be met), not general email content" ;
    oc:hasRationale "Mixing non-scheduling content would pollute the constraints output and break downstream scheduling logic" ;
    oc:severityLevel "HIGH" .

oc:kn_856d04db a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting constraints" ;
    oc:directiveContent "Capture both positive constraints (available times) and negative constraints (unavailable times) as distinct entries" ;
    oc:hasRationale "Both availability and unavailability are needed to find valid meeting slots" .

oc:kn_a850fb44 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When outputting parsed constraints" ;
    oc:directiveContent """{
  "constraints": [
    "{time_window_or_condition}",
    "{time_window_or_condition}"
  ]
}""" ;
    oc:templateVariables "constraints",
        "time_window_or_condition" .

oc:kn_bf9a7d0d a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Always when parsing constraints from email" ;
    oc:directiveContent "1. Receive raw email text 2. Identify scheduling request within text 3. Extract all time windows, unavailable periods, and conditions 4. Output as JSON constraints array" ;
    oc:stepOrder 1 .

_:ref_c42629fe91b6ea37 a oc:WorkflowStep ;
    dcterms:description "Receive raw email text containing a meeting scheduling request" ;
    oc:expectedOutcome "Email text is available for parsing" ;
    oc:stepId "receive-email" .

_:ref_da69d989553b0cc3 a oc:WorkflowStep ;
    dcterms:description "Identify and extract all time windows, unavailable periods, and scheduling conditions from the email" ;
    oc:expectedOutcome "List of constraint strings extracted" ;
    oc:stepDependsOn _:ref_c42629fe91b6ea37 ;
    oc:stepId "extract-constraints" .

