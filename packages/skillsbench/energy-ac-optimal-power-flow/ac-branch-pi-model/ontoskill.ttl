    oc:nature "Concept" ;
    oc:requiresState oc:FileExists,
        oc:NetworkAvailable ;
    oc:resolvesIntent "aggregate bus injections for nodal balance",
        "calculate branch loading percentage",
        "compute branch power flows",
        "debug sign and units issues in AC power flow",
        "enforce MVA line limits" ;
    oc:yieldsState oc:BranchFlowsComputed,
        oc:MVALimitsChecked .

oc:kn_0088f7dd a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When constructing the pi-model shunt elements" ;
    oc:directiveContent "BR_B is the total line charging susceptance b_c; each pi-model end gets b_c/2." ;
    oc:hasRationale "The standard pi-equivalent splits total charging equally between both ends of the line." ;
    oc:severityLevel "MEDIUM" .

oc:kn_12306efe a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When computing series admittance from branch impedance" ;
    oc:directiveContent "If BR_R==0 and BR_X==0, set g=0 and b=0 to avoid divide-by-zero when computing series admittance y=1/(r+jx)." ;
    oc:hasRationale "Zero impedance leads to division by zero; such branches carry no meaningful series flow." ;
    oc:severityLevel "CRITICAL" .

oc:kn_33628a37 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When rerunning branch flow calculations" ;
    oc:directiveContent "Branch flow computation is purely mathematical and deterministic given the same Vm, Va, and branch data." ;
    oc:hasRationale "No external state is modified; results are reproducible given identical inputs." ;
    oc:severityLevel "LOW" .

oc:kn_3549cd7b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When handling transformer tap and phase shift fields from MATPOWER data" ;
    oc:directiveContent "If abs(TAP) < 1e-12, treat tap=1.0 (no transformer). Always convert SHIFT from degrees to radians." ;
    oc:hasRationale "MATPOWER may encode absent transformers with zero or missing tap values; this prevents spurious transformer effects." ;
    oc:severityLevel "HIGH" .

oc:kn_6b4adb3c a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When debugging or validating branch flow results" ;
    oc:directiveContent "With SHIFT=0, TAP=1, V_i=V_j, theta_i=theta_j: P_ij≈0 and P_ji≈0 only if r=0 (lossless). For pure transformer (r=x=0), treat g=b=0." ;
    oc:hasRationale "These sanity checks catch sign errors, missing transformer terms, or incorrect angle conversions." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9bfcbfa2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "All branch flow computations" ;
    oc:directiveContent "Work in per-unit internally; convert with baseMVA: P_pu = P_MW/baseMVA, Q_pu = Q_MVAr/baseMVA, |S|_MVA = |S|_pu * baseMVA." ;
    oc:hasRationale "Per-unit normalization eliminates base scaling errors and is standard in power flow analysis." ;
    oc:severityLevel "CRITICAL" .

oc:kn_f057f22b a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before calling compute_branch_flows_pu" ;
    oc:directiveContent "Verify that bus voltage arrays (Vm, Va) and branch data arrays are loaded and that bus_id_to_idx mapping is built before computing flows." ;
    oc:hasRationale "Missing or misaligned data silently produces wrong results without errors." ;
    oc:severityLevel "HIGH" .

