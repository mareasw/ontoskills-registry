oc:skill_energy_ac_optimal_power_flow_ac_branch_pi_model a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "ac-branch-pi-model" ;
    skos:broader "Power system branch model" ;
    prov:wasDerivedFrom ".agents/skills/skillsbench/energy-ac-optimal-power-flow/ac-branch-pi-model" ;
    oc:contentHash "73133b1bba4c68d93cfeb181d31d18d35200f4548554ce542920a7df2447145d" ;
    oc:dependsOnSkill oc:skill_ontoskills_power_flow_data ;
    oc:differentia "that computes AC branch P/Q/S flows using the pi-equivalent circuit with transformer tap ratio and phase shift in per-unit" ;
    oc:handlesFailure oc:DivideByZero,
        oc:InvalidInput ;
    oc:hasCategory "engineering" ;
    oc:hasDescription "AC branch pi-model power flow equations (P/Q and |S|) with transformer tap ratio and phase shift, matching `acopf-math-model.md` and MATPOWER branch fields. Use when computing branch flows in either direction, aggregating bus injections for nodal balance, checking MVA (rateA) limits, computing branch loading %, or debugging sign/units issues in AC power flow." ;
    oc:hasName "ac-branch-pi-model" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: ac-branch-pi-model
description: "AC branch pi-model power flow equations (P/Q and |S|) with transformer tap ratio and phase shift, matching `acopf-math-model.md` and MATPOWER branch fields. Use when computing branch flows in either direction, aggregating bus injections for nodal balance, checking MVA (rateA) limits, computing branch loading %, or debugging sign/units issues in AC power flow."
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Implement the exact branch power flow equations in `acopf-math-model.md` using MATPOWER branch data:" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """[F_BUS, T_BUS, BR_R, BR_X, BR_B, RATE_A, RATE_B, RATE_C, TAP, SHIFT, BR_STATUS, ANGMIN, ANGMAX]
""" ;
                    oc:codeLanguage "" ;
                    oc:contentOrder 2 ;
                    oc:sourceLocation "lines 10-12" ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "To build the branch flow sum for each bus \\(i\\):" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "This yields arrays `P_out[i]`, `Q_out[i]` such that the nodal balance can be written as:" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Add \\(P_{ji}, Q_{ji}\\) to bus j" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Add \\(P_{ij}, Q_{ij}\\) to bus i" ] ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 4 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "\\(Q^g - Q^d + B^s|V|^2 = Q_{out}\\)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "\\(P^g - P^d - G^s|V|^2 = P_{out}\\)" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Aggregate bus injections for nodal balance" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "`loading_pct = 100 * max(|S_ij|, |S_ji|) / RATE_A` if `RATE_A > 0`, else 0." ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "For reporting “most loaded branches”:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Compute branch loading %" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "`RATE_A` is an MVA limit (may be 0 meaning “no limit”)." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:hasChild [ a oc:BulletList ;
                                                    oc:blockType "bullet_list" ;
                                                    oc:contentOrder 1 ;
                                                    oc:hasItem [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 2 ;
                                                            oc:itemText "\\(|S_{ji}| \\le RATE_A\\)" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 1 ;
                                                            oc:itemText "\\(|S_{ij}| \\le RATE_A\\)" ] ] ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Enforce in both directions:" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Enforce MVA limits (rateA)" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Common uses" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "`inv_t = 1/tap`, `inv_t2 = inv_t^2`" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "\\(V_i = |V_i| e^{j\\theta_i}\\), \\(V_j = |V_j| e^{j\\theta_j}\\)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "`tap` is real, `shift` is radians" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Let:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent "And from j→i is:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 8 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "\\(|S_{ij}| = \\sqrt{P_{ij}^2 + Q_{ij}^2}\\)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "\\(|S_{ji}| = \\sqrt{P_{ji}^2 + Q_{ji}^2}\\)" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 7 ;
                            oc:textContent "Compute apparent power:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Then the real/reactive power flow from i→j is:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 6 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "\\(P_{ji} = g |V_j|^2 - |V_i||V_j| inv\\_t (g\\cos\\delta_{ji} + b\\sin\\delta_{ji})\\)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "\\(Q_{ji} = -(b + b_c/2)|V_j|^2 - |V_i||V_j| inv\\_t (g\\sin\\delta_{ji} - b\\cos\\delta_{ji})\\)" ] ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "\\(P_{ij} = g |V_i|^2 inv\\_t2 - |V_i||V_j| inv\\_t (g\\cos\\delta_{ij} + b\\sin\\delta_{ij})\\)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "\\(Q_{ij} = -(b + b_c/2)|V_i|^2 inv\\_t2 - |V_i||V_j| inv\\_t (g\\sin\\delta_{ij} - b\\cos\\delta_{ij})\\)" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Power flow equations (use these exactly)" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:hasChild [ a oc:BulletList ;
                                                    oc:blockType "bullet_list" ;
                                                    oc:contentOrder 1 ;
                                                    oc:hasItem [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 3 ;
                                                            oc:itemText "\\(|S|_{MVA} = |S|_{pu} \\cdot baseMVA\\)" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 1 ;
                                                            oc:itemText "\\(P_{pu} = P_{MW} / baseMVA\\)" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 2 ;
                                                            oc:itemText "\\(Q_{pu} = Q_{MVAr} / baseMVA\\)" ] ] ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Convert with `baseMVA`:" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Work in per-unit internally." ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Per-unit conventions" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Use \\(T_{ij} = tap \\cdot e^{j \\cdot shift}\\)." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:hasChild [ a oc:BulletList ;
                                                    oc:blockType "bullet_list" ;
                                                    oc:contentOrder 1 ;
                                                    oc:hasItem [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:hasChild [ a oc:BulletList ;
                                                                    oc:blockType "bullet_list" ;
                                                                    oc:contentOrder 1 ;
                                                                    oc:hasItem [ a oc:BulletItem ;
                                                                            oc:blockType "bullet_item" ;
                                                                            oc:itemOrder 2 ;
                                                                            oc:itemText "\\(\\delta_{ji} = \\theta_j - \\theta_i + shift\\)" ],
                                                                        [ a oc:BulletItem ;
                                                                            oc:blockType "bullet_item" ;
                                                                            oc:itemOrder 1 ;
                                                                            oc:itemText "\\(\\delta_{ij} = \\theta_i - \\theta_j - shift\\)" ] ] ;
                                                            oc:itemOrder 3 ;
                                                            oc:itemText "Use the angle shift by modifying the angle difference:" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 1 ;
                                                            oc:itemText "If `abs(TAP) < 1e-12`, treat `tap = 1.0` (no transformer)." ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 2 ;
                                                            oc:itemText "Convert `SHIFT` from degrees to radians." ] ] ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Implementation shortcut (real tap + phase shift):**" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Transformer handling (MATPOWER TAP + SHIFT)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Given `BR_R = r`, `BR_X = x`:" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:hasChild [ a oc:BulletList ;
                                                    oc:blockType "bullet_list" ;
                                                    oc:contentOrder 1 ;
                                                    oc:hasItem [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 1 ;
                                                            oc:itemText "\\(y = 1/(r + jx) = g + jb\\)" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 2 ;
                                                            oc:itemText "\\(g = r/(r^2 + x^2)\\)" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 3 ;
                                                            oc:itemText "\\(b = -x/(r^2 + x^2)\\)" ] ] ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Else:" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "If `r == 0 and x == 0`, set `g = 0`, `b = 0` (avoid divide-by-zero)." ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Series admittance" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "`BR_B` is the **total** line charging susceptance \\(b_c\\) (per unit)." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Each end gets \\(b_c/2\\) in the standard pi model." ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "Line charging susceptance" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Model details (match the task formulation)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "With `SHIFT=0` and `TAP=1`, if \\(V_i = V_j\\) and \\(\\theta_i=\\theta_j\\), then \\(P_{ij}\\approx 0\\) and \\(P_{ji}\\approx 0\\) (lossless only if r=0)." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "For a pure transformer (`r=x=0`) you should not get meaningful flows; treat as `g=b=0` (no series element)." ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Sanity checks (fast debug)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "Example:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Use `scripts/branch_flows.py` to compute per-unit branch flows." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Treat the results as **power leaving** the “from” bus and **power leaving** the “to” bus (i.e., compute both directions explicitly)." ] ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """import json
import numpy as np

from scripts.branch_flows import compute_branch_flows_pu, build_bus_id_to_idx

data = json.load(open("/root/network.json"))
baseMVA = float(data["baseMVA"])
buses = np.array(data["bus"], dtype=float)
branches = np.array(data["branch"], dtype=float)

bus_id_to_idx = build_bus_id_to_idx(buses)

Vm = buses[:, 7]  # initial guess VM
Va = np.deg2rad(buses[:, 8])  # initial guess VA

br = branches[0]
P_ij, Q_ij, P_ji, Q_ji = compute_branch_flows_pu(Vm, Va, br, bus_id_to_idx)

S_ij_MVA = (P_ij**2 + Q_ij**2) ** 0.5 * baseMVA
S_ji_MVA = (P_ji**2 + Q_ji**2) ** 0.5 * baseMVA
print(S_ij_MVA, S_ji_MVA)
""" ;
                            oc:codeLanguage "python" ;
                            oc:contentOrder 3 ;
                            oc:sourceLocation "lines 21-43" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Quick start" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "AC Branch Pi-Model + Transformer Handling" ] ;
    oc:impartsKnowledge oc:kn_0088f7dd,
        oc:kn_12306efe,
        oc:kn_33628a37,
