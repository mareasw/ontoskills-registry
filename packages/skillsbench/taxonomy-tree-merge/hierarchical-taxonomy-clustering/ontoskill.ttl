oc:kn_04b8bfc8 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When tempted to skip Step 1 preprocessing" ;
    oc:directiveContent "Do not skip text preprocessing (cleaning special chars, lemmatizing as nouns, normalizing delimiters). Raw category text creates noisy embeddings and poor clustering." ;
    oc:hasRationale "Preprocessing quality directly determines embedding quality and clustering accuracy" ;
    oc:severityLevel "HIGH" .

oc:kn_294b8b14 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When installing dependencies before first run" ;
    oc:directiveContent "pip install pandas numpy scipy sentence-transformers nltk tqdm && python -c \"import nltk; nltk.download('wordnet'); nltk.download('omw-1.4')\"" .

oc:kn_2be225a4 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before running the pipeline" ;
    oc:directiveContent "Requires pandas, numpy, scipy, sentence-transformers, nltk, tqdm. NLTK data (wordnet, omw-1.4) must be downloaded." ;
    oc:hasRationale "Missing dependencies cause immediate failure at pipeline startup" .

oc:kn_454c606d a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When running the complete taxonomy pipeline" ;
    oc:directiveContent """1. Preprocess & merge: per-source dedup, text cleaning, normalize delimiter to ` > `, depth filter, prefix removal → merged DataFrame
2. Generate weighted embeddings: exponential decay weights, 384-dim vectors
3. Recursive clustering: average linkage + cosine distance, assign clusters at each level with auto-naming
4. Export: unified_taxonomy_full.csv + unified_taxonomy_hierarchy.csv""" ;
    oc:stepOrder 1 .

oc:kn_5156307a a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting the pipeline" ;
    oc:directiveContent "Verify each input DataFrame has a `category_path` column and that category paths use a consistent hierarchical delimiter before passing to the pipeline." ;
    oc:hasRationale "Missing or inconsistent category_path columns cause silent failures or meaningless clusters" .

oc:kn_58b06b41 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing recursive clustering in Step 3" ;
    oc:directiveContent "Use average linkage hierarchical clustering with cosine distance. Cluster count: 10-20 at L1, 3-20 at L2-L5." ;
    oc:hasRationale "Average linkage balances cluster compactness and avoids chaining artifacts of single linkage" .

oc:kn_838067f2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating weighted embeddings in Step 2" ;
    oc:directiveContent "Exponential decay weight 0.6^(i-1) per level: L1=1.0, L2=0.6, L3=0.36, L4=0.216, L5=0.1296. This ensures higher-level categories dominate embedding similarity." ;
    oc:hasRationale "Higher taxonomy levels carry more semantic weight because broader category distinctions matter more than fine-grained ones" ;
    oc:severityLevel "HIGH" .

oc:kn_baa2160b a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When exporting results in Step 4" ;
    oc:directiveContent """unified_taxonomy_full.csv: all records with unified_level_1..unified_level_N columns
unified_taxonomy_hierarchy.csv: unique taxonomy structure rows
Category names: word1 | word2 | ... (max 5 words, 70%+ coverage)""" ;
    oc:templateVariables "unified_level_1",
        "unified_level_2",
        "unified_level_3",
        "unified_level_4",
        "unified_level_5" .

oc:kn_c2a9ea91 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating category names via weighted word frequency" ;
    oc:directiveContent "Category names: max 5 words, use ` | ` separator, must cover ≥70% of records in each cluster. Exclude all ancestor words (parent, grandparent, etc.) to avoid redundancy." ;
    oc:hasRationale "Coverage threshold ensures names are representative; ancestor exclusion prevents redundant naming across levels" ;
    oc:severityLevel "HIGH" .

oc:kn_efabaf45 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When estimating pipeline runtime" ;
    oc:directiveContent "For ~10,000 records: Step 2 embedding generation takes 2-5 minutes; Step 3 clustering and naming takes 1-3 minutes." ;
    oc:hasRationale "Helps set user expectations and detect hung processes" .

