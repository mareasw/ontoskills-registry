_:ref_aaf255eee276baaa a oc:WorkflowStep ;
    dcterms:description "Generate 384-dim embeddings with exponential decay weights (0.6^(i-1)) per hierarchy level" ;
    oc:expectedOutcome "Numpy embedding matrix (n_records × 384)" ;
    oc:stepDependsOn _:ref_e69b44df606e579a ;
    oc:stepId "weighted-embeddings" .

_:ref_e69b44df606e579a a oc:WorkflowStep ;
