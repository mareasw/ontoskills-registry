_:ref_beac199580e8d0e4 a oc:WorkflowStep ;
    dcterms:description "**Intelligent Naming**: Generate category names via weighted word frequency + lemmatization + bundle word logic" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_dbee755a20e4b90e a oc:WorkflowStep ;
    dcterms:description "**Quality Control**: Exclude all ancestor words (parent, grandparent, etc.), avoid ancestor path duplicates, clean special characters" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_e5b16d73d6ab6462 a oc:WorkflowStep ;
    dcterms:description "**Recursive Clustering**: Hierarchically cluster at each level (10-20 clusters at L1, 3-20 at L2-L5) using cosine distance" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_f3b5f9260cc6c4a0 a oc:WorkflowStep ;
    dcterms:description "**Hierarchical Weighting**: Convert paths to embeddings with exponentially decaying weights (Level i gets weight 0.6^(i-1)) to signify the importance of category granularity" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_50e5243c91bd756f a oc:WorkflowStep ;
    dcterms:description "Hierarchical clustering at each level using average linkage + cosine distance, generate category names via weighted word frequency with ≥70% coverage" ;
    oc:expectedOutcome "Assignments dict mapping each index to {level_1..level_5} cluster names" ;
    oc:stepDependsOn _:ref_aaf255eee276baaa ;
    oc:stepId "recursive-clustering" .

