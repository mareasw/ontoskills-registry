oc:kn_1d8cd175 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before first Modal usage" ;
    oc:directiveContent "1. pip install modal  2. modal token set --token-id <id> --token-secret <secret>" ;
    oc:hasRationale "Modal CLI must be installed and authenticated to submit jobs to the cloud platform" .

oc:kn_2ce26edc a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any Modal GPU training script" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """import modal

app = modal.App("my-training-app")
image = modal.Image.debian_slim(python_version="3.11").pip_install("torch", "numpy")

@app.function(gpu="A100", image=image, timeout=3600)
def train():
    import torch
    device = torch.device("cuda")
    return {"loss": 0.5}

@app.local_entrypoint()
def main():
    results = train.remote()""" ;
    oc:hasRationale "This is the minimal viable pattern for Modal GPU execution: define app, build image with deps, decorate function with GPU + image + timeout, call .remote() from local_entrypoint" .

oc:kn_583f625f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When handling data and results in Modal functions" ;
    oc:directiveContent "Download data (e.g., from HuggingFace) inside the remote function using hf_hub_download, not in the local entrypoint. Return results as Python dicts from remote functions." ;
    oc:hasRationale "Remote functions run on cloud infrastructure where data must be available; downloading locally and transferring is inefficient or impossible. Dicts serialize cleanly from remote to local." ;
    oc:severityLevel "HIGH" .

oc:kn_df5a7057 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring Modal scripts" ;
    oc:directiveContent "Do not import heavy ML libraries (torch, transformers) at the top level of the script outside of remote functions. Instead, install them via image.pip_install() and import inside the decorated function." ;
    oc:hasRationale "The local entrypoint runs on your machine without GPU; importing CUDA-dependent libraries locally will fail. Image.pip_install ensures deps are in the container, and imports inside functions load them on the remote." ;
    oc:severityLevel "CRITICAL" .

oc:kn_e43a8f24 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing GPU type and timeout for a training job" ;
    oc:directiveContent "Select GPU tier by workload size: T4 (16GB) for quick experiments, A10G (24GB) for medium jobs, A100 (40/80GB) for large-scale training. Set timeout=3600 or higher for long-running jobs." ;
    oc:hasRationale "Over-provisioning GPU wastes cost; under-provisioning causes OOM. Timeout prevents runaway costs." ;
    oc:severityLevel "HIGH" .

oc:kn_fc4f7fb3 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When architecting a Modal application" ;
    oc:directiveContent "Use the Single Function pattern (one @app.function) for simple scripts and the Multi-Function pattern (multiple @app.function decorators calling .remote() between them) for complex workflows." ;
    oc:hasRationale "Single Function minimizes complexity; Multi-Function enables composition for data pipelines or multi-stage training" .

oc:kn_fdfc586a a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running a Modal training script" ;
    oc:directiveContent """modal run train_modal.py       # foreground execution
modal run --detach train_modal.py  # background execution""" ;
    oc:hasRationale "Use --detach for long-running jobs to avoid blocking the terminal" .

