oc:kn_13442c46 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When integrating mHC into Transformer models" ;
    oc:directiveContent "Wrap both attention AND MLP layers with HyperConnections in GPT/Transformer architectures for consistent residual stream mixing." ;
    oc:hasRationale "Mixing only one sublayer type creates asymmetric gradient flow; wrapping both ensures uniform stability improvements." ;
    oc:severityLevel "HIGH" .

oc:kn_4cf560a2 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding whether to apply mHC" ;
    oc:directiveContent "Do not use mHC for standard shallow networks (≤12 layers) with no stability issues — it adds unnecessary overhead." ;
    oc:hasRationale "mHC is designed for deep networks where gradient variance destabilizes training; shallow networks benefit negligibly." ;
    oc:severityLevel "MEDIUM" .

oc:kn_59b8e9bc a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When initializing HyperConnections parameters" ;
    oc:directiveContent "Initialize H_res logits with small negative values (-0.1) and zero on the diagonal to start near identity, ensuring good gradient flow at training start." ;
    oc:hasRationale "Near-identity initialization preserves the skip connection behavior initially, allowing the network to gradually learn optimal mixing." ;
    oc:severityLevel "HIGH" .

oc:kn_5b6c6af4 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When configuring HyperConnections for resource-limited environments" ;
    oc:directiveContent "num_streams parameter controls memory and compute cost quadratically (O(s²) for mixing matrices). Use num_streams=4 as default; reduce for memory-constrained training." ;
    oc:hasRationale "More streams increase mixing capacity but scale quadratically in parameter count and matrix operations." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5d6ed1a3 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring the Sinkhorn-Knopp algorithm" ;
    oc:directiveContent "Sinkhorn-Knopp iteration count (default 20) and temperature τ (default 0.05) control projection accuracy vs. compute cost. Adjust for memory-constrained scenarios." ;
    oc:hasRationale "Lower iteration counts reduce compute but may produce matrices that are less doubly stochastic; temperature controls sharpness of the projection." ;
    oc:severityLevel "MEDIUM" .

