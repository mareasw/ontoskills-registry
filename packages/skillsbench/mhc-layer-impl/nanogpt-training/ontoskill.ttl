oc:kn_39d8f6f3 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When benchmarking training runs" ;
    oc:directiveContent "Track throughput in tokens/sec as a consistent metric for comparing configurations" ;
    oc:hasRationale "Tokens/sec normalizes across different batch sizes and sequence lengths" .

oc:kn_3e4c4988 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before launching training" ;
    oc:directiveContent "Verify GPU availability and CUDA compatibility before starting training; ensure sufficient VRAM for model + optimizer states + batch" ;
    oc:hasRationale "OOM errors mid-training waste time and may corrupt checkpoints" .

oc:kn_45269f06 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When training on A100 GPUs" ;
    oc:directiveContent "Use bfloat16 mixed precision training on A100 for ~2x speedup without significant accuracy loss" ;
    oc:hasRationale "bfloat16 provides the dynamic range of float32 with the memory savings of float16, avoiding overflow issues" .

oc:kn_55f71200 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting GPU type" ;
    oc:directiveContent "Use A100 for full training runs, T4/A10G for small experiments and debugging" ;
    oc:hasRationale "Larger GPU memory and compute enable larger batch sizes and faster iteration" .

oc:kn_724bb0dc a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring model architecture" ;
    oc:directiveContent "GPTConfig defaults define the 124M parameter model: 12 layers, 12 heads, 768 embedding dim, 1024 block size, 50257 vocab size" ;
    oc:hasRationale "These parameters produce the standard GPT-2 Small configuration used as the baseline" .

oc:kn_7363fb20 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "During training loop execution" ;
    oc:directiveContent "Monitor grad norm for large spikes — these indicate training instability and suggest learning rate or batch size issues" ;
    oc:hasRationale "Grad norm spikes can cascade into divergence, wasting compute resources" ;
    oc:severityLevel "HIGH" .

oc:kn_c5908c23 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating training progress" ;
    oc:directiveContent "Use validation loss as the primary metric; its absolute value depends on dataset/tokenizer so focus on steady decrease rather than raw numbers" ;
    oc:hasRationale "Cross-dataset loss values are not directly comparable, but the trend is universally meaningful" .

