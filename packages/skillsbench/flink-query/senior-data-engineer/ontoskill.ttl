oc:kn_0dd2838c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building ETL pipelines for large datasets" ;
    oc:directiveContent "Never process full datasets when incremental processing is possible — always prefer incremental loads over full reloads" ;
    oc:hasRationale "Full reloads waste compute resources, increase latency, and raise costs unnecessarily" ;
    oc:severityLevel "HIGH" .

oc:kn_29e8556a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deploying pipelines to production" ;
    oc:directiveContent "Production batch pipelines must achieve >99% success rate, streaming pipelines must sustain 10K+ events/sec with P99 latency <1s, and data quality scores must exceed 95%" ;
    oc:hasRationale "These are the minimum performance targets for reliable data infrastructure" ;
    oc:severityLevel "HIGH" .

oc:kn_8adcd356 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When optimizing pipeline performance" ;
    oc:directiveContent "Partition large tables by date/region, use columnar formats (Parquet/ORC), leverage predicate pushdown, and monitor query patterns for optimization opportunities" ;
    oc:hasRationale "These patterns consistently deliver the best price-performance ratio for analytical workloads" .

oc:kn_8d178f43 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When pipelines fail in production" ;
    oc:directiveContent "Implement automated retry logic with exponential backoff, dead letter queues for failed records, and clear runbooks for incident response" ;
    oc:hasRationale "Automated recovery reduces MTTR and manual intervention for transient failures" ;
    oc:severityLevel "HIGH" .

oc:kn_974853f7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any data pipeline" ;
    oc:directiveContent "Use idempotent operations for safe reruns — every pipeline step must produce the same result when executed multiple times with the same input" ;
    oc:hasRationale "Idempotency prevents duplicate data and corruption during reruns caused by failures or backfills" ;
    oc:severityLevel "CRITICAL" .

oc:kn_a06f366c a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing ETL logic" ;
    oc:directiveContent "All pipeline operations must be idempotent — use merge/upsert patterns instead of inserts, and include deduplication logic at every stage" ;
    oc:hasRationale "Non-idempotent pipelines produce incorrect results on reruns and cannot safely recover from failures" .

oc:kn_a4651c85 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing new data architectures" ;
    oc:directiveContent "Choose architecture pattern based on requirements: Kappa for streaming-only workloads, Lambda for hybrid batch+streaming, Medallion (Bronze/Silver/Gold) for lakehouse architectures" ;
    oc:hasRationale "Each pattern optimizes for different latency, complexity, and cost tradeoffs" .

oc:kn_b2ee5d6b a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before deploying streaming infrastructure" ;
    oc:directiveContent "Before deploying streaming pipelines: validate YAML configuration, check Kafka topic existence and partition counts, verify Schema Registry compatibility, and confirm consumer group offsets" ;
    oc:hasRationale "Pre-deployment validation prevents costly misconfigurations from reaching production" .

