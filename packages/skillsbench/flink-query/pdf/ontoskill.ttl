oc:kn_04006f91 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before any PDF processing" ;
    oc:directiveContent "Install required Python packages: pip install pypdf pdfplumber reportlab. Optional: pip install pytesseract pdf2image pandas." ;
    oc:hasRationale "These libraries provide the core PDF manipulation capabilities." .

oc:kn_15371e59 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "1. Identify PDF type (text-based vs scanned). 2. For text-based: use pdfplumber for extraction. 3. For scanned: convert with pdf2image then OCR with pytesseract. 4. For table extraction: use pdfplumber.extract_tables() and convert to DataFrame. 5. For merge/split/rotate: use pypdf. 6. For creation: use reportlab." ;
    oc:stepOrder 1 .

