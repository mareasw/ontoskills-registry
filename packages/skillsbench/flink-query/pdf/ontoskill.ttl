oc:kn_38396eb4 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reading and writing PDFs with pypdf" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from pypdf import PdfReader, PdfWriter
reader = PdfReader("input.pdf")
writer = PdfWriter()
for page in reader.pages:
    writer.add_page(page)
with open("output.pdf", "wb") as f:
    writer.write(f)""" .

oc:kn_7e1a3a83 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting images from PDFs via command line" ;
    oc:directiveContent "pdfimages -j input.pdf output_prefix" .

oc:kn_966f3470 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When text extraction returns empty results" ;
    oc:directiveContent "If pypdf fails to extract text, fall back to pdfplumber. If both fail, the PDF may be scanned — use OCR pipeline (pdf2image + pytesseract)." ;
    oc:hasRationale "A layered fallback strategy handles the three main PDF types: text-based, layout-complex, and scanned images." .

oc:kn_99689684 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating multi-page PDF documents with reportlab Platypus" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from reportlab.lib.pagesizes import letter
from reportlab.platypus import SimpleDocTemplate, Paragraph, Spacer
from reportlab.lib.styles import getSampleStyleSheet

doc = SimpleDocTemplate("output.pdf", pagesize=letter)
styles = getSampleStyleSheet()
story = [Paragraph("Title", styles['Title']), Spacer(1, 12), Paragraph("Body", styles['Normal'])]
doc.build(story)""" .

oc:kn_9f066b8c a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When selecting a library for a PDF task" ;
    oc:directiveContent "Use pypdf for merge/split/rotate/encrypt operations, pdfplumber for text and table extraction, and reportlab for PDF creation." ;
    oc:hasRationale "Each library is optimized for its domain: pypdf for page-level manipulation, pdfplumber for content extraction with layout awareness, reportlab for rich document generation." ;
    oc:severityLevel "HIGH" .

oc:kn_9fb7bbc2 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting text preserving layout via command line" ;
    oc:directiveContent "pdftotext -layout input.pdf output.txt" .

oc:kn_a2f539c1 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When merging PDFs" ;
    oc:directiveContent "1. Read source PDFs with PdfReader. 2. Create PdfWriter. 3. Add pages in desired order. 4. Write to output file with 'wb' mode." ;
    oc:stepOrder 2 .

oc:kn_c3920f5a a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When performing merge, split, watermark, or encrypt operations" ;
    oc:directiveContent "PDF merge and watermark operations create new files; they do not modify originals. Always write to a new output file." ;
    oc:hasRationale "pypdf's writer pattern always creates new output, preserving source files as a safety mechanism." .

oc:kn_e6c89b57 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When filling interactive PDF forms" ;
    oc:directiveContent "For PDF form filling, consult forms.md and consider pdf-lib (JavaScript) or pypdf — do not attempt form filling with reportlab." ;
    oc:hasRationale "Form filling requires specific AcroForm field manipulation that reportlab's Canvas API does not support." ;
    oc:severityLevel "HIGH" .

oc:kn_ea6561b6 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting text from image-based or scanned PDFs" ;
    oc:directiveContent "Scanned PDFs require OCR (pytesseract + pdf2image) — standard text extraction will return empty or garbage results." ;
    oc:hasRationale "Scanned PDFs contain images, not text layers. OCR is the only way to extract readable text from them." ;
    oc:severityLevel "CRITICAL" .

oc:kn_f2a11ed6 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting structured content from PDFs" ;
    oc:directiveContent "Do not use pypdf's extract_text() for complex layouts or table extraction; use pdfplumber instead." ;
    oc:hasRationale "pypdf's text extraction is basic and loses layout information; pdfplumber preserves spatial relationships needed for tables and formatted text." ;
    oc:severityLevel "HIGH" .

