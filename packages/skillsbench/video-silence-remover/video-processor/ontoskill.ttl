oc:kn_2b4d14b9 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Always when processing video segments" ;
    oc:directiveContent "1. Load removal segments from JSON file(s) 2. Calculate keep segments (inverse of removal segments) 3. Build ffmpeg filter to trim and concatenate 4. Process video using ffmpeg with CRF encoding 5. Generate report with statistics" ;
    oc:stepOrder 1 .

oc:kn_57fa0432 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "Report JSON generated after processing" ;
    oc:directiveContent "{\"original_duration\": NUMBER, \"output_duration\": NUMBER, \"removed_duration\": NUMBER, \"compression_percentage\": NUMBER, \"segments_removed\": NUMBER, \"segments_kept\": NUMBER}" ;
    oc:templateVariables "compression_percentage",
        "original_duration",
        "output_duration",
        "removed_duration",
        "segments_kept",
        "segments_removed" .

oc:kn_83198cb6 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "After execution completes" ;
    oc:directiveContent "Creates a processed video file and a JSON report file with compression statistics on disk" ;
    oc:hasRationale "Agent must account for disk space consumption and know where to find the output report" ;
    oc:severityLevel "MEDIUM" .

oc:kn_8fd73cec a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running video segment removal" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "python3 /root/.claude/skills/video-processor/scripts/process_video.py --input INPUT --output OUTPUT --remove-segments SEGMENTS_JSON" .

oc:kn_a4e29fda a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When processing videos requiring sample-level precision" ;
    oc:directiveContent "Cuts are frame-accurate but not sample-accurate; audio sync is maintained but sub-frame precision may vary" ;
    oc:hasRationale "Manages expectations for edge-case timing accuracy; not suitable for frame-exact editing requirements" ;
    oc:severityLevel "LOW" .

oc:kn_a4feccb1 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring encoding parameters" ;
    oc:directiveContent "Use -preset medium for balanced speed/quality, -crf 23 for good quality at reasonable size, and 2+ CPU cores for faster encoding" ;
    oc:hasRationale "Optimizes the tradeoff between processing speed, output quality, and file size" .

oc:kn_dff298e6 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "ffmpeg must be installed with libx264 and aac codec support" .

oc:kn_e3585d9c a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before running the processing script" ;
    oc:directiveContent "Verify input video exists, segment JSON files are valid and contain 'segments' array with start/end/duration fields, and sufficient disk space is available" ;
    oc:hasRationale "Prevents wasting time on long encode jobs that would fail due to missing inputs or insufficient space" ;
    oc:severityLevel "HIGH" .

oc:kn_e95da1d8 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When preparing segment JSON input files" ;
    oc:codeLanguage "json" ;
    oc:directiveContent "{\"segments\": [{\"start\": NUMBER, \"end\": NUMBER, \"duration\": NUMBER}]}" .

oc:kn_ffd9f8be a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before starting video processing" ;
    oc:directiveContent "Processing time is ~0.3× video duration (e.g., 20 min for 65 min video). Requires sufficient disk space (output ≈ 70-80% of input size)." ;
    oc:hasRationale "Allows accurate time and resource estimation before committing to a long encode job" ;
    oc:severityLevel "MEDIUM" .

