    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:FileExists,
        oc:ToolInstalled ;
    oc:resolvesIntent "convert video audio to WAV format",
        "extract audio from video",
        "prepare audio for energy analysis" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_18cf370f a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "always" ;
    oc:directiveContent "Creates a WAV file on disk at the specified output path; overwrites if file exists" ;
    oc:hasRationale "Agent must ensure output path is writable and won't overwrite important files" .

oc:kn_25651dc2 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting audio for speech or energy analysis" ;
    oc:directiveContent "Default 16kHz sample rate is used because it is sufficient for speech analysis and reduces file size" ;
    oc:hasRationale "Speech energy is concentrated below 8kHz, so 16kHz Nyquist covers the full speech bandwidth while minimizing storage" ;
    oc:severityLevel "MEDIUM" .

oc:kn_7280bc7b a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before execution" ;
    oc:directiveContent "ffmpeg must be installed and available in PATH" ;
    oc:severityLevel "CRITICAL" .

oc:kn_83363129 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "always" ;
    oc:directiveContent "Output is always mono channel regardless of input video's channel configuration" ;
    oc:hasRationale "Mono ensures consistent energy analysis downstream without channel-averaging ambiguity" ;
    oc:severityLevel "HIGH" .

oc:kn_b9453df4 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When executed multiple times" ;
    oc:directiveContent "Re-running with the same parameters overwrites the output file with identical content" ;
    oc:hasRationale "Safe to re-run without side effects beyond overwriting the output" .

oc:kn_d0408dd2 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When selecting input video files" ;
    oc:directiveContent "Supports any video format that ffmpeg can read as input" ;
    oc:hasRationale "Leverages ffmpeg's broad codec support for maximum compatibility" .

oc:req_3fcf652e a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "python3" .

oc:req_8f2ef958 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "ffmpeg" .

_:ref_56499a0d24b00e8a a oc:WorkflowStep ;
    dcterms:description "Verify input video file exists and is readable" ;
    oc:expectedOutcome "Input file confirmed accessible" ;
    oc:stepId "verify-input" .

_:ref_9c4b8127fbaf32d5 a oc:WorkflowStep ;
    dcterms:description "Execute extract_audio.py with video path, output path, and optional parameters" ;
    oc:expectedOutcome "WAV file created at output path" ;
    oc:stepDependsOn _:ref_56499a0d24b00e8a ;
    oc:stepId "run-extraction" .

