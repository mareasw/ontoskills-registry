oc:skill_video_silence_remover_audio_extractor a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "audio-extractor" ;
    skos:broader "Audio extraction utility" ;
    prov:wasDerivedFrom ".agents/skills/skillsbench/video-silence-remover/audio-extractor" ;
    oc:contentHash "b3f93bd13397f2365900894fcbe4b35000629c5e3b3149801e906d34a01f9150" ;
    oc:differentia "converts video audio tracks to mono 16kHz PCM WAV format optimized for speech and energy analysis" ;
    oc:handlesFailure oc:FileNotFound,
        oc:PermissionDenied ;
    oc:hasArgumentHint "--video /path/to/video.mp4 --output /path/to/audio.wav" ;
    oc:hasCategory "automation" ;
    oc:hasDescription "Extract audio from video files to WAV format. Use when you need to analyze audio from video, prepare audio for energy calculation, or convert video audio to standard format for processing." ;
    oc:hasName "audio-extractor" ;
    oc:hasRequirement oc:req_3fcf652e,
        oc:req_8f2ef958 ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
