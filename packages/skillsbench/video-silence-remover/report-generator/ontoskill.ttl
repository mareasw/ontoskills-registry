    oc:yieldsState oc:DocumentCreated .

oc:kn_018f9614 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "Report output always uses this JSON structure" ;
    oc:directiveContent """{
  "original_duration_seconds": {orig_duration},
  "compressed_duration_seconds": {comp_duration},
  "removed_duration_seconds": {removed_duration},
  "compression_percentage": {percentage},
  "segments_removed": [{"start": {start}, "end": {end}, "duration": {dur}, "type": {type}}]
}""" ;
    oc:templateVariables "comp_duration",
        "dur",
        "end",
        "orig_duration",
        "percentage",
        "removed_duration",
        "start",
        "type" .

oc:kn_4ffc5997 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When re-running report generation" ;
    oc:directiveContent "Running the report generator multiple times with the same inputs produces identical output JSON" ;
    oc:hasRationale "Report generation is read-only with respect to input files; only the output file is written" .

oc:kn_51560035 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating a compression report from the CLI" ;
    oc:directiveContent "python3 /root/.claude/skills/report-generator/scripts/generate_report.py --original {original} --compressed {compressed} --segments {segments} --output {output}" .

oc:kn_58477e1f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calculating compression ratio" ;
    oc:directiveContent "Compression percentage formula: (removed_duration / original_duration) × 100" ;
    oc:hasRationale "Standardized formula ensures consistent and interpretable compression metrics" .

oc:kn_5dffe962 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, when measuring video duration" ;
    oc:directiveContent "Uses ffprobe for accurate duration measurement rather than estimating from frame count or metadata alone" ;
    oc:hasRationale "ffprobe provides frame-accurate duration from the container, avoiding drift from metadata estimation" ;
    oc:severityLevel "MEDIUM" .

oc:kn_d2b54f94 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When generating a compression report" ;
    oc:directiveContent "1. Verify original and compressed video files exist 2. Run ffprobe on both files to get durations 3. Calculate compression_percentage = (removed / original) × 100 4. Load segments JSON if provided 5. Write structured JSON report to output path" ;
    oc:hasRationale "Ensures accurate duration measurement and complete report generation" ;
    oc:stepOrder 1 .

oc:kn_fadc37f3 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before execution" ;
    oc:directiveContent "Both original and compressed video files must exist before running the report generator; segments JSON is optional" ;
    oc:hasRationale "ffprobe requires the video files to be present to measure duration" ;
    oc:severityLevel "HIGH" .

oc:payload_d9a6a859aeafe7c5 a oc:ExecutionPayload ;
    oc:code "python3 /root/.claude/skills/report-generator/scripts/generate_report.py --original {original} --compressed {compressed} --segments {segments} --output {output}" ;
    oc:executor "shell" ;
    oc:timeout 30 .

oc:req_3fcf652e a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "python3" .

oc:req_6e3538b1 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Python 3.11+" .

oc:req_ecf37d43 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "ffprobe (from ffmpeg)" .

_:ref_3a88316aec530b17 a oc:WorkflowStep ;
    dcterms:description "Execute generate_report.py with file paths as arguments" ;
    oc:expectedOutcome "JSON report written to output path" ;
    oc:stepDependsOn _:ref_f01a90f35a146ee0 ;
    oc:stepId "run-generator" .

_:ref_f01a90f35a146ee0 a oc:WorkflowStep ;
    dcterms:description "Verify original video, compressed video, and optionally segments JSON exist" ;
    oc:expectedOutcome "All required files confirmed present" ;
    oc:stepId "verify-files" .

