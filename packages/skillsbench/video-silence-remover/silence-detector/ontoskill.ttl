    dcterms:description "Find where smoothed energy exceeds baseline x multiplier" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_b78b928fcf6f3577 a oc:WorkflowStep ;
    dcterms:description "Calculate baseline from first N seconds (likely silent)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_ec5bc18d3becefaf a oc:WorkflowStep ;
    dcterms:description "Apply smoothing with moving average" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

