    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:FileExists ;
    oc:resolvesIntent "detect initial silence in recordings",
        "find pre-roll silence before content",
        "identify setup and title card periods" ;
    oc:yieldsState oc:SilenceDetected .

oc:kn_2f38bd0c a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "always" ;
    oc:directiveContent "Output format is compatible with segment-combiner skill for merging with other detection results" ;
    oc:hasRationale "Enables pipeline integration where multiple detectors feed into a combiner" .

oc:kn_5ef15d64 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "when tuning detection sensitivity" ;
    oc:directiveContent "Lower threshold_multiplier = more sensitive detection; higher = more conservative. Use initial_window to control baseline calculation duration. Use smoothing_window to control moving average window size." ;
    oc:hasRationale "Parameter tuning allows adapting to different recording characteristics" .

oc:kn_bdfd6c18 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "before execution" ;
    oc:directiveContent "Requires pre-computed energy JSON file from energy-calculator skill as input via --energies parameter" ;
    oc:hasRationale "This skill does not compute energy directly; it depends on energy-calculator output" ;
    oc:severityLevel "CRITICAL" .

oc:kn_cf391b8e a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "when detection fails" ;
    oc:directiveContent "Returns empty segments list if no clear energy transition is found" ;
    oc:hasRationale "Not all recordings have a distinct silence-to-content transition; handle empty results gracefully" ;
    oc:severityLevel "MEDIUM" .

oc:kn_d18d14ff a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "when analyzing recordings" ;
    oc:directiveContent "Works best when the initial period has distinctly lower energy than the content that follows" ;
    oc:hasRationale "The threshold-based detection relies on a clear energy transition between silence and content" ;
    oc:severityLevel "HIGH" .

oc:req_02b3c31e a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "numpy" .

oc:req_3fcf652e a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "python3" .

