    oc:hasRequirement oc:req_02b3c31e,
        oc:req_3fcf652e ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: silence-detector
description: Detect initial silence segments in audio/video using energy-based analysis. Use when you need to find low-energy periods at the start of recordings (title slides, setup time, pre-roll silence).
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Detects initial silence segments by analyzing pre-computed energy data. Finds the transition point from low-energy silence to higher-energy content." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 3 ;
                            oc:tableCaption "## Parameters Tuning" ;
                            oc:tableMarkdown """| Parameter | Lower Value | Higher Value |
|-----------|-------------|--------------|
| threshold_multiplier | More sensitive | More conservative |
| initial_window | Shorter baseline | Longer baseline |
| smoothing_window | Less smoothing | More smoothing |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Parameters Tuning" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_09d958a320b2c658 ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "How It Works" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Output format compatible with segment-combiner" ],
