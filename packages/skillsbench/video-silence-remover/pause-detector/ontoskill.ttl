oc:skill_video_silence_remover_pause_detector a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "pause-detector" ;
    skos:broader "Audio segment detector" ;
    prov:wasDerivedFrom ".agents/skills/skillsbench/video-silence-remover/pause-detector" ;
    oc:contentHash "5f63ecc8ae826e053f228c07618a42007d257146be76638cb6c96ccb86cab423" ;
    oc:dependsOnSkill oc:skill_ontoskills_energy_calculator ;
    oc:differentia "uses local dynamic thresholds on pre-computed energy data to find pause and silence segments without false positives from volume variation" ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput ;
    oc:hasAllowedTool "Bash" ;
    oc:hasArgumentHint "--energies /path/to/energies.json --output /path/to/pauses.json [--start-time SECONDS] [--threshold-ratio RATIO] [--min-duration SECONDS] [--window-size SECONDS]" ;
    oc:hasCategory "automation" ;
    oc:hasDescription "Detect pauses and silence in audio using local dynamic thresholds. Use when you need to find natural pauses in lectures, board-writing silences, or breaks between sections. Uses local context comparison to avoid false positives from volume variation." ;
    oc:hasName "pause-detector" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: pause-detector
description: Detect pauses and silence in audio using local dynamic thresholds. Use when you need to find natural pauses in lectures, board-writing silences, or breaks between sections. Uses local context comparison to avoid false positives from volume variation.
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Detects pauses and low-energy segments using local dynamic thresholds on pre-computed energy data. Unlike global threshold methods, this compares energy to surrounding context, avoiding false positives when speaker volume varies." ] ;
            oc:hasSubsection [ a oc:Section ;
