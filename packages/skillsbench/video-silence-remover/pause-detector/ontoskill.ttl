_:ref_954b91313280af67 a oc:WorkflowStep ;
    dcterms:description "Filter segments by minimum duration" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_cea0f73a921e59b0 a oc:WorkflowStep ;
    dcterms:description "Mark seconds where energy < local_avg × threshold_ratio" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_10b059a90fd88864 a oc:WorkflowStep ;
    dcterms:description "Verify energy JSON file exists from energy-calculator" ;
    oc:expectedOutcome "Energy data file confirmed at specified path" ;
    oc:stepId "verify-energy-input" .

_:ref_29f86c6a6494882b a oc:WorkflowStep ;
    dcterms:description "Run detect_pauses.py with energy input, output path, and optional parameters" ;
    oc:expectedOutcome "JSON output file with detected pause segments" ;
    oc:stepDependsOn _:ref_10b059a90fd88864 ;
    oc:stepId "run-detection" .

