    --energies energies.json \\
    --start-time 221 \\
    --output pauses.json

# Result: Found 11 pauses totaling 28 seconds
""" ;
                            oc:codeLanguage "bash" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 68-76" ] ;
