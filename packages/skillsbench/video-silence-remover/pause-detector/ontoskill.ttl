oc:kn_011b4315 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always when detecting pauses" ;
    oc:directiveContent "Uses local dynamic thresholds (sliding window) rather than global thresholds to adapt to varying speaker volume" ;
    oc:hasRationale "Global thresholds produce false positives when speaker volume varies across the recording" ;
    oc:severityLevel "HIGH" .

oc:kn_1e36cef8 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Always" ;
    oc:directiveContent "1. Load pre-computed energy data 2. Calculate local average using sliding window 3. Mark seconds where energy < local_avg × threshold_ratio 4. Group consecutive low-energy seconds into segments 5. Filter segments by minimum duration" ;
    oc:stepOrder 1 .

oc:kn_3db02925 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before execution" ;
    oc:directiveContent "Python 3.11+, numpy, and scipy must be installed" .

oc:kn_91589954 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When detecting pauses in audio" ;
    oc:directiveContent "python3 /root/.claude/skills/pause-detector/scripts/detect_pauses.py --energies /path/to/energies.json --output /path/to/pauses.json" .

oc:kn_a024ecd1 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When tuning detection sensitivity" ;
    oc:directiveContent "Lower threshold_ratio = more aggressive detection; higher min_duration = only longer pauses; larger window_size = broader context" ;
    oc:hasRationale "Parameters control tradeoff between detecting all pauses vs avoiding false positives" .

oc:kn_b3b1ac16 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before execution" ;
    oc:directiveContent "Requires pre-computed energy data from the energy-calculator skill as input via --energies parameter" ;
    oc:hasRationale "Pause detection operates on per-second RMS energy values, not raw audio files" ;
    oc:severityLevel "CRITICAL" .

_:ref_30272b510f99ffcb a oc:WorkflowStep ;
    dcterms:description "Load pre-computed energy data" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_3ebb44c11d0d1826 a oc:WorkflowStep ;
    dcterms:description "Group consecutive low-energy seconds into segments" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_94cfa0a99f06ce55 a oc:WorkflowStep ;
    dcterms:description "Calculate local average using sliding window" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
