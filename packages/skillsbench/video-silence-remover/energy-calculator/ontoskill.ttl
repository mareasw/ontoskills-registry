oc:kn_7ad7976a a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "Energy calculation output format" ;
    oc:directiveContent """{
  "sample_rate": 16000,
  "window_seconds": 1,
  "total_seconds": 600,
  "energies": [123.5, 456.7, ...],
  "stats": {"min": 45.2, "max": 892.3, "mean": 234.5, "std": 156.7}
}""" ;
    oc:templateVariables "energies",
        "sample_rate",
        "stats",
        "total_seconds",
        "window_seconds" .

oc:kn_809b781b a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When calculating audio energy profile" ;
    oc:directiveContent "1. Load audio WAV file 2. Split into window-sized segments (default 1 second) 3. Calculate RMS energy per window: sqrt(mean(samples^2)) 4. Output JSON with energies array and statistics" ;
    oc:stepOrder 1 .

oc:kn_82da3c0c a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always" ;
    oc:directiveContent "Running energy calculation multiple times on the same input produces identical output files" ;
    oc:hasRationale "RMS calculation is deterministic given the same input audio and window size" .

oc:kn_8da00e94 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before running energy calculation" ;
    oc:directiveContent "Input must be a WAV file; other audio formats must be converted first (e.g., via audio-extractor skill)" ;
    oc:hasRationale "The script reads raw WAV samples; compressed formats require decoding first" ;
    oc:severityLevel "HIGH" .

oc:kn_a6f0f1f4 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before execution" ;
    oc:directiveContent "Python 3.11+ and numpy must be installed" .

oc:kn_b198d26d a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "On execution" ;
    oc:directiveContent "Creates or overwrites the output JSON file at the specified --output path" ;
    oc:hasRationale "Agent should be aware the output file will be created or replaced" .

oc:kn_f1f6dfda a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running energy calculation on a WAV file" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "python3 /root/.claude/skills/energy-calculator/scripts/calc_energy.py --audio {audio_path} --output {output_path} [--window-seconds {window}]" .

oc:kn_f3b04e96 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When interpreting energy values" ;
    oc:directiveContent "RMS energy correlates with perceived loudness: higher values = louder audio, lower values = quieter/silence" ;
    oc:hasRationale "RMS energy is a standard proxy for perceived loudness in audio signal processing" .

oc:payload_d55ee19d70907939 a oc:ExecutionPayload ;
    oc:code "python3 /root/.claude/skills/energy-calculator/scripts/calc_energy.py --audio {audio_path} --output {output_path} [--window-seconds {window}]" ;
    oc:executor "python" ;
    oc:timeout 120 .

oc:req_00703909 a oc:RequirementTool ;
