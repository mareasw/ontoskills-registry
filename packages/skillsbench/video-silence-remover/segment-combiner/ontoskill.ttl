oc:kn_414f1592 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When combining segments from multiple detectors into a unified removal list" ;
    oc:directiveContent "1. Run individual detectors (silence-detector, pause-detector) to produce segment JSON files 2. Run combine_segments.py with all segment files via --segments flag 3. Verify output contains total_segments and total_duration_seconds 4. Pass output file to video-processor --remove-segments" ;
    oc:stepOrder 1 .

oc:kn_6c866641 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always" ;
    oc:directiveContent "Running the combiner multiple times with the same inputs produces identical output" ;
    oc:hasRationale "Deterministic output ensures reproducible video processing pipelines" .

oc:kn_7188346e a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "Output JSON structure for combined segments" ;
    oc:directiveContent "{\"segments\": [{\"start\": {start}, \"end\": {end}, \"duration\": {duration}}], \"total_segments\": {count}, \"total_duration_seconds\": {total}}" ;
    oc:templateVariables "count",
        "duration",
        "end",
        "start",
        "total" .

oc:kn_bb590967 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When preparing input files for combination" ;
    oc:directiveContent "All input files must contain a 'segments' array with objects having 'start', 'end', and 'duration' fields" ;
    oc:hasRationale "Missing or malformed segments arrays will cause the combiner to fail or produce incorrect output" ;
    oc:severityLevel "CRITICAL" .

oc:kn_c31be961 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "After running combine_segments.py" ;
    oc:directiveContent "Output file contains 'segments' array sorted by start time, 'total_segments' count, and 'total_duration_seconds' sum" .

oc:kn_ed954dd0 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before execution" ;
    oc:directiveContent "Python 3.11+ must be available on the system" .

oc:kn_ffbaf200 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When combining segments" ;
    oc:directiveContent "Do not skip the sort-by-start-time step; unsorted segments will cause incorrect video processing" ;
    oc:hasRationale "video-processor expects segments ordered chronologically for correct timeline manipulation" ;
    oc:severityLevel "HIGH" .

oc:payload_c6f215ba6f5ee62f a oc:ExecutionPayload ;
    oc:code "python3 /root/.claude/skills/segment-combiner/scripts/combine_segments.py --segments {input_files} --output {output_file}" ;
    oc:executor "shell" .

oc:req_00703909 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "Python 3.11+" .

