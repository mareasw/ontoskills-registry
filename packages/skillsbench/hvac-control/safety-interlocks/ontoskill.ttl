oc:kn_26efff9c a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When safety limits are exceeded during control computation" ;
    oc:directiveContent "Safety interlocks may override or discard computed control outputs, replacing them with safe values (e.g., min_output or 0.0)." ;
    oc:hasRationale "Agents must understand that the actual output sent to the system may differ from the controller's computed output when safety activates." .

oc:kn_2c8b44ab a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "During open-loop testing when no feedback control is active" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """def run_test_with_safety(system, input_value, duration, dt, max_limit):
    data = []
    current_input = input_value
    for step in range(int(duration / dt)):
        result = system.step(current_input)
        data.append(result)
        if result["output"] >= max_limit:
            current_input = 0.0
    return data""" .

oc:kn_33e16923 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying safety limits to any control output" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """def apply_safety_limits(measurement, command, max_limit, min_limit, max_output, min_output):
    safety_triggered = False
    if measurement >= max_limit:
        command = min_output
        safety_triggered = True
    command = max(min_output, min(max_output, command))
    return command, safety_triggered""" .

oc:kn_7035fe9e a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When wrapping an existing controller with safety interlocks" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """class SafeController:
    def __init__(self, controller, max_limit, min_output=0.0, max_output=100.0):
        self.controller = controller
        self.max_limit = max_limit
        self.min_output = min_output
        self.max_output = max_output
        self.safety_events = []
    def compute(self, measurement, dt):
        if measurement >= self.max_limit:
            self.safety_events.append({"measurement": measurement, "action": "emergency_cutoff"})
            return self.min_output
        output = self.controller.compute(measurement, dt)
        return max(self.min_output, min(self.max_output, output))""" .

oc:kn_88f683f0 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "After running a control operation with safety interlocks" ;
    oc:directiveContent "Successful safety interlock operation is indicated by: no measurements exceeding limits during operation, and a complete safety_log recording all events (even if empty)." ;
    oc:hasRationale "An empty safety event log with correct system behavior confirms interlocks are properly configured and not needed; a non-empty log indicates protective action was taken and should be reviewed." .

oc:kn_8ef29b1e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a safety condition is triggered or sensor reading is questionable" ;
    oc:directiveContent "When in doubt, fail safe by reducing output to the minimum safe value." ;
    oc:hasRationale "Reducing output prevents escalation of unsafe conditions and is the conservative protective action." .

oc:kn_b1aa870c a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "During every control loop iteration" ;
    oc:directiveContent "1. Check safety conditions (measurement >= max_limit) BEFORE applying control output 2. If limit exceeded, override command to emergency cutoff value 3. Clamp output to valid range [min_output, max_output] 4. Log all safety events with timestamps and values 5. Return safe command and safety status" ;
    oc:stepOrder 1 .

oc:kn_e8a3290e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing any control loop" ;
    oc:directiveContent "Never bypass safety code or make it conditionally disabled — safety checks must always execute before control outputs are applied." ;
    oc:hasRationale "Bypassing safety interlocks can lead to equipment damage, runaway outputs, or unsafe operating conditions." ;
    oc:severityLevel "CRITICAL" .

oc:kn_ed30c528 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing safety interlocks for control systems" ;
    oc:directiveContent "Apply defense in depth: use multiple layers of protection including limit checking, output clamping, and emergency cutoffs." ;
    oc:hasRationale "Single-layer protection can fail; redundant safety mechanisms reduce risk of equipment damage." .

oc:kn_f93d673e a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When logging safety events during control operation" ;
    oc:directiveContent """safety_log = {
    "limit": {max_limit},
    "events": [{
        "time": {timestamp},
        "measurement": {value},
        "command_before": {original_command},
        "command_after": {safe_command},
        "event_type": "limit_exceeded"
    }]
}""" ;
    oc:templateVariables "max_limit",
        "original_command",
        "safe_command",
        "timestamp",
        "value" .

oc:kn_fb2d90cc a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before executing any control loop iteration" ;
    oc:directiveContent "Before starting any control operation: verify sensor reading is reasonable (not NaN/infinite, within physical bounds), check initial conditions are at expected starting point, and confirm safety limits (max_limit, output clamping) are configured." ;
    oc:hasRationale "Invalid sensor data or missing safety configuration can cause the interlock to malfunction or pass through dangerous commands." .

