    oc:contentHash "eda4bf70a07c9fbbfb6268b981235db4a0639934e3bab22e255d6653eef6d546" ;
    oc:differentia "uses scipy.optimize.curve_fit for nonlinear least squares fitting of models to experimental data" ;
    oc:handlesFailure oc:ConvergenceFailed,
