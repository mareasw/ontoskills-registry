oc:kn_1f83b64b a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "On curve_fit failure" ;
    oc:directiveContent "RuntimeError ('Optimal parameters not found') indicates bad initial guesses or invalid data (NaN, wrong range). Fix guesses first, then validate data." ;
    oc:hasRationale "This is the most common failure mode and has a clear diagnostic path." ;
    oc:severityLevel "MEDIUM" .

oc:kn_344fcd8c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting initial guesses for first-order step response models" ;
    oc:directiveContent "Estimate K from steady-state: K_guess = (y_final - y_initial) / u. Estimate tau from 63.2% rise time: find t where output reaches 63.2% of total change." ;
    oc:hasRationale "These physics-based estimates place the optimizer close to the true solution, ensuring rapid convergence." ;
    oc:severityLevel "MEDIUM" .

oc:kn_3a537a51 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When fitting a model with initial guesses and bounds" ;
    oc:codeLanguage "python" ;
    oc:directiveContent "popt, pcov = curve_fit(model, t_data, y_data, p0=[K_guess, tau_guess], bounds=([K_min, tau_min], [K_max, tau_max]))" .

oc:kn_5924f9f3 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining the fitting problem" ;
    oc:directiveContent "Always set parameter bounds to prevent physically impossible solutions (e.g., negative time constants, negative gains for positive systems)." ;
    oc:hasRationale "Bounds constrain the search space to physically meaningful parameter values and improve convergence reliability." ;
    oc:severityLevel "HIGH" .

oc:kn_85522208 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When fit quality is poor" ;
    oc:directiveContent "If R-squared is low, check: (1) data is from the correct step response phase, (2) system is actually first-order, (3) noise level is acceptable." ;
    oc:hasRationale "Poor fit quality indicates a model-data mismatch that must be diagnosed before proceeding with controller tuning." ;
    oc:severityLevel "MEDIUM" .

oc:kn_aad6b3a5 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "After any curve fitting operation" ;
    oc:directiveContent "Always report fit quality metrics (R-squared and RMSE) alongside estimated parameters to validate the fit." ;
    oc:hasRationale "Parameters from a poor fit are unreliable and will produce bad controller tuning results." ;
    oc:severityLevel "HIGH" .

oc:kn_c9836e12 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calling curve_fit" ;
    oc:directiveContent "Never run curve_fit without initial guesses (p0) — poor or missing guesses cause convergence failures and wrong solutions." ;
    oc:hasRationale "Without good initial guesses, the optimizer may converge to local minima or fail entirely with RuntimeError." ;
    oc:severityLevel "HIGH" .

oc:kn_df1cf212 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before execution" ;
    oc:directiveContent "scipy and numpy must be installed (pip install scipy numpy). Python 3.7+ required." ;
    oc:severityLevel "CRITICAL" .

