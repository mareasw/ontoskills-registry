oc:kn_027ed625 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When filling out PDF forms" ;
    oc:directiveContent "For form filling, consult forms.md and use pdf-lib (JavaScript) or pypdf rather than the general extraction libraries." ;
    oc:hasRationale "Form filling has specific API requirements different from general PDF manipulation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_03c6d62e a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "When processing scanned/image-based PDFs" ;
    oc:directiveContent "OCR of scanned PDFs requires both pytesseract and pdf2image packages plus a Tesseract OCR installation on the system." ;
    oc:hasRationale "Standard text extraction methods return empty results on scanned PDFs; OCR pipeline is required." ;
    oc:severityLevel "HIGH" .

oc:kn_422894c7 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When extracting tables from PDFs with pdfplumber" ;
    oc:directiveContent "Always check that extracted tables are not empty before processing them with pandas (if table: guard)." ;
    oc:hasRationale "Empty table results will cause DataFrame creation errors and downstream processing failures." ;
    oc:severityLevel "MEDIUM" .

oc:kn_811b5f6e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using pypdf for any modification operation (merge, split, rotate, watermark, encrypt)" ;
    oc:directiveContent "pypdf's PdfWriter must be explicitly written to a file with writer.write(output) — unsaved writer objects are discarded." ;
    oc:hasRationale "All pypdf operations build an in-memory writer that must be flushed to disk." ;
    oc:severityLevel "CRITICAL" .

oc:kn_9e553f04 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When processing any PDF task" ;
    oc:directiveContent "1. Identify task type (extract/create/merge/split/OCR) 2. Select appropriate library from quick reference table 3. For extraction: open PDF → iterate pages → extract text/tables 4. For creation: build story/canvas → add content → save 5. For merge: create writer → add pages from each reader → write output 6. For OCR: convert to images → run pytesseract on each image" ;
    oc:stepOrder 1 .

oc:kn_c959fca6 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When text extraction returns empty strings" ;
    oc:directiveContent "Do not attempt to extract text from scanned/image-based PDFs using pypdf or pdfplumber alone — they will return empty or garbled results." ;
    oc:hasRationale "Scanned PDFs contain images, not text streams; OCR is required." ;
    oc:severityLevel "HIGH" .

oc:kn_e5881598 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When re-running PDF processing scripts" ;
    oc:directiveContent "Read-only operations (text extraction, metadata, table extraction) are safe to repeat. Write operations (merge, split, encrypt) create new files each time — avoid overwriting source files." ;
    oc:hasRationale "Overwriting source PDFs can cause data loss if the operation fails mid-process." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e9e119b9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing which PDF library to use for a task" ;
    oc:directiveContent "Use pdfplumber for text and table extraction (best layout preservation), pypdf for merge/split/rotate/encrypt operations, reportlab for creating new PDFs, and CLI tools (qpdf, pdftotext) for quick command-line tasks." ;
    oc:hasRationale "Each library has different strengths; matching the tool to the task yields better results with less code." ;
    oc:severityLevel "HIGH" .

