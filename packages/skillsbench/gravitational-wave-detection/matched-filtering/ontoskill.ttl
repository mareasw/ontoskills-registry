oc:kn_1866de55 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When frequency-domain waveform generation fails" ;
    oc:directiveContent "If get_fd_waveform raises 'Approximant not available', switch to get_td_waveform with the same approximant or try a different approximant like IMRPhenomD." ;
    oc:hasRationale "Not all waveform models implement frequency-domain generation; time-domain is universally supported." ;
    oc:severityLevel "MEDIUM" .

oc:kn_4c1dcca9 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When interpreting or finding peaks in SNR" ;
    oc:directiveContent "Always use abs() on matched filter SNR output to get the magnitude — matched_filter returns complex-valued SNR." ;
    oc:hasRationale "The complex SNR encodes phase information; for detection only the magnitude matters." ;
    oc:severityLevel "HIGH" .

oc:kn_5b9937a7 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "After running matched_filter" ;
    oc:directiveContent "Never use raw matched_filter output without cropping edge artifacts. Time-domain: crop(8, 4). Frequency-domain: crop(4, 4)." ;
    oc:hasRationale "Filtering corrupts edges of the SNR time series due to PSD estimation and template wrap-around effects." ;
    oc:severityLevel "HIGH" .

oc:kn_6cff4105 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When diagnostic SNR values are poor" ;
    oc:directiveContent "If SNR is unexpectedly low despite correct masses, verify that low_frequency_cutoff matches the high-pass filter used during data conditioning and check PSD estimation." ;
    oc:hasRationale "Mismatched frequency cutoffs between conditioning and filtering suppress signal power in the SNR calculation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_97c81748 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing between time-domain and frequency-domain approaches" ;
    oc:directiveContent "Use frequency-domain waveforms (get_fd_waveform) for computational efficiency when the approximant supports it; fall back to time-domain (get_td_waveform) for unsupported approximants like SEOBNRv4_opt." ;
    oc:hasRationale "Frequency-domain templates avoid FFT overhead and are faster, but not all approximants are available in frequency domain." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9b64bf77 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring matched_filter parameters" ;
    oc:directiveContent "Set low_frequency_cutoff to match the high-pass filter cutoff used during data conditioning (typically 15-20 Hz). Lower values capture more signal but also more noise." ;
    oc:hasRationale "Consistency between conditioning and filtering cutoffs ensures the template only operates in the frequency band where data is reliable." ;
    oc:severityLevel "HIGH" .

oc:kn_b2af4a2b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before generating any template waveform" ;
    oc:directiveContent "Template delta_t (time domain) or delta_f (frequency domain) must exactly match the conditioned data's sampling parameters." ;
    oc:hasRationale "Mismatched sampling leads to incorrect correlation and meaningless SNR values." ;
    oc:severityLevel "CRITICAL" .

oc:kn_bb58fd2e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "After generating template, before matched filtering" ;
    oc:directiveContent "Resize templates to the correct target length: time-domain templates to len(conditioned_data), frequency-domain templates to len(psd)." ;
    oc:hasRationale "Improperly sized templates cause correlation errors and filter failures." ;
    oc:severityLevel "CRITICAL" .

