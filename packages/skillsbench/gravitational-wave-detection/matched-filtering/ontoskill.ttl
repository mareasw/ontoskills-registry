                            oc:contentOrder 7 ;
                            oc:textContent "**Problem**: Edge artifacts in SNR time series" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Problem**: \"Approximant not available\" error" ],
