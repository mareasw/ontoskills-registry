        "Glob",
        "Grep" ;
    oc:hasArgumentHint "project-directory" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Migrate Java EE javax.* imports to Jakarta EE jakarta.* namespace. Use when upgrading to Spring Boot 3.x, migrating javax.persistence, javax.validation, javax.servlet imports, or fixing compilation errors after Jakarta EE transition. Covers package mappings, batch sed commands, and verification steps." ;
    oc:hasName "jakarta-namespace" ;
    oc:hasSection [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """mvn rewrite:run
""" ;
                            oc:codeLanguage "bash" ;
                            oc:contentOrder 4 ;
