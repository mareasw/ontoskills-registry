oc:kn_7537de76 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After completing all sed replacements" ;
    oc:directiveContent "After migration, grep for remaining javax.(persistence|validation|servlet|transaction|annotation) imports — these must return zero results." ;
    oc:hasRationale "Any remaining old-namespace imports will cause compilation failures in Spring Boot 3.x." ;
    oc:severityLevel "HIGH" .

oc:kn_766bdd3d a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When migrating a multi-module project" ;
    oc:directiveContent "All namespaces must be migrated together — mixed javax.* and jakarta.* imports cause runtime errors." ;
    oc:hasRationale "Partial migration creates classpath conflicts where some classes resolve to old javax and others to new jakarta, causing ClassNotFoundException or MethodNotFoundException at runtime." ;
    oc:severityLevel "HIGH" .

oc:kn_7e995b47 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting namespace migration" ;
    oc:directiveContent "Before running sed replacements, grep for all javax.* imports excluding JDK packages to assess migration scope." ;
    oc:hasRationale "Understanding the full scope prevents surprises and ensures no Java EE imports are missed." ;
    oc:severityLevel "HIGH" .

oc:kn_88c7902b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When verifying migration completeness" ;
    oc:directiveContent "Check test files, XML configurations (persistence.xml), and third-party library versions in addition to main source code." ;
    oc:hasRationale "Test classes also import javax.*, XML configs use javax namespaces, and third-party libs must have Jakarta-compatible versions." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a011d541 a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When manual sed-based migration is error-prone or the project is large" ;
    oc:directiveContent "Use OpenRewrite (org.openrewrite.java.migrate.jakarta.JavaxMigrationToJakarta) for automated migration instead of manual sed commands." ;
    oc:hasRationale "OpenRewrite performs AST-aware refactoring, avoiding regex pitfalls and handling edge cases like wildcard imports, XML configs, and deeply nested references." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e6b08536 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When verifying migration completeness for JPA entity classes" ;
    oc:directiveContent "Every JPA entity class MUST use jakarta.persistence imports after migration. If jakarta.persistence grep returns no results but entities exist, the build will fail." ;
    oc:hasRationale "Spring Boot 3.x Hibernate 6 requires jakarta.persistence namespace; javax.persistence imports will not compile." ;
    oc:severityLevel "CRITICAL" .

oc:kn_ee543b08 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing batch sed replacements of javax.* namespaces" ;
    oc:directiveContent "Never change javax.sql.*, javax.crypto.*, or javax.net.* to jakarta.* — these are JDK packages, not Java EE, and must remain unchanged." ;
    oc:hasRationale "Changing JDK-internal packages breaks compilation and runtime since these are not part of the Jakarta EE migration scope." ;
    oc:severityLevel "CRITICAL" .

_:ref_712551dfc441b666 a oc:WorkflowStep ;
    dcterms:description "**Don't change javax.sql or javax.crypto** - These are JDK packages, not Java EE" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_905fbba0ee242842 a oc:WorkflowStep ;
    dcterms:description "**Check test files too** - Test classes also need migration" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_c914a8db2d429098 a oc:WorkflowStep ;
    dcterms:description "**Third-party libraries** - Ensure all dependencies have Jakarta EE compatible versions" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_e1ef37bda0ac1507 a oc:WorkflowStep ;
    dcterms:description "**Mixed namespaces cause runtime errors** - All must be migrated together" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_fc80f1c22adc4a97 a oc:WorkflowStep ;
    dcterms:description "**Update XML configurations** - If using persistence.xml, update namespaces there too" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_20937c63390023ce a oc:WorkflowStep ;
    dcterms:description "Run sed commands to replace specific javax.* imports (persistence, validation, servlet, annotation, transaction) with jakarta.* equivalents" ;
    oc:expectedOutcome "All specific import statements updated" ;
    oc:stepDependsOn _:ref_72bdb89a7c119c19 ;
    oc:stepId "batch-replace-specific" .

_:ref_72bdb89a7c119c19 a oc:WorkflowStep ;
    dcterms:description "Grep all Java files for javax.* imports excluding JDK packages (javax.sql, javax.crypto, javax.net) to understand migration scope" ;
    oc:expectedOutcome "Complete list of files and packages needing migration" ;
    oc:stepId "assess-scope" .

