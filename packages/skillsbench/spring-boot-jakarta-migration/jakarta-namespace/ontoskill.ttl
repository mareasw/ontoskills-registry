import jakarta.servlet.http.HttpServletResponse;
""" ;
                                    oc:codeLanguage "java" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 147-155" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Example Servlet Migration" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Critical: Entity Classes Must Use jakarta.persistence" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
