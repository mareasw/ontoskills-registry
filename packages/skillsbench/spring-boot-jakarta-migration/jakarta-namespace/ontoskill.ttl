    oc:contentHash "f8efbaac74dcac0056cad8ab37f3abb4593b07b1d5711c9dcf70a5679fb21927" ;
    oc:dependsOnSkill oc:skill_ontoskills_spring_boot_migration ;
    oc:differentia "Replaces Java EE javax.* imports with Jakarta EE jakarta.* equivalents in Spring Boot 3.x upgrade path" ;
    oc:handlesFailure oc:InvalidInput,
