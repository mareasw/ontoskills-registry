    .body(payload)
    .retrieve()
    .toBodilessEntity();""" .

oc:kn_29bbb696 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing HTTP client for reactive Spring applications" ;
    oc:directiveContent "For reactive/async applications, use WebClient instead of RestClient. RestClient is for synchronous operations only." ;
    oc:hasRationale "RestClient is synchronous and will block threads in reactive applications; WebClient supports non-blocking async operations." .

oc:kn_2f01015a a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When creating RestClient configuration class" ;
    oc:codeLanguage "java" ;
    oc:directiveContent """@Configuration
public class RestClientConfig {
    @Bean
    public RestClient restClient() {
        return RestClient.builder()
            .baseUrl(${baseUrl})
            .defaultHeader(HttpHeaders.CONTENT_TYPE, MediaType.APPLICATION_JSON_VALUE)
            .build();
    }
}""" ;
    oc:templateVariables "baseUrl" .

oc:kn_64f8512b a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When constructing URLs in RestClient calls" ;
    oc:directiveContent "Use .uri() with URI template variables (e.g., \"/users/{id}\", userId) instead of string concatenation for URL construction." ;
    oc:hasRationale "Template variables handle proper encoding and prevent injection vulnerabilities." .

oc:kn_8cfd3c1d a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When migrating any service class from RestTemplate to RestClient" ;
    oc:directiveContent "1. Replace RestTemplate field with RestClient field. 2. Replace constructor new RestTemplate() with RestClient.create() or inject from @Bean config. 3. Convert template methods (getForEntity, postForEntity, exchange, delete) to fluent chain (.get()/.post()/.delete() → .uri() → .retrieve() → .body()). 4. Replace HttpEntity headers with inline .contentType()/.accept()/.header() calls. 5. Replace ResponseErrorHandler with .onStatus() handlers. 6. Use ParameterizedTypeReference for generic response types." ;
    oc:stepOrder 1 .

oc:kn_a22beb4b a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring RestClient for production use" ;
    oc:directiveContent "Use RestClient.Builder to create configured RestClient beans with shared defaults (baseUrl, default headers), then inject via constructor — avoid RestClient.create() in production services." ;
    oc:hasRationale "Centralized configuration ensures consistent headers, base URLs, and interceptors across all service methods." .

oc:kn_a2ab7453 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before starting migration" ;
    oc:directiveContent "RestClient requires Spring Framework 6.1+ (Spring Boot 3.2+). It cannot be used on Spring Boot 2.x or Spring Framework 5.x." ;
    oc:hasRationale "RestClient was introduced in Spring Framework 6.1; earlier versions do not have this class." ;
    oc:severityLevel "CRITICAL" .

oc:kn_edb322f0 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Standard GET request with error handling pattern" ;
    oc:codeLanguage "java" ;
    oc:directiveContent """restClient.get()
    .uri("/users/{id}", userId)
    .retrieve()
    .onStatus(HttpStatusCode::is4xxClientError, (req, res) -> {
        throw new CustomException("message");
    })
    .body(new ParameterizedTypeReference<Map<String, Object>>() {});""" .

oc:kn_fa688dbc a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deserializing responses with generic types like Map<K,V> or List<T>" ;
    oc:directiveContent "Do not use raw Map.class for generic response types; always use ParameterizedTypeReference<Map<String, Object>>() for type-safe deserialization of generic types." ;
    oc:hasRationale "Type erasure means Map.class loses generic type info at runtime, causing deserialization issues. ParameterizedTypeReference preserves full type information." ;
    oc:severityLevel "HIGH" .

