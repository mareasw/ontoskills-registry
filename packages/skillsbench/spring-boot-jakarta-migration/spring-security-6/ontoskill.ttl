                            oc:textContent "Don't forget the servlet import change:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """// Before
import javax.servlet.http.HttpServletResponse;

// After
import jakarta.servlet.http.HttpServletResponse;
""" ;
                            oc:codeLanguage "java" ;
                            oc:contentOrder 2 ;
