oc:kn_01299648 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When migrating any class that extends WebSecurityConfigurerAdapter" ;
    oc:directiveContent "Never extend WebSecurityConfigurerAdapter in Spring Security 6 — it is fully removed. Use SecurityFilterChain @Bean methods instead." ;
    oc:hasRationale "WebSecurityConfigurerAdapter was deprecated in Spring Security 5.7 and removed in 6.0; continued use causes compilation failure." ;
    oc:severityLevel "CRITICAL" .

oc:kn_32c07445 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When verifying migration completeness" ;
    oc:directiveContent "After migration, grep for deprecated patterns should return zero results: WebSecurityConfigurerAdapter, @EnableGlobalMethodSecurity, .antMatchers(, .authorizeRequests(" ;
    oc:hasRationale "Any remaining deprecated patterns indicate incomplete migration that will cause runtime or compilation errors." ;
    oc:severityLevel "HIGH" .

oc:kn_357c297b a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When refactoring classes that previously relied on @EnableWebSecurity providing @Configuration" ;
    oc:directiveContent "@Configuration must be added explicitly to security config classes in Spring Security 6 — it is no longer inherited from @EnableWebSecurity." ;
    oc:hasRationale "The @Configuration meta-annotation was removed from @EnableWebSecurity, so omitting it means the bean definitions are not recognized." ;
    oc:severityLevel "HIGH" .

oc:kn_3e9a6ce8 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing automated bulk migration of Spring Security API renames" ;
    oc:directiveContent """find . -name "*.java" -type f -exec sed -i 's/@EnableGlobalMethodSecurity/@EnableMethodSecurity/g' {} +
find . -name "*.java" -type f -exec sed -i 's/EnableGlobalMethodSecurity/EnableMethodSecurity/g' {} +
find . -name "*.java" -type f -exec sed -i 's/\\.antMatchers(/.requestMatchers(/g' {} +
find . -name "*.java" -type f -exec sed -i 's/\\.mvcMatchers(/.requestMatchers(/g' {} +
find . -name "*.java" -type f -exec sed -i 's/\\.authorizeRequests(/.authorizeHttpRequests(/g' {} +""" .

oc:kn_484a2220 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When exposing AuthenticationManager as a bean" ;
    oc:codeLanguage "java" ;
    oc:directiveContent """@Bean
public AuthenticationManager authenticationManager(
        AuthenticationConfiguration authConfig) throws Exception {
    return authConfig.getAuthenticationManager();
}""" ;
    oc:hasRationale "Replaces the deprecated authenticationManagerBean() override from WebSecurityConfigurerAdapter." .

oc:kn_597f2c6c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring authentication manager" ;
    oc:directiveContent "Use AuthenticationConfiguration.getAuthenticationManager() to obtain the AuthenticationManager instead of overriding authenticationManagerBean()." ;
    oc:hasRationale "The adapter pattern for exposing AuthenticationManager is gone; injection via AuthenticationConfiguration is the canonical approach." ;
    oc:severityLevel "MEDIUM" .

oc:kn_97c6f773 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When migrating method-level security annotations" ;
    oc:directiveContent "@EnableGlobalMethodSecurity is removed and MUST be replaced with @EnableMethodSecurity — the application will not compile otherwise." ;
    oc:hasRationale "The annotation class was physically removed from the Spring Security 6 API; this is a non-optional breaking change." ;
    oc:severityLevel "CRITICAL" .

oc:kn_afc72c24 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When migrating URL authorization rules" ;
    oc:directiveContent "Replace .antMatchers(), .mvcMatchers(), and .regexMatchers() with .requestMatchers() and .authorizeRequests() with .authorizeHttpRequests()." ;
    oc:hasRationale "The AntPathRequestMatcher-based methods were consolidated into a single requestMatchers() API for consistency." ;
    oc:severityLevel "HIGH" .

oc:kn_c58b79c1 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating the canonical Spring Security 6 SecurityFilterChain bean" ;
    oc:codeLanguage "java" ;
    oc:directiveContent """@Bean
public SecurityFilterChain securityFilterChain(HttpSecurity http) throws Exception {
    http
        .csrf(csrf -> csrf.disable())
        .sessionManagement(session ->
            session.sessionCreationPolicy(SessionCreationPolicy.STATELESS))
        .authorizeHttpRequests(auth -> auth
            .requestMatchers("/api/public/**").permitAll()
            .anyRequest().authenticated()
        );
    return http.build();
}""" ;
    oc:hasRationale "This is the fundamental replacement pattern for all WebSecurityConfigurerAdapter.configure(HttpSecurity) overrides." .

oc:kn_cf3320b0 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When verifying no deprecated Spring Security 5 patterns remain after migration" ;
    oc:directiveContent """grep -r "WebSecurityConfigurerAdapter" --include="*.java" .
grep -r "@EnableGlobalMethodSecurity" --include="*.java" .
grep -r "\\.antMatchers(" --include="*.java" .
grep -r "\\.authorizeRequests(" --include="*.java" .""" .

oc:kn_dbcc46a1 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When performing a complete Spring Security 5→6 migration" ;
    oc:directiveContent "1. Remove WebSecurityConfigurerAdapter extension — refactor class to use @Bean methods. 2. Replace @EnableGlobalMethodSecurity with @EnableMethodSecurity (update import). 3. Replace .antMatchers()/.mvcMatchers()/.regexMatchers() with .requestMatchers(). 4. Replace .authorizeRequests() with .authorizeHttpRequests(). 5. Convert chained HttpSecurity config to lambda DSL. 6. Move AuthenticationManager to @Bean using AuthenticationConfiguration. 7. Run verification grep commands to confirm no deprecated patterns remain." ;
    oc:hasRationale "This order minimizes compilation errors — structural changes first, then API renames, then verification." ;
    oc:stepOrder 1 .

oc:kn_e3bd4e2d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing HttpSecurity configuration" ;
    oc:directiveContent "Lambda DSL is mandatory in Spring Security 6. The chained method style (http.csrf().disable().and()...) is deprecated and removed." ;
    oc:hasRationale "The non-lambda configuration methods were removed to improve type safety and IDE support." ;
    oc:severityLevel "HIGH" .

oc:kn_eb515254 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring custom UserDetailsService" ;
    oc:directiveContent "Spring Security 6 auto-detects UserDetailsService beans — no explicit AuthenticationManagerBuilder wiring is needed." ;
    oc:hasRationale "Removing boilerplate reduces configuration errors and aligns with Spring Boot auto-configuration conventions." ;
    oc:severityLevel "LOW" .

