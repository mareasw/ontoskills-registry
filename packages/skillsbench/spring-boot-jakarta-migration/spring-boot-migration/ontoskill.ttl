oc:kn_012f3755 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before changing Spring Boot parent version to 3.x" ;
    oc:directiveContent "Spring Boot 3.x requires Java 17 minimum (Java 21 recommended). Projects on Java 8 or 11 MUST upgrade the java.version property first." ;
    oc:hasRationale "Spring Boot 3.x uses Jakarta EE 9+ and Spring Framework 6, both of which require Java 17+ bytecode and APIs." ;
    oc:severityLevel "CRITICAL" .

oc:kn_03fd1280 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When XML binding is needed in Spring Boot 3" ;
    oc:codeLanguage "xml" ;
    oc:directiveContent """<dependency>
    <groupId>jakarta.xml.bind</groupId>
    <artifactId>jakarta.xml.bind-api</artifactId>
</dependency>
<dependency>
    <groupId>org.glassfish.jaxb</groupId>
    <artifactId>jaxb-runtime</artifactId>
</dependency>""" .

oc:kn_07b48740 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning a Spring Boot 2→3 migration" ;
    oc:directiveContent "Follow the recommended migration order: (1) upgrade to Spring Boot 2.7.x, (2) update Java to 17/21, (3) remove incompatible deps, (4) update parent to 3.2.x, (5) fix javax→jakarta, (6) update Spring Security, (7) update HTTP clients, (8) run tests." ;
    oc:hasRationale "Incremental migration reduces the blast radius of errors at each step, making issues easier to diagnose and fix." ;
    oc:severityLevel "HIGH" .

oc:kn_082c3562 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "After updating Spring Boot parent POM version" ;
    oc:directiveContent "After changing Spring Boot version to 3.x, expect many compilation errors from javax.* imports. These are expected and must be resolved by migrating to jakarta.* namespace (see jakarta-namespace skill)." ;
    oc:hasRationale "This is the most visible and voluminous class of errors in a Spring Boot 3 migration, but is mechanical and straightforward to fix." ;
    oc:severityLevel "MEDIUM" .

oc:kn_0e47df72 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "Running OpenRewrite automated migration" ;
    oc:directiveContent "mvn rewrite:run" .

oc:kn_11988aff a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "Verifying migration success" ;
    oc:directiveContent "mvn clean compile && mvn test" .

oc:kn_14666ec6 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "On compilation failure after Spring Boot 3 upgrade" ;
    oc:directiveContent "If compilation fails after migration, check for: (1) remaining javax.* imports, (2) old JAXB dependencies not removed, (3) Spring Security 5 patterns, (4) Hibernate 5 specific code." ;
    oc:hasRationale "These are the four most common categories of compilation errors and each maps to a specific sub-skill for resolution." .

oc:kn_1fdff2a3 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning Spring Boot 3 migration" ;
    oc:directiveContent "Before starting migration, verify the project is on Spring Boot 2.7.x (latest 2.x line). If on an earlier 2.x, upgrade to 2.7.x first and resolve any deprecation warnings." ;
    oc:hasRationale "Spring Boot 2.7 added many deprecation warnings that directly map to required changes in 3.x, making it a natural stepping stone." ;
    oc:severityLevel "HIGH" .

oc:kn_39b1bdda a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Java 17 or 21 JDK must be installed and set as the active Java version" .

oc:kn_39f63b52 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Full Spring Boot 2 to 3 migration" ;
    oc:directiveContent "1. Upgrade to Spring Boot 2.7.x if not already → 2. Set java.version to 17 or 21 → 3. Remove javax.xml.bind:jaxb-api and related deps → 4. Replace old jjwt with modular version → 5. Update spring-boot-starter-parent to 3.2.x → 6. Fix javax.* to jakarta.* imports → 7. Update Spring Security config → 8. Replace RestTemplate with RestClient → 9. Run mvn clean compile && mvn test" ;
    oc:stepOrder 1 .

oc:kn_60ba2262 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After completing all migration steps" ;
    oc:directiveContent "After migration, run: grep for old JAXB dependencies, verify Spring Boot version is 3.2.x, check java.version is 17/21, run mvn clean compile and mvn test." ;
    oc:hasRationale "Comprehensive verification catches lingering incompatible dependencies and confirms the application compiles and tests pass on the new stack." .

oc:kn_6c7192db a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Configuring OpenRewrite for automated Spring Boot 3 migration" ;
    oc:codeLanguage "xml" ;
    oc:directiveContent """<plugin>
    <groupId>org.openrewrite.maven</groupId>
    <artifactId>rewrite-maven-plugin</artifactId>
    <version>5.42.0</version>
    <configuration>
        <activeRecipes>
            <recipe>org.openrewrite.java.spring.boot3.UpgradeSpringBoot_3_2</recipe>
        </activeRecipes>
    </configuration>
</plugin>""" .

oc:kn_9e1e7882 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Maven 3.6+ must be installed (required by Spring Boot 3.x)" .

oc:kn_a20d373d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When migrating projects with many files or modules" ;
    oc:directiveContent "For large codebases, use OpenRewrite with the UpgradeSpringBoot_3_2 recipe to automate namespace migration, version bumps, and deprecated pattern fixes." ;
    oc:hasRationale "Automated migration reduces manual error and accelerates the process for large projects. OpenRewrite handles javax→jakarta, Spring Security patterns, and property name changes." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d05e741b a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When using OpenRewrite for automated migration" ;
    oc:directiveContent "1. Add rewrite-maven-plugin with UpgradeSpringBoot_3_2 recipe to pom.xml → 2. Run mvn rewrite:run → 3. Review changes → 4. Run mvn clean compile && mvn test" ;
    oc:stepOrder 2 .

oc:kn_d5df26b3 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Setting Spring Boot 3 parent POM and Java version" ;
    oc:codeLanguage "xml" ;
    oc:directiveContent """<parent>
    <groupId>org.springframework.boot</groupId>
    <artifactId>spring-boot-starter-parent</artifactId>
    <version>3.2.0</version>
</parent>
<properties>
    <java.version>21</java.version>
</properties>""" .

oc:kn_e2d63644 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the project uses JWT tokens" ;
    oc:directiveContent "The old monolithic jjwt 0.9.1 dependency must be replaced with the modular jjwt-api/jjwt-impl/jjwt-jackson 0.12.x trio." ;
    oc:hasRationale "The old jjwt library is incompatible with Jakarta EE and Spring Boot 3's dependency tree." ;
    oc:severityLevel "HIGH" .

oc:kn_e5a86852 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "Checking for old incompatible JAXB dependencies" ;
    oc:directiveContent "grep -E \"javax\\.xml\\.bind|jaxb-api\" pom.xml" .

oc:kn_f2fb373c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When migrating pom.xml to Spring Boot 3.x" ;
    oc:directiveContent "Never leave javax.xml.bind:jaxb-api or related JAXB dependencies in pom.xml when migrating to Spring Boot 3. They conflict with jakarta.xml.bind and cause ClassNotFoundException at runtime." ;
    oc:hasRationale "javax.xml.bind uses the old Java EE namespace which conflicts with Jakarta EE's jakarta.xml.bind, causing both build failures and runtime errors when both are on the classpath." ;
    oc:severityLevel "CRITICAL" .

_:ref_0e036f33543885bd a oc:WorkflowStep ;
    dcterms:description "**Third**: Remove incompatible dependencies (JAXB, old JWT)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_185556d5465d633c a oc:WorkflowStep ;
    dcterms:description "**Fifth**: Fix namespace imports (javax → jakarta)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_1da973329ab440d5 a oc:WorkflowStep ;
    dcterms:description "**First**: Upgrade to Spring Boot 2.7.x (latest 2.x) if not already" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_24831f0e7d6bb9b6 a oc:WorkflowStep ;
    dcterms:description "**Build Failures**: Having both `javax.xml.bind` and `jakarta.xml.bind` on the classpath causes ClassNotFoundException and other runtime errors" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_31e1ab2a7ca56b8f a oc:WorkflowStep ;
    dcterms:description "**Namespace Conflict**: `javax.xml.bind` uses the old Java EE namespace, which conflicts with Jakarta EE's `jakarta.xml.bind`" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_39fc84932c0fce86 a oc:WorkflowStep ;
    dcterms:description "**Seventh**: Update HTTP clients (RestTemplate → RestClient)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_7" ;
    oc:stepOrder 7 .

_:ref_3a2ed12d946a6c2e a oc:WorkflowStep ;
    dcterms:description "**Sixth**: Update Spring Security configuration" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_6" ;
    oc:stepOrder 6 .

_:ref_5156cc1cb99ee579 a oc:WorkflowStep ;
    dcterms:description "**Second**: Update Java version to 17 or 21" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_7ec31c6747b5c688 a oc:WorkflowStep ;
    dcterms:description "**Finally**: Run full test suite" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_8" ;
    oc:stepOrder 8 .

_:ref_8f07e083c0417cad a oc:WorkflowStep ;
    dcterms:description "**Fourth**: Update Spring Boot parent to 3.2.x" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_aec949f6a41dcc11 a oc:WorkflowStep ;
    dcterms:description "**Spring Boot 3 Includes Jakarta XML Bind**: If you need XML binding, Spring Boot 3 transitively includes the Jakarta versions" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

