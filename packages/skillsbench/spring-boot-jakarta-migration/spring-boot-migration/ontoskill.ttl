    oc:hasDescription "Migrate Spring Boot 2.x applications to Spring Boot 3.x. Use when updating pom.xml versions, removing deprecated JAXB dependencies, upgrading Java to 17/21, or using OpenRewrite for automated migration. Covers dependency updates, version changes, and migration checklist." ;
    oc:hasName "spring-boot-migration" ;
    oc:hasSection [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """# Update Spring Boot parent version
sed -i 's/<version>2\\.7\\.[0-9]*<\\/version>/<version>3.2.0<\\/version>/g' pom.xml

# Update Java version
sed -i 's/<java.version>1\\.8<\\/java.version>/<java.version>21<\\/java.version>/g' pom.xml
sed -i 's/<java.version>8<\\/java.version>/<java.version>21<\\/java.version>/g' pom.xml
sed -i 's/<java.version>11<\\/java.version>/<java.version>21<\\/java.version>/g' pom.xml

# Remove old JAXB dependency (multi-line removal is complex - manual removal recommended)
""" ;
                                    oc:codeLanguage "bash" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 186-196" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Update pom.xml with sed" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """# Check for old JAXB dependencies
grep -n "jaxb-api\\|javax\\.xml\\.bind" pom.xml

# These must be manually removed from pom.xml:
# - javax.xml.bind:jaxb-api
# - com.sun.xml.bind:jaxb-impl
# - com.sun.xml.bind:jaxb-core
""" ;
                                    oc:codeLanguage "bash" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 200-208" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Remove Deprecated Dependencies" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Migration Commands" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """<!-- Before -->
<dependency>
    <groupId>io.jsonwebtoken</groupId>
    <artifactId>jjwt</artifactId>
    <version>0.9.1</version>
</dependency>

<!-- After -->
<dependency>
    <groupId>io.jsonwebtoken</groupId>
    <artifactId>jjwt-api</artifactId>
    <version>0.12.3</version>
</dependency>
<dependency>
    <groupId>io.jsonwebtoken</groupId>
    <artifactId>jjwt-impl</artifactId>
    <version>0.12.3</version>
    <scope>runtime</scope>
</dependency>
<dependency>
    <groupId>io.jsonwebtoken</groupId>
    <artifactId>jjwt-jackson</artifactId>
    <version>0.12.3</version>
    <scope>runtime</scope>
</dependency>
""" ;
                                    oc:codeLanguage "xml" ;
