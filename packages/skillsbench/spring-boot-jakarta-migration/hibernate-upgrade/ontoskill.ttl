oc:kn_0da1ef20 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining or migrating entity mappings" ;
    oc:directiveContent "Be explicit about fetch strategies (FetchType.LAZY), entity aliases in JPQL, enum mappings (EnumType.STRING), and date/time types (java.time over java.util.Date)." ;
    oc:hasRationale "Hibernate 6 is stricter about entity mappings and implicit behavior; explicitness reduces ambiguity and migration issues." ;
    oc:severityLevel "MEDIUM" .

oc:kn_2cde41ff a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When migrating any Criteria-based queries from Hibernate 5" ;
    oc:directiveContent "Do not use the deprecated org.hibernate.Criteria API — it is completely removed in Hibernate 6. Use JPA Criteria API (CriteriaBuilder/CriteriaQuery) instead." ;
    oc:hasRationale "The legacy Criteria API was deprecated in Hibernate 5 and fully removed in Hibernate 6 with no backwards compatibility." ;
    oc:severityLevel "CRITICAL" .

oc:kn_5c0f3954 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When migrating HQL/JPQL update queries from Hibernate 5" ;
    oc:directiveContent "Never use 'update from' syntax in HQL/JPQL queries with Hibernate 6 — remove the optional 'from' keyword from update statements." ;
    oc:hasRationale "Hibernate 6 has stricter query parsing and the 'update from' pattern is non-standard and will cause syntax errors." ;
    oc:severityLevel "CRITICAL" .

oc:kn_6bc805bf a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting Hibernate 5 to 6 migration" ;
    oc:directiveContent "Before migrating, scan codebase for: session.createCriteria, @TypeDef, @Type(type=), 'update from' in queries, and javax.persistence imports." ;
    oc:hasRationale "Identifying all affected patterns upfront prevents runtime failures after migration." ;
    oc:severityLevel "HIGH" .

oc:kn_7b7afc88 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When migrating custom type mappings (e.g., JSON columns) from Hibernate 5" ;
    oc:directiveContent "Do not use @TypeDef or @Type(type=...) annotations — replace with @JdbcTypeCode(SqlTypes.JSON) or custom type definitions." ;
    oc:hasRationale "@TypeDef and the old @Type annotation were removed in Hibernate 6, replaced by the new @JdbcTypeCode mechanism." ;
    oc:severityLevel "HIGH" .

oc:kn_96f541cf a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After completing Hibernate 6 migration" ;
    oc:directiveContent "After migration, enable hibernate.generate_statistics=true and log SQL queries to validate query plans and detect N+1 regressions." ;
    oc:hasRationale "Silent performance regressions are the most common post-migration issue and require active monitoring to detect." ;
    oc:severityLevel "HIGH" .

oc:kn_cb878c59 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing JPA configuration properties" ;
    oc:directiveContent "Remove explicit dialect configuration (spring.jpa.database-platform) unless you need specific database behavior — Hibernate 6 auto-detects dialects from JDBC URLs." ;
    oc:hasRationale "Hardcoded dialect configuration can cause issues when switching environments and is often unnecessary with Hibernate 6." ;
    oc:severityLevel "LOW" .

oc:kn_ddb6de10 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "After completing Hibernate 6 migration during testing phase" ;
    oc:directiveContent "Hibernate 6 may generate different SQL for lazy-loaded collections, potentially causing N+1 query behavior changes. Enable statistics and monitor query counts after migration." ;
    oc:hasRationale "Changes in Hibernate 6's SQL generation can silently introduce performance regressions in production." ;
    oc:severityLevel "HIGH" .

oc:kn_f6711212 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When migrating JPQL queries with join fetch that use 'select distinct'" ;
    oc:directiveContent "The 'distinct' keyword is no longer needed for collection join-fetch queries in Hibernate 6 — duplicates are automatically filtered." ;
    oc:hasRationale "Hibernate 6 changed its duplicate handling semantics; using distinct unnecessarily may cause unexpected query behavior." ;
    oc:severityLevel "MEDIUM" .

