                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """# Common properties that remain the same
spring.jpa.hibernate.ddl-auto=create-drop
spring.jpa.show-sql=true

# Properties that may need review
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.properties.hibernate.use_sql_comments=true

# New in Hibernate 6
spring.jpa.properties.hibernate.timezone.default_storage=NORMALIZE
""" ;
                            oc:codeLanguage "properties" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 149-160" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Some Hibernate properties changed:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Configuration Properties" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """# Remove "from" keyword in update queries
find . -name "*.java" -type f -exec sed -i 's/update from /update /g' {} +
""" ;
                                    oc:codeLanguage "bash" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 247-250" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Fix Common Issues" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """# Check for old Criteria API usage
grep -r "session.createCriteria\\|org.hibernate.Criteria" --include="*.java" .

# Check for deprecated @Type usage
grep -r "@Type(type\\s*=" --include="*.java" .

# Check for @TypeDef
grep -r "@TypeDef" --include="*.java" .

# Check for "update from" pattern in queries
grep -r "update from" --include="*.java" .
""" ;
                                    oc:codeLanguage "bash" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 231-243" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Check for Hibernate 5 Patterns" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 8 ;
                    oc:sectionTitle "Migration Commands" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasSubsection [ a oc:Section ;
                                    oc:hasContent [ a oc:CodeExample ;
                                            oc:blockType "code_block" ;
                                            oc:codeContent """// Before (Hibernate 5)
@Query(value = "SELECT * FROM users WHERE active = 1", nativeQuery = true)
List<User> findActiveUsersNative();

// After (Hibernate 6) - works the same, but be careful with projections
@Query(value = "SELECT * FROM users WHERE active = true", nativeQuery = true)
List<User> findActiveUsersNative();
""" ;
                                            oc:codeLanguage "java" ;
                                            oc:contentOrder 2 ;
                                            oc:sourceLocation "lines 86-94" ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "Native query result mapping changed:" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 2 ;
                                    oc:sectionTitle "Native Queries" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "Some JPQL syntax has stricter validation:" ],
                                        [ a oc:CodeExample ;
                                            oc:blockType "code_block" ;
                                            oc:codeContent """// Be explicit about entity aliases
@Query("SELECT u FROM User u WHERE u.active = true")
List<User> findActiveUsers();

// Avoid implicit joins - be explicit
@Query("SELECT u FROM User u JOIN u.roles r WHERE r.name = :roleName")
List<User> findByRoleName(@Param("roleName") String roleName);
""" ;
                                            oc:codeLanguage "java" ;
                                            oc:contentOrder 2 ;
                                            oc:sourceLocation "lines 72-80" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 1 ;
                                    oc:sectionTitle "JPQL Changes" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "4. Query Changes" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """# Before (often required in Hibernate 5)
spring.jpa.database-platform=org.hibernate.dialect.H2Dialect

# After (Hibernate 6) - often can be removed
# Hibernate auto-detects based on JDBC URL
# Only specify if you need specific behavior
""" ;
                                    oc:codeLanguage "properties" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 49-56" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "If you must specify:" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Hibernate 6 can auto-detect dialects in most cases:" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """# Hibernate 6 dialects (some renamed)
spring.jpa.database-platform=org.hibernate.dialect.H2Dialect
spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.database-platform=org.hibernate.dialect.MySQLDialect
""" ;
                                    oc:codeLanguage "properties" ;
                                    oc:contentOrder 4 ;
                                    oc:sourceLocation "lines 59-64" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "3. Dialect Configuration" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Hibernate 6 uses Jakarta Persistence:" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """// Before (Hibernate 5)
import javax.persistence.*;
import org.hibernate.annotations.*;

// After (Hibernate 6)
import jakarta.persistence.*;
import org.hibernate.annotations.*;
""" ;
                                    oc:codeLanguage "java" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 18-26" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "1. Package Namespace" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """@ManyToOne(fetch = FetchType.LAZY)
@JoinColumn(name = "department_id")
private Department department;

@OneToMany(mappedBy = "user", fetch = FetchType.LAZY)
private List<Order> orders;
""" ;
                                    oc:codeLanguage "java" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 115-122" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Default fetch behavior remains similar, but be explicit:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 6 ;
                            oc:sectionTitle "6. Fetch Strategies" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """// Enum mapping - explicit is better
@Enumerated(EnumType.STRING)
@Column(nullable = false)
private Role role;

// Date/Time - use java.time classes
@Column(name = "created_at")
private LocalDateTime createdAt;  // Preferred over java.util.Date
""" ;
                                    oc:codeLanguage "java" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 100-109" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Some type mappings changed:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
                            oc:sectionTitle "5. Type Mappings" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """// Recommended approach for cross-database compatibility
@Id
@GeneratedValue(strategy = GenerationType.IDENTITY)
private Long id;

// Or using sequences (preferred for some databases)
@Id
@GeneratedValue(strategy = GenerationType.SEQUENCE, generator = "user_seq")
@SequenceGenerator(name = "user_seq", sequenceName = "user_sequence", allocationSize = 1)
private Long id;
""" ;
                                    oc:codeLanguage "java" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 32-43" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Hibernate 6 changed the default ID generation strategy:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "2. ID Generation Strategies" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Key Changes" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Spring Boot 3 uses Hibernate 6, which includes significant changes from Hibernate 5. This skill covers the key migration considerations." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Overview" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """// Add this to application.properties to monitor queries
spring.jpa.properties.hibernate.generate_statistics=true
logging.level.org.hibernate.stat=debug
logging.level.org.hibernate.SQL=debug
""" ;
                                    oc:codeLanguage "java" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 220-225" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Hibernate 6 may generate different SQL for lazy-loaded collections. Monitor your queries:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "4. N+1 Query Behavior Changes" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """// BEFORE (Hibernate 5) - needed distinct to avoid duplicates
@Query("select distinct u from User u join fetch u.roles")

// AFTER (Hibernate 6) - duplicates are automatically filtered
@Query("select u from User u join fetch u.roles")
""" ;
                                    oc:codeLanguage "java" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 190-196" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "2. Distinct is No Longer Needed for Collections" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """// BEFORE (Hibernate 5) - this worked but was non-standard
@Query("update from User u set u.active = false where u.id = :id")

// AFTER (Hibernate 6) - remove the optional "from" keyword
@Query("update User u set u.active = false where u.id = :id")
""" ;
                                    oc:codeLanguage "java" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 180-186" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "1. HQL/JPQL Query Parsing is Stricter" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "The deprecated `org.hibernate.Criteria` API is completely removed. You must use JPA Criteria API:" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """// BEFORE (Hibernate 5 - old Criteria)
Criteria criteria = session.createCriteria(User.class);
criteria.add(Restrictions.eq("active", true));
List<User> users = criteria.list();

// AFTER (Hibernate 6 - JPA Criteria)
CriteriaBuilder cb = entityManager.getCriteriaBuilder();
CriteriaQuery<User> cq = cb.createQuery(User.class);
Root<User> root = cq.from(User.class);
cq.where(cb.equal(root.get("active"), true));
List<User> users = entityManager.createQuery(cq).getResultList();
""" ;
                                    oc:codeLanguage "java" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 202-214" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "3. Legacy Criteria API Removed" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 7 ;
                    oc:sectionTitle "Critical Breaking Changes" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """// Before (Hibernate 5 with custom type)
@TypeDef(name = "json", typeClass = JsonType.class)
@Type(type = "json")
private JsonNode metadata;

// After (Hibernate 6)
@JdbcTypeCode(SqlTypes.JSON)
private JsonNode metadata;
""" ;
                                    oc:codeLanguage "java" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 134-143" ] ;
