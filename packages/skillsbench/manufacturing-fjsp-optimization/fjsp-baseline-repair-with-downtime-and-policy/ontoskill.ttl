oc:kn_21f23f92 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, after placing each operation" ;
    oc:directiveContent "After selecting a start time for an operation, immediately record it on the machine timeline in the same precedence-aware order, so the result matches the evaluator's step-by-step simulation." ;
    oc:hasRationale "Lazy or batched recording can cause conflicts between operations that the sequential placement would avoid, leading to infeasible results." ;
    oc:severityLevel "HIGH" .

oc:kn_305d0dcb a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting machines for operations with tight policy budgets" ;
    oc:directiveContent "Do not naively always keep the baseline machine if it causes large start-time shifts. A large shift on one operation can cascade and blow up the total L1 shift budget." ;
    oc:hasRationale "Keeping the baseline machine is preferred, but if the shift exceeds a threshold (e.g., 6 time units), considering alternate machines can reduce total shift enough to stay within budget." ;
    oc:severityLevel "HIGH" .

oc:kn_4991b2e2 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When the baseline schedule assigns an illegal machine to an operation" ;
    oc:directiveContent "If the baseline machine is not in the allowed set for an operation, replace it with the machine having the minimum processing time as a legal default." ;
    oc:hasRationale "An invalid baseline machine must be replaced to produce any feasible schedule; minimum duration is a good heuristic to minimize makespan impact." ;
    oc:severityLevel "HIGH" .

oc:kn_5e8a2a48 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When finding earliest_feasible_time for any operation" ;
    oc:directiveContent "Scan integer time forward by +1 from anchor to find earliest feasible time. Never jump to 'next gap' without checking every integer, as it may break minimality." ;
    oc:hasRationale "Skipping integer time points can miss the true earliest feasible slot, violating the optimality guarantee." ;
    oc:severityLevel "CRITICAL" .

oc:kn_7b927ee0 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing among candidate machine/time placements for an operation" ;
    oc:directiveContent "Use a lexicographic score (machine_change, start_shift, start_time, machine) to rank candidate placements. Pick the smallest score while respecting the remaining machine-change budget." ;
    oc:hasRationale "Lexicographic ordering prioritizes minimizing machine changes first, then start-time shifts, then makespan, which aligns with the policy budget priorities." ;
    oc:severityLevel "MEDIUM" .

oc:kn_8d87857b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When placing any operation during repair" ;
    oc:directiveContent "Never start any operation earlier than its baseline start time. Anchor(j,o) = max(start_base(j,o), end_new(j,o-1)), and the new start must be >= anchor." ;
    oc:hasRationale "This ensures monotonicity relative to baseline and maintains the policy constraint on L1 start-time shift." ;
    oc:severityLevel "CRITICAL" .

oc:kn_d0e37c4f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When iterating over operations for repair" ;
    oc:directiveContent "Operations must be processed in precedence-aware order: sorted by (operation_index, baseline_start_time, baseline_list_position). This ensures end(j,o) <= start(j,o+1) for all jobs." ;
    oc:hasRationale "Processing out of order would mean later operations are placed before earlier ones, making it impossible to correctly compute the anchor from the previous operation's new end time." ;
    oc:severityLevel "CRITICAL" .

_:ref_2d32b68e4d59b585 a oc:WorkflowStep ;
    dcterms:description "List only machines allowed for this operation with their processing times. If baseline machine is illegal, replace with min-duration legal machine." ;
    oc:expectedOutcome "Candidate machine set with durations." ;
    oc:stepDependsOn _:ref_cabf90582840b363 ;
    oc:stepId "list-machines" .

_:ref_361252b03c325ac4 a oc:WorkflowStep ;
    dcterms:description "Sort all operations into precedence-aware order: by (op_index, baseline_start, baseline_position)." ;
    oc:expectedOutcome "Ordered list of (job, op) keys ready for sequential placement." ;
    oc:stepId "sort-ops" .

_:ref_41c8df178366f8ac a oc:WorkflowStep ;
    dcterms:description "For each candidate machine, scan forward from anchor by +1 to find the earliest time with no overlap against machine intervals and downtime windows." ;
    oc:expectedOutcome "Earliest feasible (start_time, machine) pair per candidate." ;
    oc:stepDependsOn _:ref_2d32b68e4d59b585 ;
    oc:stepId "find-feasible-times" .

_:ref_860002dd263e7fd8 a oc:WorkflowStep ;
    dcterms:description "Score each candidate with lexicographic (machine_change, start_shift, start_time, machine). If baseline machine shift >= THRESH and machine-change budget remains, also consider alternate machines. Pick best." ;
    oc:expectedOutcome "Selected (start_time, machine) for current operation within policy budgets." ;
    oc:stepDependsOn _:ref_41c8df178366f8ac ;
    oc:stepId "score-and-select" .

_:ref_cabf90582840b363 a oc:WorkflowStep ;
    dcterms:description "For each operation, compute anchor = max(start_base(j,o), end_new(j,o-1))." ;
    oc:expectedOutcome "Anchor time below which placement is forbidden." ;
    oc:stepDependsOn _:ref_361252b03c325ac4 ;
    oc:stepId "compute-anchor" .

