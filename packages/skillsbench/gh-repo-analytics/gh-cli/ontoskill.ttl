oc:kn_1228efd8 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "when operating on a repo different from the current directory" ;
    oc:directiveContent "Use -R, --repo [HOST/]OWNER/REPO flag to target a repository other than the current working directory's repo" ;
    oc:hasRationale "Without -R flag, gh operates on the repo detected from the current directory's git remote" ;
    oc:severityLevel "MEDIUM" .

oc:kn_1e9e63cc a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "when querying PRs with structured output" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "gh pr list --search \"state:open author:@me\" --json number,title,updatedAt" ;
    oc:hasRationale "Combining --search with --json enables precise, machine-readable filtering of GitHub resources" .

oc:kn_4ceafd40 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "when listing issues or PRs with filters" ;
    oc:directiveContent "Use --search flag with GitHub search syntax (qualifiers like author:@me, created:>=YYYY-MM-DD, label:\"bug fix\") to filter issues and PRs efficiently" ;
    oc:hasRationale "Server-side filtering via --search is faster and more accurate than post-processing client-side results" .

oc:kn_666156a7 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "before execution" ;
    oc:directiveContent "gh CLI must be installed and authenticated via 'gh auth login' before any commands can be used" ;
    oc:hasRationale "Unauthenticated or missing gh CLI will fail on all GitHub operations" .

oc:kn_922db0ec a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "when performing any gh operation" ;
    oc:directiveContent "1. Identify target resource (PR, issue, repo) by number, URL, or branch name 2. Use appropriate gh subcommand 3. Add --json for machine-readable output 4. Use -R for cross-repo operations" ;
    oc:stepOrder 1 .

oc:kn_c5baf096 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "when specifying GitHub resources as arguments" ;
    oc:directiveContent "PRs can be referenced by number (123), URL (https://github.com/OWNER/REPO/pull/123), or head branch name (patch-1); issues by number or URL; repos as OWNER/REPO or URL" ;
    oc:hasRationale "Flexible argument formats reduce friction when working across different contexts (terminal, browser, documentation)" .

oc:kn_eaa00ed4 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "when scripting or automating gh commands" ;
    oc:directiveContent "Do not parse human-readable gh output; always use --json flag and --jq for scripting" ;
    oc:hasRationale "Human-readable output format may change between versions; JSON output is stable and parseable" ;
    oc:severityLevel "HIGH" .

oc:kn_f8da1280 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "when checking out a pull request branch locally" ;
    oc:directiveContent "gh pr checkout PR_NUMBER" ;
    oc:hasRationale "Shortcut for fetching and switching to a PR's head branch" .

