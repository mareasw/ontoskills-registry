                                    oc:textContent "Prefix qualifier with `-` to exclude:" ],
                                [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 2 ;
                                    oc:rowCount 2 ;
                                    oc:tableCaption "Prefix qualifier with `-` to exclude" ;
                                    oc:tableMarkdown """| Query | Example |
|-------|---------|
| `-QUALIFIER` | `stars:>10 -language:javascript` — exclude JavaScript repos |
| `NOT` | `hello NOT world` — has "hello" but not "world" |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "Exclude Results" ],
                        [ a oc:Section ;
