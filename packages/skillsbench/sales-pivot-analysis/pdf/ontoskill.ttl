oc:kn_214297ba a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When extraction returns empty or garbled results" ;
    oc:directiveContent "Scanned/image-based PDFs cannot be processed with pdfplumber alone — use OCR (pytesseract) instead. Merged cells may extract incorrectly." ;
    oc:hasRationale "pdfplumber works on vector/text PDFs only; image-based PDFs require OCR preprocessing." ;
    oc:severityLevel "MEDIUM" .

oc:kn_98a61888 a oc:KnowledgeNode,
