    oc:appliesToContext "Always — pdfplumber.open reads files without writing" ;
    oc:directiveContent "PDF processing with pdfplumber is read-only — no modifications are made to the source PDF file." ;
    oc:hasRationale "Safe for sensitive documents; original files are never altered." ;
    oc:severityLevel "LOW" .

