oc:kn_0fce5765 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building multi-sheet workbooks with pivot tables" ;
    oc:directiveContent "Each pivot table should have its own dedicated sheet. Name sheets clearly (e.g., 'SourceData', 'RevenueByCategory')." ;
    oc:hasRationale "Separation prevents data conflicts and improves workbook organization" ;
    oc:severityLevel "MEDIUM" .

oc:kn_18ea8bd0 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing which library to use for a spreadsheet task" ;
    oc:directiveContent "Use pandas for data manipulation and analysis; use openpyxl for Excel-specific features like formatting, formulas, and pivot tables." ;
    oc:hasRationale "Each library has different strengths — pandas excels at data operations, openpyxl at Excel format features" ;
    oc:severityLevel "MEDIUM" .

oc:kn_3c3ee0a3 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When verifying pivot table output programmatically" ;
    oc:directiveContent "Pivot table values are NOT calculated when the file is created. Values populate only when the file is opened in Excel or LibreOffice." ;
    oc:hasRationale "Pivot tables are defined structurally in XML; the application computes aggregated values at open time" ;
    oc:severityLevel "HIGH" .

oc:kn_7857194c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining CacheDefinition for pivot tables" ;
    oc:directiveContent "The order of cacheFields must exactly match the order of columns in your source data. Field indices (0, 1, 2...) correspond positionally to source columns." ;
    oc:hasRationale "Mismatched field indices cause incorrect data mapping or runtime errors" ;
    oc:severityLevel "HIGH" .

oc:kn_8810a552 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When defining CacheField sharedItems" ;
    oc:directiveContent "For categorical cache fields, set the count parameter to approximate number of unique values. For numeric fields, omit count." ;
    oc:hasRationale "Incorrect count values may cause Excel to display warnings or truncate data" ;
    oc:severityLevel "LOW" .

oc:kn_93bc977c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any pivot table with openpyxl" ;
    oc:directiveContent "ALL pivot tables MUST use cacheId=0. Using any other cacheId (1, 2, etc.) will cause openpyxl to fail with KeyError when reading the file back." ;
    oc:hasRationale "This is a known openpyxl limitation where non-zero cacheId values break file readability" ;
    oc:severityLevel "CRITICAL" .

oc:kn_fb388740 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When modifying existing Excel files" ;
    oc:directiveContent "Reading xlsx files is idempotent. Writing/saving overwrites the target file completely — always save to a new file or accept data loss on overwrite." ;
    oc:hasRationale "openpyxl save() is a full file write, not an incremental update" ;
    oc:severityLevel "MEDIUM" .

