oc:kn_07948e60 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When querying PubChem for any compound" ;
    oc:directiveContent "Never assume a compound lookup will always return results. Always wrap get_compounds() calls in try/except handling NotFoundError, BadRequestError, TimeoutError, and IndexError." ;
    oc:hasRationale "Network failures, typos in names, and invalid SMILES will crash unhandled code" ;
    oc:severityLevel "HIGH" .

oc:kn_0efc544f a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When querying PubChem for compound data" ;
    oc:directiveContent "1. Import pubchempy as pcp 2. Query compound using get_compounds(identifier, namespace) 3. Handle NotFoundError/BadRequestError/TimeoutError 4. Access compound properties via attributes (molecular_weight, xlogp, tpsa, etc.) 5. For similarity/substructure: use searchtype parameter with Threshold and MaxRecords" ;
    oc:stepOrder 1 .

oc:kn_20aeff71 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When retrieving specific properties for a compound" ;
    oc:codeLanguage "python" ;
