oc:kn_d2ce0656 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing structural searches or accessing compound properties" ;
    oc:directiveContent "Always specify MaxRecords parameter for similarity/substructure searches to avoid timeouts. Not all properties are available for all compounds — check for None before using." ;
    oc:hasRationale "Unbounded searches can hang indefinitely and accessing missing properties causes AttributeError" .

oc:kn_e1689498 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When making any PubChem API request" ;
    oc:directiveContent "PubChem API rate limits: max 5 requests/second, max 400 requests/minute, max 300 seconds running time per minute. Add 0.2-0.3 second delays between requests." ;
    oc:hasRationale "Exceeding rate limits results in blocked requests and potential IP bans from NCBI" ;
    oc:severityLevel "HIGH" .

