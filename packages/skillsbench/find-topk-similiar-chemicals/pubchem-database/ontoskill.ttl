oc:kn_2f607ac0 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When performing similarity or substructure searches" ;
    oc:directiveContent "Similarity and substructure searches are asynchronous operations that may take 15-30 seconds to complete. PubChemPy handles the polling pattern automatically but agents should account for this latency." ;
    oc:hasRationale "Large structural searches require server-side processing; timing out without accounting for this gives false negatives" .

oc:kn_4f6a5af3 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before using this skill" ;
    oc:directiveContent "Network access to https://pubchem.ncbi.nlm.nih.gov required. PubChemPy must be installed (uv pip install pubchempy). Requests library needed for direct API calls." .

oc:kn_6877347f a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "On query failures or empty results" ;
    oc:directiveContent "When compound not found: try alternative names/synonyms, use CID if known, check spelling. When timeout: reduce MaxRecords, add delays, use CIDs. When empty properties: check if property exists with `if compound.xlogp:` before accessing." ;
    oc:hasRationale "PubChem has multiple naming conventions and not all properties exist for all compounds" .

oc:kn_72cc20c2 a oc:CodePattern,
