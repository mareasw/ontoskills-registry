oc:kn_7ed9f72e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When optimizing query performance" ;
    oc:directiveContent "Use CIDs for repeated queries as they are more efficient than names or structures. Cache results locally for frequently accessed data. Batch requests when processing multiple compounds." ;
    oc:hasRationale "CID lookups are O(1) on PubChem's index while name/structure lookups require additional resolution" .

oc:kn_b763aa21 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When installing required dependencies" ;
    oc:directiveContent "uv pip install pubchempy requests" .

