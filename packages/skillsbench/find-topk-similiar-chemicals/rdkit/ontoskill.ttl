oc:kn_02b08050 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When parsing any molecular structure (SMILES, SDF, InChI, MOL blocks)" ;
    oc:directiveContent "Never use a parsed molecule without checking for None first. All MolFrom* functions return None on failure." ;
    oc:hasRationale "Silent None propagation causes AttributeError crashes in downstream code" ;
    oc:severityLevel "CRITICAL" .

oc:kn_07e17729 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calculating hydrogen-dependent molecular descriptors" ;
    oc:directiveContent "Use AddHs() before calculating properties that depend on hydrogen atoms (e.g., TPSA, HBD/HBA). Use RemoveHs() for storage and depiction." ;
    oc:hasRationale "RDKit represents molecules without explicit hydrogens by default, which can lead to incorrect descriptor values" ;
    oc:severityLevel "HIGH" .

oc:kn_08150ae9 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing large molecular datasets (>10K compounds)" ;
    oc:directiveContent "Use ForwardSDMolSupplier for large SDF files to stream one molecule at a time instead of loading all into memory. Use pickle for fast re-loading of processed molecule lists." ;
    oc:hasRationale "SDMolSupplier loads the entire file into memory; ForwardSDMolSupplier streams molecules sequentially with constant memory" ;
    oc:severityLevel "MEDIUM" .

oc:kn_9ad4f34d a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When visualizing molecules or performing 3D analysis" ;
    oc:directiveContent "Generate appropriate coordinates before analysis: Compute2DCoords for depiction/visualization, EmbedMolecule for 3D analysis. Add explicit hydrogens for 3D embedding." ;
    oc:hasRationale "Missing coordinates produce empty or incorrect visualizations; 3D embedding requires explicit hydrogens for accuracy" ;
    oc:severityLevel "HIGH" .

oc:kn_a89cdb3f a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When molecules fail to parse or sanitize" ;
    oc:directiveContent "Use Chem.DetectChemistryProblems(mol) to identify specific sanitization issues, then use partial sanitization via sanitizeOps parameter to skip problematic steps." ;
    oc:hasRationale "Allows recovery from non-critical chemistry issues without discarding the entire molecule" ;
    oc:severityLevel "MEDIUM" .

oc:kn_ac0d9edf a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When parsing fails or produces unexpected results" ;
    oc:directiveContent "Molecules are automatically sanitized on import (13-step validation). Use sanitize=False and DetectChemistryProblems() to debug parsing failures before manual sanitization." ;
    oc:hasRationale "Valence violations, aromatic ring errors, and kekulization failures can be diagnosed before sanitization" ;
    oc:severityLevel "MEDIUM" .

oc:kn_c00a5930 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing molecules in parallel or multithreaded environments" ;
    oc:directiveContent "MolSupplier objects are NOT thread-safe when accessed concurrently. Use separate supplier instances per thread or use MultithreadedSDMolSupplier." ;
    oc:hasRationale "Concurrent access to a shared supplier produces corrupted or duplicated molecules" ;
    oc:severityLevel "HIGH" .

oc:kn_fb79382f a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When computing similarity for large molecule sets" ;
    oc:directiveContent "Use BulkTanimotoSimilarity() instead of looping individual TanimotoSimilarity() calls. Use pickle serialization instead of re-parsing SMILES/SDF for repeated access." ;
    oc:hasRationale "Bulk operations are vectorized and significantly faster than individual calls in Python loops" ;
    oc:severityLevel "MEDIUM" .

