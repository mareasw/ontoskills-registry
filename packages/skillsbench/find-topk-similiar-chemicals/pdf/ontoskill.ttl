oc:kn_22cbc723 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting tables from PDFs" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """import pdfplumber
with pdfplumber.open('document.pdf') as pdf:
    for page in pdf.pages:
        tables = page.extract_tables()
        for table in tables:
            # process rows""" .

oc:kn_26444dae a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When merging multiple PDFs into one" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from pypdf import PdfReader, PdfWriter
writer = PdfWriter()
for pdf_file in file_list:
    reader = PdfReader(pdf_file)
    for page in reader.pages:
        writer.add_page(page)
with open(output_path, 'wb') as f:
    writer.write(f)""" .

oc:kn_35787b01 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When performing any PDF operation" ;
    oc:directiveContent "1. Identify the task (extract, create, merge, split, OCR, encrypt) 2. Select the appropriate library from the Quick Reference table 3. Use the corresponding code pattern or CLI command 4. For advanced features consult reference.md or forms.md" ;
    oc:stepOrder 1 .

oc:kn_46f41dcf a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing which library to use for a PDF task" ;
    oc:directiveContent "Use pdfplumber for text/table extraction (better layout preservation) and pypdf for structural operations (merge, split, rotate, encrypt). Use reportlab for PDF creation." ;
    oc:hasRationale "Each library has different strengths: pdfplumber excels at content extraction with layout awareness, pypdf handles page-level manipulation, and reportlab provides full document generation capabilities." ;
    oc:severityLevel "HIGH" .

oc:kn_97161e8c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When text extraction returns empty or garbled results from a scanned document" ;
    oc:directiveContent "Scanned PDFs contain images, not text — OCR (pytesseract + pdf2image) is required, not standard text extraction." ;
    oc:hasRationale "Scanned PDFs store content as raster images; standard text extraction libraries read embedded text streams which don't exist in scans." ;
    oc:severityLevel "CRITICAL" .

oc:kn_9fb7bbc2 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting text via CLI preserving layout" ;
    oc:directiveContent "pdftotext -layout input.pdf output.txt" .

oc:kn_b6ec4784 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When standard text extraction fails on a PDF" ;
    oc:directiveContent "If text extraction returns empty results, the PDF may be scanned. Fall back to OCR: convert pages to images with pdf2image, then use pytesseract.image_to_string()." ;
    oc:hasRationale "Scanned PDFs don't contain selectable text — they're raster images that require OCR to extract content." ;
    oc:severityLevel "HIGH" .

oc:kn_c65348ac a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before using this skill" ;
    oc:directiveContent "Python 3.8+ with pypdf, pdfplumber, and reportlab installed. Optional: poppler-utils (pdftotext, pdfimages), qpdf, pytesseract, pdf2image, pandas." .

oc:kn_ca0e85bf a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When performing write operations on PDFs" ;
    oc:directiveContent "Writing merged/split/encrypted PDFs creates new files on disk. Always specify explicit output paths to avoid overwriting originals." ;
    oc:hasRationale "PDF manipulation creates new file artifacts; without explicit output paths, source files could be overwritten." ;
    oc:severityLevel "MEDIUM" .

oc:kn_dd2b89b5 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting text or data from PDFs with tables or complex formatting" ;
    oc:directiveContent "Do not use pypdf's extract_text() for complex layouts or table extraction — use pdfplumber instead." ;
    oc:hasRationale "pypdf's text extraction is basic and loses layout information; pdfplumber preserves spatial relationships needed for table extraction." ;
    oc:severityLevel "HIGH" .

oc:kn_f9bc4beb a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When reporting PDF metadata" ;
    oc:directiveContent """## PDF Metadata
- **Title**: {meta.title}
- **Author**: {meta.author}
- **Pages**: {len(reader.pages)}
- **Subject**: {meta.subject}
- **Creator**: {meta.creator}""" ;
    oc:templateVariables "len(reader.pages)",
        "meta.author",
        "meta.creator",
        "meta.subject",
        "meta.title" .

oc:kn_fb3517af a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When merging PDFs via CLI" ;
    oc:directiveContent "qpdf --empty --pages file1.pdf file2.pdf -- merged.pdf" .

