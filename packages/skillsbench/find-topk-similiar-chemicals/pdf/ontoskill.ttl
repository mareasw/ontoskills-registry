        "decrypt pdf",
        "encrypt pdf with password",
        "extract images from pdf",
        "extract pdf metadata",
        "extract tables from pdf",
        "extract text from pdf",
        "fill pdf forms",
        "merge pdf files",
        "ocr scanned pdf",
        "rotate pdf pages",
