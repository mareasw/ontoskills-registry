oc:kn_03d7dc74 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When replacing any placeholder in a Word document" ;
    oc:directiveContent "Never search for placeholders at the run level — Word splits placeholder text across multiple XML runs due to spell-check, formatting changes, or internal XML structure. Always operate at the paragraph level using paragraph.text." ;
    oc:hasRationale "Run-level matching silently fails when a placeholder like {{CANDIDATE_NAME}} is split into runs such as '{{CANDI' and 'DATE_NAME}}', producing unreplaced placeholders in the output." ;
    oc:severityLevel "CRITICAL" .

oc:kn_12e8623e a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When handling conditional sections in templates" ;
    oc:directiveContent "After processing conditional sections ({{IF_...}}...{{END_IF_...}}), always strip the markers themselves regardless of whether the section was kept or removed. If removed, set the entire paragraph text to empty." ;
    oc:hasRationale "Leaving conditional markers behind corrupts the document output and confuses downstream processing." ;
    oc:severityLevel "MEDIUM" .

oc:kn_4cf3267e a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When deciding whether to re-process a document" ;
    oc:directiveContent "Placeholder replacement is non-idempotent in the sense that repeated runs on an already-replaced document will not find placeholders to replace, effectively making it safe to re-run. However, the operation is NOT reversible — original placeholders are lost after save." ;
    oc:hasRationale "Understanding idempotency helps prevent double-replacement bugs and informs whether to keep template copies." ;
    oc:severityLevel "LOW" .

oc:kn_72abf962 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When replacing placeholders that span multiple runs" ;
    oc:directiveContent "When rebuilding a paragraph after replacement, put the full new text into the first run and clear all subsequent runs' text. This preserves the first run's formatting while ensuring correct text content." ;
    oc:hasRationale "Clearing all runs and setting text on the first run avoids duplicating text and preserves formatting from the dominant run." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ae230759 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing table content in a Word document" ;
    oc:directiveContent "Tables can be nested — a cell may contain sub-tables via cell.tables. Must recurse into nested tables to ensure all placeholders are replaced." ;
    oc:hasRationale "Missing nested tables leaves placeholders unreplaced in deeply nested structures." ;
    oc:severityLevel "HIGH" .

oc:kn_be3721e0 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing all document content for placeholder replacement" ;
    oc:directiveContent "Headers and footers are NOT included in doc.paragraphs — they must be accessed separately through doc.sections iterating over section.header.paragraphs and section.footer.paragraphs." ;
    oc:hasRationale "Forgetting headers/footers is a common pitfall that leaves placeholders unreplaced in those sections." ;
    oc:severityLevel "HIGH" .

