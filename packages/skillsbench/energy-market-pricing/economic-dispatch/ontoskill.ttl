        oc:kn_e7bae4a5 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:NetworkDataLoaded,
        oc:ToolInstalled ;
    oc:resolvesIntent "calculate operating margins",
        "co-optimize energy and reserves",
        "compute optimal generator setpoints",
        "minimize generation costs",
        "solve economic dispatch for power systems" ;
    oc:yieldsState oc:EconomicDispatchSolved,
        oc:GeneratorSetpointsComputed .

oc:kn_04a652d5 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting a solver for economic dispatch or DC-OPF" ;
    oc:directiveContent "Use CLARABEL solver for quadratic costs with network constraints; OSQP may fail on ill-conditioned DC-OPF problems." ;
    oc:hasRationale "CLARABEL is a robust interior-point solver that handles ill-conditioned quadratic programs better than OSQP." ;
    oc:severityLevel "HIGH" .

oc:kn_2ce3cd45 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When indexing into bus or generator arrays from MATPOWER data" ;
    oc:directiveContent "Never assume bus numbers are contiguous 1..N. Always build a bus_num_to_idx mapping to handle non-contiguous bus numbering." ;
    oc:hasRationale "Real power systems often have non-contiguous bus numbering; direct index access will produce wrong results." ;
    oc:severityLevel "HIGH" .

oc:kn_4aac6327 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "Always" ;
    oc:directiveContent "This skill is purely computational — it solves an optimization problem and returns results. It does not modify any external system state." ;
    oc:hasRationale "No side effects means safe to re-run and experiment with different parameters." .

oc:kn_4d09e39f a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When considering re-execution of dispatch" ;
    oc:directiveContent "Economic dispatch is deterministic for given input data and solver settings; re-running with identical inputs yields identical dispatch." ;
    oc:hasRationale "CVXPY with CLARABEL produces deterministic solutions given deterministic inputs, making re-runs safe." ;
    oc:severityLevel "LOW" .

oc:kn_bb351299 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before solving economic dispatch" ;
    oc:directiveContent "Verify that gencost MODEL type is 2 (polynomial) for all generators; verify NCOST is consistent with available coefficient columns; verify baseMVA is defined." ;
    oc:hasRationale "Non-polynomial cost models or missing coefficients will cause incorrect cost calculations or solver errors." ;
    oc:severityLevel "HIGH" .

oc:kn_c13b0bc7 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building the cost objective function for economic dispatch" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """Pg = cp.Variable(n_gen)
cost = 0
for i in range(n_gen):
    ncost = int(gencost[i, 3])
    Pg_MW = Pg[i] * baseMVA
    if ncost >= 3:
        c2, c1, c0 = gencost[i, 4], gencost[i, 5], gencost[i, 6]
        cost += c2 * cp.square(Pg_MW) + c1 * Pg_MW + c0
    elif ncost == 2:
        c1, c0 = gencost[i, 4], gencost[i, 5]
        cost += c1 * Pg_MW + c0""" .

oc:kn_d329b4c1 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When formatting economic dispatch results" ;
    oc:directiveContent """Generator dispatch per unit: {"id": gen_id, "bus": bus_num, "output_MW": Pg, "reserve_MW": Rg, "pmax_MW": PMax}
Totals: {"cost_dollars_per_hour": total_cost, "load_MW": total_load, "generation_MW": total_gen, "reserve_MW": total_reserve}""" ;
    oc:templateVariables "PMax",
        "Pg",
        "Rg",
        "bus_num",
        "gen_id",
        "total_cost",
        "total_gen",
        "total_load",
        "total_reserve" .

oc:kn_d4f34381 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When co-optimizing reserves alongside energy dispatch" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """Rg = cp.Variable(n_gen)
constraints.append(Rg >= 0)
for i in range(n_gen):
    constraints.append(Rg[i] <= reserve_capacity[i])
    constraints.append(Pg[i] * baseMVA + Rg[i] <= gens[i, 8])
constraints.append(cp.sum(Rg) >= reserve_requirement)""" .

oc:kn_d81c6ebf a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When solving economic dispatch" ;
    oc:directiveContent "Economic dispatch formulation: 1) Parse generator data (PMAX, PMIN, bus mapping) 2) Parse gencost coefficients (handle variable NCOST) 3) Define decision variables Pg (and Rg if reserves needed) 4) Build cost objective from polynomial coefficients 5) Add generator limit constraints (MW to per-unit) 6) Add power balance constraint 7) Add reserve constraints if co-optimizing 8) Solve with CLARABEL 9) Extract dispatch results in MW" ;
    oc:hasRationale "Ensures all formulation steps are followed in correct order with proper unit handling." ;
    oc:stepOrder 1 .

oc:kn_e7bae4a5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formulating the economic dispatch optimization" ;
    oc:directiveContent "Generator output must satisfy PMIN ≤ Pg ≤ PMAX for every generator, and total generation must equal total load (power balance)." ;
    oc:hasRationale "Violating generator limits causes physical damage; violating power balance makes the solution physically infeasible." ;
    oc:severityLevel "CRITICAL" .

