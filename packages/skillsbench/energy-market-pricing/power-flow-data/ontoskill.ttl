oc:kn_18c6ee12 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When loading network data files" ;
    oc:directiveContent "Never read network JSON files line-by-line with sed, head, or similar tools. Network files can be 100K+ lines for realistic grids." ;
    oc:hasRationale "Line-by-line reading wastes time and LLM context on very large files" ;
    oc:severityLevel "CRITICAL" .

oc:kn_253cc241 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When indexing into bus, generator, or branch arrays" ;
    oc:directiveContent "Power system bus numbers may not be contiguous. Always create a mapping from bus numbers to 0-indexed positions using: bus_num_to_idx = {int(buses[i, 0]): i for i in range(n_bus)}" ;
    oc:hasRationale "Non-contiguous bus numbering causes index errors if used directly as array indices" ;
    oc:severityLevel "CRITICAL" .

oc:kn_2e3eea56 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When loading network data for economic dispatch or OPF problems" ;
    oc:directiveContent "Network files may include optional reserve_capacity (array, MW per generator) and reserve_requirement (float, MW total system reserves) fields." ;
    oc:hasRationale "Reserve data is required for reserve-constrained optimization problems but may be absent in basic test cases" ;
    oc:severityLevel "MEDIUM" .

oc:kn_3b1052ed a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When loading any network data file" ;
    oc:directiveContent "1. Use Python json.load() to parse the entire file. 2. Print summary (bus count, gen count, branch count, total load). 3. Convert arrays to numpy arrays. 4. Build bus number-to-index mapping." ;
    oc:hasRationale "Structured loading prevents errors and provides immediate validation of data integrity" ;
    oc:severityLevel "HIGH" ;
    oc:stepOrder 1 .

oc:kn_3de5bb3a a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When interpreting power, voltage, or impedance values from network data" ;
    oc:directiveContent "All electrical quantities in network data use the per-unit system normalized to baseMVA (typically 100 MVA). Convert with P_pu = P_MW / baseMVA." ;
    oc:hasRationale "Per-unit normalization is required for power flow calculations and avoids magnitude scaling issues" ;
    oc:severityLevel "HIGH" .

oc:req_0066e159 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "Python json module" .

oc:req_02b3c31e a oc:RequirementTool ;
    oc:isOptional false ;
