oc:kn_056efbe3 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building a basic dialogue graph with branching" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """graph = Graph()
graph.add_node(Node(id="Start", speaker="Guard", text="Halt!", type="line"))
graph.add_node(Node(id="Choices", type="choice"))
graph.add_edge(Edge(source="Start", target="Choices"))
graph.add_edge(Edge(source="Choices", target="End", text="1. Run away"))
errors = graph.validate()""" .

oc:kn_27dff27d a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When serializing or deserializing dialogue graphs" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """data = graph.to_dict()   # {"nodes": [...], "edges": [...]}
json_str = graph.to_json()
graph2 = Graph.from_dict(data)
graph3 = Graph.from_json(json_str)
graph4 = Graph.from_file('dialogue.json')""" .

oc:kn_42c56377 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "After constructing or modifying a dialogue graph" ;
    oc:directiveContent "Always call graph.validate() after building a graph to catch integrity errors like edges pointing to missing nodes." ;
    oc:hasRationale "Validation returns a list of error strings describing structural problems like dangling edge references." .

oc:kn_56900c15 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building any dialogue graph" ;
    oc:directiveContent "Dialogue graphs are composed of Nodes (content) and Edges (transitions). Nodes have types: 'line' for dialogue and 'choice' for branching points." ;
    oc:hasRationale "Separating content nodes from transition edges enables clean validation and serialization of branching structures." .

oc:kn_a81ac8b2 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before using any dialogue graph functionality" ;
    oc:directiveContent "Requires the dialogue_graph module to be importable: `from dialogue_graph import Graph, Node, Edge`" .

oc:kn_b758522c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using graph.visualize()" ;
    oc:directiveContent "Graphviz binary must be installed system-wide (not just the pip package) for visualization to work." ;
    oc:hasRationale "The Python graphviz package is only a wrapper; the actual rendering engine must be installed separately." ;
    oc:severityLevel "HIGH" .

oc:kn_c02b5f7e a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When exporting a dialogue graph to JSON or dict format" ;
    oc:directiveContent "{\"nodes\": [{\"id\": \"...\", \"speaker\": \"...\", \"text\": \"...\", \"type\": \"line|choice\"}], \"edges\": [{\"source\": \"...\", \"target\": \"...\", \"text\": \"...\"}]}" ;
    oc:templateVariables "edges",
        "id",
        "nodes",
        "source",
        "speaker",
        "target",
        "text",
        "type" .

oc:kn_cb23459b a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When needing to edit or inspect an existing dialogue graph" ;
    oc:directiveContent "Use Graph.from_file(), Graph.from_dict(), or Graph.from_json() to reconstruct a graph from previously serialized data." ;
    oc:hasRationale "Round-trip serialization preserves graph structure for editing and re-export." .

oc:kn_f4b78c62 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When building a dialogue graph from scratch" ;
    oc:directiveContent "1. Create Graph instance → 2. Add Nodes (line/choice types) → 3. Add Edges (with optional text for choices) → 4. Validate with graph.validate() → 5. Export via to_dict()/to_json() or visualize()" ;
    oc:stepOrder 1 .

oc:req_1cce9dfa a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "Python 3.10+" .

oc:req_3d15a7eb a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "graphviz (binary + pip package)" .

oc:req_72c92b35 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "dialogue_graph Python module" .

_:ref_10182ae97d1e0e43 a oc:WorkflowStep ;
    dcterms:description "Add/remove nodes and edges as needed" ;
    oc:expectedOutcome "Graph updated with new content" ;
    oc:stepDependsOn _:ref_968c3c03bc053bd5 ;
    oc:stepId "modify-graph" .

_:ref_1ce7dda16b265c67 a oc:WorkflowStep ;
    dcterms:description "Add Edge objects connecting source nodes to target nodes, with optional text for choice transitions" ;
    oc:expectedOutcome "All transitions and branching paths defined" ;
    oc:stepDependsOn _:ref_ddc6db19fc7f0f21 ;
    oc:stepId "add-edges" .

_:ref_968c3c03bc053bd5 a oc:WorkflowStep ;
    dcterms:description "Load graph using Graph.from_file(), from_dict(), or from_json()" ;
    oc:expectedOutcome "Graph object populated with existing nodes and edges" ;
    oc:stepId "load-graph" .

_:ref_a9e80cb92043f287 a oc:WorkflowStep ;
    dcterms:description "Instantiate an empty Graph object" ;
    oc:expectedOutcome "Empty graph container ready for nodes" ;
    oc:stepId "create-graph" .

_:ref_b4b39f14b5b2aa6e a oc:WorkflowStep ;
    dcterms:description "Call graph.validate() and check the returned error list" ;
    oc:expectedOutcome "Empty error list confirming graph integrity" ;
    oc:stepDependsOn _:ref_1ce7dda16b265c67 ;
    oc:stepId "validate" .

_:ref_ddc6db19fc7f0f21 a oc:WorkflowStep ;
    dcterms:description "Add Node objects with id, speaker, text, and type ('line' or 'choice')" ;
    oc:expectedOutcome "All content and choice nodes registered in the graph" ;
    oc:stepDependsOn _:ref_a9e80cb92043f287 ;
    oc:stepId "add-nodes" .

