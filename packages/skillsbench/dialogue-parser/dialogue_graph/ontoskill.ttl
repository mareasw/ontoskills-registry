    prov:wasDerivedFrom ".agents/skills/skillsbench/dialogue-parser/dialogue_graph" ;
    oc:contentHash "79a709efdc62bf2e1c33f0419953c42b09eb1e764f7b633d9282d901ff28fb49" ;
    oc:differentia "that builds, validates, visualizes, and serializes dialogue graphs for branching narrative structures" ;
