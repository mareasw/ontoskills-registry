        oc:InvalidInput ;
    oc:hasArgumentHint "dialogue definition (nodes and edges) or JSON file path" ;
    oc:hasCategory "development" ;
    oc:hasDescription "A library for building, validating, visualizing, and serializing dialogue graphs. Use this when parsing scripts or creating branching narrative structures." ;
