                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 27-29" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "1. The `Graph` Class" ],
