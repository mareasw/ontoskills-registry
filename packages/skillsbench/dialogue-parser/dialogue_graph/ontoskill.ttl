        oc:ToolInstalled ;
    oc:resolvesIntent "build dialogue graphs",
        "create branching narrative structures",
        "parse scripts into dialogue structures",
        "serialize dialogue graphs to JSON",
        "validate dialogue trees",
        "visualize dialogue flows" ;
