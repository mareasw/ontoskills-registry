oc:kn_133aa661 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running factor analysis" ;
    oc:directiveContent "Use varimax rotation with factor_analyzer to produce interpretable, orthogonal factors before computing contributions." ;
    oc:hasRationale "Varimax rotation maximizes variance of squared loadings, making factors more interpretable and category-mappable." .

oc:kn_29575765 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When validating contribution results" ;
    oc:directiveContent "Contributions that do not sum to the total R² are normal — R² decomposition is approximate, not exact." ;
    oc:hasRationale "Leave-one-out R² decomposition captures marginal contributions which may overlap across factors." ;
    oc:severityLevel "LOW" .

oc:kn_564e5fa3 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When preparing data for R² decomposition" ;
    oc:directiveContent "Never run separate PCA/factor analysis per variable category; always run ONE global factor analysis on all variables together." ;
    oc:hasRationale "Separate analyses per category produce incomparable factor spaces, making contribution decomposition invalid." ;
    oc:severityLevel "CRITICAL" .

oc:kn_5e298791 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When contribution values are negative" ;
    oc:directiveContent "Negative contribution values indicate a suppressor effect — check for multicollinearity among predictors." ;
    oc:hasRationale "Suppressor variables can artificially enhance other predictors' contributions, producing negative values when removed." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b18c3ec4 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before fitting FactorAnalyzer" ;
    oc:directiveContent "Standardize all variables using StandardScaler before factor analysis." ;
    oc:hasRationale "Variables on different scales would dominate factor extraction based on magnitude rather than covariance structure." .

