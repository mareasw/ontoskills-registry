                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 3 ;
                            oc:tableCaption "## Common Issues" ;
                            oc:tableMarkdown """| Issue | Cause | Solution |
|-------|-------|----------|
| Loadings all similar | Too few factors | Increase n_factors |
| Negative loadings | Inverse relationship | Normal, interpret direction |
| Low variance explained | Data not suitable for PCA | Check correlations first |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 8 ;
                    oc:sectionTitle "Common Issues" ],
