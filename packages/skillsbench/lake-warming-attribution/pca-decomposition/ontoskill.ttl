oc:kn_249af064 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Kaiser criterion for selecting number of factors" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """eigenvalues, _ = fa.get_eigenvalues()
n_factors = sum(eigenvalues > 1)""" .

oc:kn_53a706a7 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using PCA for attribution/contribution analysis with predefined categories" ;
    oc:directiveContent "Do NOT run separate PCA for each category. Run ONE global PCA on all variables together, then use the resulting factor scores for contribution analysis." ;
    oc:hasRationale "Separate PCA per category destroys the shared variance structure needed for valid R² decomposition across categories." ;
    oc:severityLevel "CRITICAL" .

oc:kn_6e81e25e a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Core PCA with varimax rotation pattern" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)
fa = FactorAnalyzer(n_factors=4, rotation='varimax')
fa.fit(X_scaled)
loadings = fa.loadings_
scores = fa.transform(X_scaled)""" .

oc:kn_79bb5b6f a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before running any PCA decomposition" ;
    oc:directiveContent "Requires scikit-learn (StandardScaler) and factor_analyzer (FactorAnalyzer) Python packages." ;
    oc:severityLevel "HIGH" .

oc:kn_97961dd2 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When fitting FactorAnalyzer for PCA" ;
    oc:directiveContent "Use varimax rotation for interpretability — it maximizes variance of squared loadings, producing simpler factor structures." ;
    oc:hasRationale "Unrotated components are often hard to interpret; varimax produces near-simple structure where each variable loads highly on few factors." ;
    oc:severityLevel "HIGH" .

oc:kn_a637c6d0 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When interpreting factor loadings or low variance explained" ;
    oc:directiveContent "If all loadings are similar, increase n_factors. If variance explained is low, check correlations first — PCA is unsuitable for uncorrelated data." ;
    oc:hasRationale "These symptoms indicate either under-extraction of factors or data that lacks the correlational structure PCA requires." ;
    oc:severityLevel "MEDIUM" .

oc:kn_af9a7210 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Complete PCA decomposition workflow" ;
    oc:directiveContent "1. Select all variables from all categories into one matrix 2. Standardize with StandardScaler 3. Fit FactorAnalyzer with n_factors and varimax rotation 4. Extract factor loadings for interpretation 5. Compute factor scores for downstream analysis" ;
    oc:stepOrder 1 .

oc:kn_e8d26d32 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before fitting PCA on any dataset" ;
    oc:directiveContent "Always standardize data before PCA using StandardScaler — raw-scale differences will dominate components." ;
    oc:hasRationale "Variables measured on different scales produce misleading components dominated by high-variance features." ;
    oc:severityLevel "CRITICAL" .

oc:kn_f8ddea95 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "Re-running PCA decomposition" ;
    oc:directiveContent "PCA with fixed random_state is deterministic — same input yields identical loadings and scores." ;
    oc:hasRationale "Deterministic results ensure reproducible attribution analyses." ;
    oc:severityLevel "LOW" .

oc:kn_faf0e648 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding number of factors to extract" ;
    oc:directiveContent "Choose n_factors using Kaiser criterion (eigenvalue > 1) or domain knowledge of expected category count." ;
    oc:hasRationale "Kaiser criterion provides data-driven factor count; domain knowledge ensures factors align with meaningful conceptual groupings." ;
    oc:severityLevel "MEDIUM" .

