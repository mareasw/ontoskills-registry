    oc:expectedOutcome "Appropriate method selected given data distribution and outlier presence" ;
    oc:stepDependsOn _:ref_50cf97186f362c35 ;
    oc:stepId "select-method" .

_:ref_3a2fea77e8e4edf5 a oc:WorkflowStep ;
    dcterms:description "Execute trend detection using scipy linregress or pymannkendall" ;
