oc:kn_3c00827a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing or interpreting linear regression trend analysis" ;
    oc:directiveContent "Linear regression assumes linearity, normally distributed residuals, and homoscedasticity (constant variance). Violating these assumptions reduces result reliability." ;
    oc:hasRationale "Parametric methods produce unreliable results when their statistical assumptions are violated" .

oc:kn_7aa733f9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When presenting trend analysis results" ;
    oc:directiveContent "Report both slope magnitude (rate of change) and p-value (statistical significance) together; round results to 2 decimal places." ;
    oc:hasRationale "Slope magnitude indicates practical significance while p-value indicates statistical confidence" ;
    oc:severityLevel "MEDIUM" .

oc:kn_9a397d54 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When linear regression and Mann-Kendall give contradictory results" ;
    oc:directiveContent "When parametric and non-parametric methods conflict, trust Sen's slope for environmental data due to its robustness to assumption violations." ;
    oc:hasRationale "Conflicting results arise from different distributional assumptions; Sen's slope does not require normality" .

oc:kn_ade53765 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "Before running any trend analysis" ;
    oc:directiveContent "Use at least 10 data points for reliable trend analysis results. Fewer than 8-10 years of data may produce NaN p-values." ;
    oc:hasRationale "Insufficient data leads to unreliable or undefined statistical results" ;
    oc:severityLevel "HIGH" .

oc:kn_c89d947b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting a trend detection method" ;
    oc:directiveContent "Prefer Sen's slope with Mann-Kendall test for environmental time series; use linear regression when data is normally distributed and free of outliers." ;
    oc:hasRationale "Environmental data often contains outliers and non-normal distributions, making non-parametric methods more robust" .

oc:kn_fb36241c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When interpreting trend results with large datasets" ;
    oc:directiveContent "Do not rely solely on p-value significance when slope magnitude is near zero with large sample sizes — check practical significance." ;
    oc:hasRationale "Large samples can make trivially small trends statistically significant without being practically meaningful" ;
    oc:severityLevel "MEDIUM" .

