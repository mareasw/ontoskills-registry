oc:kn_0425dda3 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When editing existing presentations via OOXML" ;
    oc:directiveContent "Always validate XML immediately after each edit and fix any validation errors before proceeding: python ooxml/scripts/validate.py <dir> --original <file>" ;
    oc:hasRationale "XML corruption can render the entire presentation unusable. Immediate validation catches errors when context is fresh." ;
    oc:severityLevel "CRITICAL" .

oc:kn_098b8778 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "Applying text replacements to generate final presentation" ;
    oc:directiveContent "python scripts/replace.py working.pptx replacement-text.json output.pptx" .

oc:kn_0e9625a1 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Editing existing presentation" ;
    oc:directiveContent "1. Read ooxml.md fully → 2. Unpack: python ooxml/scripts/unpack.py <file> <dir> → 3. Edit XML files (ppt/slides/slide{N}.xml) → 4. Validate: python ooxml/scripts/validate.py <dir> --original <file> → 5. Pack: python ooxml/scripts/pack.py <dir> <output>" ;
    oc:stepOrder 2 .

oc:kn_15ca8c2d a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "markitdown[pptx], pptxgenjs, playwright, sharp, LibreOffice, poppler-utils, defusedxml must be installed" .

oc:kn_1dd00efd a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting any presentation task" ;
    oc:directiveContent "Read html2pptx.md completely (never with range limits) before creating new presentations. Read ooxml.md completely before editing existing presentations." ;
    oc:hasRationale "These reference files contain critical syntax rules and best practices that cannot be skipped without risking broken output." ;
    oc:severityLevel "CRITICAL" .

oc:kn_289454f5 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Extracting text content from a presentation" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "python -m markitdown path-to-file.pptx" .

oc:kn_29acd2aa a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "Extracting text inventory from working presentation" ;
    oc:directiveContent "python scripts/inventory.py working.pptx text-inventory.json" .

oc:kn_3e2f01df a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Generating thumbnail grids for visual analysis" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "python scripts/thumbnail.py presentation.pptx [output_prefix] [--cols 4]" .

oc:kn_412b1708 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "Replacement text JSON for template-based presentations" ;
    oc:directiveContent """{
  "slide-N": {
    "shape-N": {
      "paragraphs": [
        {"text": "...", "bold": true, "alignment": "CENTER"},
        {"text": "...", "bullet": true, "level": 0},
        {"text": "...", "color": "FF0000"}
      ]
    }
  }
}""" ;
    oc:templateVariables "alignment",
        "bold",
        "bullet",
        "color",
        "font_name",
        "font_size",
        "level",
        "shape-N",
        "slide-N",
        "text",
        "theme_color" .

oc:kn_4a2aa650 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting color palette for new presentations" ;
    oc:directiveContent "Choose 3-5 colors that work together (dominant + supporting + accent). Think beyond defaults: match topic, industry, mood, energy, audience. Ensure text readability on backgrounds." ;
    oc:hasRationale "Intentional color selection creates visually cohesive presentations that communicate effectively." ;
    oc:severityLevel "MEDIUM" .

oc:kn_4f55ac9d a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When unpacking a .pptx file for raw XML access" ;
    oc:directiveContent "The unpack.py script location is skills/pptx/ooxml/scripts/unpack.py. If not found at this path, use 'find . -name unpack.py' to locate it." ;
    oc:hasRationale "Script location may vary depending on project structure; fallback search prevents workflow blocking." ;
    oc:severityLevel "LOW" .

oc:kn_718f6593 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Converting slides to images for visual analysis" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "soffice --headless --convert-to pdf template.pptx && pdftoppm -jpeg -r 150 template.pdf slide" .

oc:kn_7cd32f2d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating HTML slides for html2pptx workflow" ;
    oc:directiveContent "Rasterize gradients and icons as PNG images FIRST using Sharp, then reference them in HTML. Do not rely on CSS gradients for html2pptx conversion." ;
    oc:hasRationale "The html2pptx converter may not accurately render CSS gradients; pre-rasterized images ensure visual fidelity." ;
    oc:severityLevel "MEDIUM" .

oc:kn_82e06a83 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating new presentations via html2pptx" ;
    oc:directiveContent "Use web-safe fonts only: Arial, Helvetica, Times New Roman, Georgia, Courier New, Verdana, Tahoma, Trebuchet MS, Impact. No other fonts." ;
    oc:hasRationale "Non-web-safe fonts may not render correctly in PowerPoint, causing display inconsistencies." ;
    oc:severityLevel "HIGH" .

oc:kn_8383020e a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Creating presentation from template" ;
    oc:directiveContent "1. Extract text + thumbnails → 2. Analyze template, save inventory.md (0-indexed) → 3. Create outline with template mapping → 4. Rearrange: python scripts/rearrange.py template.pptx working.pptx indices → 5. Inventory: python scripts/inventory.py working.pptx text-inventory.json → 6. Generate replacement-text.json → 7. Apply: python scripts/replace.py working.pptx replacement-text.json output.pptx" ;
    oc:stepOrder 3 .

oc:kn_83ff8bea a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "Rearranging template slides by 0-based indices" ;
    oc:directiveContent "python scripts/rearrange.py template.pptx working.pptx 0,34,34,50,52" .

oc:kn_85ba2ed0 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "Unpacking a .pptx file for raw XML editing" ;
    oc:directiveContent "python ooxml/scripts/unpack.py <office_file> <output_dir>" .

oc:kn_8cdd70fd a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying text replacements to template-based presentations" ;
    oc:directiveContent "When using replace.py, ALL text shapes from the inventory will be cleared unless you provide 'paragraphs' for them. Only reference shapes that actually exist in the inventory." ;
    oc:hasRationale "Unintentional clearing of shapes destroys content; referencing non-existent shapes causes validation errors." ;
    oc:severityLevel "CRITICAL" .

oc:kn_a3360014 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When generating any code for PPTX operations" ;
    oc:directiveContent "Write concise code. Avoid verbose variable names, redundant operations, and unnecessary print statements." ;
    oc:hasRationale "Clean code reduces errors and improves maintainability of generated scripts." ;
    oc:severityLevel "LOW" .

oc:kn_a87cb2f3 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "Validating OOXML after editing" ;
    oc:directiveContent "python ooxml/scripts/validate.py <dir> --original <file>" .

oc:kn_b98660c4 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "Repacking edited OOXML into .pptx" ;
    oc:directiveContent "python ooxml/scripts/pack.py <input_directory> <office_file>" .

oc:kn_d9c8de96 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Creating new presentation without template" ;
    oc:directiveContent "1. Read html2pptx.md fully → 2. Create HTML files per slide (720pt×405pt for 16:9) with placeholders → 3. Rasterize gradients/icons as PNG first → 4. Run JS with html2pptx() + PptxGenJS for charts/tables → 5. Generate thumbnails → 6. Visual inspection loop until correct" ;
    oc:stepOrder 1 .

oc:kn_dfa250ac a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before creating any new presentation" ;
    oc:directiveContent "State your content-informed design approach BEFORE writing any code. Analyze subject matter, check for branding, match palette to content, and explain design choices." ;
    oc:hasRationale "Forces intentional design decisions rather than autopilot defaults, resulting in presentations that match their content's tone and purpose." ;
    oc:severityLevel "CRITICAL" .

oc:kn_eeac8b0e a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When generating replacement text for template-based presentations" ;
    oc:directiveContent "When bullet: true in replacement JSON, do NOT include bullet symbols (•, -, *) in text - they are added automatically. Do not set alignment property when bullet is true." ;
    oc:hasRationale "Double-bulleting or conflicting alignment properties corrupt the slide formatting." ;
    oc:severityLevel "HIGH" .

oc:kn_ef651649 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating slides with charts or tables" ;
    oc:directiveContent "Never vertically stack charts/tables below text in a single column. Use two-column layout (40%/60% split) or full-slide layout instead." ;
    oc:hasRationale "Vertical stacking causes poor readability and layout issues; two-column layouts provide better visual balance." ;
    oc:severityLevel "HIGH" .

oc:kn_f8cc2f15 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After creating or modifying a presentation" ;
    oc:directiveContent "Generate thumbnail grids and visually inspect for text cutoff, text overlap, positioning issues, and contrast problems. Adjust and regenerate if issues found." ;
    oc:hasRationale "Visual validation catches layout problems that XML structure alone cannot reveal, ensuring professional-quality output." ;
    oc:severityLevel "HIGH" .

oc:kn_febfa0e9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting template layouts for presentation content" ;
    oc:directiveContent "Match layout structure to actual content: two-column layouts only for exactly 2 items, three-column only for exactly 3 items. Never use layouts with more placeholders than you have content." ;
    oc:hasRationale "Mismatched layouts leave empty placeholders that look unprofessional and confusing." ;
    oc:severityLevel "HIGH" .

