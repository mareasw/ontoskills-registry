                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 2 ;
                                    oc:sectionTitle "Visual Details Options" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Design Principles" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**NEVER vertically stack**: Do not place charts/tables below text in a single column - this causes poor readability and layout issues" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Two-column layout (PREFERRED)**: Use a header spanning the full width, then two columns below - text/bullets in one column and the featured content in the other. This provides better balance and makes charts/tables more readable. Use flexbox with unequal column widths (e.g., 40%/60% split) to optimize space for each content type." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Full-slide layout**: Let the featured content (chart/table) take up the entire slide for maximum impact and readability" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "**When creating slides with charts or tables:**" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Layout Tips" ],
                        [ a oc:Section ;
                            oc:hasContent _:ref_77d82d8e37cab152 ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Workflow" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Creating a new PowerPoint presentation **without a template**" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "A user may ask you to create, edit, or analyze the contents of a .pptx file. A .pptx file is essentially a ZIP archive containing XML files and other resources that you can read or edit. You have different tools and workflows available for different tasks." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Overview" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**IMPORTANT**: When generating code for PPTX operations:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Avoid verbose variable names and redundant operations" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Avoid unnecessary print statements" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Write concise code" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 8 ;
                    oc:sectionTitle "Code Style Guidelines" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "You need raw XML access for: comments, speaker notes, slide layouts, animations, design elements, and complex formatting. For any of these features, you'll need to unpack a presentation and read its raw XML contents." ] ;
                            oc:hasSubsection [ a oc:Section ;
                                    oc:hasContent [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 1 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 5 ;
                                                    oc:itemText "`ppt/slideLayouts/` - Layout templates for slides" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "`ppt/presentation.xml` - Main presentation metadata and slide references" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 4 ;
                                                    oc:itemText "`ppt/comments/modernComment_*.xml` - Comments for specific slides" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 7 ;
                                                    oc:itemText "`ppt/theme/` - Theme and styling information" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "`ppt/slides/slide{N}.xml` - Individual slide contents (slide1.xml, slide2.xml, etc.)" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 6 ;
                                                    oc:itemText "`ppt/slideMasters/` - Master slide templates" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 8 ;
                                                    oc:itemText "`ppt/media/` - Images and other media files" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 3 ;
                                                    oc:itemText "`ppt/notesSlides/notesSlide{N}.xml` - Speaker notes for each slide" ] ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 2 ;
                                    oc:sectionTitle "Key file structures" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "**When given an example design to emulate**: Always analyze the presentation's typography and colors first using the methods below:" ],
                                        _:ref_f27ff6819e4a1227 ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 3 ;
                                    oc:sectionTitle "Typography and color extraction" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 2 ;
                                            oc:textContent "**Note**: The unpack.py script is located at `skills/pptx/ooxml/scripts/unpack.py` relative to the project root. If the script doesn't exist at this path, use `find . -name \"unpack.py\"` to locate it." ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "`python ooxml/scripts/unpack.py <office_file> <output_dir>`" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 1 ;
                                    oc:sectionTitle "Unpacking a file" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Raw XML access" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "If you just need to read the text contents of a presentation, you should convert the document to markdown:" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """# Convert document to markdown
python -m markitdown path-to-file.pptx
""" ;
                                    oc:codeLanguage "bash" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 18-21" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Text extraction" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Reading and analyzing content" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Required dependencies (should already be installed):" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**pptxgenjs**: `npm install -g pptxgenjs` (for creating presentations via html2pptx)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 8 ;
                                    oc:itemText "**defusedxml**: `pip install defusedxml` (for secure XML parsing)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 7 ;
                                    oc:itemText "**Poppler**: `sudo apt-get install poppler-utils` (for pdftoppm to convert PDF to images)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**react-icons**: `npm install -g react-icons react react-dom` (for icons)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**sharp**: `npm install -g sharp` (for SVG rasterization and image processing)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**markitdown**: `pip install \"markitdown[pptx]\"` (for text extraction from presentations)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "**LibreOffice**: `sudo apt-get install libreoffice` (for PDF conversion)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**playwright**: `npm install -g playwright` (for HTML rendering in html2pptx)" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 9 ;
                    oc:sectionTitle "Dependencies" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_05c4ec0e65cf16d6,
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "To visually analyze PowerPoint slides, convert them to images using a two-step process:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Options:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """pdftoppm -jpeg -r 150 -f 2 -l 5 template.pdf slide  # Converts only pages 2-5
""" ;
                            oc:codeLanguage "bash" ;
                            oc:contentOrder 6 ;
                            oc:sourceLocation "lines 463-465" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "`-jpeg`: Output JPEG format (use `-png` for PNG if preferred)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "`-f N`: First page to convert (e.g., `-f 2` starts from page 2)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "`slide`: Prefix for output files" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
