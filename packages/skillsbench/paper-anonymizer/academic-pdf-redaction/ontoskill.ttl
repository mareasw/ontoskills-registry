oc:kn_0a1bb838 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building the patterns list for redaction" ;
    oc:directiveContent "Redact 8 categories of identifying info before References: author full names, affiliations, emails, venue names, arXiv IDs, DOIs, acknowledgement names, equal-contribution footnotes." ;
    oc:hasRationale "These are the standard identifying elements that peer reviewers would use to deanonymize a submission." ;
    oc:severityLevel "MEDIUM" .

oc:kn_22c3e3a5 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When re-running redaction on previously processed files" ;
    oc:directiveContent "Running redaction multiple times on already-redacted PDFs is not idempotent — each run applies to whatever text remains, which may be less than expected." ;
    oc:hasRationale "Redaction permanently removes text; re-running may fail to find patterns that were already removed, or if the first run was wrong, damage compounds." ;
    oc:severityLevel "MEDIUM" .

oc:kn_407c3cea a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining patterns to redact" ;
    oc:directiveContent "Use FULL names and phrases for pattern matching, never partial strings like just a surname." ;
    oc:hasRationale "Partial matches like 'Smith' will incorrectly redact 'Smith et al.' citations in the references and other legitimate mentions." ;
    oc:severityLevel "HIGH" .

oc:kn_6e86a115 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After every redaction operation" ;
    oc:directiveContent "Always run verify_redaction() after saving. Check: page count unchanged, retained text >= 70% of original, total chars >= 1000." ;
    oc:hasRationale "Catches catastrophic failures like corrupted PDFs, over-redaction, or page count changes before the file is distributed." ;
    oc:severityLevel "CRITICAL" .

oc:kn_76557b02 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying redactions to any page" ;
    oc:directiveContent "Never redact entire pages, blocks, or rectangular regions. Only redact specific search matches for exact text strings." ;
    oc:hasRationale "Blanket redaction removes non-identifying content and corrupts the paper's readability. Targeted redaction preserves 80%+ of original text." ;
    oc:severityLevel "CRITICAL" .

oc:kn_bcc89c32 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, when scanning pages for redaction" ;
    oc:directiveContent "NEVER redact the References section. Self-citations and all references must remain fully intact. Stop redacting at the page where 'references' appears." ;
    oc:hasRationale "References are critical for peer review and must be preserved; removing them violates academic norms and breaks citation integrity." ;
    oc:severityLevel "CRITICAL" .

