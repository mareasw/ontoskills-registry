                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """from sympy import simplify, expand, factor, cancel
simplify(sin(x)**2 + cos(x)**2)  # Returns 1
expand((x + 1)**3)  # x**3 + 3*x**2 + 3*x + 1
factor(x**2 - 1)    # (x - 1)*(x + 1)
""" ;
