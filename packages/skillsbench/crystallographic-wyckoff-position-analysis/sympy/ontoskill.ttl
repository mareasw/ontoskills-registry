oc:kn_18850ecf a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Symbolic matrix operations" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from sympy import symbols, Matrix
M = Matrix([[1, 2], [3, 4]])
print(M.det(), M.eigenvals(), M**-1)""" .

oc:kn_20031a45 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When encountering 'cannot solve' errors" ;
    oc:directiveContent "If an equation cannot be solved algebraically, try alternative solvers (solve, solveset, nsolve) or fall back to numerical methods with nsolve()." ;
    oc:hasRationale "Not all equations have closed-form symbolic solutions. Numerical methods provide approximate solutions when exact ones are unavailable." ;
    oc:severityLevel "MEDIUM" .

oc:kn_30d66e1b a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When evaluating symbolic expressions over many numeric inputs" ;
    oc:directiveContent "Using subs() and evalf() in loops is very slow. Use lambdify() to create a fast NumPy-compatible function for bulk numerical evaluation." ;
    oc:hasRationale "lambdify compiles the symbolic expression into native NumPy operations, avoiding the overhead of symbolic substitution per element." ;
    oc:severityLevel "HIGH" .

oc:kn_3fdf222c a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "SymPy Python package must be installed (pip install sympy). NumPy optional for lambdify numerical evaluation." .

oc:kn_4ca8da96 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before constructing any symbolic expression" ;
    oc:directiveContent "Always define symbols using symbols() before using them in expressions. Using undefined variable names causes NameError." ;
    oc:hasRationale "SymPy symbols are Python objects, not built-in variable types. They must be explicitly created." ;
    oc:severityLevel "CRITICAL" .

oc:kn_63268747 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "General symbolic computation workflow" ;
    oc:directiveContent "1. Define symbols with assumptions → 2. Construct expression → 3. Simplify/manipulate symbolically → 4. Solve or compute → 5. Convert to numeric (lambdify) or formatted output (latex/pretty) as needed" ;
    oc:stepOrder 1 .

oc:kn_72ac7e82 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Converting symbolic expressions to fast NumPy functions" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from sympy import symbols, diff, sin, cos
from sympy import lambdify
x, y = symbols('x y')
expr = sin(x) + cos(y)
f = lambdify((x, y), expr, 'numpy')
results = f(x_array, y_array)""" .

oc:kn_832e632c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining symbols that have known mathematical properties" ;
    oc:directiveContent "Use assumptions (real=True, positive=True, integer=True) on symbols to enable better simplification and more specific results." ;
    oc:hasRationale "Assumptions allow SymPy to simplify expressions more aggressively (e.g., sqrt(x**2) → x when x is positive)." ;
    oc:severityLevel "MEDIUM" .

oc:kn_95d3341f a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When symbolic simplification produces unexpected results" ;
    oc:directiveContent "If simplification is not working, try different functions (simplify, factor, expand, trigsimp) or use simplify(expr, force=True) for aggressive simplification, or add more assumptions to symbols." ;
    oc:hasRationale "Different simplification strategies target different mathematical domains. Aggressive mode can handle edge cases at the cost of computation time." ;
    oc:severityLevel "LOW" .

oc:kn_aa2baf0f a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When documenting or presenting symbolic computation results" ;
    oc:directiveContent """LaTeX: {latex(expr)} = {latex(result)}
Pretty: {pretty(expr)} = {pretty(result)}
Numerical: {result.evalf()}""" ;
    oc:templateVariables "expr",
        "result" .

oc:kn_b36590f5 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When solving any equation or system of equations" ;
    oc:directiveContent "Use the appropriate solver for each equation type: solveset for algebraic, linsolve for linear systems, nonlinsolve for nonlinear systems, dsolve for differential equations." ;
    oc:hasRationale "Each solver is optimized for its domain. Using the wrong solver leads to incomplete results, errors, or poor performance." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c8b04db2 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Solving equations and verifying solutions" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from sympy import symbols, solve, simplify
x = symbols('x')
expr = x**2 - 5*x + 6
solutions = solve(expr, x)
for sol in solutions:
    assert simplify(expr.subs(x, sol)) == 0""" .

oc:kn_ddffc358 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When constructing symbolic expressions with fractions or constants" ;
    oc:directiveContent "Never use floating-point literals like 0.5 in symbolic expressions. Use Rational(1,2) or S(1)/2 for exact arithmetic." ;
    oc:hasRationale "Floating-point values introduce numerical approximation and break exact symbolic computation, producing unexpected results." ;
    oc:severityLevel "HIGH" .

