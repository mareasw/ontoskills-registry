oc:kn_0c918afc a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating whether to parallelize" ;
    oc:directiveContent "Avoid parallelizing workloads with fewer than ~1000 items—parallel overhead will exceed gains" ;
    oc:hasRationale "Process/thread creation and inter-process communication have fixed overhead costs that dominate small workloads" ;
    oc:severityLevel "MEDIUM" .

oc:kn_2a2ef7ec a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Always" ;
    oc:directiveContent "Python 3.7+ required for asyncio.run() and modern concurrent.futures API" .

oc:kn_5780c3b5 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When parallelizing CPU-intensive computations" ;
    oc:directiveContent "Never use threading for CPU-bound Python code—the GIL prevents true parallelism; use multiprocessing instead" ;
    oc:hasRationale "Python's Global Interpreter Lock (GIL) allows only one thread to execute Python bytecode at a time, making threading ineffective for CPU-bound work" ;
    oc:severityLevel "CRITICAL" .

oc:kn_6b8a9b2a a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When parallel tasks may fail individually" ;
    oc:directiveContent "Use executor.submit() instead of executor.map() for granular error handling—submit returns Future objects with per-task exception info" ;
    oc:hasRationale "map() propagates exceptions on iteration, making it hard to handle partial failures; submit() + Future allows per-task error inspection" ;
    oc:severityLevel "MEDIUM" .

oc:kn_6cec9c3b a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting independent CPU-bound loops to parallel execution" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from concurrent.futures import ProcessPoolExecutor

with ProcessPoolExecutor() as executor:
    results = list(executor.map(expensive_computation, items))""" .

oc:kn_6dd9fa28 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting sequential HTTP requests to concurrent async I/O" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """import asyncio
import aiohttp

async def fetch_all(urls):
    async with aiohttp.ClientSession() as session:
        tasks = [fetch_one(session, url) for url in urls]
        return await asyncio.gather(*tasks)""" .

oc:kn_806d1c44 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When replacing nested loops over numerical arrays with vectorized operations" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """import numpy as np
result = np.outer(a, b)""" .

oc:kn_8731afeb a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before finalizing parallelized code" ;
    oc:directiveContent "Verify: output matches sequential version for test inputs, no race conditions, exceptions handled, resources cleaned up, worker count bounded, imports added" ;
    oc:hasRationale "Parallelization introduces subtle correctness risks that must be explicitly validated against sequential baseline" .

oc:kn_8a7489e5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When analyzing code for parallelization candidates" ;
    oc:directiveContent "Shared mutable state across iterations breaks parallelism—identify and synchronize or eliminate shared state before parallelizing" ;
    oc:hasRationale "Race conditions from unsynchronized shared state produce incorrect, non-deterministic results" ;
    oc:severityLevel "CRITICAL" .

oc:kn_b4892226 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When passing large data structures to multiprocessing" ;
    oc:directiveContent "ProcessPoolExecutor copies data to each worker process—use shared memory (multiprocessing.shared_memory) for large datasets to avoid memory explosion" ;
    oc:hasRationale "Each subprocess gets its own memory space; large data duplicated across workers can exhaust available memory" ;
    oc:severityLevel "HIGH" .

oc:kn_b4c5eb79 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using multiprocessing.Pool or ProcessPoolExecutor" ;
    oc:directiveContent "Do not pass lambda functions or nested classes to multiprocessing—they cannot be pickled and will raise exceptions at runtime" ;
    oc:hasRationale "Multiprocessing serializes arguments and functions via pickle; lambdas and nested classes are not picklable" ;
    oc:severityLevel "HIGH" .

oc:kn_c59193e6 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Always when parallelizing Python code" ;
    oc:directiveContent "1. Analyze code for parallelization candidates 2. Classify workload type (CPU/IO/data-parallel) 3. Select strategy from decision tree 4. Transform with proper synchronization and error handling 5. Verify correctness against sequential baseline" ;
    oc:stepOrder 1 .

oc:kn_d54e5a02 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting a parallelization strategy" ;
    oc:directiveContent "Classify workload first: CPU-bound → multiprocessing, I/O-bound → asyncio/threading, data-parallel → vectorization (NumPy/Pandas)" ;
    oc:hasRationale "Each workload type has an optimal concurrency mechanism; mismatching strategy to workload type yields poor or negative performance gains" ;
    oc:severityLevel "HIGH" .

oc:kn_de22e019 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When code has both CPU-bound and I/O-bound workloads requiring mixed parallelism" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """import asyncio
from concurrent.futures import ProcessPoolExecutor

async def hybrid_pipeline(data, urls):
    loop = asyncio.get_event_loop()
    with ProcessPoolExecutor() as pool:
        processed = await loop.run_in_executor(pool, cpu_heavy_fn, data)
    results = await asyncio.gather(*[fetch(url) for url in urls])
    return processed, results""" .

