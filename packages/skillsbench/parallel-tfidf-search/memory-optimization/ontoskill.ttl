oc:kn_2bd28596 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting lists to generators" ;
    oc:directiveContent "Generators add iteration overhead — always verify that performance remains acceptable after switching from materialized collections" ;
    oc:hasRationale "Memory savings from generators can come at the cost of CPU time due to repeated iteration" ;
    oc:severityLevel "MEDIUM" .

oc:kn_314acd7f a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before finalizing optimized code" ;
    oc:directiveContent "Verify memory usage reduced (measure with profiler), functionality preserved (same outputs), no new leaks introduced, performance acceptable, code remains readable" ;
    oc:hasRationale "Memory optimization must not sacrifice correctness or maintainability" .

oc:kn_51110291 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating large collections of similar objects" ;
    oc:directiveContent "Use __slots__ on classes with many instances to eliminate per-instance __dict__ overhead, reducing memory by 40-60%" ;
    oc:hasRationale "Per-instance dictionaries dominate memory for large collections of simple objects" .

oc:kn_51aeae8a a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When optimizing any Python code for memory" ;
    oc:directiveContent "1. Profile to identify memory bottlenecks (largest allocations, leak patterns) 2. Analyze data structures and object lifecycles 3. Select optimization strategies based on access patterns 4. Transform code with memory-efficient alternatives 5. Verify memory reduction without correctness loss" ;
    oc:stepOrder 1 .

oc:kn_65e55863 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before starting any memory optimization" ;
    oc:directiveContent "Never skip profiling before optimizing — guessing memory bottlenecks leads to wasted effort optimizing the wrong data structures" ;
    oc:hasRationale "Memory bottlenecks are often non-obvious; profiler data reveals the true hotspots" ;
    oc:severityLevel "HIGH" .

oc:kn_811f16c7 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When diagnosing memory leaks" ;
    oc:directiveContent "Common leak patterns: growing caches without eviction, unregistered event listeners, circular references, global list accumulation, closures capturing large objects" ;
    oc:hasRationale "These five patterns account for the majority of Python memory leaks" .

oc:kn_a5e22e37 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting which transformation pattern to apply" ;
    oc:directiveContent "Match the optimization strategy to the consumption pattern: large collections → __slots__/generators, data processing → chunking/mmap, object lifecycle → weakref/explicit cleanup" ;
    oc:hasRationale "Different memory problems require fundamentally different solutions; applying the wrong pattern wastes time and may hurt performance" .

