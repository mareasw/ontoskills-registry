oc:kn_e47a4912 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When choosing data structures for memory-sensitive code" ;
    oc:directiveContent "Data structure memory hierarchy from highest to lowest: list of dict (~400+ bytes/item) > list of class (~300) > list of __slots__ class (~120) > namedtuple (~80) > numpy ndarray (8 bytes/float64) > pandas DataFrame (~10-50 bytes/cell)" .

oc:kn_fa497a95 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing CSV files too large for RAM" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """def process_large_csv(filepath, chunksize=10000):
    results = []
    for chunk in pd.read_csv(filepath, chunksize=chunksize):
        result = process_chunk(chunk)
        results.append(result)
        del chunk
    return pd.concat(results)""" .

