oc:kn_20dd44a1 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reducing Pandas DataFrame memory usage" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """def optimize_dtypes(df):
    for col in df.select_dtypes(include=['int']):
        df[col] = pd.to_numeric(df[col], downcast='integer')
    for col in df.select_dtypes(include=['float']):
        df[col] = pd.to_numeric(df[col], downcast='float')
    return df""" .

