        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing partition granularity" ;
    oc:directiveContent "Partitioning overhead must be significantly less than individual task cost. If partitioning cost approaches task cost, reduce partition count or batch small items together." ;
