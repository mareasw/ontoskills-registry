    oc:nature "Tool" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "compare ground travel options",
        "estimate driving distance between cities",
        "estimate taxi cost between cities",
        "validate itinerary travel legs" ;
    oc:yieldsState oc:DrivingDistanceEstimated .

oc:kn_08ad9682 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building multi-modal travel itineraries" ;
    oc:directiveContent "Use this skill for ground travel comparison; pair with search-flights for air travel to give users a complete transport picture." ;
    oc:hasRationale "Comprehensive travel planning requires comparing both ground and air options." ;
    oc:severityLevel "LOW" .

oc:kn_140e313e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using distance/duration estimates for travel planning" ;
    oc:directiveContent "Distance estimates rely on a bundled distance matrix CSV, not live API calls; results may not reflect real-time traffic or road closures." ;
    oc:hasRationale "Bundled data provides deterministic results but may be outdated compared to live routing services." ;
    oc:severityLevel "MEDIUM" .

oc:kn_403a6082 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before running the skill" ;
    oc:directiveContent "pandas, numpy, and requests must be installed (pip install pandas numpy requests)" ;
    oc:hasRationale "The GoogleDistanceMatrix class depends on these Python packages for CSV parsing and potential API interaction." .

oc:kn_559e93d9 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "Always" ;
    oc:directiveContent "This skill performs read-only lookups against a local CSV dataset; no external state is modified." ;
    oc:hasRationale "Safe to call multiple times without concern for data mutation." .

oc:kn_cf863753 a oc:ExecutionDeterminism,
        oc:KnowledgeNode ;
    oc:appliesToContext "When comparing multiple travel options" ;
    oc:directiveContent "Results are deterministic given the same origin/destination inputs since the data source is a static bundled CSV." ;
    oc:hasRationale "Deterministic output enables reliable comparisons across itinerary planning iterations." .

oc:req_02b3c31e a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "numpy" .

oc:req_746aacc9 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "pandas" .

oc:req_83483d58 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "bundled distance matrix CSV dataset" .

oc:req_83e3d412 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "requests" .

_:ref_679562a37542bd3b a oc:WorkflowStep ;
    dcterms:description "Call GoogleDistanceMatrix.run(origin, destination, mode) to get distance/duration/cost" ;
    oc:expectedOutcome "Distance, duration, and estimated cost returned" ;
    oc:stepDependsOn _:ref_db45622751b0b96e ;
    oc:stepId "query-distance" .

_:ref_db45622751b0b96e a oc:WorkflowStep ;
    dcterms:description "Verify origin and destination city names exist in the dataset using search-cities" ;
    oc:expectedOutcome "Confirmed valid city names" ;
    oc:stepId "validate-cities" .

