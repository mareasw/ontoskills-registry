                [ a oc:WorkflowStep ;
                    dcterms:description "Present the distance, duration, and cost estimates in a user-friendly format" ;
                    oc:expectedOutcome "Clear travel comparison data for the user" ;
                    oc:stepDependsOn _:ref_679562a37542bd3b ;
