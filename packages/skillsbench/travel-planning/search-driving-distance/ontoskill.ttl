oc:skill_travel_planning_search_driving_distance a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "search-driving-distance" ;
    skos:broader "Distance lookup service" ;
    prov:wasDerivedFrom ".agents/skills/skillsbench/travel-planning/search-driving-distance" ;
    oc:contentHash "afee0bbcd4b9034aa6f603d5fe4b8894cf7594dbdd3ec6f3f94eac26e9d9c48e" ;
    oc:dependsOnSkill oc:skill_ontoskills_search_cities ;
    oc:differentia "estimates driving/taxi duration, distance, and cost between two cities using a bundled distance matrix CSV" ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput ;
    oc:hasArgumentHint "origin, destination, mode (e.g. driving)" ;
    oc:hasCategory "travel-planning" ;
    oc:hasDescription "Estimate driving/taxi duration, distance, and rough cost between two cities using the bundled distance matrix CSV. Use this skill when comparing ground travel options or validating itinerary legs." ;
    oc:hasName "search-driving-distance" ;
    oc:hasRequirement oc:req_02b3c31e,
        oc:req_746aacc9,
        oc:req_83483d58,
        oc:req_83e3d412 ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: search-driving-distance
description: Estimate driving/taxi duration, distance, and rough cost between two cities using the bundled distance matrix CSV. Use this skill when comparing ground travel options or validating itinerary legs.
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Look up distance/duration between an origin and destination." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """pip install pandas numpy requests
""" ;
