oc:skill_travel_planning_search_cities a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "search-cities" ;
    skos:broader "Search utility" ;
    prov:wasDerivedFrom ".agents/skills/skillsbench/travel-planning/search-cities" ;
    oc:contentHash "256802aec5f803282714f04d7585373eb648fee0c8c1eb022a4350782385b8e7" ;
    oc:differentia "maps US states to their available cities using bundled background data for travel planning" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "state name (e.g., \"California\")" ;
    oc:hasCategory "research" ;
    oc:hasDescription "List cities for a given state using the bundled background data. Use this skill to validate state inputs or expand destination choices before flight/restaurant/attraction/driving/accommodation lookups." ;
    oc:hasName "search-cities" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Map states to their cities from the background text file." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "No external dependencies." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Installation" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """from search_cities import Cities

cities = Cities()
print(cities.run("California"))
""" ;
                            oc:codeLanguage "python" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 16-21" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Quick Start" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Search Cities" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: search-cities
description: List cities for a given state using the bundled background data. Use this skill to validate state inputs or expand destination choices before flight/restaurant/attraction/driving/accommodation lookups.
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
    oc:impartsKnowledge oc:kn_5bbce320,
        oc:kn_716bbfee,
        oc:kn_d73af2c6,
        oc:kn_f2b3f8fe,
        oc:kn_fb301f1f ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "discover available destinations in a state",
        "list cities in a state",
        "validate state input" ;
    oc:yieldsState oc:CitiesListed .

oc:kn_5bbce320 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "when orchestrating travel planning workflows" ;
    oc:directiveContent "Use this skill to validate state inputs before calling flight, restaurant, attraction, driving, or accommodation lookup skills" ;
    oc:hasRationale "Validating state names against the dataset prevents downstream errors in dependent searches" .

oc:kn_716bbfee a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "before execution" ;
    oc:directiveContent "No external dependencies required; uses bundled background data file" .

oc:kn_d73af2c6 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "when user provides a state name" ;
    oc:directiveContent "Only states present in the bundled background data will return results; unknown states return empty or error" ;
    oc:severityLevel "MEDIUM" .

oc:kn_f2b3f8fe a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "when looking up cities for a state" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from search_cities import Cities
cities = Cities()
print(cities.run("California"))""" .

oc:kn_fb301f1f a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "always" ;
    oc:directiveContent "Running this skill multiple times with the same state input produces identical results with no side effects" .

