    oc:hasArgumentHint "city name (e.g., \"New York\")" ;
    oc:hasCategory "research" ;
    oc:hasDescription "Retrieve attractions by city from the bundled dataset. Use this skill when surfacing points of interest or building sightseeing suggestions for a destination." ;
    oc:hasName "search-attractions" ;
    oc:hasRequirement oc:req_746aacc9 ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
