oc:kn_0b313384 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "always" ;
    oc:directiveContent "This skill is read-only and idempotent; running it multiple times with the same city returns the same results without side effects" ;
    oc:hasRationale "Ensures safe retry behavior when querying the static bundled dataset" .

oc:kn_123711b0 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When searching for attractions" ;
    oc:directiveContent "1. Import Attractions class 2. Instantiate Attractions() 3. Call .run(city_name) with target city" ;
    oc:hasRationale "Standard usage pattern for the bundled attractions search module" ;
    oc:stepOrder 1 .

oc:kn_607ad5f4 a oc:DataProvenance,
        oc:KnowledgeNode ;
    oc:appliesToContext "When interpreting or presenting results to users" ;
    oc:directiveContent "Attraction data comes from a bundled dataset, not a live API; results may not reflect real-time availability or seasonal closures" ;
    oc:hasRationale "Agents should qualify recommendations noting the data source is bundled and may be outdated" ;
    oc:severityLevel "MEDIUM" .

oc:kn_92d26826 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When querying attractions for a city" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from search_attractions import Attractions

attractions = Attractions()
print(attractions.run("New York"))""" .

oc:kn_b8d83bed a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "before execution" ;
    oc:directiveContent "pip install pandas must be completed before running this skill" ;
    oc:hasRationale "The skill relies on pandas for reading the bundled attractions CSV dataset" .

oc:req_746aacc9 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "pandas" .

