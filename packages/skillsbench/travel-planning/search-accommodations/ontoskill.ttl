oc:kn_20f61d08 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "when searching accommodations" ;
    oc:directiveContent "1. Install pandas (pip install pandas) 2. Import Accommodations from search_accommodations 3. Instantiate Accommodations() 4. Call acc.run(city_name) with target city 5. Use returned result for recommendations" ;
    oc:stepOrder 1 .

oc:kn_36dd6f44 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "before execution" ;
    oc:directiveContent "pandas must be installed (pip install pandas) before using the Accommodations class" ;
    oc:hasRationale "The search_accommodations module depends on pandas for dataset operations" .

oc:kn_7ed613eb a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "when querying accommodations by city" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from search_accommodations import Accommodations

acc = Accommodations()
result = acc.run("Seattle")""" .

oc:kn_b1e15b5d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "when integrating into a larger workflow" ;
    oc:directiveContent "This skill is intended as a building block within travel itinerary planning, not a standalone booking tool" ;
    oc:hasRationale "The skill description emphasizes filtering lodging options before building an itinerary" .

oc:kn_e9068681 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "when querying accommodations" ;
    oc:directiveContent "The search accepts a city name as input; only cities present in the bundled dataset will return results" ;
    oc:hasRationale "The skill queries a static bundled CSV dataset, not a live API, so coverage is limited to included cities" ;
    oc:severityLevel "MEDIUM" .

oc:req_746aacc9 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "pandas" .

_:ref_228f88395d8c533d a oc:WorkflowStep ;
    dcterms:description "Install pandas dependency (pip install pandas)" ;
    oc:expectedOutcome "pandas package available in environment" ;
    oc:stepId "install-deps" .

_:ref_6e688718c5abf92c a oc:WorkflowStep ;
    dcterms:description "Import and instantiate the Accommodations class" ;
    oc:expectedOutcome "Accommodations object ready to query" ;
    oc:stepDependsOn _:ref_228f88395d8c533d ;
    oc:stepId "instantiate-searcher" .

