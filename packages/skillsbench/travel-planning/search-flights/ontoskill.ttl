    oc:dependsOnSkill oc:skill_ontoskills_search_cities ;
    oc:differentia "filters a bundled flights CSV dataset by origin city, destination city, and departure date to return matching flight records" ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput ;
    oc:hasArgumentHint "origin_city, destination_city, departure_date (YYYY-MM-DD)" ;
    oc:hasCategory "automation" ;
    oc:hasDescription "Search flights by origin, destination, and departure date using the bundled flights dataset. Use this skill when proposing flight options or checking whether a route/date combination exists." ;
