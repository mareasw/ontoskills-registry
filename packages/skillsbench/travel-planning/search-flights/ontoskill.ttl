oc:kn_598cf4b7 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "before execution" ;
    oc:directiveContent "pandas must be installed: pip install pandas" ;
    oc:hasRationale "The Flights class depends on pandas to parse and filter the CSV dataset" .

oc:kn_62b69fc8 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When querying flights for a specific route and date" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from search_flights import Flights

flights = Flights()
print(flights.run("New York", "Los Angeles", "2022-01-15"))""" ;
    oc:hasRationale "Canonical usage pattern: instantiate Flights(), call run() with origin, destination, and YYYY-MM-DD date string" .

oc:kn_68910cca a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When specifying the departure_date argument" ;
    oc:directiveContent "Date parameter must be in YYYY-MM-DD format (e.g., \"2022-01-15\")" ;
    oc:hasRationale "The bundled dataset uses ISO date format; other formats will not match records" ;
    oc:severityLevel "HIGH" .

oc:kn_85ba0741 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "always" ;
    oc:directiveContent "This skill performs read-only queries against a bundled static CSV dataset; no external API calls or state mutations occur" ;
    oc:hasRationale "Agents can safely call this skill multiple times without side effects" .

oc:kn_e64f08eb a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "always" ;
    oc:directiveContent "Calling Flights.run() multiple times with the same parameters returns identical results" ;
    oc:hasRationale "The dataset is static and bundled; results are deterministic for the same inputs" .

oc:kn_f797f470 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When specifying origin and destination" ;
    oc:directiveContent "Origin and destination city names must match the city names stored in the bundled flights CSV" ;
    oc:hasRationale "City name mismatches will return no results; use search-cities skill to validate city names first" ;
    oc:severityLevel "MEDIUM" .

oc:req_1405193b a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Flights CSV dataset bundled with the skill" .

oc:req_746aacc9 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "pandas" .

_:ref_93ace46ef78bac24 a oc:WorkflowStep ;
    dcterms:description "Validate origin and destination city names against known cities, and confirm date is in YYYY-MM-DD format" ;
    oc:expectedOutcome "Confirmed valid city names and date format" ;
    oc:stepId "validate-inputs" .

_:ref_c787f0f2452993cb a oc:WorkflowStep ;
    dcterms:description "Install pandas dependency via pip install pandas" ;
    oc:expectedOutcome "pandas is available in the Python environment" ;
    oc:stepId "install-deps" .

