oc:skill_travel_planning_search_restaurants a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "search-restaurants" ;
    skos:broader "Data lookup skill" ;
    prov:wasDerivedFrom ".agents/skills/skillsbench/travel-planning/search-restaurants" ;
    oc:contentHash "73299c5ce85928e8acd4f616f4da358c779d2bbc000a1421b1cdfc7eef417b2a" ;
    oc:dependsOnSkill oc:skill_ontoskills_search_cities ;
    oc:differentia "queries bundled restaurant dataset by city name to retrieve dining options" ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput ;
    oc:hasAllowedTool "python" ;
    oc:hasArgumentHint "city name (e.g., \"San Francisco\")" ;
    oc:hasCategory "travel-planning" ;
    oc:hasDescription "Retrieve restaurants by city from the bundled dataset. Use this skill when recommending places to eat or validating dining options for a destination." ;
    oc:hasName "search-restaurants" ;
    oc:hasRequirement oc:req_489c6397,
        oc:req_746aacc9 ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Query restaurants for a given city." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """from search_restaurants import Restaurants

restaurants = Restaurants()
print(restaurants.run("San Francisco"))
""" ;
                            oc:codeLanguage "python" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 18-23" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Quick Start" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """pip install pandas
""" ;
                            oc:codeLanguage "bash" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 12-14" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Installation" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Search Restaurants" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: search-restaurants
description: Retrieve restaurants by city from the bundled dataset. Use this skill when recommending places to eat or validating dining options for a destination.
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
    oc:impartsKnowledge oc:kn_92d8d5d0,
        oc:kn_b1d23fb7,
        oc:kn_b85f7971,
        oc:kn_ebcff17f,
        oc:kn_f324f5d4,
        oc:kn_fba22799 ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "find restaurants in a city",
        "recommend places to eat",
        "validate dining options for a destination" ;
    oc:yieldsState oc:RestaurantsRetrieved .

oc:kn_92d8d5d0 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When providing query input" ;
    oc:directiveContent "The input must be a valid city name present in the bundled dataset; unknown cities will return no results" ;
    oc:hasRationale "The skill queries a fixed bundled dataset and cannot discover restaurants outside its scope" ;
    oc:severityLevel "MEDIUM" .

oc:kn_b1d23fb7 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Every execution" ;
    oc:directiveContent "1. Install pandas (pip install pandas) 2. Import Restaurants class 3. Instantiate Restaurants() 4. Call .run(city_name) with target city" ;
    oc:stepOrder 1 .

oc:kn_b85f7971 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before running the skill" ;
    oc:directiveContent "pandas must be installed (pip install pandas)" ;
    oc:severityLevel "HIGH" .

oc:kn_ebcff17f a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When querying restaurants for any city" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from search_restaurants import Restaurants
restaurants = Restaurants()
restaurants.run("San Francisco")""" .

oc:kn_f324f5d4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning travel" ;
    oc:directiveContent "Use this skill alongside search-accommodations and search-attractions to build complete travel itineraries" ;
    oc:hasRationale "Dining is one component of a full travel plan; combining with lodging and activities provides comprehensive recommendations" .

oc:kn_fba22799 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "Repeated executions" ;
    oc:directiveContent "This skill is read-only and idempotent; calling .run() multiple times with the same city returns the same results" ;
    oc:hasRationale "No state is mutated; safe to retry or call repeatedly" .

oc:req_489c6397 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "bundled restaurant dataset CSV" .

oc:req_746aacc9 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "pandas" .

