oc:skill_dynamic_object_aware_egomotion_dyn_object_masks a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "dyn-object-masks" ;
    skos:broader "Binary mask generator" ;
    prov:wasDerivedFrom ".agents/skills/skillsbench/dynamic-object-aware-egomotion/dyn-object-masks" ;
    oc:contentHash "837a3acc58582ca1e5640eaaf2db46148a0f71cdd2ec5841b3311412bccec65b" ;
    oc:dependsOnSkill oc:skill_ontoskills_egomotion_estimation,
        oc:skill_ontoskills_sampling_and_indexing ;
    oc:differentia "detects dynamic objects via global-motion-compensated frame differencing and outputs CSR sparse masks" ;
    oc:handlesFailure oc:InvalidWarpMatrix,
        oc:ThresholdComputationFailed ;
    oc:hasCategory "computer-vision" ;
    oc:hasDescription "Generate dynamic-object binary masks after global motion compensation, output CSR sparse format." ;
    oc:hasName "dyn-object-masks" ;
    oc:hasRequirement oc:req_0f2f0139,
        oc:req_f64b87fe,
        oc:req_ffc7dfbb ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent _:ref_702bd7f34f7ec9a4 ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 2 ;
            oc:sectionTitle "Workflow" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: dyn-object-masks
description: "Generate dynamic-object binary masks after global motion compensation, output CSR sparse format."
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 1 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "Detect moving objects in scenes with camera motion; produce sparse masks aligned to sampled frames." ] ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "When to use" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """warped_prev = cv2.warpAffine(prev_gray, M, (W,H), flags=cv2.INTER_LINEAR, borderValue=0)
valid = cv2.warpAffine(np.ones((H,W),uint8), M, (W,H), flags=cv2.INTER_NEAREST)>0
diff = cv2.absdiff(curr_gray, warped_prev)
vals = diff[valid]
thr = max(20, np.median(vals) + 3*1.4826*np.median(np.abs(vals - np.median(vals))))
raw = (diff>thr) & valid
m = cv2.morphologyEx(raw.astype(uint8)*255, cv2.MORPH_OPEN, k3)
m = cv2.morphologyEx(m, cv2.MORPH_CLOSE, k7)
n, cc, stats, _ = cv2.connectedComponentsWithStats(m>0, connectivity=8)
mask = np.zeros_like(raw, dtype=bool)
for cid in range(1,n):
    if stats[cid, cv2.CC_STAT_AREA] >= min_area:
        mask |= (cc==cid)
""" ;
                    oc:codeLanguage "python" ;
                    oc:contentOrder 1 ;
                    oc:sourceLocation "lines 21-35" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 3 ;
            oc:sectionTitle "Code sketch" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 1 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "[ ] Border fill not treated as foreground; threshold stats computed on valid region only." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "[ ] Threshold + morphology + area filter applied." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "[ ] Masks only for sampled frames; keys match sampled indices." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "[ ] `shape` stored as `[H, W]` int32; `len(indptr)==H+1`; `indptr[-1]==indices.size`." ] ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 4 ;
            oc:sectionTitle "Self-check" ] ;
    oc:hasWorkflow _:ref_702bd7f34f7ec9a4,
        [ a oc:Workflow ;
            dcterms:description "Generate binary masks for dynamic objects from sampled video frames using global-motion-compensated differencing." ;
            oc:hasStep [ a oc:WorkflowStep ;
                    dcterms:description "Encode final boolean mask as CSR sparse arrays (indptr, indices, data) and store as f_{i}_data/indices/indptr." ;
                    oc:expectedOutcome "CSR sparse mask files written to disk" ;
                    oc:stepDependsOn _:ref_4f9632a45815436d ;
                    oc:stepId "csr-encode" ],
                _:ref_4f9632a45815436d,
                _:ref_7842501bb9401a11,
                _:ref_b0d37c736f9dca6a,
                _:ref_f60e205b8b41b3b1 ;
            oc:workflowId "dyn-mask-gen" ;
            oc:workflowName "Dynamic Object Mask Generation" ] ;
    oc:impartsKnowledge oc:kn_1d29947c,
        oc:kn_4c1880a2,
        oc:kn_57d7145d,
        oc:kn_9139174f,
        oc:kn_c557db63 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:CameraMotionEstimated,
        oc:VideoFramesSampled ;
    oc:resolvesIntent "detect moving objects in video with camera motion",
        "generate binary masks for dynamic objects",
        "produce sparse CSR-encoded foreground masks aligned to sampled frames" ;
    oc:yieldsState oc:DynamicObjectMasksGenerated .

oc:kn_1d29947c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When encoding final mask to CSR sparse format" ;
    oc:directiveContent "CSR output must satisfy: shape stored as [H, W] int32, len(indptr)==H+1, indptr[-1]==indices.size, data as uint8 ones, indices as int32 column indices." ;
    oc:hasRationale "Inconsistent CSR structure breaks downstream consumers that parse indptr/indices/data arrays." ;
    oc:severityLevel "HIGH" .

oc:kn_4c1880a2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When computing adaptive threshold on warped difference image" ;
    oc:directiveContent "Threshold statistics (median, MAD) must be computed only on the valid (non-border-fill) region; border pixels from warping must be excluded to avoid false foreground detection." ;
    oc:hasRationale "Border fill values from cv2.warpAffine are arbitrary (0) and would corrupt noise-level estimation, producing too-low thresholds and spurious detections at image borders." ;
    oc:severityLevel "CRITICAL" .

oc:kn_57d7145d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing global alignment warp" ;
    oc:directiveContent "Do not skip the valid-region mask computation — warping an all-ones image alongside the frame is required to know which pixels are reliable." ;
    oc:hasRationale "Without the valid region mask, border artifacts from warp extrapolation are treated as valid pixels, introducing systematic false detections at image boundaries." ;
    oc:severityLevel "HIGH" .

oc:kn_9139174f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When computing adaptive threshold" ;
    oc:directiveContent "Use a minimum threshold floor (e.g., 20) alongside the adaptive median+3*MAD threshold to avoid triggering on sensor noise in near-static regions." ;
    oc:hasRationale "In homogeneous regions the MAD can be very small, causing the adaptive threshold to drop below sensor noise level and produce excessive false positives." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c557db63 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When post-processing raw difference mask" ;
    oc:directiveContent "Apply morphological open (remove noise) then close (fill gaps), then filter connected components by minimum area — tune as fraction of image area or fixed pixel threshold." ;
    oc:hasRationale "Raw thresholded difference contains salt-and-pepper noise and fragmented regions; morphology + area filtering yields coherent object-level masks." ;
    oc:severityLevel "MEDIUM" .

oc:req_0f2f0139 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "NumPy" .

oc:req_f64b87fe a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "OpenCV (cv2)" .

oc:req_ffc7dfbb a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Affine/homography warp from egomotion estimation" .

_:ref_0909edfba5a25f07 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 3 ;
    oc:itemText "`counts = bincount(rows, minlength=H)`; `indptr = cumsum(counts, prepend=0)`" .

_:ref_792f4e51345a59f8 a oc:WorkflowStep ;
    dcterms:description "**Difference + adaptive threshold**: `diff = abs(curr - warp_prev)`; on `diff[valid]` compute median + 3×MAD; use a reasonable minimum threshold to avoid triggering on noise." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_897c25088a63b252 a oc:WorkflowStep ;
    dcterms:description "**Valid region**: also warp an all-ones mask to get `valid` pixels, avoiding border fill." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_8f708b4468bb4d2a a oc:WorkflowStep ;
    dcterms:description "**CSR encoding**: for final bool mask" ;
    oc:blockType "workflow_step" ;
    oc:hasChild [ a oc:BulletList ;
            oc:blockType "bullet_list" ;
            oc:contentOrder 1 ;
            oc:hasItem _:ref_0909edfba5a25f07,
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 1 ;
                    oc:itemText "`rows, cols = nonzero(mask)`" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 2 ;
                    oc:itemText "`indices = cols.astype(int32)`; `data = ones(nnz, uint8)`" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 4 ;
                    oc:itemText "store as `f_{i}_data/indices/indptr`" ] ] ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_af935e67aff2ca5d a oc:WorkflowStep ;
    dcterms:description "**Morphology + area filter**: open then close; keep connected components above a minimum area (tune as fraction of image area or a fixed pixel threshold)." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_bd43b19ee6907a5b a oc:WorkflowStep ;
    dcterms:description "**Global alignment**: warp previous gray frame to current using estimated affine/homography." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_4f9632a45815436d a oc:WorkflowStep ;
    dcterms:description "Apply morphological open then close, then keep connected components above minimum area." ;
    oc:expectedOutcome "Cleaned binary mask with coherent object regions" ;
    oc:stepDependsOn _:ref_b0d37c736f9dca6a ;
    oc:stepId "morphology-filter" .

_:ref_702bd7f34f7ec9a4 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_792f4e51345a59f8,
        _:ref_897c25088a63b252,
        _:ref_8f708b4468bb4d2a,
        _:ref_af935e67aff2ca5d,
        _:ref_bd43b19ee6907a5b ;
    oc:workflowId "procedure_1" ;
    oc:workflowName "Ordered Procedure" .

_:ref_7842501bb9401a11 a oc:WorkflowStep ;
    dcterms:description "Warp previous grayscale frame to current frame coordinates using estimated affine/homography matrix M." ;
    oc:expectedOutcome "warped_prev aligned to current frame" ;
    oc:stepId "warp-prev" .

_:ref_b0d37c736f9dca6a a oc:WorkflowStep ;
    dcterms:description "Compute absolute difference, calculate adaptive threshold (median + 3*MAD on valid pixels), apply minimum floor." ;
    oc:expectedOutcome "Raw binary foreground mask" ;
    oc:stepDependsOn _:ref_f60e205b8b41b3b1 ;
    oc:stepId "diff-threshold" .

_:ref_f60e205b8b41b3b1 a oc:WorkflowStep ;
    dcterms:description "Warp all-ones mask with same transformation to identify valid (non-border-fill) pixels." ;
    oc:expectedOutcome "valid boolean mask marking reliable pixels" ;
    oc:stepDependsOn _:ref_7842501bb9401a11 ;
    oc:stepId "compute-valid" .

