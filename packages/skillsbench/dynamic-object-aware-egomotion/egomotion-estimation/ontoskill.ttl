oc:skill_dynamic_object_aware_egomotion_egomotion_estimation a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "egomotion-estimation" ;
    skos:broader "Motion estimation pipeline" ;
    prov:wasDerivedFrom ".agents/skills/skillsbench/dynamic-object-aware-egomotion/egomotion-estimation" ;
    oc:contentHash "c586e76f61bf4f8cdc2daf91803b1c098eefa1d357deaa3c4f7e65f88f1840e2" ;
    oc:dependsOnSkill oc:skill_ontoskills_sampling_and_indexing ;
    oc:differentia "that classifies camera egomotion into multi-label categories (Stay/Dolly/Pan/Tilt/Roll) per frame using optical flow and robust affine/homography transforms with RANSAC" ;
    oc:handlesFailure oc:InsufficientFeatures,
        oc:TransformEstimationFailed ;
    oc:hasCategory "research" ;
    oc:hasDescription "Estimate camera motion with optical flow + affine/homography, allow multi-label per frame." ;
    oc:hasName "egomotion-estimation" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 1 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "Low texture/low light: increase feature count, use larger LK windows, and relax RANSAC settings." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "Tune thresholds based on resolution and frame rate (e.g., normalize translation by image width/height, rotation in degrees, scale as relative ratio)." ] ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 4 ;
            oc:sectionTitle "Heuristic starting points (720p, high fps; scale with resolution/fps)" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: egomotion-estimation
description: "Estimate camera motion with optical flow + affine/homography, allow multi-label per frame."
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """labels=[]
for each frame i>0:
    lbl=[]
    if abs(scale-1)>th_scale: lbl.append("Dolly In" if scale>1 else "Dolly Out")
    if abs(rot)>th_rot: lbl.append("Roll Right" if rot>0 else "Roll Left")
    if abs(dx)>th_trans and abs(dx)>=abs(dy): lbl.append("Pan Left" if dx>0 else "Pan Right")
    if abs(dy)>th_trans and abs(dy)>abs(dx): lbl.append("Tilt Up" if dy>0 else "Tilt Down")
    if not lbl: lbl.append("Stay")
    labels.append(lbl)
""" ;
                    oc:codeLanguage "python" ;
                    oc:contentOrder 1 ;
                    oc:sourceLocation "lines 19-29" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 3 ;
            oc:sectionTitle "Decision sketch" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 1 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "You need to classify camera motion (Stay/Dolly/Pan/Tilt/Roll) from video, allowing multiple labels on the same frame." ] ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "When to use" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 1 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "[ ] Direction conventions consistent (image right shift = camera pans left)." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "[ ] Compressed intervals cover all sampled frames; keys formatted correctly." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "[ ] Multi-label allowed; no forced single label." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "[ ] Fallback to identity transform on failure; never emit empty labels." ] ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 5 ;
            oc:sectionTitle "Self-check" ],
        [ a oc:Section ;
            oc:hasContent _:ref_0fc5033adf1a9e63 ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 2 ;
            oc:sectionTitle "Workflow" ] ;
    oc:hasWorkflow _:ref_0fc5033adf1a9e63,
        [ a oc:Workflow ;
            dcterms:description "Full pipeline from video frames to compressed motion interval labels." ;
            oc:hasStep _:ref_06295fc81be95f1b,
                _:ref_3f5f94d97bb44a26,
                _:ref_888fc18c5c78d294,
                _:ref_89352670dd26c532,
                [ a oc:WorkflowStep ;
                    dcterms:description "Merge consecutive frames with identical label sets into start->end intervals." ;
                    oc:expectedOutcome "Compressed interval list covering all sampled frames" ;
                    oc:stepDependsOn _:ref_06295fc81be95f1b ;
                    oc:stepId "interval-compress" ] ;
            oc:workflowId "egomotion-pipeline" ;
            oc:workflowName "Egomotion Estimation Pipeline" ] ;
    oc:impartsKnowledge oc:kn_23200783,
        oc:kn_2e35b9b4,
        oc:kn_80adb719,
        oc:kn_a596521c,
        oc:kn_ac667303,
        oc:kn_d0695074,
        oc:kn_eda95ffd,
        oc:kn_f17c2e8c ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady,
        oc:VideoFramesAvailable ;
    oc:resolvesIntent "classify camera movement types per frame",
        "detect dolly pan tilt roll stay labels in video",
        "estimate camera motion from video",
        "produce temporal motion labels with interval compression" ;
    oc:yieldsState oc:EgomotionEstimated,
        oc:MotionLabelsGenerated .

oc:kn_23200783 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring motion classification thresholds" ;
    oc:directiveContent "Tune thresholds based on resolution and frame rate: normalize translation by image width/height, rotation in degrees, scale as relative ratio. Starting values target 720p high fps." ;
    oc:hasRationale "Raw pixel thresholds are resolution-dependent; normalizing ensures consistent classification across different video formats." ;
    oc:severityLevel "HIGH" .

oc:kn_2e35b9b4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When classifying frame-level motion" ;
    oc:directiveContent "Allow multiple labels per frame: if scale and translate are both significant, emit both Dolly + Pan; rotation is independent for Roll." ;
    oc:hasRationale "Camera motion is compositional — a camera can dolly and pan simultaneously. Forcing a single label loses information." ;
    oc:severityLevel "CRITICAL" .

oc:kn_80adb719 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When labeling any frame" ;
    oc:directiveContent "Never emit empty labels for a frame. Always fall back to at least 'Stay' when no motion threshold is exceeded." ;
    oc:hasRationale "Empty labels break downstream interval compression and create coverage gaps." ;
    oc:severityLevel "CRITICAL" .

oc:kn_a596521c a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When interpreting motion vectors" ;
    oc:directiveContent "Direction conventions must be consistent: image right shift means camera pans left. Verify and document the convention used." ;
    oc:hasRationale "Confusing image motion direction with camera motion direction inverts pan/tilt labels and invalidates results." ;
    oc:severityLevel "CRITICAL" .

oc:kn_ac667303 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When estimateAffinePartial2D or homography estimation returns failure" ;
    oc:directiveContent "Fall back to identity transform when robust estimation fails (e.g., too few inliers). Label frame as 'Stay'." ;
    oc:hasRationale "A graceful fallback prevents pipeline crashes and maintains temporal continuity." .

oc:kn_d0695074 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When re-executing the pipeline" ;
    oc:directiveContent "Re-running estimation on the same video with the same parameters and thresholds should produce identical labels." ;
    oc:hasRationale "Deterministic output ensures reproducibility of motion annotations." .

oc:kn_eda95ffd a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After interval compression step" ;
    oc:directiveContent "Verify that compressed intervals cover all sampled frames, keys are formatted correctly, and no frame has empty labels." ;
    oc:hasRationale "Gaps in coverage or malformed keys break downstream mask alignment and output validation." .

oc:kn_f17c2e8c a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When feature tracking produces too few points" ;
    oc:directiveContent "Low texture / low light scenes produce insufficient feature tracks. Increase feature count, use larger LK windows, and relax RANSAC settings to compensate." ;
    oc:hasRationale "Sparse or unreliable features lead to unstable transform estimation and noisy labels." ;
    oc:severityLevel "HIGH" .

_:ref_19630410b245926a a oc:WorkflowStep ;
    dcterms:description "**Feature tracking**: `goodFeaturesToTrack` + `calcOpticalFlowPyrLK`; drop if too few points." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_269bb9b33fe0ff49 a oc:WorkflowStep ;
    dcterms:description "**Interval compression**: merge consecutive frames with identical label sets into `start->end`." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_303c684a1f7f6858 a oc:WorkflowStep ;
    dcterms:description "**Thresholding (example values)**" ;
    oc:blockType "workflow_step" ;
    oc:hasChild [ a oc:BulletList ;
            oc:blockType "bullet_list" ;
            oc:contentOrder 1 ;
            oc:hasItem [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 1 ;
                    oc:itemText "Translate threshold `th_trans` (px/frame), rotation (rad), scale delta (ratio)." ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 2 ;
                    oc:itemText "Allow multiple labels: if scale and translate are both significant, emit Dolly + Pan; rotation independent for Roll." ] ] ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_3997257d398a5347 a oc:WorkflowStep ;
    dcterms:description "**Temporal smoothing**: windowed mode/median to reduce flicker." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_e047ff515f0e529a a oc:WorkflowStep ;
    dcterms:description "**Robust transform**: `estimateAffinePartial2D` (or homography) with RANSAC to get tx, ty, rotation, scale." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_06295fc81be95f1b a oc:WorkflowStep ;
    dcterms:description "Apply windowed mode/median smoothing across frames to reduce label flicker." ;
    oc:expectedOutcome "Smoothed per-frame label sequences" ;
    oc:stepDependsOn _:ref_89352670dd26c532 ;
    oc:stepId "temporal-smooth" .

_:ref_0fc5033adf1a9e63 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_19630410b245926a,
        _:ref_269bb9b33fe0ff49,
        _:ref_303c684a1f7f6858,
        _:ref_3997257d398a5347,
        _:ref_e047ff515f0e529a ;
    oc:workflowId "procedure_1" ;
    oc:workflowName "Ordered Procedure" .

_:ref_3f5f94d97bb44a26 a oc:WorkflowStep ;
    dcterms:description "Track features across consecutive frames using goodFeaturesToTrack + calcOpticalFlowPyrLK. Drop frame if too few points." ;
    oc:expectedOutcome "Sparse optical flow field between frame pairs" ;
    oc:stepId "feature-track" .

_:ref_888fc18c5c78d294 a oc:WorkflowStep ;
    dcterms:description "Estimate affine/homography transform with RANSAC to extract tx, ty, rotation, scale parameters." ;
    oc:expectedOutcome "Per-frame motion parameters (translation, rotation, scale)" ;
    oc:stepDependsOn _:ref_3f5f94d97bb44a26 ;
    oc:stepId "robust-transform" .

_:ref_89352670dd26c532 a oc:WorkflowStep ;
    dcterms:description "Apply thresholds on translation, rotation, and scale to assign multi-label motion categories (Dolly/Pan/Tilt/Roll/Stay)." ;
    oc:expectedOutcome "Multi-label list per frame" ;
    oc:stepDependsOn _:ref_888fc18c5c78d294 ;
    oc:stepId "threshold-label" .

