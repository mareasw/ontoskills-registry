oc:skill_threejs_structure_parser_obj_exporter a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "obj-exporter" ;
    skos:broader "Exporter" ;
    prov:wasDerivedFrom ".agents/skills/skillsbench/threejs-structure-parser/obj-exporter" ;
    oc:contentHash "73413a8de78217680378453cf0ce2e4a2d40896c0270310ef31b3b3c5ffc7e67" ;
    oc:differentia "Converts Three.js 3D geometry to Wavefront OBJ text format for interoperability with external 3D software" ;
    oc:handlesFailure oc:InvalidInput,
        oc:PermissionDenied ;
    oc:hasArgumentHint "object3D or scene root to export" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Three.js OBJExporter utility for exporting 3D geometry to Wavefront OBJ format. Use when converting Three.js scenes, meshes, or geometries to OBJ files for use in other 3D software like Blender, Maya, or MeshLab." ;
    oc:hasName "obj-exporter" ;
    oc:hasRequirement oc:req_06c12759,
        oc:req_2a52f6bb,
        oc:req_439772b0,
        oc:req_7d80f8ee ;
    oc:hasSection [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """import { OBJExporter } from 'three/examples/jsm/exporters/OBJExporter.js';

const exporter = new OBJExporter();

function exportMesh(mesh, filepath) {
    let geom = mesh.geometry.clone();
    geom.applyMatrix4(mesh.matrixWorld);
    if (geom.index) {
        geom = geom.toNonIndexed();
    }
    if (!geom.attributes.normal) {
        geom.computeVertexNormals();
    }
    const tempMesh = new THREE.Mesh(geom);
    tempMesh.name = mesh.name;
    const objData = exporter.parse(tempMesh);
    fs.writeFileSync(filepath, objData);
}
""" ;
                            oc:codeLanguage "javascript" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 132-151" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Export Individual Meshes (World Transforms)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Write OBJ files to the paths specified by the task instructions or a provided output root variable. Avoid hardcoding fixed directories in the skill itself." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Output Paths" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """function collectComponentMeshes(root) {
    const componentMap = {};
    root.traverse(obj => {
        if (obj instanceof THREE.Group && obj.name) {
            componentMap[obj.name] = { group: obj, meshes: [] };
        }
    });

    root.traverse(obj => {
        if (obj instanceof THREE.Mesh) {
            let parent = obj.parent;
            while (parent && !(parent instanceof THREE.Group && parent.name)) {
                parent = parent.parent;
            }
            if (parent && componentMap[parent.name]) {
                componentMap[parent.name].meshes.push(obj);
            }
        }
    });

    return Object.fromEntries(
        Object.entries(componentMap).filter(([_, data]) => data.meshes.length > 0)
    );
}
""" ;
                            oc:codeLanguage "javascript" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 103-128" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Treat each **named `THREE.Group`** as a component/part. Preserve hierarchy by using the **nearest named parent group** in the ancestor chain as the owning component for each mesh. Call `root.updateMatrixWorld(true)` before exporting so `matrixWorld` is correct." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Component Definition (Hierarchy-Aware)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """import { mergeGeometries } from 'three/examples/jsm/utils/BufferGeometryUtils.js';

function mergeMeshes(meshes) {
    const geometries = [];
    for (const mesh of meshes) {
        let geom = mesh.geometry.clone();
        geom.applyMatrix4(mesh.matrixWorld);
        if (geom.index) {
            geom = geom.toNonIndexed();
        }
        if (!geom.attributes.normal) {
            geom.computeVertexNormals();
        }
        geometries.push(geom);
    }
    if (geometries.length === 0) return null;
    return new THREE.Mesh(mergeGeometries(geometries, false));
}
""" ;
                            oc:codeLanguage "javascript" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 155-174" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Export Merged Component Meshes (Optional)" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 2 ;
            oc:sectionTitle "OBJ Export for Scene Components" ],
        [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """import { mergeGeometries } from 'three/examples/jsm/utils/BufferGeometryUtils.js';

const geometries = [];
root.traverse((obj) => {
  if (obj instanceof THREE.Mesh) {
    const geom = obj.geometry.clone();
    geom.applyMatrix4(obj.matrixWorld);
    geometries.push(geom);
  }
});

const merged = mergeGeometries(geometries);
const mergedMesh = new THREE.Mesh(merged);
const objData = exporter.parse(mergedMesh);
""" ;
                            oc:codeLanguage "javascript" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 65-80" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Merging Multiple Geometries" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "To export geometry in world coordinates:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """// Update world matrices first
root.updateMatrixWorld(true);

// Clone and transform geometry
const worldGeometry = mesh.geometry.clone();
worldGeometry.applyMatrix4(mesh.matrixWorld);

// Create new mesh for export
const exportMesh = new THREE.Mesh(worldGeometry);
const objData = exporter.parse(exportMesh);
""" ;
                            oc:codeLanguage "javascript" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 50-61" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Exporting with World Transforms" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Three.js provides `OBJExporter` in examples:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """import { OBJExporter } from 'three/examples/jsm/exporters/OBJExporter.js';

const exporter = new OBJExporter();
const objString = exporter.parse(object3D);

// Write to file (Node.js)
import fs from 'fs';
fs.writeFileSync('output.obj', objString);
""" ;
                            oc:codeLanguage "javascript" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 35-44" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Three.js OBJExporter" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """// package.json
{ "type": "module" }
""" ;
                            oc:codeLanguage "json" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 86-89" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "For running Three.js in Node.js:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """// script.js
import * as THREE from 'three';
import { OBJExporter } from 'three/examples/jsm/exporters/OBJExporter.js';
""" ;
                            oc:codeLanguage "javascript" ;
