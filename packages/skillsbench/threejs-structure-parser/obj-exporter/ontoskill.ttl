oc:kn_4d852009 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing geometry for export" ;
    oc:directiveContent "Never export geometry without cloning first — mesh.geometry.clone() is required before applyMatrix4 to avoid mutating the original scene geometry" ;
    oc:hasRationale "applyMatrix4 mutates the geometry in-place; without cloning, the live scene geometry would be corrupted" ;
    oc:severityLevel "CRITICAL" .

oc:kn_4edee1f5 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "When running OBJ export in Node.js environment" ;
    oc:directiveContent "Three.js must be installed (npm install three) and package.json must have 'type': 'module' for ES module imports" .

oc:kn_64796b04 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When exporting a single mesh with correct world transforms and normals" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """let geom = mesh.geometry.clone();
geom.applyMatrix4(mesh.matrixWorld);
if (geom.index) { geom = geom.toNonIndexed(); }
if (!geom.attributes.normal) { geom.computeVertexNormals(); }
const tempMesh = new THREE.Mesh(geom);
const objData = exporter.parse(tempMesh);""" .

oc:kn_88d2e023 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining output file paths" ;
    oc:directiveContent "Write OBJ files to paths specified by task instructions or a provided output root variable — avoid hardcoding fixed directories" ;
    oc:hasRationale "Hardcoded paths reduce reusability and may cause conflicts across different execution contexts" ;
    oc:severityLevel "MEDIUM" .

oc:kn_ad12e6bc a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When exporting any Three.js mesh to OBJ" ;
    oc:directiveContent "1. Import OBJExporter from three/examples/jsm/exporters/OBJExporter.js 2. Call root.updateMatrixWorld(true) to ensure correct transforms 3. Clone geometry and applyMatrix4(mesh.matrixWorld) for world-space export 4. Convert indexed geometry to non-indexed (toNonIndexed) 5. Compute vertex normals if missing (computeVertexNormals) 6. Create temp mesh with processed geometry 7. Call exporter.parse(tempMesh) to get OBJ string 8. Write string to file with fs.writeFileSync" ;
    oc:hasRationale "Ensures exported geometry is in world coordinates with valid normals for import into external tools" ;
    oc:stepOrder 1 .

oc:kn_c1e6f25d a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When mapping meshes to their owning named parent group for component-based export" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """root.traverse(obj => {
    if (obj instanceof THREE.Mesh) {
        let parent = obj.parent;
        while (parent && !(parent instanceof THREE.Group && parent.name)) {
            parent = parent.parent;
        }
        if (parent && componentMap[parent.name]) {
            componentMap[parent.name].meshes.push(obj);
        }
    }
});""" .

oc:kn_d4ca9a73 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When users expect material/texture data in export" ;
    oc:directiveContent "OBJExporter does not export materials or textures — only geometry (vertices, normals, faces)" ;
    oc:hasRationale "OBJ format supports materials via MTL files but Three.js OBJExporter only outputs geometry data" ;
    oc:severityLevel "HIGH" .

oc:kn_d4efc807 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When exporting scene components with hierarchy awareness" ;
    oc:directiveContent "1. Traverse root to collect named THREE.Group instances as components 2. For each mesh, walk ancestor chain to find nearest named parent Group 3. Group meshes by their owning component name 4. Filter out components with no meshes 5. Export each component's meshes (individually or merged) to separate OBJ files" ;
    oc:hasRationale "Preserves logical structure of the scene so that exported files correspond to meaningful parts" ;
    oc:stepOrder 2 .

oc:kn_eb1f92c3 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before any export operation" ;
    oc:directiveContent "Always call root.updateMatrixWorld(true) before traversing the scene for export" ;
    oc:hasRationale "Without updated world matrices, exported vertices will be in local space, producing incorrect geometry in the OBJ file" ;
    oc:severityLevel "CRITICAL" .

