                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "**IMPORTANT: Use `detect_port_scan()` from pcap_utils.py for accurate results!**" ],
