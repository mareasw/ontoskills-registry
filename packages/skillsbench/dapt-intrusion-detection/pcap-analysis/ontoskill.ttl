                                            oc:itemText "No beaconing behavior (use `detect_beaconing()`)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "No port scanning detected (use `detect_port_scan()`)" ],
                                        [ a oc:BulletItem ;
