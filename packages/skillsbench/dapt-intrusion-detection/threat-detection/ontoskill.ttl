                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """def detect_beaconing(iat_cv):
    \"\"\"Regular timing (CV < 0.5) suggests C2 beaconing.\"\"\"
    return iat_cv < 0.5
""" ;
