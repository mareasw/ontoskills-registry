oc:kn_14639a22 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating DoS patterns" ;
    oc:directiveContent "DoS detection requires max/avg packets-per-minute ratio > 20. Ratios of 5x, 10x, or 15x are normal traffic variations, NOT DoS." ;
    oc:hasRationale "Normal traffic has natural spikes up to 15x average. Only extreme spikes (>20x) indicate actual denial-of-service attacks." ;
    oc:severityLevel "CRITICAL" .

oc:kn_24b2eb78 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When running detection in production pipelines" ;
    oc:directiveContent "Detection functions are read-only analyzers that do not modify network data. They return boolean results without altering the input packets." ;
    oc:hasRationale "Safe to run multiple detection passes without corrupting evidence." ;
    oc:severityLevel "LOW" .

oc:kn_50049e07 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating beaconing behavior" ;
    oc:directiveContent "C2 beaconing is detected when IAT coefficient of variation (CV = std/mean) < 0.5. High CV (>1.0) indicates normal human/bursty traffic." ;
    oc:hasRationale "Beaconing malware communicates on regular intervals producing low timing variance. Human traffic is bursty with high variance." ;
    oc:severityLevel "CRITICAL" .

oc:kn_5e425ce5 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before executing any detection" ;
    oc:directiveContent "Requires pcap-analysis skill with pcap_utils module available at /root/skills/pcap-analysis/, or scapy library for manual implementation." ;
    oc:hasRationale "Detection functions depend on either the shared utility module or scapy for packet parsing." ;
    oc:severityLevel "HIGH" .

oc:kn_76fab5e6 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When interpreting port entropy values" ;
    oc:directiveContent "Normal port traffic has entropy around 4-5 bits (clustered on few well-known ports). Scanner traffic has entropy > 6 bits (uniform distribution across ports)." ;
    oc:hasRationale "Legitimate traffic concentrates on common service ports (80, 443, 22), producing low entropy. Scanners probe ports uniformly, producing high entropy." ;
    oc:severityLevel "MEDIUM" .

oc:kn_cca7e098 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When making final traffic classification" ;
    oc:directiveContent "Traffic is benign ONLY if ALL threat detections return false. Any single positive detection means the traffic is not benign." ;
    oc:hasRationale "Conservative classification ensures no threats are missed. A single confirmed threat pattern is sufficient to flag traffic." ;
    oc:severityLevel "HIGH" .

oc:kn_d9e93d9d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating port scan detection results" ;
    oc:directiveContent "Port scan detection requires ALL THREE conditions simultaneously: port entropy > 6.0 bits, SYN-only ratio > 0.7, AND unique ports > 100. If ANY condition is not met, there is NO port scan." ;
    oc:hasRationale "Multi-condition detection eliminates false positives from normal high-port-count traffic that clusters on specific ports or completes TCP handshakes." ;
    oc:severityLevel "CRITICAL" .

oc:kn_f7856d2a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When detecting port scans" ;
    oc:directiveContent "Never use simple port count as the sole indicator of port scanning. A high unique port count alone can be normal service traffic." ;
    oc:hasRationale "Traffic hitting many ports to one target can be normal if it has low entropy (clustered on few ports) and low SYN-only ratio (completing handshakes). Single-metric detection produces false positives." ;
    oc:severityLevel "CRITICAL" .

