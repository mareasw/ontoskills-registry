                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """def detect_dos_pattern(ppm_avg, ppm_max):
    \"\"\"DoS requires ratio > 20. Lower ratios are normal variation.\"\"\"
    if ppm_avg == 0:
        return False
    ratio = ppm_max / ppm_avg
    return ratio > 20
""" ;
