oc:kn_0b8fada9 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """Quality checklist before commit:
- [ ] `lake build` succeeds on full project
- [ ] All sorries documented with concrete strategy
- [ ] No new axioms without elimination plan
- [ ] Imports minimal""" ;
    oc:templateVariables "checklist items" .

oc:kn_19af6792 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "Check which axioms a theorem depends on" ;
    oc:codeLanguage "lean" ;
    oc:directiveContent "#print axioms theorem_name" .

oc:kn_3d0a450a a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When developing any Lean 4 proof" ;
    oc:directiveContent "1. Structure Before Solving — outline proof strategy with `have` statements and documented sorries. 2. Helper Lemmas First — build infrastructure bottom-up. 3. Incremental Filling — fill ONE sorry at a time, compile after each. 4. Type Class Management — add explicit `haveI`/`letI` instances when synthesis fails." ;
    oc:stepOrder 1 .

oc:kn_4696a571 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When proofs fail to compile" ;
    oc:directiveContent "Use compiler-guided repair for failing proofs: compile → extract structured error → try solver cascade (rfl → simp → ring → linarith → nlinarith → omega → exact? → apply? → aesop) → escalate to LLM if needed → apply minimal patch → recompile → repeat." ;
    oc:hasRationale "Error-driven action selection with a free solver cascade and model escalation is far more efficient than random resampling." .

oc:kn_56432473 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When evaluating proof completeness" ;
    oc:directiveContent "Success = `lake build` passes + zero sorries + zero custom axioms. Standard mathlib axioms (Classical.choice, propext, quot.sound) are acceptable." ;
    oc:hasRationale "Only axioms from the standard set are safe; custom axioms can introduce inconsistency and must have elimination plans." ;
    oc:severityLevel "CRITICAL" .

oc:kn_6f0d081d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before every commit in a Lean 4 project" ;
    oc:directiveContent "ALWAYS compile before committing. Run `lake build` to verify. 'Compiles' ≠ 'Complete' — files can compile with sorries/axioms but aren't done until those are eliminated." ;
    oc:hasRationale "The Lean type checker is your test suite; successful compilation catches most errors early but does not guarantee proof completeness." ;
    oc:severityLevel "CRITICAL" .

oc:kn_7d46c520 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When encountering 'failed to synthesize instance' or 'maximum recursion depth' errors" ;
    oc:codeLanguage "lean" ;
    oc:directiveContent "When type class synthesis fails, add explicit instances: `haveI : Instance := ...` for have-level instances or `letI := ...` to break recursion depth issues." ;
    oc:hasRationale "Lean's type class resolution can fail in complex instance chains; explicit provision bypasses synthesis and avoids infinite loops." .

oc:kn_92a23a35 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing or committing proofs" ;
    oc:directiveContent "Do NOT accept sorries or axioms as complete work. 'Should be in mathlib', 'infrastructure lemma', or 'will prove later' without a concrete plan are not acceptable justifications." ;
    oc:hasRationale "Sorries and axioms are scaffolding, not results. Undocumented sorries accumulate technical debt." ;
    oc:severityLevel "HIGH" .

oc:kn_9a6183ff a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When proof size exceeds thresholds" ;
    oc:directiveContent "Monolithic proofs >100 lines and `have` blocks >30 lines should be refactored into separate lemmas." ;
    oc:hasRationale "Large proofs are hard to maintain, debug, and compose. Extracted lemmas are reusable and independently verifiable." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ca9416ec a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "Verify Lean 4 project compiles successfully" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "lake build" .

oc:kn_cd164afb a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before starting any new proof" ;
    oc:directiveContent "Search before prove. Mathlib has 100,000+ theorems. Use `/search-mathlib`, LSP server search tools, or automation scripts to find existing lemmas before attempting to prove something from scratch." ;
    oc:hasRationale "Duplicating existing mathlib results wastes effort and may be less general than what already exists." .

_:ref_10b5974c7cbf1520 a oc:WorkflowStep ;
    dcterms:description "**Structure Before Solving** - Outline proof strategy with `have` statements and documented sorries before writing tactics" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_1ecf55697cd0aefb a oc:WorkflowStep ;
    dcterms:description "Apply minimal patch (1-5 lines), recompile, repeat (max 24 attempts)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_4805b60d0f8ec640 a oc:BulletList ;
    oc:blockType "bullet_list" ;
    oc:contentOrder 1 ;
    oc:hasItem [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 1 ;
            oc:itemText "Order: `rfl → simp → ring → linarith → nlinarith → omega → exact? → apply? → aesop`" ] .

_:ref_7399e8394ffd63b6 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 1 ;
    oc:itemText "**Stage 1:** Haiku (fast, most common cases) - 6 attempts" .

