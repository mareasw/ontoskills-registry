    oc:templateVariables "meets_conveyor",
        "meets_peak",
        "peak_c",
        "ramp_c_per_s",
        "required_min_speed_cm_min",
        "required_peak_c",
        "run_id",
        "tal_s" .

oc:kn_2b4e0f36 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When extracting limits from the handbook" ;
    oc:directiveContent "If the handbook provides multiple applicable constraints for the same metric, implement all and use the stricter constraint, documenting the choice in code comments." ;
    oc:hasRationale "Multiple overlapping constraints from different handbook sections must be reconciled; stricter compliance ensures no violation is missed." ;
    oc:severityLevel "MEDIUM" .

oc:kn_2df1dfca a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "End-to-end reflow profile compliance computation" ;
    oc:directiveContent "1. Load MES log and thermocouple CSVs; cast run_id/tc_id to string 2. Sort both DataFrames with mergesort 3. Extract compact cfg object from handbook (regions, limits, windows, margins, feasibility rules) 4. Compute per-run metrics: max ramp via finite-difference slope, TAL via interpolated time-above-threshold, peak with coldest-sensor tie-break, conveyor feasibility 5. Build JSON outputs with sorted IDs and 2dp rounding 6. Run sanity checks 7. Write to /app/output" ;
    oc:stepOrder 1 .

oc:kn_4d395cf4 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before writing final compliance output files" ;
    oc:directiveContent "Verify before output: ID fields are strings, arrays sorted lexicographically, floats rounded to 2 decimals, no NaN/Inf in JSON, sensor selection uses deterministic tie-breaks, TAL uses interpolation." ;
    oc:hasRationale "Catches data type and ordering errors that would silently corrupt compliance reports." ;
    oc:severityLevel "HIGH" .

oc:kn_73231d69 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When encountering missing thermocouple data for a run" ;
    oc:directiveContent "If a run has no TC records or no valid segments for a metric, set numeric outputs to null and avoid claiming 'pass' unless explicitly allowed by handbook rules." ;
    oc:hasRationale "Missing data must not be interpreted as compliance; null signals the consumer that the metric could not be evaluated." ;
    oc:severityLevel "HIGH" .

oc:kn_8850ebd2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before any thermocouple computation" ;
    oc:directiveContent "Always sort thermocouple samples by (run_id, tc_id, time_s) using mergesort before any computation; ignore segments where dt <= 0 (non-monotonic timestamps)." ;
    oc:hasRationale "Ensures deterministic results regardless of input data ordering and prevents division-by-zero or backward slope artifacts." ;
    oc:severityLevel "CRITICAL" .

oc:kn_89f2ddb1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When constructing any output JSON" ;
    oc:directiveContent "Round all floats to 2 decimals; never emit NaN or Inf — use null instead. Sort all lists lexicographically by primary ID and emit dict keys in sorted order." ;
    oc:hasRationale "Guarantees stable, diffable JSON output that can be deterministically validated and compared across executions." ;
    oc:severityLevel "HIGH" .

oc:kn_a5424414 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When computing TAL or wetting time metrics" ;
    oc:directiveContent "Never use naive threshold counting for time-above-liquidus; always use linear interpolation to find crossing points between samples." ;
    oc:hasRationale "Naive threshold counting introduces systematic error proportional to sample rate; interpolation yields accurate sub-sample timing." ;
    oc:severityLevel "CRITICAL" .

oc:kn_afaf97f0 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring handbook-derived configuration" ;
    oc:directiveContent "Represent all handbook parameters as a compact cfg object with typed region definitions (temp_band, zone_band, time_band) and structured rule objects for conveyor feasibility, enabling single-source-of-truth parameterization." ;
    oc:hasRationale "Decouples handbook knowledge from computation logic, making it easy to swap or update limits without changing algorithms." .

oc:kn_be6cffc4 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When computing ramp rate in a temperature-band region" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """def max_slope_in_temp_band(df_tc, tmin, tmax):
    g = df_tc.sort_values("time_s")
    t = g["time_s"].to_numpy(dtype=float)
    y = g["temp_c"].to_numpy(dtype=float)
    best = None
    for i in range(1, len(g)):
        dt = t[i] - t[i-1]
        if dt <= 0: continue
        if (tmin <= y[i-1] <= tmax) and (tmin <= y[i] <= tmax):
            s = (y[i] - y[i-1]) / dt
            best = s if best is None else max(best, s)
    return best""" .

oc:kn_e1fda612 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting representative sensor results for a run" ;
    oc:directiveContent "When reducing multiple thermocouples to one run-level result, use deterministic tie-breaks: for max metrics choose (max_value, smallest_tc_id); for min metrics choose (min_value, smallest_tc_id)." ;
    oc:hasRationale "Prevents non-deterministic output when multiple sensors report identical values, ensuring reproducible compliance reports across runs." ;
    oc:severityLevel "HIGH" .

oc:kn_e4d9881a a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "On repeated execution with same input data" ;
    oc:directiveContent "All computations are deterministic: same inputs produce identical outputs thanks to mergesort ordering, fixed tie-breaks, and 2-decimal rounding." ;
    oc:hasRationale "Reproducibility is essential for manufacturing audit trails and regulatory compliance verification." ;
    oc:severityLevel "MEDIUM" .

