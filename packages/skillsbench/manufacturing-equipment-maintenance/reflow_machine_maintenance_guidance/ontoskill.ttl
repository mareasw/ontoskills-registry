oc:kn_58de2059 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing any thermocouple data computation" ;
    oc:directiveContent "Always sort thermocouple samples by time before any computation, and ignore segments where dt <= 0 to avoid division by zero or nonsensical slopes." ;
    oc:hasRationale "Unsorted or duplicate timestamps produce incorrect slope and time-above calculations" ;
    oc:severityLevel "CRITICAL" .

oc:kn_650c67ca a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When answering any reflow maintenance question" ;
    oc:directiveContent "1. Retrieve related info from the handbook for the question 2. Load corresponding datasets (MES log, thermocouples CSV) 3. Build a config object from handbook values 4. Apply equations (max slope, time above threshold, peak metrics, conveyor speed) 5. Cross-validate computed results against handbook limits 6. Report findings with specific values and tc_ids" ;
    oc:stepOrder 1 .

oc:kn_71b90806 a oc:KnowledgeNode,
