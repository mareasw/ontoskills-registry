    oc:appliesToContext "Before performing any cross-validation computation" ;
    oc:directiveContent "Requires MES log CSV (run_id, solder_liquidus_c, etc.) and thermocouples CSV (run_id, tc_id, time_s, temp_c) with consistent run_id types cast to string." .

