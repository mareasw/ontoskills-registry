        oc:kn_aa92cf96 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ToolInstalled ;
    oc:resolvesIntent "parse and manipulate seismic event metadata using Catalog and Event objects",
        "read seismological waveform files into ObsPy Stream objects",
        "understand ObsPy's core data class structure and relationships",
        "work with station metadata using Inventory hierarchy" ;
    oc:yieldsState oc:DataLoaded .

oc:kn_2cc1e11e a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before using any ObsPy functionality" ;
    oc:directiveContent "ObsPy must be installed (pip install obspy). NumPy is a required dependency." .

oc:kn_4efd8076 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When working with real-world seismic recordings that may have gaps" ;
    oc:directiveContent "A Trace represents a gap-less continuous time series. If waveform data contains gaps, it must be split into multiple Trace objects within a Stream." ;
    oc:hasRationale "Trace objects cannot contain gaps; any discontinuity requires separate Trace objects, which affects how data is processed and filtered." ;
    oc:severityLevel "HIGH" .

oc:kn_5110728e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When working with ObsPy data objects" ;
    oc:directiveContent "ObsPy organizes all seismological data into three independent hierarchies: waveform data (Stream→Trace), event metadata (Catalog→Event→Origin/Magnitude), and station metadata (Inventory→Network→Station→Channel). Each hierarchy models a distinct aspect of seismic information." ;
    oc:hasRationale "Understanding this three-pillar architecture is essential for correctly navigating and manipulating seismological data without confusing waveform samples with metadata." ;
    oc:severityLevel "CRITICAL" .

oc:kn_6ffd2046 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When modifying Trace header information" ;
    oc:directiveContent "Trace stats attributes are interrelated: starttime, sampling_rate, delta, endtime, and npts are all derived from each other. Modifying one may affect the others." ;
    oc:hasRationale "Changing sampling_rate will change delta and endtime; changing npts will change endtime. Agents must be aware of these side effects to avoid data corruption." .

oc:kn_7d11c242 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When processing seismological waveform data end-to-end" ;
    oc:directiveContent "1. Import read (or read_events/read_inventory) from obspy. 2. Load data via read() with filename or URL argument (or no argument for example data). 3. Access individual Traces via Stream indexing (st[0]). 4. Inspect .data for NumPy array and .stats for metadata. 5. Use Trace methods (filter, taper, resample, integrate, remove_response) for signal processing." ;
    oc:stepOrder 1 .

oc:kn_806cf29d a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When loading and inspecting waveform data" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from obspy import read
st = read()  # example data
tr = st[0]  # access first Trace
tr.data   # NumPy ndarray of time series
tr.stats  # Stats object with metadata (network, station, channel, starttime, sampling_rate, etc.)
tr.stats.starttime  # UTCDateTime object""" ;
    oc:hasRationale "This is the canonical pattern for accessing waveform data in ObsPy: read into Stream, index for Trace, access .data and .stats." .

oc:kn_aa92cf96 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When importing seismological data from files or URLs" ;
    oc:directiveContent "Use the read() function to load waveform files, read_events() for event data, and read_inventory() for station metadata. Each returns its respective top-level container object (Stream, Catalog, Inventory)." ;
    oc:hasRationale "These three entry-point functions handle auto-detection of file formats (SAC, MiniSEED, GSE2, SEISAN, Q, QuakeML, StationXML, etc.) and return the correct object hierarchy." .

