oc:kn_d65f5b80 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting tables to a structured format like Excel" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """import pandas as pd

with pdfplumber.open("document.pdf") as pdf:
    all_tables = []
    for page in pdf.pages:
        tables = page.extract_tables()
        for table in tables:
            if table:
                df = pd.DataFrame(table[1:], columns=table[0])
                all_tables.append(df)
    combined_df = pd.concat(all_tables, ignore_index=True)
    combined_df.to_excel("extracted_tables.xlsx", index=False)""" .

oc:kn_e7d0b118 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When encountering corrupted or password-protected PDFs" ;
    oc:directiveContent "If pypdf fails to read a PDF, try qpdf to linearize/repair first, then retry. For encrypted PDFs, use qpdf --decrypt." ;
    oc:hasRationale "Some PDFs have minor structural issues or unknown encryption that qpdf can fix or remove" ;
    oc:severityLevel "HIGH" .

oc:kn_f7178177 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting text where layout fidelity matters" ;
    oc:directiveContent "Do not use pypdf's extract_text() for layout-sensitive extraction; use pdfplumber instead which preserves layout and handles tables." ;
    oc:hasRationale "pypdf's text extraction is basic and loses layout information; pdfplumber is purpose-built for layout-aware extraction" ;
    oc:severityLevel "MEDIUM" .

oc:kn_fb3517af a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When merging PDFs via command line" ;
    oc:directiveContent "qpdf --empty --pages file1.pdf file2.pdf -- merged.pdf" .

