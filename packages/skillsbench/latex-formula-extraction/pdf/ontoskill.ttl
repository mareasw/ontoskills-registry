oc:kn_49133e8c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing a PDF library for a task" ;
    oc:directiveContent "Use pypdf for basic operations (merge, split, rotate, encrypt), pdfplumber for text/table extraction with layout, and reportlab for PDF creation. Each library has a distinct role." ;
