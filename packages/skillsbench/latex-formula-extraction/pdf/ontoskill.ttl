        oc:Procedure ;
    oc:appliesToContext "When performing any PDF operation" ;
    oc:directiveContent "1. Identify the PDF task (extract text, extract tables, merge, split, create, OCR, watermark, encrypt) 2. Select the appropriate library (pdfplumber for extraction, pypdf for manipulation, reportlab for creation, pytesseract for OCR) 3. Install missing dependencies 4. Execute operation 5. Verify output file or extracted content" ;
