oc:kn_56ae7122 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When performing PDF manipulation operations" ;
    oc:directiveContent "PDF merge, split, watermark, encrypt, and rotate operations create new files but do not modify originals unless the same filename is used for output." ;
