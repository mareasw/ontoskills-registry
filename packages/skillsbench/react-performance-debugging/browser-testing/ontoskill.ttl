oc:kn_345f60fa a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When diagnosing slow page loads with sequential network requests" ;
    oc:directiveContent "Sequential await patterns in API calls cause cascading delays — use Promise.all() to parallelize independent requests." ;
    oc:hasRationale "Sequential fetches waste time waiting for each to complete before starting the next; parallel execution reduces total time to that of the slowest request." ;
    oc:severityLevel "HIGH" .

oc:kn_6beba682 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before running any measurement command" ;
    oc:directiveContent "Ensure the target URL is accessible and the dev server is running before executing measurement scripts." ;
    oc:hasRationale "Scripts will fail with network errors if the server isn't running or the URL is unreachable." .

oc:kn_758741ea a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When interpreting performance measurements" ;
    oc:directiveContent "The relative difference (before/after fix) matters more than absolute CLS values. Measurements vary due to build type, viewport size, setTimeout variance, and network conditions." ;
    oc:hasRationale "Absolute CLS numbers are non-deterministic; comparing before/after isolates the impact of your change from environmental noise." ;
    oc:severityLevel "HIGH" .

oc:kn_79510a79 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running measurement scripts" ;
    oc:directiveContent "Performance measurement is read-only and can be run multiple times safely, though results may vary between runs due to non-deterministic timing." ;
    oc:hasRationale "No state is mutated by measurement scripts, making them safe for repeated execution to confirm results." .

oc:kn_a0aa7a6c a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When evaluating measurement output" ;
    oc:directiveContent "Key performance thresholds: totalMs < 1000ms, LayoutCount < 50 per page, ScriptDuration < 0.5s, CLS < 0.1, JSHeapUsedSize not growing over time." ;
    oc:hasRationale "These thresholds indicate acceptable user experience; exceeding them signals a performance problem requiring investigation." .

oc:kn_e0a833bc a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "Before any performance optimization work" ;
    oc:directiveContent "Always measure BEFORE and AFTER making changes to confirm fixes actually improve performance." ;
    oc:hasRationale "Without baseline measurements, you cannot verify that changes had the intended effect or didn't cause regressions." ;
    oc:severityLevel "CRITICAL" .

oc:kn_e448021d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When measuring CLS on pages with lazy-loaded or below-fold content" ;
    oc:directiveContent "CLS only measures shifts within the viewport. Content below the fold doesn't contribute until scrolled into view. Use the --scroll flag for accurate measurement." ;
    oc:hasRationale "Without scrolling, late-loading content that causes layout shifts goes undetected, giving a false sense of stability." ;
    oc:severityLevel "MEDIUM" .

oc:kn_fa012f46 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing components that load content asynchronously" ;
    oc:directiveContent "Reserve space for dynamic content (images, banners, sidebars) using explicit dimensions, min-height, or CSS to prevent layout shifts." ;
    oc:hasRationale "Unreserved space causes content to push other elements when it loads, creating visible CLS." ;
    oc:severityLevel "HIGH" .

