oc:kn_48a59a04 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any JavaScript logic within React components" ;
    oc:directiveContent "For JS performance: use Set/Map for O(1) lookups instead of array.includes, combine multiple filter/map into one loop, return early from functions, hoist RegExp outside loops, use loops for min/max instead of sort." ;
    oc:hasRationale "Micro-optimizations compound in frequently-executed code paths like render functions and effect handlers" ;
    oc:severityLevel "LOW" .

oc:kn_4c93ee7b a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building server components and API routes in Next.js" ;
    oc:directiveContent "Minimize data serialized to client components. Use React.cache() for per-request deduplication and LRU caches for cross-request caching. Use after() for non-blocking server operations." ;
    oc:hasRationale "Excessive server-to-client serialization increases payload size and hydration cost; caching eliminates redundant fetches" ;
    oc:severityLevel "HIGH" .

oc:kn_733bf0bd a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When managing React component state and effects" ;
    oc:directiveContent "For re-render optimization: defer state reads used only in callbacks, use functional setState for stable callbacks, pass functions to useState for expensive initial values, use startTransition for non-urgent updates, and subscribe to derived booleans not raw values." ;
    oc:hasRationale "Unnecessary re-renders are the most common source of React performance degradation in production apps" ;
    oc:severityLevel "MEDIUM" .

oc:kn_bab76a69 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing any async data fetching pattern" ;
    oc:directiveContent "Start promises early, await late. Use Promise.all() for independent operations. Move await into branches where the value is actually used, not at the top of the function." ;
    oc:hasRationale "Deferring await allows parallel execution of independent operations, eliminating sequential waterfall patterns" ;
    oc:severityLevel "HIGH" .

oc:kn_beb4ff48 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always before any React/Next.js development task" ;
    oc:directiveContent "MUST read this skill and AGENTS.md BEFORE writing, modifying, or debugging ANY React.js or Next.js code. The quick reference is just an index; actual before/after code examples live in AGENTS.md and individual rule files." ;
    oc:hasRationale "Debugging performance issues without reading this skill first leads to missed optimizations and common mistakes" ;
    oc:severityLevel "CRITICAL" .

oc:kn_ca95e715 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When looking up specific optimization patterns" ;
    oc:directiveContent "Rules are prefixed by category (async-, bundle-, server-, client-, rerender-, rendering-, js-, advanced-). Reference specific rule files in rules/ directory for detailed before/after code patterns." ;
    oc:hasRationale "Prefix-based naming enables quick lookup and systematic application of rules by domain" ;
    oc:severityLevel "LOW" .

oc:kn_d95e5bb7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When prioritizing which performance issues to fix" ;
    oc:directiveContent "Eliminating waterfalls and bundle size optimization are CRITICAL priority. Address async-parallel, async-defer-await, async-api-routes, barrel-imports, and dynamic-imports rules first before any other optimization." ;
    oc:hasRationale "Waterfalls cause sequential blocking requests that dramatically increase load times; large bundles block initial page render" ;
    oc:severityLevel "CRITICAL" .

oc:kn_f6634008 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing import statements and conditional JSX" ;
    oc:directiveContent "Avoid barrel file imports (import { X } from 'library'). Import directly from specific modules (import X from 'library/X'). Use ternary operators instead of && for conditional rendering to avoid rendering falsy values." ;
    oc:hasRationale "Barrel imports force bundlers to include the entire library; && with falsy values like 0 renders unexpected content" ;
    oc:severityLevel "HIGH" .

_:ref_1d7b9dcfd5022898 a oc:WorkflowStep ;
    dcterms:description "Apply client- and rerender- rules: add SWR for deduplication, fix state subscriptions, use functional setState, add memoization" ;
    oc:expectedOutcome "Client-side re-renders minimized" ;
    oc:stepDependsOn _:ref_27421b7fb5493e86 ;
    oc:stepId "optimize-client" .

_:ref_27421b7fb5493e86 a oc:WorkflowStep ;
    dcterms:description "Apply server- rules: add React.cache(), minimize client serialization, parallelize server fetches" ;
    oc:expectedOutcome "Server-side data fetching optimized and deduplicated" ;
    oc:stepDependsOn _:ref_52af9d216f9479d6 ;
    oc:stepId "optimize-server" .

_:ref_52af9d216f9479d6 a oc:WorkflowStep ;
    dcterms:description "Apply async- rules: check for sequential awaits, use Promise.all, defer awaits to usage sites, start promises early in API routes" ;
    oc:expectedOutcome "All data fetching waterfalls eliminated" ;
    oc:stepDependsOn _:ref_426689630a266d5a ;
    oc:stepId "fix-waterfalls" .

_:ref_426689630a266d5a a oc:WorkflowStep ;
    dcterms:description "Read AGENTS.md for detailed before/after code patterns before making any fixes" ;
    oc:expectedOutcome "Agent has full context of all 45 rules with code examples" ;
    oc:stepId "read-rules" .

