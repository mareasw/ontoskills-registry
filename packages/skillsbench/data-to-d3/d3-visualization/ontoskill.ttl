oc:kn_134d696b a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """dist/chart.html — standalone HTML rendering
vendor/d3.v7.9.0.min.js — pinned D3 library
Optionally: dist/chart.svg, dist/chart.png""" ;
    oc:templateVariables "chart.html",
        "chart.png",
        "chart.svg",
        "d3.v7.9.0.min.js" .

oc:kn_1ebc83e6 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When user provides incomplete specifications" ;
    oc:directiveContent "When chart details are missing, make reasonable defaults and document them in comments near the top of the output file." ;
    oc:hasRationale "Documenting defaults ensures reproducibility and helps users understand what was assumed" ;
    oc:severityLevel "MEDIUM" .

oc:kn_6da2c848 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "All rendering code" ;
    oc:directiveContent "Never use Math.random(), d3-random, transitions, or animations. Sort input rows deterministically before binding. Use explicit d3.format/d3.timeFormat with fixed locale strings." ;
    oc:hasRationale "Randomness and animations introduce non-deterministic output that prevents diffing and hashing verification" ;
    oc:severityLevel "CRITICAL" .

oc:kn_7551fe15 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When using d3.forceSimulation" ;
    oc:directiveContent "Force simulation layouts are non-deterministic by default. If required, fix tick count, set deterministic initial positions (sorted nodes on a grid), and run exactly N ticks then stop." ;
    oc:hasRationale "Force layouts iterate until convergence, producing different positions across runs unless seeded and bounded" ;
    oc:severityLevel "HIGH" .

oc:kn_8a9790c4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always when generating D3 visualizations" ;
    oc:directiveContent "Never load D3 from a CDN. Pin to d3@7.9.0 and vendor a minified bundle (vendor/d3.v7.9.0.min.js) or use a lockfile." ;
    oc:hasRationale "CDN loading introduces network dependency and version drift, breaking determinism and offline reproducibility" ;
    oc:severityLevel "CRITICAL" .

oc:kn_9087e954 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding click-to-select highlighting on chart elements" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """svg.selectAll('.bar')
    .on('click', function(event, d) {
        d3.selectAll('.bar').classed('selected', false);
        d3.select(this).classed('selected', true);
    });

.bar.selected { stroke: #000; stroke-width: 3px; }""" .

oc:kn_bc113387 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When user requests data display without visual encoding" ;
    oc:directiveContent "Avoid using D3 for simple tables or summary outputs—use markdown or a spreadsheet instead." ;
    oc:hasRationale "Over-engineering with D3 adds unnecessary complexity for tasks that don't need visual encoding" ;
    oc:severityLevel "MEDIUM" .

oc:kn_bce564b0 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before visualization generation" ;
    oc:directiveContent "Local data files must exist: CSV, TSV, or JSON format. D3 v7.9.0 must be vendored locally." .

oc:kn_cc2f4d19 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Standard visualization workflow" ;
    oc:directiveContent "1. Read local data files (CSV/TSV/JSON) 2. Sort data deterministically 3. Create standalone HTML with vendored D3 and fixed dimensions 4. Generate SVG with stable IDs and explicit formatting 5. Output to dist/chart.html, dist/chart.svg, optionally dist/chart.png" ;
    oc:stepOrder 1 .

oc:kn_e20002f2 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "All SVG/HTML output generation" ;
    oc:directiveContent "Produce stable SVG output by avoiding auto-generated IDs. If IDs are needed (clipPath, gradients), derive them from stable strings like 'clip-plot'. Use LF line endings and round numerics to 2–4 decimals." ;
    oc:hasRationale "Auto-generated IDs and floating-point variance cause spurious diffs in version control" ;
    oc:severityLevel "HIGH" .

oc:kn_ef995e1d a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding interactive tooltips to D3 visualizations" ;
    oc:codeLanguage "html" ;
    oc:directiveContent """<div id="tooltip" class="tooltip"></div>

.tooltip { position: absolute; padding: 10px; background: rgba(0,0,0,0.8); color: white; border-radius: 4px; pointer-events: none; opacity: 0; transition: opacity 0.2s; z-index: 1000; }
.tooltip.visible { opacity: 1; }

svg.selectAll('circle')
    .on('mouseover', function(event, d) {
        d3.select('#tooltip').classed('visible', true)
            .html(`<strong>${d.name}</strong><br/>${d.value}`)
            .style('left', (event.pageX + 10) + 'px')
            .style('top', (event.pageY - 10) + 'px');
    })
    .on('mouseout', function() {
        d3.select('#tooltip').classed('visible', false);
    });""" .

