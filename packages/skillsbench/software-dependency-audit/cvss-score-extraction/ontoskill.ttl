oc:kn_0f46fbe7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When no CVSS score is found across all sources" ;
    oc:directiveContent "Always return 'N/A' when no score is available. Never return None, 0.0, or raise exceptions for missing scores." ;
    oc:hasRationale "Consistent sentinel value ('N/A') makes downstream report generation predictable and avoids null-reference errors" ;
    oc:severityLevel "HIGH" .

oc:kn_18a26703 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before extracting CVSS scores from any vulnerability record" ;
    oc:directiveContent "Validate that vulnerability data contains a 'CVSS' key that is a dictionary before attempting score extraction. Use isinstance(cvss, dict) guard." ;
    oc:hasRationale "Prevents AttributeError/TypeError when CVSS field is missing or unexpectedly non-dict (e.g., null, string)" ;
    oc:severityLevel "HIGH" .

oc:kn_8c263e5b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When parsing vulnerability data from any source" ;
    oc:directiveContent "Never assume CVSS data is always present or well-formed. Always use safe dictionary access (.get()), validate types (isinstance checks), and return 'N/A' for missing scores." ;
    oc:hasRationale "Vulnerability databases may have missing entries, malformed data, or unexpected types. Hard failures on missing data break report generation pipelines" ;
    oc:severityLevel "CRITICAL" .

oc:kn_91d91416 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When multiple CVSS versions are available for the same vulnerability" ;
    oc:directiveContent "Prefer CVSS v3/v3.1 scores over v2 scores. Only fall back to v2 when no v3 score exists across all sources." ;
    oc:hasRationale "CVSS v3 provides refined metrics and more accurate severity assessments than the legacy v2 system" ;
    oc:severityLevel "MEDIUM" .

oc:kn_a4ff7a00 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always" ;
    oc:directiveContent "CVSS score extraction is purely read-only and idempotent — calling the extraction function multiple times on the same data always returns the same result with no side effects." ;
    oc:hasRationale "Read-only data extraction from static vulnerability records guarantees reproducible reports" ;
    oc:severityLevel "LOW" .

oc:kn_a98dc8c2 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When multiple sources provide conflicting CVSS scores" ;
    oc:directiveContent "Different sources may assign different CVSS scores to the same CVE due to differing interpretations of impact. Always use the highest-priority source's score rather than averaging or picking extremes." ;
    oc:hasRationale "Averaging scores loses the authority signal of the primary source; the priority cascade resolves conflicts deterministically" ;
    oc:severityLevel "MEDIUM" .

oc:kn_c0b65dd9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting CVSS scores from multi-source vulnerability data" ;
    oc:directiveContent "Use source priority cascade: NVD → GHSA → RedHat → N/A. NVD is most authoritative; never skip to a lower-priority source when a higher one has a valid score." ;
    oc:hasRationale "NVD (NIST) is the most comprehensive and authoritative source; vendor-specific sources may have incomplete coverage or biased assessments" ;
    oc:severityLevel "HIGH" .

