oc:kn_405c08e5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When interpreting TLS results" ;
    oc:directiveContent "SDE > 6 indicates a strong transit candidate. SDE > 9 is very strong. SDE < 6 is weak and may be a false positive. SNR > 7 is generally considered reliable." ;
    oc:hasRationale "These thresholds distinguish genuine transit signals from noise in the periodogram" .

oc:kn_589f4b11 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before running TLS" ;
    oc:directiveContent "Preprocessing must follow: remove outliers (sigma=3-5) → flatten/detrend → then search for transits. Ensure data quality flags are filtered before analysis." ;
    oc:hasRationale "Detrending and outlier removal are essential to reveal shallow transit signals that would otherwise be masked by systematic trends" .

oc:kn_81f9a805 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When searching for multi-planet systems" ;
    oc:directiveContent "For multiple planet detection: search → identify candidate → refine period → mask transits → search again on masked data. Repeat for each additional planet." ;
    oc:hasRationale "Masking known transits prevents them from biasing the search for additional signals" .

oc:kn_b21b42f2 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing a periodogram method" ;
    oc:directiveContent "Use TLS for exoplanet transit detection specifically. Use Lomb-Scargle for general periodic signals (rotation, pulsation, eclipsing binaries)." ;
    oc:hasRationale "TLS fits actual transit models and is more sensitive for transit-shaped box-like signals, while Lomb-Scargle fits sinusoids which are better for smooth periodic variations" .

oc:kn_c464dd28 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When TLS warns about missing transits" ;
    oc:directiveContent "TLS may report 'X of Y transits without data. The true period may be twice the given period.' Check if period*2 also shows a signal. The true period might be double or half of reported value." ;
    oc:hasRationale "Data gaps cause period aliasing, leading to incorrect period identification" ;
    oc:severityLevel "MEDIUM" .

oc:kn_eb9ae629 a oc:Heuristic,
