    oc:appliesToContext "When searching for transit periods" ;
    oc:directiveContent "Use broad period search first, then refine in a narrow window (±2-10%) around the candidate period for better precision." ;
    oc:hasRationale "Broad searches use coarse grids (fast but imprecise). Refinement in a narrow range uses dense grids for high precision." ;
    oc:severityLevel "HIGH" .

oc:kn_f0191c43 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When constructing tls.transitleastsquares() input" ;
    oc:directiveContent "Never run TLS without providing flux_err (flux uncertainties). TLS cannot properly weight data points without uncertainties." ;
    oc:hasRationale "Without flux errors, TLS produces unreliable results with incorrect weighting of observations" ;
    oc:severityLevel "CRITICAL" .

