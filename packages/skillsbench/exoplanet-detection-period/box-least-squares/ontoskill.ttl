                            oc:contentOrder 1 ;
                            oc:textContent "The BLS periodogram is sensitive to period grid spacing. The `autoperiod()` method provides a conservative grid:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
