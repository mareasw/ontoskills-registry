oc:kn_00136446 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When preprocessing light curves for BLS" ;
    oc:directiveContent "Do not over-process light curves before BLS. Too-aggressive detrending or outlier removal can remove real transit signals." ;
    oc:hasRationale "BLS detects shallow dips; any filtering that suppresses brief flux drops will reduce detection sensitivity." ;
    oc:severityLevel "HIGH" .

oc:kn_0464a1af a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Validating BLS transit candidate" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """stats = model.compute_stats(
    periodogram.period[max_power_idx],
    periodogram.duration[max_power_idx],
    periodogram.transit_time[max_power_idx]
)
print(f"Depth SNR: {stats['depth_snr']:.2f}")
print(f"Transits: {stats['transit_count']}")""" .

oc:kn_13608d08 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When period aliasing is suspected" ;
    oc:directiveContent "If detected period is 2× or 0.5× expected: check both periods manually, examine odd-even statistics, and inspect phase-folded plots for both periods." ;
    oc:hasRationale "Missing alternating transits, data gaps, or true period aliasing can produce harmonics or sub-harmonics." .

oc:kn_33ee698f a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When evaluating BLS candidates with compute_stats()" ;
    oc:directiveContent "Validate transit candidates with: depth SNR > 7, low odd-even depth mismatch, multiple transits observed, and physically reasonable duration for the orbit." ;
    oc:hasRationale "These criteria distinguish true planetary transits from eclipsing binaries and instrumental artifacts." ;
    oc:severityLevel "CRITICAL" .

oc:kn_366c2eb0 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Full BLS analysis pipeline" ;
    oc:directiveContent "1. Quality filter flagged data → 2. Remove outliers → 3. Detrend stellar variability (gentle methods like flatten()) → 4. Run BLS search → 5. Validate with compute_stats()" ;
    oc:hasRationale "Preprocessing must preserve transit shapes; aggressive cleaning removes real signals." ;
    oc:stepOrder 1 .

oc:kn_3fad9f90 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When validating BLS candidates" ;
    oc:directiveContent "A high odd-even depth mismatch (> 3× depth_err) suggests the signal is not a planetary transit — likely an eclipsing binary or instrumental artifact." ;
    oc:hasRationale "Planetary transits should have consistent depth at every epoch; alternating depths indicate two bodies of different sizes (binary star)." ;
    oc:severityLevel "HIGH" .

oc:kn_44d0432d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining custom period grids with power()" ;
    oc:directiveContent "Period grid quality matters more for BLS than for Lomb-Scargle. A too-coarse grid will miss the true period entirely." ;
    oc:hasRationale "BLS evaluates a box model at each grid point; narrow transit features require dense sampling to capture." ;
    oc:severityLevel "HIGH" .

oc:kn_47ec0556 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When transit duration is unknown" ;
    oc:directiveContent "Search multiple transit durations (e.g., np.linspace(0.05, 0.3, 10) * u.day) to find the best fit rather than guessing a single duration." ;
    oc:hasRationale "The true transit duration is often uncertain; scanning a range ensures the model matches the data." ;
    oc:severityLevel "MEDIUM" .

oc:kn_6a4484a7 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Phase-folding light curve at detected period" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """phase = ((time.value - best_t0.value) % best_period.value) / best_period.value
plt.plot(phase, flux, '.')
plt.xlabel('Phase')
plt.ylabel('Flux')""" .

oc:kn_936311c5 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting BLS objective function" ;
    oc:directiveContent "Use objective='snr' when correlated noise is present; use objective='likelihood' (default) for general cases." ;
    oc:hasRationale "The SNR objective weights transit depth by its measurement uncertainty, improving reliability in noisy data." .

oc:kn_99e89897 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When BLS returns no significant peak" ;
    oc:directiveContent "If no clear BLS peak: try wider duration range, extend period search range, use less aggressive flatten() window, or check raw data directly." ;
    oc:hasRationale "Multiple factors can suppress the BLS signal; systematic troubleshooting covers the most common causes." .

oc:kn_9c4672ff a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running BLS period search" ;
    oc:directiveContent "Use autopower() for initial searches (automatic period grid), then use finer grids with power() around promising candidates for refinement." ;
    oc:hasRationale "autopower provides a conservative grid suitable for discovery; custom grids allow focused sensitivity around candidates." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a6226880 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Core BLS search pattern" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """model = BoxLeastSquares(time * u.day, flux, dy=flux_err)
durations = np.linspace(0.05, 0.3, 10) * u.day
periodogram = model.autopower(durations, objective='likelihood')
max_power_idx = np.argmax(periodogram.power)
best_period = periodogram.period[max_power_idx]
best_duration = periodogram.duration[max_power_idx]
best_t0 = periodogram.transit_time[max_power_idx]""" .

oc:kn_f1d8fe5b a oc:KnowledgeNode,
