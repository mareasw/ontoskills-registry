    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:LightCurveLoaded ;
    oc:resolvesIntent "analyze radial velocity data for periodic variations",
        "detect stellar pulsation periods",
        "detect stellar rotation periods",
        "find periodic signals in light curves",
        "identify eclipsing binary periods",
        "search for exoplanet orbital periods" ;
    oc:yieldsState oc:PeriodDetected,
        oc:PeriodogramComputed .

oc:kn_1fe46afb a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before running any Lomb-Scargle analysis" ;
    oc:directiveContent "Python packages lightkurve, numpy, and matplotlib must be installed (pip install lightkurve numpy matplotlib)" ;
    oc:hasRationale "The skill depends entirely on the lightkurve library for periodogram computation." .

oc:kn_3841505b a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When fitting a sinusoidal model to validate a detected period" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """frequency = pg.frequency_at_max_power
model = pg.model(time=lc.time, frequency=frequency)""" ;
    oc:hasRationale "Model fitting provides visual validation that the detected period actually fits the data." .

oc:kn_557a90fb a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating a periodogram" ;
    oc:directiveContent "Always specify minimum_period and maximum_period based on the science case: stellar rotation (0.1-100d), exoplanet transits (0.5-50d), eclipsing binaries (0.1-100d), pulsations (0.001-1d)." ;
    oc:hasRationale "Narrowing the period range reduces computational cost and false positives from irrelevant period ranges." ;
    oc:severityLevel "HIGH" .

oc:kn_58eecbce a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When interpreting any Lomb-Scargle periodogram result" ;
    oc:directiveContent "Do not trust a single high-power peak without checking for harmonics at period/2 and period*2, and aliases at integer multiples." ;
    oc:hasRationale "The strongest peak may be a harmonic or alias of the true fundamental period, leading to incorrect period identification." ;
    oc:severityLevel "HIGH" .

oc:kn_9e098aa9 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Core pattern for creating a periodogram and extracting the dominant period" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """lc = lk.LightCurve(time=time, flux=flux, flux_err=error)
pg = lc.to_periodogram(maximum_period=15)
strongest_period = pg.period_at_max_power""" ;
    oc:hasRationale "This is the minimal working pattern for Lomb-Scargle analysis with lightkurve." .

oc:kn_b17fe4b0 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When plotting periodogram results" ;
    oc:directiveContent "Use view='period' when plotting periodograms to interpret results in period space rather than frequency space." ;
    oc:hasRationale "The default view='frequency' shows 1/period, which is less intuitive for astronomical period analysis." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d5eef509 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Standard Lomb-Scargle analysis workflow" ;
    oc:directiveContent "1. Load/create LightCurve from time, flux, flux_err → 2. Call to_periodogram(minimum_period=..., maximum_period=...) → 3. Extract period_at_max_power and max_power → 4. Check for harmonics/aliases → 5. Optionally fit model with pg.model(time, frequency) → 6. Plot data and model for validation" ;
    oc:hasRationale "Following this sequence ensures systematic period detection and validation." ;
    oc:stepOrder 1 .

oc:kn_e972168d a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When searching specifically for exoplanet transits" ;
    oc:directiveContent "For exoplanet detection, use Lomb-Scargle for initial period search, then follow up with Transit Least Squares (TLS) for higher sensitivity." ;
    oc:hasRationale "TLS is more sensitive than Lomb-Scargle for transit-shaped signals, but Lomb-Scargle provides a good initial survey." ;
    oc:severityLevel "MEDIUM" .

