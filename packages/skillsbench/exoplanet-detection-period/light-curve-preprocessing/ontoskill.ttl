    oc:contentHash "f6109ef5022fb07b156c0a0a6d575211f8340d38a8053dbdc4455689a57ceb67" ;
    oc:differentia "Cleans astronomical light curves by removing outliers, trends, and quality-flagged data while preserving transit signals for exoplanet detection" ;
