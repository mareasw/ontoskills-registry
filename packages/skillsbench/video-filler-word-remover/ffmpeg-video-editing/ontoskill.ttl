oc:kn_18c44dde a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When removing many short segments like filler words" ;
    oc:directiveContent "For batch segment removal, calculate keep segments (inverse of remove segments), extract each keep segment, then concatenate rather than removing one segment at a time." ;
    oc:hasRationale "Removing segments sequentially requires N full re-encodes; the inverse-keep approach requires only one extraction pass and one concatenation." ;
    oc:severityLevel "HIGH" .

oc:kn_2d19f787 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running any ffmpeg command" ;
    oc:directiveContent "FFmpeg operations are not idempotent if output files already exist; always use `-y` flag to overwrite or ensure unique output names." ;
    oc:hasRationale "Without `-y`, ffmpeg prompts for overwrite confirmation, which hangs in non-interactive subprocess execution." ;
    oc:severityLevel "HIGH" .

oc:kn_4095b7db a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing concatenation method" ;
    oc:directiveContent "Use the concat demuxer (`-f concat`) with `-c copy` for same-codec files; use filter_complex only when re-encoding is necessary." ;
    oc:hasRationale "The concat demuxer with stream copy is dramatically faster and lossless compared to filter_complex re-encoding." ;
    oc:severityLevel "MEDIUM" .

oc:kn_8968788b a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When concatenating multiple extracted segments" ;
    oc:directiveContent "Gaps or glitches at cut points can occur if segments overlap. Add a small buffer (0.01s) between adjacent segments to avoid overlap artifacts." ;
    oc:hasRationale "Floating-point timestamp precision can cause micro-overlaps that produce glitches at splice points." ;
    oc:severityLevel "MEDIUM" .

oc:kn_917de5e1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When cutting video at arbitrary timestamps" ;
    oc:directiveContent "Never use `-c copy` when cutting at non-keyframe positions; always re-encode with `-c:v libx264 -c:a aac` for frame-accurate cuts." ;
    oc:hasRationale "Stream copy mode can only cut at keyframes, causing audio/video sync drift and incorrect segment boundaries." ;
    oc:severityLevel "CRITICAL" .

