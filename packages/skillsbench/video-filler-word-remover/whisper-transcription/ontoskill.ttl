                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**Recommendation: Start with `tiny` - it handles clear interview/podcast audio well.**" ],
                        [ a oc:Table ;
