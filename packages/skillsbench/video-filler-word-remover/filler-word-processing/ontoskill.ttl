oc:kn_47c3ab36 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When merging overlapping or adjacent filler word segments" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """def merge_overlapping_segments(segments, min_gap=0.1):
    sorted_segs = sorted(segments)
    merged = [sorted_segs[0]]
    for start, end in sorted_segs[1:]:
        prev_start, prev_end = merged[-1]
        if start <= prev_end + min_gap:
            merged[-1] = (prev_start, max(prev_end, end))
        else:
            merged.append((start, end))
    return merged""" .

oc:kn_53258ae8 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When filler words are close together in time" ;
    oc:directiveContent "Merge segments that overlap or are within 0.1s (min_gap) of each other to avoid micro-segments between close fillers." ;
    oc:hasRationale "Micro-cuts between adjacent fillers create unnatural audio artifacts; merging produces smoother results" .

oc:kn_53e13c5e a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When re-running the pipeline on the same annotations" ;
    oc:directiveContent "The annotation-to-segment conversion is deterministic: same input annotations with same parameters always produce the same segments." ;
    oc:hasRationale "Deterministic processing enables safe re-processing and testing without side effects" .

oc:kn_80d536a8 a oc:KnowledgeNode,
