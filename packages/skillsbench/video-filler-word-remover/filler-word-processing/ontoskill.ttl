                                    oc:itemText "**Too conservative**: Filler words partially audible" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Sweet spot**: Clean cuts with natural-sounding result" ] ] ;
                    oc:sectionLevel 2 ;
