    oc:appliesToContext "Before running this skill" ;
    oc:directiveContent "Requires a JSON annotations file with entries containing 'word' (string) and 'timestamp' (float, seconds) fields, typically produced by speech-to-text transcription." .

oc:kn_810f2c10 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Always, when processing filler word annotations" ;
    oc:directiveContent "1. Load JSON annotations with word/timestamp pairs. 2. For each annotation, compute cut segment: start = max(0, timestamp - buffer), end = timestamp + word_duration (lookup from WORD_DURATIONS dict, fallback 0.4s). 3. Sort segments by start time. 4. Merge overlapping/adjacent segments (gap < min_gap). 5. Return merged segment list." ;
    oc:stepOrder 1 .

