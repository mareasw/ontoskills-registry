oc:kn_cdedf4bf a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting annotations to cut segments" ;
    oc:directiveContent "Each filler word requires a word-specific duration: short fillers (uh, um) ~0.3-0.4s, sustained hums (hum, hmm, mhm) ~0.55-0.6s, quick single words (like, yeah, so, well) ~0.25-0.35s, longer words (okay, basically) ~0.4-0.55s, multi-word phrases (you know, i mean, kind of, i guess) ~0.5-0.55s. Default fallback is 0.4s." ;
    oc:hasRationale "Different filler words have different spoken lengths; using a uniform duration would either cut into adjacent words (too long) or leave audible remnants (too short)" ;
    oc:severityLevel "HIGH" .

