oc:kn_12b6d203 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When tuning word durations and buffer parameters" ;
    oc:directiveContent "Do not use overly aggressive durations that cut into adjacent words, nor overly conservative durations that leave filler words partially audible. Test with a few samples before processing full video." ;
    oc:hasRationale "Too aggressive cuts sound choppy; too conservative cuts leave disfluencies audible. The sweet spot is clean cuts with natural-sounding result" ;
    oc:severityLevel "MEDIUM" .

oc:kn_43f5aa97 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When computing cut segment start times" ;
    oc:directiveContent "Apply a 0.05s buffer before each filler word start time (start = max(0, timestamp - buffer)) to capture the word onset cleanly." ;
    oc:hasRationale "Timestamps may slightly precede the audible word; the buffer ensures the full filler is captured for removal" .

