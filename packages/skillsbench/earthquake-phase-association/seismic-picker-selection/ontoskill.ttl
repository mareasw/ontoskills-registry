oc:skill_earthquake_phase_association_seismic_picker_selection a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "seismic-picker-selection" ;
    skos:broader "Decision framework" ;
    prov:wasDerivedFrom ".agents/skills/skillsbench/earthquake-phase-association/seismic-picker-selection" ;
    oc:contentHash "78139a1e621c770fdf54d3edadd007fee9c107245f58ece17bfc73cc12f7867a" ;
    oc:differentia "that compares earthquake event detection and phase picking methods by their tradeoffs in generalizability, sensitivity, speed, and false positive rates" ;
    oc:extends oc:skill_ontoskills_seisbench_model_api ;
    oc:hasCategory "research" ;
    oc:hasDescription "This is a summary the advantages and disadvantages of earthquake event detection and phase picking methods, shared by leading seismology researchers at the 2025 Earthquake Catalog Workshop. Use it when you have a seismic phase picking task at hand." ;
    oc:hasName "seismic-picker-selection" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: seismic-picker-selection
description: This is a summary the advantages and disadvantages of earthquake event detection and phase picking methods, shared by leading seismology researchers at the 2025 Earthquake Catalog Workshop. Use it when you have a seismic phase picking task at hand.
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Requires manual review and refinement of picks for a quality catalog" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Automatic picks not as precise" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "High rate of false detections during active sequences" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Limitations" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Amplitude-based detector: Reliably detects large earthquake signals" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Runs very fast: Automatically operates in real-time" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "No prior knowledge needed: Does not require information about earthquake sources or waveforms" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Easy to understand & implement: Can optimize for different window lengths and ratios" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Advantages" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "STA/LTA (Short-Term Average / Long-Term Average)" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Best on broadband stations, but also produces usable picks on accelerometers, nodals, and Raspberry Shakes" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Automatically and rapidly create more complete catalog during active sequences" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "**Use case**: Temporary deployment of broadband or nodal stations where you want an automatically generated local earthquake catalog" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Adds most value when existing seismic networks are sparse or nonexistent" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Requires continuous seismic data" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "When to Use" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "No prior knowledge needed about earthquake sources or waveforms" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Relatively easy to set up and run: Reasonable runtime with parallel processing. SeisBench provides easy-to-use model APIs and pretrained models." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Finds lots of small local earthquakes (lower magnitude of completeness, Mc) with fewer false detections than STA/LTA" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Advantages" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Cannot pick phases completely buried in noise - Not quite as sensitive as template-matching" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Out-of-distribution data issues: For datasets not represented in training data, expect larger automated pick errors (0.1-0.5 s) and missed picks" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText """Sometimes misses picks from larger earthquakes that are obvious to humans, for unexplained
reason""" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Limitations" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Deep Learning Pickers" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Requires prior knowledge about earthquake sources: Need **template waveforms** with good picks from a preexisting catalog" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Setup effort required: Must extract template waveforms and configure processing" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Computationally intensive" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Does not improve spatial resolution: Unknown earthquake sources that are not similar enough to templates cannot be found" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Limitations" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Optimally sensitive detector (more sensitive than deep-learning): Can find smallest earthquakes buried in noise, if similar enough to template waveform" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "False detections are not as concerning when using high detection threshold" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Excellent for improving temporal resolution of earthquake sequences" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Advantages" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Template Matching" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "This skill is a derivative of Beauce, Eric and Tepp, Gabrielle and Yoon, Clara and Yu, Ellen and Zhu, Weiqiang. _Building a High Resolution Earthquake Catalog from Raw Waveforms: A Step-by-Step Guide_ Seismological Society of America (SSA) Annual Meeting, 2025. https://ai4eps.github.io/Earthquake_Catalog_Workshop/" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Perol et al. (2018) - Deep learning for seismic detection" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Huang & Beroza (2015) - Template matching methods" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Allen (1978) - STA/LTA method" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "Yoon and Shelly (2024), TSR - Deep learning vs template matching comparison" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "References" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "When choosing an event detection and phase picking method, consider these key tradeoffs:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 3 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Generalizability**: Ability to find arbitrary earthquake signals" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Sensitivity**: Ability to find small earthquakes" ] ],
                        [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 2 ;
                            oc:rowCount 4 ;
                            oc:tableCaption "When choosing an event detection and phase picking method, consider these key tradeoffs" ;
                            oc:tableMarkdown """| Method | Generalizability | Sensitivity | Speed, Ease-of-Use | False Positives |
|--------|------------------|-------------|-------------------|-----------------|
| STA/LTA | High | Low | Fast, Easy | Many |
| Manual | High | High | Slow, Difficult | Few |
| Deep Learning | High | High | Fast, Easy | Medium |
| Template Matching | Low | High | Slow, Difficult | Few |
""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent "**Key insight:** Each method has strengths and weaknesses. Purpose and resources should guide your choice." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Overview: Method Tradeoffs" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Seismic Event Detection & Phase Picking Method Selection Guide" ] ;
    oc:impartsKnowledge oc:kn_16ce0653,
        oc:kn_202fd342,
        oc:kn_5d4af176,
        oc:kn_7dd6d423,
        oc:kn_95dfae16,
        oc:kn_a55ccda2,
        oc:kn_b015564b,
        oc:kn_b34c7383 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:SeismicDataAvailable ;
    oc:resolvesIntent "choose earthquake detection method",
        "compare STA/LTA vs template matching vs deep learning pickers",
        "evaluate phase picking tradeoffs",
        "select seismic phase picking method" ;
    oc:yieldsState oc:MethodSelected .

oc:kn_16ce0653 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using STA/LTA for phase picking" ;
    oc:directiveContent "Do not rely on STA/LTA without manual review if you need a quality catalog — it produces high false positive rates during active sequences and imprecise automatic picks." ;
    oc:hasRationale "STA/LTA is amplitude-based and cannot distinguish earthquake signals from other transient amplitude changes." ;
    oc:severityLevel "HIGH" .

oc:kn_202fd342 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding whether to use deep learning pickers" ;
    oc:directiveContent "Deep learning pickers add the most value when existing seismic networks are sparse or nonexistent, and for rapidly creating more complete catalogs during active sequences." ;
    oc:hasRationale "Deep learning generalizes well to arbitrary signals without prior knowledge, unlike template matching which requires preexisting waveforms." .

oc:kn_5d4af176 a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting a picking method for a given station type" ;
    oc:directiveContent "Deep learning pickers perform best on broadband stations but also produce usable picks on accelerometers, nodals, and Raspberry Shakes. All methods require continuous seismic data." ;
    oc:hasRationale "Station instrumentation affects picker performance and reliability." .

oc:kn_7dd6d423 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting a seismic event detection method" ;
    oc:directiveContent "Let purpose and available resources guide the choice of picking method: STA/LTA for speed, template matching for sensitivity, deep learning for generalizability+sensitivity combined, manual for highest quality." ;
    oc:hasRationale "Each method has distinct strengths and weaknesses; no single method dominates on all axes." ;
    oc:severityLevel "HIGH" .

oc:kn_95dfae16 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When selecting and applying a seismic phase picking method" ;
    oc:directiveContent "1. Assess available resources (preexisting catalog, station types, compute) → 2. Determine priority (speed, sensitivity, spatial resolution, catalog quality) → 3. Match method to use case using the tradeoff table → 4. Apply selected method → 5. Validate picks against manual review" ;
    oc:stepOrder 1 .

oc:kn_a55ccda2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When considering template matching for phase detection" ;
    oc:directiveContent "Template matching requires preexisting template waveforms with good picks from a known catalog, and cannot find earthquakes dissimilar to those templates." ;
    oc:hasRationale "Template matching does not improve spatial resolution beyond what templates cover." ;
    oc:severityLevel "HIGH" .

oc:kn_b015564b a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When evaluating runtime and setup requirements" ;
    oc:directiveContent "Deep learning pickers run relatively fast with parallel processing; SeisBench provides pretrained models for easy deployment. STA/LTA is the fastest. Template matching is computationally intensive." ;
    oc:hasRationale "Computational cost varies significantly across methods and affects feasibility for real-time or large-scale processing." .

oc:kn_b34c7383 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When using deep learning pickers" ;
    oc:directiveContent "Deep learning pickers can miss picks from larger earthquakes that are obvious to humans, and produce larger errors (0.1-0.5 s) on out-of-distribution data." ;
    oc:hasRationale "Training data coverage gaps lead to unpredictable failures on certain event types." ;
    oc:severityLevel "MEDIUM" .

