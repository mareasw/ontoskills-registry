@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_earthquake_phase_association_seisbench_model_api a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "seisbench-model-api" ;
    skos:broader "API reference" ;
    prov:wasDerivedFrom ".agents/skills/skillsbench/earthquake-phase-association/seisbench-model-api" ;
    oc:contentHash "eda9d4472758cb3f433ed98e88768c1fc34bc27d76b9f9a2288997f8a4ba072f" ;
    oc:dependsOnSkill oc:skill_ontoskills_obspy_data_api ;
    oc:differentia "that provides a bridge between PyTorch ML models and ObsPy waveform streams for seismic data annotation and classification using pretrained deep learning models" ;
    oc:handlesFailure oc:InvalidInput,
        oc:NetworkTimeout ;
    oc:hasArgumentHint "waveform stream (ObsPy Stream object or file path)" ;
    oc:hasCategory "development" ;
    oc:hasDescription "An overview of the core model API of SeisBench, a Python framework for training and applying machine learning algorithms to seismic data. It is useful for annotating waveforms using pretrained SOTA ML models, for tasks like phase picking, earthquake detection, waveform denoising and depth estimation. For any waveform, you can manipulate it into an obspy stream object and it will work seamlessly with seisbench models." ;
    oc:hasName "seisbench-model-api" ;
    oc:hasRequirement oc:req_065d5379,
        oc:req_130776d1,
        oc:req_4adadf05,
        oc:req_69d81af3,
        oc:req_70d0caaa,
        oc:req_c2ef2f1a ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: seisbench-model-api
description: An overview of the core model API of SeisBench, a Python framework for training and applying machine learning algorithms to seismic data. It is useful for annotating waveforms using pretrained SOTA ML models, for tasks like phase picking, earthquake detection, waveform denoising and depth estimation. For any waveform, you can manipulate it into an obspy stream object and it will work seamlessly with seisbench models.
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """pip install seisbench
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 10-12" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "The recommended way is installation through pip. Simply run:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Installing SeisBench" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 2 ;
                            oc:rowCount 16 ;
                            oc:tableCaption "You don't have to build models from scratch if you don't want to. SeisBench integrates the following notable models from the literature for you to use. Again, as they inherit from the common SeisBench model interface, all these deep learning models are constructed through PyTorch. Where possible, the original trained weights are imported and made available. These can be accessed via the `from_pretrained` method." ;
                            oc:tableMarkdown """| Integrated Model | Task |
|------------------|------|
| `BasicPhaseAE` | Phase Picking |
| `CRED` | Earthquake Detection |
| `DPP` | Phase Picking |
| `DepthPhaseNet` | Depth estimation from depth phases |
| `DepthPhaseTEAM` | Depth estimation from depth phases |
| `DeepDenoiser` | Denoising |
| `SeisDAE` | Denoising |
| `EQTransformer` | Earthquake Detection/Phase Picking |
| `GPD` | Phase Picking |
| `LFEDetect` | Phase Picking (Low-frequency earthquakes) |
| `OBSTransformer` | Earthquake Detection/Phase Picking |
| `PhaseNet` | Phase Picking |
| `PhaseNetLight` | Phase Picking |
| `PickBlue` | Earthquake Detection/Phase Picking |
| `Skynet` | Phase Picking |
| `VariableLengthPhaseNet` | Phase Picking |
""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Currently integrated models are capable of earthquake detection and phase picking, waveform denoising, depth estimation, and low-frequency earthquake phase picking. Furthermore, with SeisBench you can build ML models to perform general seismic tasks such as magnitude and source parameter estimation, hypocentre determination etc." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "You don't have to build models from scratch if you don't want to. SeisBench integrates the following notable models from the literature for you to use. Again, as they inherit from the common SeisBench model interface, all these deep learning models are constructed through PyTorch. Where possible, the original trained weights are imported and made available. These can be accessed via the `from_pretrained` method." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Models Integrated into SeisBench" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent "The `classify` function also takes an obspy stream as input, but in contrast to the `annotate` function returns discrete results. The structure of these results might be model dependent. For example, a pure picking model will return a list of picks, while a picking and detection model might return a list of picks and a list of detections." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 7 ;
                            oc:textContent "Both `annotate` and `classify` can be supplied with waveforms from multiple stations at once and will automatically handle the correct grouping of the traces. For details on how to build your own model with SeisBench, check the documentation of `WaveformModel`. For details on how to apply models, check out the Examples." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "The `SeisBenchModel` bridges the gap between the pytorch interface of the models and the obspy interface common in seismology. It automatically assembles obspy streams into pytorch tensors and reassembles the results into streams. It also takes care of batch processing. Computations can be run on GPU by simply moving the model to GPU." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "The `annotate` function takes an obspy stream object as input and returns annotations as stream again. For example, for picking models the output would be the characteristic functions, i.e., the pick probabilities over time." ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """stream = obspy.read("my_waveforms.mseed")
annotations = model.annotate(stream)  # Returns obspy stream object with annotations
""" ;
                            oc:codeLanguage "python" ;
                            oc:contentOrder 4 ;
                            oc:sourceLocation "lines 22-25" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """stream = obspy.read("my_waveforms.mseed")
outputs = model.classify(stream)  # Returns a list of picks
print(outputs)
""" ;
                            oc:codeLanguage "python" ;
                            oc:contentOrder 6 ;
                            oc:sourceLocation "lines 29-33" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "SeisBench offers the abstract class `WaveformModel` that every SeisBench model should subclass. This class offers two core functions, `annotate` and `classify`. Both of the functions are automatically generated based on configurations and submethods implemented in the specific model." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Overview" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Pretrained models can not only be used for annotating data, but also offer a great starting point for transfer learning." ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """import seisbench.models as sbm

sbm.PhaseNet.list_pretrained()                  # Get available models
model = sbm.PhaseNet.from_pretrained("original")  # Load the original model weights released by PhaseNet authors
""" ;
                            oc:codeLanguage "python" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 41-46" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "For annotating waveforms in a meaningful way, trained model weights are required. SeisBench offers a range of pretrained model weights through a common interface. Model weights are downloaded on the first use and cached locally afterwards. For some model weights, multiple versions are available. For details on accessing these, check the documentation at `from_pretrained`." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Loading Pretrained Models" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "The seisbench model API can process a stream of waveform data of arbitrary length. Hence, it is not necessary to segment the data yourself. In addition, you should not assume a stream of waveform can only contain one P-wave and one S-wave. It is the best to treat the stream like what it is: a stream of continuous data." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Although the seisbench model API will normalize the waveform for you, it is still highly suggested to apply normalization yourself. Since seisbench's normalization scheme uses an epsilon `(waveform - mean(waveform)) / (std(waveform) + epsilon)`, for extremely small values (such as `<=1e-10`), their normalization can destroy the signals in the waveform." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "If the waveform data happen to be extremely small in scale (`<=1e-10`), there might be risk of numerical instability. It is acceptable to increase the value first (by multiplying a large number like `1e10`) before normalization or passing to the model." ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Best Practices" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "When applying models to large datasets, run time is often a major concern. Here are a few tips to make your model run faster:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Use a large `batch_size`.** This parameter can be passed as an optional argument to all models. Especially on GPUs, larger batch sizes lead to faster annotations. As long as the batch fits into (GPU) memory, it might be worth increasing the batch size." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Run on GPU.** Execution on GPU is usually faster, even though exact speed-ups vary between models. However, we note that running on GPU is not necessarily the most economic option. For example, in cloud applications it might be cheaper (and equally fast) to pay for a handful of CPU machines to annotate a large dataset than for a GPU machine." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Manual resampling.** While SeisBench can automatically resample the waveforms, it can be faster to do the resampling manually beforehand. SeisBench uses obspy routines for resampling, which (as of 2023) are not parallelised. Check the required sampling rate with `model.sampling_rate`. Alternative routines are available, e.g., in the Pyrocko library." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Compile your model (torch 2.0+).** If you are using torch in version 2.0 or newer, compile your model. It's as simple as running `model = torch.compile(model)`. The compilation will take some time but if you are annotating large amounts of waveforms, it should pay off quickly. Note that there are many options for compile that might influence the performance gains considerably." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Use asyncio interface.** Load data in parallel while executing the model using the asyncio interface, i.e., `annotate_asyncio` and `classify_asyncio`. This is usually substantially faster because data loading is IO-bound while the actual annotation is compute-bound." ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Speeding Up Model Application" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "SeisBench Model API" ] ;
    oc:impartsKnowledge oc:kn_14c83d77,
        oc:kn_4fb18aba,
        oc:kn_7931d391,
        oc:kn_7b2275aa,
        oc:kn_c5b826f0 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady,
        oc:FileExists ;
    oc:resolvesIntent "annotate seismic waveforms with ML model outputs",
        "apply phase picking models to waveform data",
        "classify seismic waveforms to extract discrete picks and detections",
        "denoise seismic waveforms using deep learning",
        "detect earthquakes in continuous waveform data",
        "load pretrained seismic ML models" ;
    oc:yieldsState oc:AnnotationsGenerated .

oc:kn_14c83d77 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before passing waveforms to any SeisBench model" ;
    oc:directiveContent "Apply waveform normalization yourself rather than relying solely on SeisBench's built-in normalization, especially for edge-case data." ;
    oc:hasRationale "SeisBench's normalization scheme can destroy signals for extreme-value waveforms." ;
    oc:severityLevel "HIGH" .

oc:kn_4fb18aba a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing waveform streams with classify or annotate" ;
    oc:directiveContent "Do not assume waveform data only contains one P-wave and one S-wave. Treat the stream as continuous data with potentially multiple events." ;
    oc:hasRationale "SeisBench can process arbitrary-length streams and detect multiple events; assuming a single event leads to missed detections." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7931d391 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When waveform amplitude values are extremely small" ;
    oc:directiveContent "For extremely small waveform values (<=1e-10), multiply by a large number (e.g., 1e10) before normalization or passing to the model to avoid numerical instability." ;
    oc:hasRationale "SeisBench's normalization uses epsilon: (waveform - mean) / (std + epsilon). For tiny values, this can destroy the signal." ;
    oc:severityLevel "CRITICAL" .

oc:kn_7b2275aa a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When applying models to large seismic datasets" ;
    oc:directiveContent "Use GPU execution, large batch_size, torch.compile (2.0+), asyncio interface (annotate_asyncio/classify_asyncio), and manual resampling to accelerate model inference on large datasets." ;
    oc:hasRationale "Data loading is IO-bound while annotation is compute-bound; parallelizing both yields substantial speedups." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c5b826f0 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, when using SeisBench models" ;
    oc:directiveContent "The SeisBench model API bridges ObsPy streams and PyTorch tensors automatically. Always provide input as ObsPy Stream objects and expect Stream or structured output." ;
    oc:hasRationale "The SeisBenchModel handles tensor assembly, batch processing, and result reassembly transparently." ;
    oc:severityLevel "HIGH" .

oc:req_065d5379 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "ObsPy Stream/Trace objects" .

oc:req_130776d1 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Seismology waveform data formats (MSEED, SAC, etc.)" .

oc:req_4adadf05 a oc:RequirementHardware ;
    oc:isOptional true ;
    oc:requirementValue "GPU (optional, for faster inference)" .

oc:req_69d81af3 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "obspy" .

oc:req_70d0caaa a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "torch" .

oc:req_c2ef2f1a a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "seisbench" .

