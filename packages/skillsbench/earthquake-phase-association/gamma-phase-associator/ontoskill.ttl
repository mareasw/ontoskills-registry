                                                    oc:contentOrder 1 ;
                                                    oc:rowCount 4 ;
                                                    oc:tableCaption "##### `stations` DataFrame" ;
                                                    oc:tableMarkdown """| Column | Type | Description | Example |
|--------|------|-------------|---------|
| `id` | str | Station identifier | `"CI.CCC..BH"`|
| `x(km)` | float | X coordinate in km (projected) | `-35.6` |
| `y(km)` | float | Y coordinate in km (projected) | `45.2` |
| `z(km)` | float | Z coordinate (elevation, typically negative) | `-0.67` |
""" ],
                                                [ a oc:BulletList ;
                                                    oc:blockType "bullet_list" ;
                                                    oc:contentOrder 3 ;
                                                    oc:hasItem [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 3 ;
                                                            oc:itemText "Group stations by unique `id`, identical attribute are collapsed to a single value and conflicting metadata are preseved as a sorted list." ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 1 ;
                                                            oc:itemText "Coordinates should be in a projected local coordinate system (e.g., you can use the `pyproj` package)" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 2 ;
                                                            oc:itemText "The `id` column must match the `id` values in the picks DataFrame (e.g., `network.station.` or `network.station.location.channel`)" ] ] ;
                                            oc:sectionLevel 5 ;
                                            oc:sectionOrder 2 ;
                                            oc:sectionTitle "`stations` DataFrame" ] ;
                                    oc:sectionLevel 4 ;
