                                    oc:hasContent [ a oc:CodeExample ;
                                            oc:blockType "code_block" ;
                                            oc:codeContent """def association(picks, stations, config, event_idx0=0, method="BGMM", **kwargs)
""" ;
                                            oc:codeLanguage "python" ;
                                            oc:contentOrder 1 ;
                                            oc:sourceLocation "lines 27-29" ] ;
                                    oc:sectionLevel 4 ;
