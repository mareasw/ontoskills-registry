    oc:requirementValue "pandas" .

oc:req_c1ea9da0 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "scikit-learn" .

oc:req_daebd8f7 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Gaussian Mixture Models and Expectation-Maximization" .

oc:req_e0952fcd a oc:RequirementTool ;
