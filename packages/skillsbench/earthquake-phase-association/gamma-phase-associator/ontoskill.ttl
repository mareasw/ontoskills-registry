                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 3 ;
                                                            oc:itemText "`gamma_score`: Probability/confidence of assignment" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 1 ;
                                                            oc:itemText "`pick_index`: Index in the original `picks` DataFrame" ] ],
                                                [ a oc:Paragraph ;
                                                    oc:blockType "paragraph" ;
                                                    oc:contentOrder 1 ;
                                                    oc:textContent "List of tuples `(pick_index, event_index, gamma_score)`:" ] ;
                                            oc:sectionLevel 5 ;
