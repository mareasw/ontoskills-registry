                                                    oc:hasItem [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 4 ;
                                                            oc:itemText "The DataFrame index is used to track pick identities in the output" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 2 ;
                                                            oc:itemText "Phase types are forced to lowercase internally" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 3 ;
                                                            oc:itemText "Picks with `amp == 0` or `amp == -1` are filtered when `use_amplitude=True`" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 1 ;
                                                            oc:itemText "Timestamps must be in UTC or converted to UTC" ] ],
                                                [ a oc:Table ;
                                                    oc:blockType "table" ;
                                                    oc:contentOrder 1 ;
                                                    oc:rowCount 5 ;
                                                    oc:tableCaption "##### `picks` DataFrame" ;
                                                    oc:tableMarkdown """| Column | Type | Description | Example |
|--------|------|-------------|---------|
| `id` | str | Station identifier (must match `stations`) | `network.station.` or `network.station.location.channel` |
| `timestamp` | datetime/str | Pick arrival time (ISO format or datetime) | `"2019-07-04T22:00:06.084"` |
| `type` | str | Phase type: `"p"` or `"s"` (lowercase) | `"p"` |
| `prob` | float | Pick probability/weight (0-1) | `0.94` |
| `amp` | float | Amplitude in m/s (required if `use_amplitude=True`) | `0.000017` |
""" ] ;
                                            oc:sectionLevel 5 ;
                                            oc:sectionOrder 1 ;
                                            oc:sectionTitle "`picks` DataFrame" ],
