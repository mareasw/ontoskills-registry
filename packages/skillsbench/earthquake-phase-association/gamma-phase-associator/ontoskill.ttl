oc:skill_earthquake_phase_association_gamma_phase_associator a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "gamma-phase-associator" ;
    skos:broader "API reference" ;
    prov:wasDerivedFrom ".agents/skills/skillsbench/earthquake-phase-association/gamma-phase-associator" ;
    oc:contentHash "e24de7f555428b8f48ca353dc1e3053e350862cde48013f2866001ff04965b09" ;
    oc:dependsOnSkill oc:skill_ontoskills_seismic_picker_selection ;
    oc:differentia "documents the GaMMA Python library for earthquake phase association via Bayesian Gaussian Mixture Models" ;
    oc:handlesFailure oc:ClusteringFailed,
        oc:InsufficientPicks,
        oc:InvalidInput ;
    oc:hasArgumentHint "picks DataFrame, stations DataFrame, config dict" ;
    oc:hasCategory "research" ;
    oc:hasDescription "An overview of the python package for running the GaMMA earthquake phase association algorithm. The algorithm expects phase picks data and station data as input and produces (through unsupervised clustering) earthquake events with source information like earthquake location, origin time and magnitude. The skill explains commonly used functions and the expected input/output format." ;
    oc:hasName "gamma-phase-associator" ;
    oc:hasRequirement oc:req_02b3c31e,
        oc:req_4d64f8b0,
        oc:req_746aacc9,
