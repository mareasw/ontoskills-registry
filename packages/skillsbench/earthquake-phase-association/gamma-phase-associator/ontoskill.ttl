    oc:requirementValue "numpy" .

oc:req_4d64f8b0 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Seismic phase picking (P/S wave identification)" .

oc:req_746aacc9 a oc:RequirementTool ;
