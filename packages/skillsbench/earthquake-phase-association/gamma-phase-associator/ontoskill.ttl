                                    oc:sectionTitle "2. Required DataFrame Columns" ],
                                [ a oc:Section ;
                                    oc:hasSubsection [ a oc:Section ;
                                            oc:hasContent [ a oc:BulletList ;
                                                    oc:blockType "bullet_list" ;
                                                    oc:contentOrder 3 ;
                                                    oc:hasItem [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 1 ;
                                                            oc:itemText "Options: `[\"x(km)\", \"y(km)\", \"z(km)\"]`, `[\"x(km)\", \"y(km)\"]`, or `[\"x(km)\"]`" ] ],
                                                [ a oc:Paragraph ;
                                                    oc:blockType "paragraph" ;
                                                    oc:contentOrder 4 ;
                                                    oc:textContent "**Notes on `bfgs_bounds`:**" ],
                                                [ a oc:Table ;
                                                    oc:blockType "table" ;
                                                    oc:contentOrder 1 ;
                                                    oc:rowCount 6 ;
                                                    oc:tableCaption "##### Required Keys" ;
                                                    oc:tableMarkdown """| Key | Type | Description | Example |
|-----|------|-------------|---------|
| `dims` | list[str] | Location dimensions to solve for | `["x(km)", "y(km)", "z(km)"]` |
| `min_picks_per_eq` | int | Minimum picks required per earthquake | `5` |
| `max_sigma11` | float | Maximum allowed time residual in seconds | `2.0` |
| `use_amplitude` | bool | Whether to use amplitude in clustering | `True` |
| `bfgs_bounds` | tuple | Bounds for BFGS optimization | `((-35, 92), (-128, 78), (0, 21), (None, None))` |
| `oversample_factor` | float | Factor for oversampling initial GMM components | `5.0` for `BGMM`, `1.0` for `GMM`|
""" ],
                                                [ a oc:BulletList ;
                                                    oc:blockType "bullet_list" ;
                                                    oc:contentOrder 5 ;
                                                    oc:hasItem [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 1 ;
                                                            oc:itemText "Format: `((x_min, x_max), (y_min, y_max), (z_min, z_max), (None, None))`" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 2 ;
                                                            oc:itemText "The last tuple is for time (unbounded)" ] ],
                                                [ a oc:Paragraph ;
                                                    oc:blockType "paragraph" ;
                                                    oc:contentOrder 2 ;
                                                    oc:textContent "**Notes on `dims`:**" ] ;
