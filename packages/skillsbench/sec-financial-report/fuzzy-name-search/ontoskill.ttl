        oc:kn_f5ec061c ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:NetworkAvailable ;
    oc:resolvesIntent "find SEC 13F filing manager information",
        "find stock CUSIP information",
        "lookup fund by accession number",
        "search fund by name",
        "search stock CUSIP by name" ;
    oc:yieldsState oc:SearchResultsAvailable .

oc:kn_40ca4184 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "always" ;
    oc:directiveContent "All search operations are read-only queries; running them multiple times produces the same results without side effects." ;
    oc:hasRationale "Search scripts only query data and do not modify any state." .

oc:kn_6f8a7db6 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running search_fund.py" ;
    oc:directiveContent "Fund search requires a --quarter parameter in YYYY-Q# format (e.g., 2025-q2); stock CUSIP search does not require a quarter." ;
    oc:hasRationale "SEC 13F filings are quarterly, so fund metadata is scoped to a specific reporting quarter." ;
    oc:severityLevel "HIGH" .

oc:kn_71728acc a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When tuning search performance" ;
    oc:directiveContent "Use --topk to control the number of results returned; lower topk values improve response time when only the best match is needed." ;
    oc:hasRationale "Fuzzy matching across large SEC datasets can be expensive; limiting results reduces computation and output size." .

oc:kn_aaecfdb7 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When searching for fund or stock information" ;
    oc:directiveContent "Use fuzzy search when the exact fund or stock name is uncertain; use accession number lookup when the exact identifier is known for precise matching." ;
    oc:hasRationale "Fuzzy search returns ranked results with similarity scores, while accession number search returns an exact match if found." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f5ec061c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When interpreting fuzzy search results" ;
    oc:directiveContent "Do not assume the top-ranked result is always the correct match; review the similarity score and all returned results to identify the intended entity." ;
    oc:hasRationale "Multiple funds may have similar names (e.g., 'Bridgewater Associates, LP' vs 'Bridgewater Advisors Inc.') with comparable scores." ;
    oc:severityLevel "MEDIUM" .

oc:payload_e4931e7708eec882 a oc:ExecutionPayload ;
    oc:code "python3 scripts/search_fund.py --keywords \"{keywords}\" --quarter {quarter} --topk {topk}" ;
    oc:executor "python" ;
    oc:timeout 30000 .

oc:req_3f905e24 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "scripts/search_fund.py" .

oc:req_3fcf652e a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "python3" .

oc:req_aaeed979 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "scripts/search_stock_cusip.py" .

_:ref_5d669a49314cb853 a oc:WorkflowStep ;
    dcterms:description "Review ranked results to identify the correct fund from similarity scores and metadata" ;
    oc:expectedOutcome "Identified correct fund with accession number" ;
    oc:stepDependsOn _:ref_caeafaffd0b06bad ;
    oc:stepId "review-results" .

_:ref_c8ad0d888f71e110 a oc:WorkflowStep ;
    dcterms:description "Run search_stock_cusip.py with --keywords and optional --topk" ;
    oc:expectedOutcome "Ranked list of stocks matching the keyword with CUSIP codes" ;
    oc:stepId "search-stock" .

_:ref_caeafaffd0b06bad a oc:WorkflowStep ;
    dcterms:description "Run search_fund.py with --keywords, --quarter, and optional --topk" ;
    oc:expectedOutcome "Ranked list of funds matching the keyword with similarity scores" ;
    oc:stepId "fuzzy-search" .

