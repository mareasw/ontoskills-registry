** Rank 2 (score = 81.818) **
  ACCESSION_NUMBER: 0001085146-25-004534
  REPORTCALENDARORQUARTER: 30-JUN-2025
  FILINGMANAGER_NAME: Bridgewater Advisors Inc.
  FILINGMANAGER_STREET: 600 FIFTH AVENUE
  FILINGMANAGER_CITY: NEW YORK
  FILINGMANAGER_STATEORCOUNTRY: NY
  FORM13FFILENUMBER: 028-16088
...
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 3 ;
                            oc:sourceLocation "lines 20-39" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """python3 scripts/search_fund.py --keywords "bridgewater" --quarter 2025-q2 --topk 10
""" ;
                            oc:codeLanguage "bash" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 15-17" ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Fuzzy search a fund using its name" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 2 ;
            oc:sectionTitle "Usage" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "This tool is essentially a search engine that provides you the ability to search a fund or stock meta information with a name. Note that you don't have to provide the accurate name since this tool has built-in fuzzy string search algorithms based on Levinsteins." ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Overview" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Search for stock CUSIP information using an approximate stock name" ;
            oc:hasStep [ a oc:WorkflowStep ;
                    dcterms:description "Select the correct stock from ranked results based on name and score" ;
                    oc:expectedOutcome "Correct stock CUSIP identified" ;
                    oc:stepDependsOn _:ref_c8ad0d888f71e110 ;
                    oc:stepId "select-match" ],
                _:ref_c8ad0d888f71e110 ;
            oc:workflowId "stock-cusip-search" ;
            oc:workflowName "Stock CUSIP Search Workflow" ],
        [ a oc:Workflow ;
            dcterms:description "Search for SEC 13F fund information using an approximate fund name" ;
            oc:hasStep [ a oc:WorkflowStep ;
                    dcterms:description "Optionally confirm identity using --accession_number for exact lookup" ;
                    oc:expectedOutcome "Exact single-match confirmation of the fund" ;
                    oc:stepDependsOn _:ref_5d669a49314cb853 ;
                    oc:stepId "confirm-exact" ],
