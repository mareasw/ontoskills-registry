oc:skill_sec_financial_report_fuzzy_name_search a oc:ExecutableSkill,
        oc:Skill ;
    dcterms:identifier "fuzzy-name-search" ;
    skos:broader "search engine" ;
    prov:wasDerivedFrom ".agents/skills/skillsbench/sec-financial-report/fuzzy-name-search" ;
    oc:contentHash "e4931e7708eec882eebc57ea36b603b1099b113a774ad674e12040c59f6d5899" ;
    oc:differentia "provides fuzzy string matching for SEC 13F fund and stock metadata using approximate names" ;
    oc:handlesFailure oc:NetworkTimeout,
        oc:NoResultsFound ;
    oc:hasAllowedTool "Bash" ;
    oc:hasArgumentHint "--keywords \\\"fund or stock name\\\" --quarter YYYY-Q# --topk N" ;
    oc:hasCategory "finance" ;
    oc:hasDescription "This skill includes search capability in 13F, such as fuzzy search a fund information using possibly inaccurate name, or fuzzy search a stock cusip info using its name." ;
    oc:hasName "fuzzy-name-search" ;
    oc:hasPayload oc:payload_e4931e7708eec882 ;
    oc:hasRequirement oc:req_3f905e24,
