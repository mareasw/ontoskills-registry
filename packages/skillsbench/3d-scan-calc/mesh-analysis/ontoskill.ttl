oc:kn_4373f8e6 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calculating mass from mesh analysis results" ;
    oc:directiveContent "To calculate Mass: 1) Read Material ID from analysis report, 2) Look up density from material reference data, 3) Mass = Volume × Density. If density table uses same unit system, multiply directly without conversion." ;
    oc:hasRationale "Mass calculation is the primary downstream use of volume analysis results." ;
    oc:severityLevel "HIGH" .

oc:kn_680789a8 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When interpreting volume results or calculating mass" ;
    oc:directiveContent "Volume is returned in the same units as the STL file's coordinates (cubed). Do not assume millimeters or inches — check task instructions for coordinate system units." ;
    oc:hasRationale "Incorrect unit assumptions lead to mass calculation errors by orders of magnitude." ;
    oc:severityLevel "CRITICAL" .

oc:kn_b3177c24 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing dirty scan data with multiple disconnected components" ;
    oc:directiveContent "Use analyze_largest_component() to isolate the main part from noisy 3D scan data containing debris and disconnected fragments." ;
    oc:hasRationale "Noisy 3D scans typically contain small disconnected fragments; the largest component is usually the intended part." ;
    oc:severityLevel "MEDIUM" .

oc:kn_fff70353 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When working with STL files that contain embedded metadata" ;
    oc:directiveContent "The tool automatically handles Binary STL files and extracts the 2-byte attribute field (often used for color or material ID)." ;
    oc:hasRationale "Binary STL attribute bytes are commonly used to encode material or color information that is critical for manufacturing workflows." ;
    oc:severityLevel "MEDIUM" .

