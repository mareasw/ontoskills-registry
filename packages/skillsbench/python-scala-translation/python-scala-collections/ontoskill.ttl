    oc:dependsOnSkill oc:skill_ontoskills_python_scala_syntax_mapping ;
    oc:differentia "maps Python collection operations (lists, dicts, sets, transformations) to idiomatic Scala equivalents, covering creation, transformation, access, sorting, grouping, and mutability patterns" ;
    oc:extends oc:skill_ontoskills_python_scala_idioms ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "Python collection code snippet or operation name to translate" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Guide for translating Python collection operations to idiomatic Scala. Use when converting Python code that uses lists, dictionaries, sets, or involves collection transformations like map, filter, reduce, sorting, and aggregations." ;
