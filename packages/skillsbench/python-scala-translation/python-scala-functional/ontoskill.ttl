oc:kn_16cbab8d a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting Python yield-based generators to Scala" ;
    oc:codeLanguage "scala" ;
    oc:directiveContent """// Python generators → Scala LazyList
def fibonacci: LazyList[BigInt] = {
  def loop(a: BigInt, b: BigInt): LazyList[BigInt] =
    a #:: loop(b, a + b)
  loop(0, 1)
}""" .

oc:kn_4e409461 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When translating Python recursive functions to Scala" ;
    oc:directiveContent "Use @tailrec annotation on all recursive functions that should be tail-optimized; Python has no equivalent guarantee." ;
    oc:hasRationale "The @tailrec annotation causes a compile-time error if the compiler cannot optimize tail calls, preventing silent stack overflows." ;
    oc:severityLevel "HIGH" .

oc:kn_51a6a893 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When translating Python compose() or pipe() helpers to Scala" ;
    oc:directiveContent "Use Scala's built-in compose and andThen for function composition instead of defining custom compose/pipe utilities." ;
    oc:hasRationale "Scala's Function1 has compose and andThen built in, providing idiomatic and type-safe composition." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7916a8ea a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting Python try/except patterns to Scala" ;
    oc:directiveContent "Prefer Try for wrapping exceptions and Either for custom error types with meaningful error information." ;
    oc:hasRationale "Try captures exceptions as values; Either allows typed error channels that are more informative than exception hierarchies." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7b47136a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting Python @decorator patterns to Scala" ;
    oc:directiveContent "Translate Python decorators to Scala function composition using higher-order functions or by-name parameters, not via annotation-based decoration." ;
    oc:hasRationale "Scala lacks Python-style decorators; function composition and by-name parameters achieve the same cross-cutting concerns more explicitly." ;
    oc:severityLevel "HIGH" .

oc:kn_7d78acfc a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When translating Python match/case on structured data to Scala" ;
    oc:directiveContent "Use sealed traits with case classes for pattern matching instead of open inheritance hierarchies." ;
    oc:hasRationale "Sealed traits enable exhaustive matching checked by the compiler, preventing unhandled cases." ;
    oc:severityLevel "HIGH" .

oc:kn_a6e394d3 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting Python recursive functions to Scala" ;
    oc:codeLanguage "scala" ;
    oc:directiveContent """// Tail recursion with accumulator pattern
import scala.annotation.tailrec
def factorial(n: Int): BigInt = {
  @tailrec
  def loop(n: Int, acc: BigInt): BigInt = {
    if (n <= 1) acc else loop(n - 1, n * acc)
  }
  loop(n, 1)
}""" .

oc:kn_b0d48980 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "Translation output format for each functional pattern" ;
    oc:directiveContent """## {Pattern Name}
```python
# Python
{python_code}
```
```scala
// Scala
{scala_code}
```""" ;
    oc:templateVariables "Pattern Name",
        "python_code",
        "scala_code" .

oc:kn_b2c49450 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting Python Optional[T] or None-returning functions" ;
    oc:directiveContent "Never translate Python None checks to null in Scala; always use Option[T] with map/flatMap/for-comprehensions." ;
    oc:hasRationale "Using null defeats Scala's null-safety guarantees and loses the monadic chaining benefits of Option." ;
    oc:severityLevel "CRITICAL" .

oc:kn_c49d673a a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When translating any Python functional code to Scala" ;
    oc:directiveContent "1. Identify the Python functional pattern (HOF, decorator, generator, Option, exception, composition, currying, recursion, type class) 2. Map to the corresponding Scala idiom 3. Use Scala's type system (generics, sealed traits, Option/Either/Try) 4. Verify pattern exhaustiveness and type safety" ;
    oc:stepOrder 1 .

oc:kn_f0854af8 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting chained Python None checks to Scala Option chaining" ;
    oc:codeLanguage "scala" ;
    oc:directiveContent """// Python: nested None checks → Scala: for-comprehension
def getUserCity(userId: Int): Option[String] = for {
  user <- findUser(userId)
  address <- user.address
  city <- Option(address.city)
} yield city""" .

oc:kn_f191f3a7 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When converting Python generator functions to Scala" ;
    oc:directiveContent "Translate Python generators (yield) to Scala LazyList for memoized lazy sequences or Iterator for non-memoized ones." ;
    oc:hasRationale "LazyList (Scala 2.13+) is the idiomatic replacement for Python generators, with #:: as the lazy cons operator." ;
    oc:severityLevel "MEDIUM" .

