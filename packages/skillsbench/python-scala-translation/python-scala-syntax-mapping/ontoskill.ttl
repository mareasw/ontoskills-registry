    oc:isUserInvocable true ;
    oc:nature "Reference" ;
    oc:resolvesIntent "convert Python None/null handling to Scala Option",
        "convert Python control flow to Scala",
        "convert Python functions to Scala",
        "map Python operators to Scala equivalents",
        "map Python types to Scala types",
        "translate Python comprehensions to Scala",
        "translate Python exception handling to Scala",
        "translate Python syntax to Scala" .

oc:kn_0330dbd7 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When translating Python boolean expressions and membership tests" ;
    oc:directiveContent "Python logical operators `and`, `or`, `not` map to Scala `&&`, `||`, `!` respectively. Python's `in` operator maps to `.contains()` method, and `is` maps to `eq` (reference equality)." ;
    oc:hasRationale "Scala does not have keyword-based logical or membership operators; using the wrong mapping causes compilation errors." ;
    oc:severityLevel "HIGH" .

oc:kn_1134a2a5 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When declaring variables in Scala translated from Python" ;
    oc:directiveContent "Prefer `val` over `var` when translating Python variable declarations to Scala. Use `val` (immutable) by default; only use `var` (mutable) when mutation is explicitly required." ;
    oc:hasRationale "Scala idiomatic style favors immutability for safer, more predictable code." ;
    oc:severityLevel "MEDIUM" .

oc:kn_4c6a3150 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When translating Python f-string formatting to Scala" ;
    oc:codeLanguage "scala" ;
    oc:directiveContent """// Python f-string → Scala string interpolation
// f"Hello, {name}!"        →  s"Hello, $name!"
// f"Value: {x:.2f}"       →  f"Value: $x%.2f"
// f"{x + y}"              →  s"${x + y}\"""" ;
    oc:hasRationale "Scala uses `s` interpolator for simple substitution and `f` interpolator for formatted output, mirroring Python's f-string capabilities." .

oc:kn_55c86def a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When translating any Python syntax to Scala" ;
    oc:directiveContent "1. Identify the Python syntax construct (variable, type, control flow, comprehension, function, operator, exception, null-handling). 2. Look up the corresponding Scala equivalent from the mapping tables. 3. Apply Scala-idiomatic patterns (val over var, if-as-expression, Option over null, Try monad for exceptions). 4. Verify the translated code compiles and preserves semantics." ;
    oc:stepOrder 1 .

oc:kn_a78e03c1 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When translating Python list comprehensions to Scala" ;
    oc:codeLanguage "scala" ;
    oc:directiveContent """// Python list comprehension → Scala map/filter or for-comprehension
// [x**2 for x in range(10)]  →  (0 until 10).map(x => x * x).toList
// [x for x in nums if x%2==0] →  numbers.filter(_ % 2 == 0)
// [(x,y) for x in xs for y in ys] →  for { x <- xs; y <- ys } yield (x, y)""" ;
    oc:hasRationale "Python comprehensions have direct Scala equivalents but use different syntax; map/filter is more common for simple cases, for-comprehensions for nested generators." .

oc:kn_df7c94fd a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When translating Python None/null handling patterns" ;
    oc:directiveContent "Prefer Scala's `Option[T]` with pattern matching or `map/getOrElse` over direct null handling when translating Python's None checks." ;
    oc:hasRationale "Option is Scala's idiomatic way to represent optional values and avoids null pointer exceptions." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e1ed16fc a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting Python exception handling to Scala" ;
    oc:directiveContent "Translate Python try/except to either Scala try/catch/finally (imperative style) or `scala.util.Try` monad with Success/Failure pattern matching (functional style, preferred)." ;
    oc:hasRationale "The Try monad integrates exception handling into Scala's functional composition model, enabling safer chained operations." ;
    oc:severityLevel "LOW" .

oc:kn_e9bdb2cf a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting Python conditional assignment patterns" ;
    oc:directiveContent "Scala `if/else` is an expression that returns a value. Translate Python if/elif/else blocks that assign to a variable into a single `val result = if (...) ... else if (...) ... else ...` expression." ;
    oc:hasRationale "Using if-as-expression is idiomatic Scala and eliminates mutable intermediate variables." ;
    oc:severityLevel "MEDIUM" .

