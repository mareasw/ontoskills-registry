oc:kn_1affda2b a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When presenting Python-to-Scala translation guidance" ;
    oc:directiveContent """## Core Principle
- {principle_name}: {description}

```python
# Python pattern
{python_code}
```

```scala
// Idiomatic Scala
{scala_code}
```""" ;
    oc:templateVariables "description",
        "principle_name",
        "python_code",
        "scala_code" .

oc:kn_3faeb7af a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When translating Python None-check chains to Scala Option" ;
    oc:codeLanguage "scala" ;
    oc:directiveContent """def findUser(id: Int): Option[String] = for {
  user <- db.get(id)
  profile <- user.profile
  email <- profile.email
} yield email""" .

oc:kn_407964b3 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When translating Python duck typing or isinstance checks" ;
    oc:directiveContent "Never use Any or asInstanceOf casts. Use sealed trait hierarchies and pattern matching for domain types." ;
    oc:hasRationale "Type safety eliminates an entire class of runtime errors and enables compiler-verified exhaustive matching." ;
    oc:severityLevel "CRITICAL" .

oc:kn_48f99611 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When translating Python control flow to Scala" ;
    oc:directiveContent "Use expression-based style: everything should return a value. Replace statement-based if-elif-else chains with pattern match expressions." ;
    oc:hasRationale "Scala treats most constructs as expressions, enabling more concise and composable code." ;
    oc:severityLevel "HIGH" .

oc:kn_8270b137 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When translating any Python mutable pattern to Scala" ;
    oc:directiveContent "Prefer immutability: use val over var, immutable collections, and case class copy methods instead of mutation." ;
    oc:hasRationale "Immutable code is easier to reason about, thread-safe, and aligns with Scala's functional paradigm." ;
    oc:severityLevel "CRITICAL" .

oc:kn_854e90cc a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When translating Python string-based type dispatch to Scala" ;
    oc:codeLanguage "scala" ;
    oc:directiveContent """sealed trait PaymentMethod
case class CreditCard(number: String, expiry: String) extends PaymentMethod
case class DebitCard(number: String) extends PaymentMethod

def process(method: PaymentMethod): Unit = method match {
  case CreditCard(num, exp) => // ...
  case DebitCard(num) => // ...
}""" .

oc:kn_9dfd7b97 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "1. Identify Python pattern (mutation, None checks, loops, string dispatch) 2. Map to idiomatic Scala equivalent (case class copy, Option, collection methods, sealed trait) 3. Apply Scala naming conventions (camelCase) 4. Ensure expression-based style (no unnecessary statements) 5. Verify type safety (no Any, no null, no asInstanceOf)" ;
    oc:stepOrder 1 .

oc:kn_aac52803 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When translating Python None checks or exception handling" ;
    oc:directiveContent "Never use null in Scala. Use Option, Either, or Try to represent absence or failure." ;
    oc:hasRationale "Null references are a major source of runtime errors. Option/Either/Try make absence explicit and force handling at compile time." ;
    oc:severityLevel "CRITICAL" .

oc:kn_abebe144 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When translating Python for-loops that accumulate results" ;
    oc:directiveContent "Do not use mutable accumulators with var in loops. Use foldLeft, foldRight, or collection methods like sum, map, filter." ;
    oc:hasRationale "Functional transformations are more composable, testable, and avoid shared mutable state." ;
    oc:severityLevel "HIGH" .

oc:kn_c2bc8e82 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When naming any Scala identifier translated from Python" ;
    oc:directiveContent "Convert snake_case Python names to camelCase for Scala methods/variables. Constants can use CamelCase or PascalCase in Scala." ;
    oc:hasRationale "Following Scala naming conventions ensures code is readable and consistent with the ecosystem." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c5822b12 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When translating Python functions that implicitly return None after performing side effects" ;
    oc:directiveContent "Avoid returning Unit from methods. Return Either[Error, Result], Try, or at minimum useful diagnostic information." ;
    oc:hasRationale "Returning meaningful types enables callers to handle results functionally and improves error propagation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e76e5d05 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When translating Python code that uses string comparisons or isinstance for branching on types" ;
    oc:directiveContent "Use sealed traits for domain modeling instead of string-based dispatch. The compiler will warn on non-exhaustive matches." ;
    oc:hasRationale "Sealed hierarchies provide compile-time guarantees that all cases are handled." ;
    oc:severityLevel "MEDIUM" .

