                                            oc:itemOrder 2 ;
                                            oc:itemText "If value = 107.5 (outside range) → likely in g/L" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Expected range: 3.0 - 20.0 g/dL" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Try factor 0.1: 107.5 × 0.1 = 10.75 g/dL ✓ (in range)" ] ],
                                _:ref_0e55fb2725197618,
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 5 ;
                                    oc:textContent "**Example 1**: Serum Creatinine" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 7 ;
                                    oc:textContent "**Example 2**: Hemoglobin" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 6 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Try factor 0.0113: 673.4 × 0.0113 = 7.61 mg/dL ✓ (in range)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Expected range: 0.2 - 20.0 mg/dL" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "If value = 673.4 (outside range) → likely in µmol/L" ] ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """def convert_unit_if_needed(value, column, reference_ranges, conversion_factors):
    \"\"\"
    If value is outside expected range, try conversion factors.

    Logic:
    1. If value is within range [min, max], return as-is
    2. If outside range, try each conversion factor
    3. Return first converted value that falls within range
    4. If no conversion works, return original (NO CLAMPING!)
    \"\"\"
    if pd.isna(value):
        return value

    if column not in reference_ranges:
        return value

    min_val, max_val = reference_ranges[column]

    # If already in range, no conversion needed
    if min_val <= value <= max_val:
        return value

    # Get conversion factors for this column
    factors = conversion_factors.get(column, [])

    # Try each factor
    for factor in factors:
        converted = value * factor
        if min_val <= converted <= max_val:
            return converted

    # No conversion worked - return original (NO CLAMPING!)
    return value

# Apply to all numeric columns
for col in numeric_cols:
    df[col] = df[col].apply(lambda x: convert_unit_if_needed(x, col, reference_ranges, conversion_factors))
""" ;
