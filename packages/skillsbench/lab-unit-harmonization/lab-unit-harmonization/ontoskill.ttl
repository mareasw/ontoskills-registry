                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "The harmonization process follows these steps in order:" ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Before harmonization, filter out rows with any missing values:" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """def count_missing(row, numeric_cols):
    \"\"\"Count missing/empty values in numeric columns\"\"\"
    count = 0
    for col in numeric_cols:
        val = row[col]
        if pd.isna(val) or str(val).strip() in ['', 'NaN', 'None', 'nan', 'none']:
            count += 1
    return count

# Keep only rows with NO missing values
missing_counts = df.apply(lambda row: count_missing(row, numeric_cols), axis=1)
complete_mask = missing_counts == 0
df = df[complete_mask].reset_index(drop=True)
""" ;
