oc:kn_01841c73 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using openpyxl load_workbook()" ;
    oc:directiveContent "Never open a workbook with data_only=True and save it — formulas are permanently replaced with cached values and cannot be recovered." ;
    oc:hasRationale "data_only=True reads the last cached calculated values but discards all formula strings; saving overwrites the file with values only." ;
    oc:severityLevel "CRITICAL" .

oc:kn_33f8960a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building financial models unless user or existing template specifies otherwise" ;
    oc:directiveContent "Use financial model color coding: Blue (0,0,255) for hardcoded inputs, Black (0,0,0) for formulas, Green (0,128,0) for cross-sheet links, Red (255,0,0) for external links, Yellow background (255,255,0) for key assumptions." ;
    oc:hasRationale "Industry-standard color coding allows users to instantly distinguish inputs from calculations and identify data sources." ;
    oc:severityLevel "MEDIUM" .

oc:kn_371858b1 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When validating formula recalculations" ;
    oc:directiveContent "recalc.py returns JSON with status 'success' and total_errors: 0." ;
    oc:hasRationale "Zero errors confirms all formulas evaluate correctly without #REF!, #DIV/0!, #VALUE!, #N/A, or #NAME? errors." ;
    oc:severityLevel "MEDIUM" .

oc:kn_37971016 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before executing any Excel workflow with formulas" ;
    oc:directiveContent "LibreOffice must be installed for formula recalculation via recalc.py (auto-configures on first run). Python packages openpyxl and pandas required." .

oc:kn_456ec06d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When hardcoding any data values into Excel cells" ;
    oc:directiveContent "Document all hardcoded values with source citations in format: 'Source: [System/Document], [Date], [Specific Reference], [URL if applicable]'." ;
    oc:hasRationale "Traceability of hardcoded data is essential for audit compliance and verification." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5082630c a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When working with any Excel file" ;
    oc:directiveContent "1. Choose tool (pandas for data, openpyxl for formulas/formatting) 2. Create new workbook or load existing file 3. Add/edit data, formulas, and formatting 4. Save to file 5. Run 'python recalc.py output.xlsx' (MANDATORY if formulas used) 6. Verify JSON output — fix any errors and recalculate again" ;
    oc:hasRationale "This is the canonical workflow ensuring formula correctness from creation through delivery." ;
    oc:severityLevel "HIGH" ;
    oc:stepOrder 1 .

oc:kn_56aa51fe a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After saving any Excel file containing formulas" ;
    oc:directiveContent "After saving any file with formulas, run 'python recalc.py <file>' and check the JSON output for error_summary. If status is 'errors_found', fix identified errors and recalculate again." ;
    oc:hasRationale "openpyxl writes formulas as strings without evaluating them; recalc.py validates all formulas and reports errors by location." ;
    oc:severityLevel "CRITICAL" .

oc:kn_5b6854a2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When modifying existing Excel files" ;
    oc:directiveContent "When editing existing templates, study and EXACTLY match existing format, style, and conventions. Existing template conventions ALWAYS override default guidelines." ;
    oc:hasRationale "Consistency with established formatting prevents confusion and maintains document integrity." ;
    oc:severityLevel "HIGH" .

oc:kn_608b40e9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When delivering any Excel file" ;
    oc:directiveContent "Every Excel model MUST be delivered with ZERO formula errors (#REF!, #DIV/0!, #VALUE!, #N/A, #NAME?)." ;
    oc:hasRationale "Formula errors indicate broken calculations and undermine the spreadsheet's reliability and usability." ;
    oc:severityLevel "CRITICAL" .

oc:kn_90f46997 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating new Excel files with formulas and formatting" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from openpyxl import Workbook
from openpyxl.styles import Font, PatternFill, Alignment

wb = Workbook()
sheet = wb.active
sheet['A1'] = 'Label'
sheet['B2'] = '=SUM(A1:A10)'
sheet['A1'].font = Font(bold=True, color='FF0000')
sheet['A1'].fill = PatternFill('solid', start_color='FFFF00')
sheet.column_dimensions['A'].width = 20
wb.save('output.xlsx')""" .

oc:kn_959d0f04 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "recalc.py output format" ;
    oc:directiveContent """{
  "status": "{success|errors_found}",
  "total_errors": {count},
  "total_formulas": {count},
  "error_summary": {
    "#REF!": {"count": N, "locations": ["Sheet!Cell"]}
  }
}""" ;
    oc:templateVariables "error_summary",
        "status",
        "total_errors",
        "total_formulas" .

oc:kn_991ad6b5 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before creating formulas in Excel via openpyxl" ;
    oc:directiveContent "Before building formulas broadly: test 2-3 sample references, confirm column mapping (e.g., column 64 = BL), remember row offset (DataFrame row 5 = Excel row 6), and check for null values with pd.notna()." ;
    oc:hasRationale "Off-by-one errors and column index mistakes are the most common source of broken formulas." ;
    oc:severityLevel "HIGH" .

oc:kn_a5a241fe a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing data to Excel cells that involve calculations" ;
    oc:directiveContent "Never hardcode calculated values in cells. Always use Excel formulas (e.g., '=SUM(B2:B9)') instead of writing Python-computed results (e.g., sheet['B10'] = 5000)." ;
    oc:hasRationale "Hardcoded values make the spreadsheet static and break when source data changes; formulas preserve dynamic recalculation." ;
    oc:severityLevel "CRITICAL" .

oc:kn_b8509e7b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building financial or projection models" ;
    oc:directiveContent "Place ALL assumptions (growth rates, margins, multiples) in separate cells and reference them in formulas (e.g., =B5*(1+$B$6)) instead of hardcoding values into formulas (e.g., =B5*1.05)." ;
    oc:hasRationale "Centralized assumptions enable scenario analysis and prevent errors from scattered hardcoded values." ;
    oc:severityLevel "HIGH" .

oc:kn_c159bf50 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reading and analyzing Excel data" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """import pandas as pd
df = pd.read_excel('file.xlsx')
all_sheets = pd.read_excel('file.xlsx', sheet_name=None)
df.head()
df.describe()
df.to_excel('output.xlsx', index=False)""" .

oc:kn_ca81fa3f a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When editing existing Excel files while preserving formulas" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from openpyxl import load_workbook
wb = load_workbook('existing.xlsx')
sheet = wb.active
sheet['A1'] = 'New Value'
sheet.insert_rows(2)
sheet.delete_cols(3)
new_sheet = wb.create_sheet('NewSheet')
new_sheet['A1'] = 'Data'
wb.save('modified.xlsx')""" .

oc:kn_d3e53092 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When recalculating formulas" ;
    oc:directiveContent "Running recalc.py multiple times on the same file is safe — it recalculates all formulas and overwrites cached values each time." ;
    oc:hasRationale "Idempotent recalculation ensures repeated runs don't corrupt the file." ;
    oc:severityLevel "LOW" .

oc:kn_fa013673 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When choosing which library to use for a task" ;
    oc:directiveContent "Library selection: pandas for data analysis, bulk operations, and simple export; openpyxl for complex formatting, formulas, and Excel-specific features." ;
    oc:hasRationale "Each library has different strengths; using the wrong one leads to unnecessary complexity or missing capabilities." ;
    oc:severityLevel "MEDIUM" .

