                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """# Basic formatting
python scripts/format_bibtex.py references.bib

# Sort by year (newest first)
python scripts/format_bibtex.py references.bib \\
  --sort year \\
  --descending \\
  --output sorted_refs.bib

# Remove duplicates
python scripts/format_bibtex.py references.bib \\
  --deduplicate \\
  --output clean_refs.bib

# Complete cleanup
python scripts/format_bibtex.py references.bib \\
  --deduplicate \\
  --sort year \\
  --validate \\
  --auto-fix \\
  --output final_refs.bib
""" ;
