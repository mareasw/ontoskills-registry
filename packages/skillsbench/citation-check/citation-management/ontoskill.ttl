oc:kn_0732caf7 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Cleaning an existing messy BibTeX file" ;
    oc:directiveContent "1. Run format_bibtex.py to standardize formatting. 2. Run format_bibtex.py --deduplicate to remove duplicates. 3. Run validate_citations.py --auto-fix to fix issues. 4. Run format_bibtex.py --sort year --descending for final ordering. 5. Run validate_citations.py --report for final validation." ;
    oc:stepOrder 2 .

oc:kn_19f39273 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When constructing search queries for academic databases" ;
    oc:directiveContent "Start broad with general search terms, then narrow with specific keywords, filters, and Boolean operators. Use synonyms and related terms with OR to maximize recall." ;
    oc:hasRationale "Progressive refinement balances recall (finding all relevant work) with precision (avoiding irrelevant results)" ;
    oc:severityLevel "MEDIUM" .

oc:kn_1bd64f13 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "After metadata extraction from any API" ;
    oc:directiveContent "Never accept extracted metadata blindly without verification. Always spot-check author names, journal names, publication year, and page numbers against original sources." ;
    oc:hasRationale "API-returned metadata can contain errors, missing fields, or incorrect information that propagates into bibliographies" ;
    oc:severityLevel "HIGH" .

oc:kn_1c3a4dbf a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before searching or extracting metadata from online sources" ;
    oc:directiveContent "Network access required for CrossRef, PubMed, and arXiv API calls" .

oc:kn_2106be91 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding new citations to a bibliography" ;
    oc:directiveContent "Never manually type BibTeX entries by hand. Always extract from metadata sources using scripts to avoid transcription errors." ;
    oc:hasRationale "Manual entry introduces typos, inconsistent formatting, and missing fields that are hard to detect later" ;
    oc:severityLevel "HIGH" .

oc:kn_22a2a962 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing preprint citations (arXiv, bioRxiv)" ;
    oc:directiveContent "Never cite a preprint when the published version exists. Always check if preprints have been formally published and update to the journal version." ;
    oc:hasRationale "Citing the published version ensures reference stability and gives credit to the peer-reviewed record" ;
    oc:severityLevel "MEDIUM" .

oc:kn_2a719375 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Extracting metadata from various paper identifier types" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """python scripts/extract_metadata.py --doi 10.1038/s41586-021-03819-2
python scripts/extract_metadata.py --pmid 34265844
python scripts/extract_metadata.py --arxiv 2103.14030
python scripts/extract_metadata.py --input identifiers.txt --output citations.bib""" .

oc:kn_3dd80849 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After running the complete citation management pipeline" ;
    oc:directiveContent "After generating final BibTeX, review the validation report JSON for errors (severity: high) and fix all issues before using the file in LaTeX." ;
    oc:hasRationale "Unreviewed validation reports may mask critical errors like broken DOIs or missing required fields" ;
    oc:severityLevel "HIGH" .

oc:kn_47a1ba80 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before running any citation management scripts" ;
    oc:directiveContent "Python 3.10+ with requests, bibtexparser, and biopython packages installed" .

oc:kn_5f4f84b1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When identifying and extracting citation metadata" ;
    oc:directiveContent "Use DOIs as the primary identifier when available. DOIs provide the most reliable permanent link and best metadata via CrossRef." ;
    oc:hasRationale "DOIs are persistent identifiers that resolve reliably and return structured metadata from CrossRef" ;
    oc:severityLevel "HIGH" .

oc:kn_7c6a9e66 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "Installing required Python dependencies" ;
    oc:directiveContent "pip install requests bibtexparser biopython" .

oc:kn_7d14d1e7 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning any citation management workflow" ;
    oc:directiveContent "Verify Python 3.10+ is installed and required packages (requests, bibtexparser, biopython) are available before running any scripts." ;
    oc:hasRationale "Missing dependencies cause immediate failures and frustrate users" ;
    oc:severityLevel "HIGH" .

oc:kn_7dfc02d5 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When validate_citations.py reports broken or invalid DOIs" ;
    oc:directiveContent "When DOIs fail to resolve, search for the paper title on Google Scholar or CrossRef to find the correct identifier. Update the BibTeX entry with the verified DOI." ;
    oc:hasRationale "Broken DOIs are common due to publisher migrations or typos; manual re-lookup restores citation integrity" ;
    oc:severityLevel "MEDIUM" .

oc:kn_8574c278 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Formatting and validating BibTeX files" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """python scripts/format_bibtex.py references.bib --deduplicate --sort year --descending --output clean.bib
python scripts/validate_citations.py references.bib --auto-fix --report report.json --output validated.bib""" .

oc:kn_88b27a03 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Standard BibTeX entry format for journal articles" ;
    oc:codeLanguage "bibtex" ;
    oc:directiveContent """@article{citationkey,
  author  = {Last1, First1 and Last2, First2},
  title   = {Article Title},
  journal = {Journal Name},
  year    = {2024},
  volume  = {10},
  number  = {3},
  pages   = {123--145},
  doi     = {10.1234/example}
}""" .

oc:kn_90b47644 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before submitting any manuscript or thesis" ;
    oc:directiveContent "Always validate the complete bibliography before final submission. Run validate_citations.py with --auto-fix and --report as the last step." ;
    oc:hasRationale "Citation errors discovered after submission damage credibility and may require corrections" ;
    oc:severityLevel "CRITICAL" .

oc:kn_920892ea a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When searching for academic papers" ;
    oc:directiveContent "Never rely on a single database (Google Scholar or PubMed alone). Always search multiple databases for comprehensive coverage to avoid source bias." ;
    oc:hasRationale "Single source bias leads to incomplete literature coverage and missed relevant papers" ;
    oc:severityLevel "HIGH" .

oc:kn_939b99c5 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Complete bibliography building workflow" ;
    oc:directiveContent "1. Search papers via Google Scholar and/or PubMed with targeted queries. 2. Extract metadata from identifiers using extract_metadata.py. 3. Add specific known papers via doi_to_bibtex.py. 4. Combine and format with format_bibtex.py (deduplicate, sort). 5. Validate with validate_citations.py (auto-fix, report). 6. Review validation report for remaining issues. 7. Use final_references.bib in LaTeX." ;
    oc:stepOrder 1 .

oc:kn_95505128 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Searching academic databases for papers" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """python scripts/search_google_scholar.py "CRISPR gene editing" --limit 50 --output results.json
python scripts/search_pubmed.py '"Alzheimer Disease"[MeSH]' --date-start 2020 --limit 100 --output alzheimers.json""" .

oc:kn_af58f197 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formatting BibTeX entries" ;
    oc:directiveContent "Use meaningful citation keys following the pattern FirstAuthorYEARkeyword. Protect capitalization in titles with curly braces. Use double-dash (--) for page ranges." ;
    oc:hasRationale "Consistent citation key conventions improve readability and maintainability of BibTeX files across teams and tools" ;
    oc:severityLevel "MEDIUM" .

oc:kn_afd6ca80 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Converting DOIs to BibTeX entries (single or batch)" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """python scripts/doi_to_bibtex.py 10.1038/s41586-021-03819-2
python scripts/doi_to_bibtex.py --input dois.txt --output references.bib""" .

oc:kn_b943e08e a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """{
  "total_entries": {N},
  "valid_entries": {N},
  "errors": [{"citation_key": "{key}", "error_type": "{type}", "field": "{field}", "severity": "{level}"}],
  "warnings": [{"citation_key": "{key}", "warning_type": "{type}", "severity": "{level}"}]
}""" ;
    oc:templateVariables "N",
        "field",
        "key",
        "level",
        "type" .

oc:kn_ce591185 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When metadata extraction returns entries with non-ASCII characters" ;
    oc:directiveContent "Special characters in BibTeX entries (accents, symbols, Unicode) can break LaTeX compilation. Always use proper LaTeX escaping or ensure Unicode is handled correctly." ;
    oc:hasRationale "LaTeX compilation failures from special characters are a common and frustrating source of build errors" ;
    oc:severityLevel "MEDIUM" .

oc:kn_cf5c5000 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting which papers to include in a literature review or bibliography" ;
    oc:directiveContent "Prioritize papers by citation count, venue quality, and author reputation. For papers 0-3 years old, 100+ citations = highly influential; 7+ years old, 1000+ = foundational. Prefer Tier 1 venues (Nature, Science, Cell, NEJM, Lancet, JAMA, PNAS)." ;
    oc:hasRationale "Citation-based triage ensures the most impactful and authoritative sources are included in academic work" ;
    oc:severityLevel "MEDIUM" .

