oc:skill_skillsbench_energy_casadi_ipopt_nlp a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "casadi-ipopt-nlp" ;
    skos:broader "Optimization framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/skills/author/skillsbench-energy/casadi-ipopt-nlp" ;
