                                                            oc:itemText "\\(Q_{pu} = Q_{MVAr} / baseMVA\\)" ] ] ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Convert with `baseMVA`:" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "Per-unit conventions" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Given `BR_R = r`, `BR_X = x`:" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "If `r == 0 and x == 0`, set `g = 0`, `b = 0` (avoid divide-by-zero)." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:hasChild [ a oc:BulletList ;
                                                    oc:blockType "bullet_list" ;
                                                    oc:contentOrder 1 ;
                                                    oc:hasItem [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 2 ;
                                                            oc:itemText "\\(g = r/(r^2 + x^2)\\)" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 3 ;
                                                            oc:itemText "\\(b = -x/(r^2 + x^2)\\)" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 1 ;
                                                            oc:itemText "\\(y = 1/(r + jx) = g + jb\\)" ] ] ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Else:" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 6 ;
                            oc:sectionTitle "Series admittance" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Use \\(T_{ij} = tap \\cdot e^{j \\cdot shift}\\)." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:hasChild [ a oc:BulletList ;
                                                    oc:blockType "bullet_list" ;
                                                    oc:contentOrder 1 ;
                                                    oc:hasItem [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 2 ;
                                                            oc:itemText "Convert `SHIFT` from degrees to radians." ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 1 ;
                                                            oc:itemText "If `abs(TAP) < 1e-12`, treat `tap = 1.0` (no transformer)." ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:hasChild [ a oc:BulletList ;
                                                                    oc:blockType "bullet_list" ;
                                                                    oc:contentOrder 1 ;
                                                                    oc:hasItem [ a oc:BulletItem ;
                                                                            oc:blockType "bullet_item" ;
                                                                            oc:itemOrder 1 ;
                                                                            oc:itemText "\\(\\delta_{ij} = \\theta_i - \\theta_j - shift\\)" ],
                                                                        [ a oc:BulletItem ;
                                                                            oc:blockType "bullet_item" ;
                                                                            oc:itemOrder 2 ;
                                                                            oc:itemText "\\(\\delta_{ji} = \\theta_j - \\theta_i + shift\\)" ] ] ;
                                                            oc:itemOrder 3 ;
                                                            oc:itemText "Use the angle shift by modifying the angle difference:" ] ] ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Implementation shortcut (real tap + phase shift):**" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
                            oc:sectionTitle "Transformer handling (MATPOWER TAP + SHIFT)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "`BR_B` is the **total** line charging susceptance \\(b_c\\) (per unit)." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Each end gets \\(b_c/2\\) in the standard pi model." ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 7 ;
                            oc:sectionTitle "Line charging susceptance" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Model details (match the task formulation)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "\\(V_i = |V_i| e^{j\\theta_i}\\), \\(V_j = |V_j| e^{j\\theta_j}\\)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "`tap` is real, `shift` is radians" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "`inv_t = 1/tap`, `inv_t2 = inv_t^2`" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 7 ;
                            oc:textContent "Compute apparent power:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 8 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "\\(|S_{ij}| = \\sqrt{P_{ij}^2 + Q_{ij}^2}\\)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "\\(|S_{ji}| = \\sqrt{P_{ji}^2 + Q_{ji}^2}\\)" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Then the real/reactive power flow from i→j is:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "\\(Q_{ij} = -(b + b_c/2)|V_i|^2 inv\\_t2 - |V_i||V_j| inv\\_t (g\\sin\\delta_{ij} - b\\cos\\delta_{ij})\\)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "\\(P_{ij} = g |V_i|^2 inv\\_t2 - |V_i||V_j| inv\\_t (g\\cos\\delta_{ij} + b\\sin\\delta_{ij})\\)" ] ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 6 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "\\(P_{ji} = g |V_j|^2 - |V_i||V_j| inv\\_t (g\\cos\\delta_{ji} + b\\sin\\delta_{ji})\\)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "\\(Q_{ji} = -(b + b_c/2)|V_j|^2 - |V_i||V_j| inv\\_t (g\\sin\\delta_{ji} - b\\cos\\delta_{ji})\\)" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Let:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent "And from j→i is:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 8 ;
                    oc:sectionTitle "Power flow equations (use these exactly)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "For a pure transformer (`r=x=0`) you should not get meaningful flows; treat as `g=b=0` (no series element)." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "With `SHIFT=0` and `TAP=1`, if \\(V_i = V_j\\) and \\(\\theta_i=\\theta_j\\), then \\(P_{ij}\\approx 0\\) and \\(P_{ji}\\approx 0\\) (lossless only if r=0)." ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 13 ;
                    oc:sectionTitle "Sanity checks (fast debug)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "Example:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """import json
import numpy as np

from scripts.branch_flows import compute_branch_flows_pu, build_bus_id_to_idx

data = json.load(open("/root/network.json"))
baseMVA = float(data["baseMVA"])
buses = np.array(data["bus"], dtype=float)
branches = np.array(data["branch"], dtype=float)

bus_id_to_idx = build_bus_id_to_idx(buses)

Vm = buses[:, 7]  # initial guess VM
Va = np.deg2rad(buses[:, 8])  # initial guess VA

br = branches[0]
P_ij, Q_ij, P_ji, Q_ji = compute_branch_flows_pu(Vm, Va, br, bus_id_to_idx)

S_ij_MVA = (P_ij**2 + Q_ij**2) ** 0.5 * baseMVA
S_ji_MVA = (P_ji**2 + Q_ji**2) ** 0.5 * baseMVA
print(S_ij_MVA, S_ji_MVA)
""" ;
                            oc:codeLanguage "python" ;
                            oc:contentOrder 3 ;
                            oc:sourceLocation "lines 21-43" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Treat the results as **power leaving** the “from” bus and **power leaving** the “to” bus (i.e., compute both directions explicitly)." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Use `scripts/branch_flows.py` to compute per-unit branch flows." ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Quick start" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "AC Branch Pi-Model + Transformer Handling" ] ;
