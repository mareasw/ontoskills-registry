                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Add \\(P_{ij}, Q_{ij}\\) to bus i" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Add \\(P_{ji}, Q_{ji}\\) to bus j" ] ],
