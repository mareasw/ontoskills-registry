oc:kn_7850b7fd a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When querying large hex ranges" ;
    oc:directiveContent "get_tiles_in_range has O(radius²) complexity. For large radii, consider pre-filtering candidates before distance checks." ;
    oc:hasRationale "The brute-force scan over all dx/dy combinations can be slow for large radii on big maps" .

oc:kn_78e37eb0 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calculating hex distances" ;
    oc:directiveContent "Convert offset coordinates to cube coordinates (cx, cy, cz where cy = -cx - cz) before computing distances. Distance = (|Δcx| + |Δcy| + |Δcz|) / 2." ;
    oc:hasRationale "Cube coordinates make distance calculation a simple max/sum operation rather than a complex offset-aware formula" .

oc:kn_962f0a58 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up any hex grid coordinate system" ;
    oc:directiveContent "Use odd-r offset coordinates where odd rows (y % 2 == 1) are shifted right by half a hex. Tile 0 is at bottom-left, X increases rightward, Y increases upward." ;
    oc:hasRationale "Consistent coordinate convention prevents offset parity errors in neighbor and distance calculations" .

oc:kn_b8bb838d a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always" ;
    oc:directiveContent "All functions (get_neighbors, hex_distance, get_tiles_in_range) are pure functions with no side effects. They can be called repeatedly with identical results." ;
    oc:hasRationale "Pure functions are safe to call in optimization loops and constraint solvers without risk of state corruption" .

oc:kn_f4d129a3 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When computing hex neighbors" ;
    oc:directiveContent "The even/odd row parity determines diagonal neighbor offsets. Directions NE, NW, SW, SE differ between even and odd rows, while East (0) and West (3) are always (1,0) and (-1,0)." ;
    oc:hasRationale "Using wrong parity produces incorrect neighbor coordinates, leading to broken spatial logic" ;
    oc:severityLevel "CRITICAL" .

