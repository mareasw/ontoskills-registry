oc:kn_0e3d8f1d a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When describing ioctl with simple integer value" ;
    oc:codeLanguage "syzlang" ;
    oc:directiveContent "ioctl$CMD(fd fd_type, cmd const[CMD], arg intptr[0:1])" .

oc:kn_18f7001d a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When describing ioctl with input struct parameter" ;
    oc:codeLanguage "syzlang" ;
    oc:directiveContent "ioctl$CMD(fd fd_type, cmd const[CMD], arg ptr[in, struct_type])" .

oc:kn_1ea0b02f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing pointer direction for ioctl arguments" ;
    oc:directiveContent "Use ptr[in, ...] for input to kernel, ptr[out, ...] for output from kernel, ptr[inout, ...] for bidirectional data" ;
    oc:hasRationale "Correct direction annotation ensures the fuzzer generates valid inputs and captures outputs properly" .

oc:kn_24ed3fc0 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "General syzlang syscall declaration pattern" ;
    oc:directiveContent "syscall$VARIANT(arg1 type1, arg2 type2, ...) return_type" ;
    oc:templateVariables "VARIANT",
        "arg1",
        "return_type",
        "type1" .

oc:kn_47f8b79d a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining struct types for ioctl arguments" ;
    oc:codeLanguage "syzlang" ;
    oc:directiveContent """struct_name {
    field1    type1
    field2    type2
}""" .

oc:kn_a5b32323 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining ioctl commands and constants" ;
    oc:directiveContent "Some constants only exist on certain architectures; run `make descriptions` after edits to validate syntax" ;
    oc:hasRationale "Architecture-specific constants will cause build failures on other architectures" ;
    oc:severityLevel "HIGH" .

oc:kn_e0c465d8 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before writing any new ioctl description" ;
    oc:directiveContent "Check existing description files (e.g., sys/linux/socket.txt) for patterns before writing new descriptions" ;
    oc:hasRationale "Existing files demonstrate established conventions and reusable type definitions" .

oc:kn_e19576ea a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When writing new ioctl descriptions in syzlang" ;
    oc:directiveContent "1. Study existing descriptions in sys/linux/*.txt for patterns 2. Define resources (fd types) 3. Define flag sets 4. Define structs with typed fields 5. Write ioctl$CMD descriptions with correct ptr direction 6. Run `make descriptions` to validate syntax" ;
    oc:stepOrder 1 .

oc:kn_f78a2706 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When describing ioctl with output parameter" ;
    oc:codeLanguage "syzlang" ;
    oc:directiveContent "ioctl$CMD(fd fd_type, cmd const[CMD], arg ptr[out, int32])" .

