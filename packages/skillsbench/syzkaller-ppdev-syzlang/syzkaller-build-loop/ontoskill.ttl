oc:kn_1c1a4c4e a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When encountering constant definition errors during build" ;
    oc:directiveContent "'SOME_CONST is defined for none of the arches' means the constant is missing from the .const file — add it to sys/linux/your_file.txt.const with correct values per architecture" ;
    oc:hasRationale "Constants must be extracted and available for all target architectures before descriptions can compile" ;
    oc:severityLevel "HIGH" .

oc:kn_40bb7fa7 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before any build attempt" ;
    oc:directiveContent "Syzkaller source must be checked out at /opt/syzkaller with Go toolchain available" .

oc:kn_44ccdda5 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When encountering missing reference errors during build" ;
    oc:directiveContent "'undefined reference to some_type' indicates a type defined in another file is not being found — check includes or existing type definitions" ;
    oc:hasRationale "Cross-file type references require proper file structure or the type must already exist in the codebase" .

oc:kn_58381e37 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When exploring existing code for patterns before writing new descriptions" ;
    oc:directiveContent "Use grep -r to search /opt/syzkaller/sys/linux/ for patterns like 'resource fd_', 'ioctl$', 'read$/write$', 'struct.*{' to find existing examples" ;
    oc:hasRationale "Existing descriptions provide proven patterns for resource definitions, ioctl calls, and struct layouts" ;
    oc:severityLevel "MEDIUM" .

oc:kn_5b30667f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing syzlang description files" ;
    oc:directiveContent "Never use a type before it is defined; all custom types must be defined earlier in the file or in an included file" ;
    oc:hasRationale "Forward references cause 'unknown type' build errors" ;
    oc:severityLevel "HIGH" .

oc:kn_8612658e a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Quick rebuild after minor description edits without constant changes" ;
    oc:directiveContent "1. cd /opt/syzkaller 2. Run `make descriptions` to recompile with syz-sysgen" ;
    oc:hasRationale "Saves time by skipping full rebuild when only descriptions changed" ;
    oc:stepOrder 2 .

oc:kn_93234e5d a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When iterating on description files" ;
    oc:directiveContent "`make descriptions` and `make all` are idempotent — safe to re-run after any edit" ;
    oc:hasRationale "Build system only recompiles changed files, so repeated builds are safe and efficient" .

oc:kn_c37f7f7e a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When adding new syscall descriptions to syzkaller" ;
    oc:directiveContent "1. Write/edit .txt description file in sys/linux/ 2. Create .const file named sys/linux/your_file.txt.const with constant values 3. Run `make descriptions` to compile 4. Run `make all` to build syzkaller" ;
    oc:hasRationale "Full build loop ensures both descriptions and constants are compiled and linked into the fuzzer" ;
    oc:stepOrder 1 .

_:ref_21e2c944458d9f62 a oc:WorkflowStep ;
    dcterms:description "Write/edit the .txt description file in sys/linux/" ;
    oc:expectedOutcome "New or updated syzlang description file exists" ;
    oc:stepId "write-desc" .

_:ref_9bc44c0ad8a95985 a oc:WorkflowStep ;
    dcterms:description "Run make descriptions to compile with syz-sysgen" ;
    oc:expectedOutcome "Descriptions compile without unknown type or undefined reference errors" ;
    oc:stepDependsOn _:ref_fc1631c5e4d9dccb ;
    oc:stepId "compile-desc" .

_:ref_fc1631c5e4d9dccb a oc:WorkflowStep ;
    dcterms:description "Create .const file with constant values at sys/linux/your_file.txt.const" ;
    oc:expectedOutcome "Constants file exists with correct per-architecture values" ;
    oc:stepDependsOn _:ref_21e2c944458d9f62 ;
    oc:stepId "create-const" .

