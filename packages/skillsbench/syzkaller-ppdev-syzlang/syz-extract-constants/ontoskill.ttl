    oc:expectedOutcome "Syzlang description file created with syscall/resource definitions" ;
    oc:stepId "write-description" .

_:ref_4753f565b1d462a9 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 2 ;
    oc:hasStep _:ref_79c28b020fe88611,
        _:ref_c5f035a736b4c9f0 ;
    oc:workflowId "procedure_2" ;
    oc:workflowName "Ordered Procedure" .

_:ref_7dfd5bf176e567f6 a oc:WorkflowStep ;
    dcterms:description "Run 'make descriptions' to compile descriptions and validate constants" ;
    oc:expectedOutcome "Descriptions compile without 'defined for none of the arches' errors" ;
    oc:stepDependsOn _:ref_c9ece573b90c57d8 ;
    oc:stepId "compile-descriptions" .

_:ref_c9ece573b90c57d8 a oc:WorkflowStep ;
