                    oc:stepId "full-build" ],
                _:ref_c9ece573b90c57d8 ;
            oc:workflowId "define-constants-workflow" ;
            oc:workflowName "Define and Extract Constants Workflow" ] ;
    oc:impartsKnowledge oc:kn_043d32b1,
        oc:kn_5177690d,
        oc:kn_9e045a03,
        oc:kn_aafa3d70,
        oc:kn_ac4a7215,
        oc:kn_cf96a411,
        oc:kn_d51f180a,
        oc:kn_dd4ad27a,
        oc:kn_f4b31968 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:SyzkallerInstalled,
        oc:SyzlangDescriptionWritten ;
    oc:resolvesIntent "calculate Linux ioctl numbers from type and nr",
        "create manual .const files for syzlang",
        "define kernel constants for syzlang descriptions",
        "extract ioctl values for syzkaller fuzzing",
        "troubleshoot syzkaller constant extraction errors" ;
    oc:yieldsState oc:ConstantsFileCreated,
        oc:SyzlangDescriptionsCompiled .

oc:kn_043d32b1 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "After creating .const file to compile and build syzkaller" ;
    oc:directiveContent "cd /opt/syzkaller && make descriptions && make all" .

oc:kn_5177690d a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When encountering build or extraction errors" ;
    oc:directiveContent "'is defined for none of the arches' → add missing constant to .const file and verify arches line. 'cannot find include file' → check kernel source path. 'unknown file' → use 'make extract FILES=...' instead of calling bin/syz-extract directly." ;
    oc:hasRationale "These are the most common errors when working with syzlang constants and each has a specific resolution" ;
    oc:severityLevel "HIGH" .

oc:kn_9e045a03 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before running make descriptions" ;
    oc:directiveContent "Verify all constants referenced in the .txt file are defined in the .const file and the arches line lists all target architectures before building." ;
    oc:severityLevel "HIGH" .

oc:kn_aafa3d70 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing between manual and automated constant extraction methods" ;
    oc:directiveContent "Use manual .const files (Method 1) when kernel source is unavailable; use syz-extract (Method 2) only when kernel source headers are accessible." ;
    oc:hasRationale "This environment lacks kernel source, making automated extraction impossible" ;
    oc:severityLevel "HIGH" .

oc:kn_ac4a7215 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating a manual .const file for syzlang descriptions" ;
    oc:codeLanguage "syzlang-const" ;
    oc:directiveContent """arches = 386, amd64, arm, arm64, mips64le, ppc64le, riscv64, s390x
PPCLAIM = 28811
PPRELEASE = 28812
IEEE1284_MODE_NIBBLE = 0""" .

oc:kn_cf96a411 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting constants automatically from kernel source headers" ;
    oc:directiveContent "make extract TARGETOS=linux SOURCEDIR=/path/to/linux FILES=sys/linux/dev_ppdev.txt" .

oc:kn_d51f180a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When manually calculating ioctl numbers from kernel macro definitions" ;
    oc:directiveContent "Linux ioctl encoding: _IO(type,nr) = type<<8|nr; _IOR = 2<<30|size<<16|type<<8|nr; _IOW = 1<<30|size<<16|type<<8|nr; _IOWR = 3<<30|size<<16|type<<8|nr" ;
    oc:hasRationale "Ioctl numbers are bit-encoded values that must be computed from type, number, and size parameters" .

oc:kn_dd4ad27a a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Full workflow for defining constants and building syzkaller" ;
    oc:directiveContent "1. Write syzlang description file (.txt) 2. Create companion .const file with arches line and constant values 3. Run 'make descriptions' to compile 4. Run 'make all' for full build" ;
    oc:stepOrder 1 .

oc:kn_f4b31968 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always when creating manual constants files" ;
    oc:directiveContent "The .const file must be named exactly as the .txt file with '.const' suffix (e.g., dev_ppdev.txt → dev_ppdev.txt.const) and must include an 'arches' line listing all supported architectures." ;
    oc:hasRationale "Syzkaller's build system uses strict file naming conventions to locate and validate constants" ;
    oc:severityLevel "CRITICAL" .

