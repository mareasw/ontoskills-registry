oc:kn_32443a9b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing diarization turns with no matching transcription" ;
    oc:directiveContent "Mark segments shorter than 0.3 seconds or with no overlapping transcription as '[INAUDIBLE]' rather than leaving them empty." ;
    oc:hasRationale "Empty segments break subtitle timing and continuity; explicit inaudible markers maintain segment integrity" .

oc:kn_55e16b92 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When mapping transcriptions to speaker turns" ;
    oc:directiveContent "Never skip timestamp alignment between Whisper segments and diarization turns — multiple Whisper segments can overlap one diarization turn." ;
    oc:hasRationale "Misaligned timestamps produce speaker-labeled subtitles where text is attributed to the wrong speaker" ;
    oc:severityLevel "CRITICAL" .

oc:kn_74d8e3cf a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When selecting a Whisper model for transcription" ;
    oc:directiveContent "Use 'small' as minimum Whisper model size; use 'large-v3' for maximum accuracy. Avoid tiny/base for production subtitles." ;
    oc:hasRationale "Smaller models sacrifice accuracy significantly, producing unreliable subtitles" ;
    oc:severityLevel "HIGH" .

oc:kn_c354aaca a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When aligning Whisper output with diarization segments" ;
    oc:directiveContent "Whisper segments may not align 1:1 with diarization turns — always use overlap detection (seg_start < turn_end AND seg_end > turn_start) rather than direct matching." ;
    oc:hasRationale "Whisper segments audio differently than diarization tools, creating boundary mismatches that simple index matching cannot resolve" ;
    oc:severityLevel "HIGH" .

oc:kn_cfe67e31 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When processing long audio files or batch processing" ;
    oc:directiveContent "Use faster-whisper with int8 quantization for 2-4x speed improvement with similar accuracy to standard Whisper. Use CPU+int8 for memory-constrained environments." ;
    oc:hasRationale "Standard Whisper large-v3 requires significant GPU memory; faster-whisper with quantization reduces memory footprint dramatically" .

