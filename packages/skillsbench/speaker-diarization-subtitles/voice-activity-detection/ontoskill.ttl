oc:kn_06099275 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When VAD output quality is poor" ;
    oc:directiveContent "For too many false alarms: increase threshold or min_speech_duration_ms. For missing short segments: use Silero VAD or decrease threshold. For over-segmentation: increase merge_gap. For missing speech at boundaries: decrease min_silence_duration_ms." ;
    oc:hasRationale "Tuning VAD parameters resolves the most common quality issues without switching tools." ;
    oc:severityLevel "MEDIUM" .

oc:kn_60d6b7a2 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building diarization workflows" ;
    oc:directiveContent "VAD is a critical first step in speaker diarization pipelines — it determines which audio regions are passed to embedding extraction and clustering." ;
    oc:hasRationale "Accurate VAD boundaries directly improve downstream speaker clustering by eliminating non-speech noise." ;
    oc:severityLevel "HIGH" .

oc:kn_6eafc066 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "After running any VAD tool" ;
    oc:directiveContent "Do not skip postprocessing VAD boundaries — always merge close segments, remove very short segments, and smooth boundaries." ;
    oc:hasRationale "Raw VAD output often contains over-segmentation, false positives from brief noise, and jagged boundaries that degrade downstream diarization." ;
    oc:severityLevel "HIGH" .

oc:kn_bfbec431 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always" ;
    oc:directiveContent "VAD is read-only and idempotent on the same audio input with the same parameters — re-running produces identical boundaries." ;
    oc:hasRationale "No state mutation occurs; VAD only produces timestamp lists." ;
    oc:severityLevel "LOW" .

oc:kn_f67640a9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting a VAD tool" ;
    oc:directiveContent "Choose VAD tool based on use case: Silero VAD for short segments and real-time, SpeechBrain VAD for general purpose and longer files, WebRTC VAD for lightweight/low-latency applications." ;
    oc:hasRationale "Each tool has different accuracy/speed tradeoffs optimized for different scenarios." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ffd7b7c1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using WebRTC VAD" ;
    oc:directiveContent "WebRTC VAD requires audio frames of exactly 10ms, 20ms, or 30ms duration." ;
    oc:hasRationale "WebRTC VAD will error on non-standard frame sizes." ;
    oc:severityLevel "HIGH" .

