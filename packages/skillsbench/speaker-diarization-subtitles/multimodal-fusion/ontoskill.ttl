oc:kn_5461545e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When fusing visual cues with diarization turns" ;
    oc:directiveContent "Assign confidence scores based on visual evidence: high (lip moving + face detected), medium (face detected, no lip movement), low (no visual confirmation)." ;
    oc:hasRationale "Tiered confidence scoring allows downstream consumers to weight visual evidence appropriately" ;
    oc:severityLevel "MEDIUM" .

oc:kn_7383106f a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When interpreting visual feature extraction results" ;
    oc:directiveContent "Face detection fails in poor lighting, extreme angles, or occluded faces. Lip movement detection using pixel differencing is approximate and can produce false positives/negatives." ;
    oc:hasRationale "Understanding limitations prevents over-reliance on noisy visual signals" ;
    oc:severityLevel "MEDIUM" .

oc:kn_7cf47812 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When aligning visual feature timestamps with audio diarization timestamps" ;
    oc:directiveContent "Temporal alignment between visual features and audio timestamps must use a tolerance window (default 0.5 seconds) to handle desynchronization." ;
    oc:hasRationale "Video and audio streams may have slight timing offsets; tolerance windows prevent missed alignments" ;
    oc:severityLevel "HIGH" .

oc:kn_87952716 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "After initial audio diarization produces a predicted speaker count" ;
    oc:directiveContent "Cross-validate predicted speaker count against maximum face count detected in video frames. Flag a warning when the difference exceeds 1." ;
    oc:hasRationale "Discrepancies between audio and visual speaker counts indicate potential diarization errors" ;
    oc:severityLevel "MEDIUM" .

oc:kn_8c18c280 a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When visual extraction fails or video quality is poor" ;
    oc:directiveContent "Always maintain a fallback to audio-only diarization when visual features are unavailable, unreliable, or processing fails." ;
    oc:hasRationale "Visual features are supplementary; the system must degrade gracefully to audio-only mode rather than fail completely" ;
    oc:severityLevel "CRITICAL" .

oc:kn_d1d45774 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before starting multimodal fusion pipeline" ;
    oc:directiveContent "Do not use multimodal fusion on audio-only files, poor quality video, or when no faces are visible — visual processing adds cost without benefit in these cases." ;
    oc:hasRationale "Visual feature extraction is computationally expensive and provides no value without usable visual data" ;
    oc:severityLevel "HIGH" .

oc:kn_d609faa1 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting visual features from video frames" ;
    oc:directiveContent "Use frame_skip (process every other frame at most) to balance computational cost with feature extraction accuracy. Calculate as max(1, int(fps / 2))." ;
    oc:hasRationale "Processing every frame is computationally prohibitive; skipping frames with timestamp interpolation is sufficient for diarization alignment" ;
    oc:severityLevel "HIGH" .

oc:kn_d8b5b183 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When estimating processing time for multimodal diarization" ;
    oc:directiveContent "Video processing is computationally expensive. Processing time scales linearly with video duration and inversely with frame_skip factor." ;
    oc:hasRationale "Allows informed trade-offs between accuracy and processing time" ;
    oc:severityLevel "LOW" .

