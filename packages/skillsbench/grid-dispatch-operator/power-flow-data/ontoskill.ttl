oc:kn_6fb55a69 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When loading any network.json file" ;
    oc:directiveContent "Never read large network JSON files line-by-line with sed, head, or similar tools — always use Python's json.load() to parse the entire file at once." ;
    oc:hasRationale "Network files can exceed 100K lines; line-by-line reading wastes time and LLM context window." ;
    oc:severityLevel "CRITICAL" .

oc:kn_742fa1c3 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When working with bus, generator, or branch data arrays" ;
    oc:directiveContent "Bus numbers in power system data may not be contiguous. Always create a mapping from bus numbers to 0-indexed positions before accessing bus arrays." ;
    oc:hasRationale "Non-contiguous bus numbering is standard in MATPOWER format; direct indexing will produce incorrect results." ;
    oc:severityLevel "CRITICAL" .

oc:kn_8b05b69d a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When starting any power flow analysis task" ;
    oc:directiveContent "1. Load JSON with json.load() 2. Print quick summary (bus/gen/branch counts, total load) 3. Create bus number mapping 4. Convert arrays to numpy 5. Identify slack bus (type=3) 6. Map generators to buses using mapping" ;
    oc:stepOrder 1 .

