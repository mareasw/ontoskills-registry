oc:kn_e87ee2c8 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting between real and per-unit values" ;
    oc:directiveContent "Use the per-unit system for all electrical quantities. baseMVA is typically 100 MVA." ;
    oc:hasRationale "Per-unit normalization is standard in power systems analysis and required by MATPOWER format." ;
    oc:severityLevel "HIGH" .

oc:kn_f2767d95 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When loading network data for analysis" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """def load_network(filepath):
    with open(filepath) as f:
        data = json.load(f)
    return {
        'baseMVA': data['baseMVA'],
        'bus': np.array(data['bus']),
        'gen': np.array(data['gen']),
        'branch': np.array(data['branch']),
        'gencost': np.array(data['gencost']),
        'reserve_capacity': np.array(data['reserve_capacity']),
        'reserve_requirement': data['reserve_requirement']
    }""" .

