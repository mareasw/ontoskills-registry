    oc:directiveContent "bus_num_to_idx = {int(buses[i, 0]): i for i in range(n_bus)}" .

oc:kn_65e52a80 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "After loading any network file" ;
    oc:directiveContent "Always compute a quick summary first (bus count, generator count, branch count, total load) after loading network data to validate the dataset." ;
    oc:hasRationale "Quick summary validates data integrity before running expensive computations." ;
