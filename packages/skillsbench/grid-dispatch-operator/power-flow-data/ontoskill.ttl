oc:kn_d657a02a a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When loading network data files" ;
    oc:directiveContent "Python's json.load() is fast even for multi-MB files. Use it directly instead of streaming parsers." ;
    oc:hasRationale "Network files are typically under 100MB and load in under a second with the standard library parser." .

oc:kn_dfdd35df a oc:KnowledgeNode,
