_:ref_b9c078945bf343a8 a oc:WorkflowStep ;
    dcterms:description "Open and parse the YAML file using yaml.safe_load()" ;
    oc:expectedOutcome "Parsed configuration dictionary" ;
    oc:stepDependsOn _:ref_74418e967719b422 ;
    oc:stepId "parse-yaml" .

