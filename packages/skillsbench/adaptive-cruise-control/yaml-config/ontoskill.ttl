oc:kn_1242d0c1 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing YAML files" ;
    oc:directiveContent "Use default_flow_style=False and sort_keys=False when calling yaml.dump() to produce human-readable block-style output that preserves insertion order." ;
    oc:hasRationale "Block style is far more readable than flow style for configuration files, and preserving key order matches the developer's mental model." .

oc:kn_6abdd5e5 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When loading configuration files that may be absent or corrupt" ;
    oc:directiveContent "Catch FileNotFoundError and yaml.YAMLError separately — return an empty dict or defaults dict on both, never crash on missing or malformed config." ;
    oc:hasRationale "Configuration files should be optional; the application should fall back gracefully to sensible defaults rather than failing to start." .

oc:kn_8ed704fc a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reading any YAML file" ;
    oc:directiveContent "Always use yaml.safe_load() instead of yaml.load() to prevent arbitrary code execution vulnerabilities." ;
    oc:hasRationale "yaml.load() can deserialize arbitrary Python objects, enabling remote code execution if the YAML file contains malicious payloads." ;
    oc:severityLevel "CRITICAL" .

oc:kn_967e4aa5 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always" ;
    oc:directiveContent "Reading a YAML config file is idempotent; writing the same data produces identical output. The load_config helper merges loaded values over defaults deterministically." ;
    oc:hasRationale "Repeated reads or writes with identical inputs yield identical results, making config operations safe to retry." .

oc:kn_ec7097c5 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before loading optional configuration files" ;
    oc:directiveContent "Verify the YAML file exists with os.path.exists() before attempting to open it when optional loading is needed." ;
    oc:hasRationale "Checking existence first allows returning defaults without triggering exception overhead." .

oc:req_666f5839 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "PyYAML (pip install pyyaml)" .

