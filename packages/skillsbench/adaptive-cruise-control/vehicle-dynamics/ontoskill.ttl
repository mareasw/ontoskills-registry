    oc:yieldsState oc:VehicleStateComputed .

oc:kn_07303525 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing adaptive cruise control logic" ;
    oc:directiveContent "Use a state machine with three modes (cruise, follow, emergency) determined by lead vehicle presence and TTC threshold" ;
    oc:hasRationale "Mode-based logic cleanly separates control strategies and ensures safe transitions between driving scenarios" .

oc:kn_246f6974 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When computing acceleration outputs from a controller" ;
    oc:directiveContent "Acceleration must always be clamped to [max_decel, max_accel] bounds using max(max_decel, min(accel, max_accel))" ;
    oc:hasRationale "Real vehicles have physical limits on braking and throttle; unclamped values cause unrealistic simulation behavior" ;
    oc:severityLevel "HIGH" .

oc:kn_2739fc09 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always" ;
    oc:directiveContent "Kinematic updates are deterministic: same inputs always produce same outputs. Simulation is replayable." ;
    oc:hasRationale "Deterministic simulation enables reproducible testing and debugging of control algorithms" ;
    oc:severityLevel "MEDIUM" .

oc:kn_d3b35c92 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calculating time-to-collision" ;
    oc:directiveContent "Never compute TTC when ego_speed <= lead_speed without returning None or infinity, as relative_speed <= 0 means vehicles are not converging" ;
    oc:hasRationale "Dividing by zero or negative relative speed produces meaningless or misleading TTC values" ;
    oc:severityLevel "CRITICAL" .

oc:kn_ea1b814a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calculating following distance for any speed" ;
    oc:directiveContent "Use time headway model for safe following distance: safe_distance = speed * time_headway + min_distance" ;
    oc:hasRationale "The time headway model scales gap with speed, providing proportional safety margin at all velocities" .

oc:kn_f7ddcd60 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When updating vehicle speed in any simulation step" ;
    oc:directiveContent "Vehicle speed must be clamped to non-negative values after every update: new_speed = max(0, new_speed + acceleration * dt)" ;
    oc:hasRationale "Negative speed is physically meaningless in forward-moving vehicle models and would corrupt position and distance calculations" ;
    oc:severityLevel "CRITICAL" .

_:ref_3f872779390e5eb8 a oc:WorkflowStep ;
    dcterms:description "Update relative distance: new_distance = current_distance - (ego_speed - lead_speed) * dt" ;
    oc:expectedOutcome "Updated inter-vehicle distance" ;
    oc:stepDependsOn _:ref_7aaedbf25622469c ;
    oc:stepId "update-distance" .

_:ref_c70382b45b822285 a oc:WorkflowStep ;
    dcterms:description "Calculate TTC: distance / relative_speed if approaching, else None" ;
    oc:expectedOutcome "TTC value in seconds or None if not approaching" ;
    oc:stepDependsOn _:ref_3f872779390e5eb8 ;
    oc:stepId "compute-ttc" .

_:ref_7aaedbf25622469c a oc:WorkflowStep ;
    dcterms:description "Update ego vehicle speed: new_speed = max(0, current_speed + acceleration * dt)" ;
    oc:expectedOutcome "Non-negative updated speed value" ;
    oc:stepId "update-speed" .

