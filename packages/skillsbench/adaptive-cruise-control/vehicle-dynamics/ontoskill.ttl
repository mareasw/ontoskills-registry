oc:skill_skillsbench_adaptive_cruise_control_vehicle_dynamics a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "vehicle-dynamics" ;
    skos:broader "Kinematic simulation framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/skills/author/skillsbench-adaptive-cruise-control/vehicle-dynamics" ;
    oc:contentHash "85fa334604776b2eee0723df9057d9d120ac182d25fbaf622044641289cd96c8" ;
    oc:dependsOnSkill oc:skill_ontoskills_pid_controller ;
    oc:differentia "that models vehicle motion, safe following distances, time-to-collision, and cruise control state machines using discrete-time equations" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasCategory "development" ;
    oc:hasDescription "Use this skill when simulating vehicle motion, calculating safe following distances, time-to-collision, speed/position updates, or implementing vehicle state machines for cruise control modes." ;
    oc:hasName "vehicle-dynamics" ;
    oc:hasSection [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """def time_to_collision(distance, ego_speed, lead_speed):
    \"\"\"
    Calculate time to collision.

    Returns None if not approaching (ego slower than lead).
    \"\"\"
    relative_speed = ego_speed - lead_speed

    if relative_speed <= 0:
        return None  # Not approaching

    return distance / relative_speed
""" ;
                            oc:codeLanguage "python" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 51-64" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "TTC estimates time until collision at current velocities:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Time-to-Collision (TTC)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """def safe_following_distance(speed, time_headway, min_distance):
    \"\"\"
    Calculate safe distance based on current speed.

    Args:
        speed: Current vehicle speed (m/s)
        time_headway: Time gap to maintain (seconds)
        min_distance: Minimum distance at standstill (meters)
    \"\"\"
    return speed * time_headway + min_distance
""" ;
                            oc:codeLanguage "python" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 34-45" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "The time headway model calculates safe following distance:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Safe Following Distance" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """def determine_mode(lead_present, ttc, ttc_threshold):
    \"\"\"
    Determine operating mode based on conditions.

    Returns one of: 'cruise', 'follow', 'emergency'
    \"\"\"
    if not lead_present:
        return 'cruise'

    if ttc is not None and ttc < ttc_threshold:
        return 'emergency'

    return 'follow'
""" ;
                            oc:codeLanguage "python" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 80-94" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Vehicle control often uses mode-based logic:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "State Machine Pattern" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent "**Position Update:**" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """new_position = current_position + speed * dt
""" ;
                            oc:codeLanguage "python" ;
                            oc:contentOrder 5 ;
                            oc:sourceLocation "lines 19-21" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "For vehicle simulations, use discrete-time kinematic equations." ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """new_speed = current_speed + acceleration * dt
new_speed = max(0, new_speed)  # Speed cannot be negative
""" ;
                            oc:codeLanguage "python" ;
                            oc:contentOrder 3 ;
                            oc:sourceLocation "lines 13-16" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Speed Update:**" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 6 ;
                            oc:textContent "**Distance Between Vehicles:**" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """# When following another vehicle
relative_speed = ego_speed - lead_speed
new_distance = current_distance - relative_speed * dt
""" ;
                            oc:codeLanguage "python" ;
                            oc:contentOrder 7 ;
                            oc:sourceLocation "lines 24-28" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Basic Kinematic Model" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """def clamp_acceleration(accel, max_accel, max_decel):
    \"\"\"Constrain acceleration to physical limits.\"\"\"
    return max(max_decel, min(accel, max_accel))
""" ;
                            oc:codeLanguage "python" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 70-74" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Real vehicles have physical constraints:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Acceleration Limits" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Vehicle Dynamics Simulation" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: vehicle-dynamics
description: Use this skill when simulating vehicle motion, calculating safe following distances, time-to-collision, speed/position updates, or implementing vehicle state machines for cruise control modes.
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Execute one discrete-time step of vehicle dynamics simulation" ;
            oc:hasStep _:ref_3f872779390e5eb8,
                [ a oc:WorkflowStep ;
                    dcterms:description "Determine mode from state machine: cruise / follow / emergency" ;
                    oc:expectedOutcome "Operating mode string" ;
                    oc:stepDependsOn _:ref_c70382b45b822285 ;
                    oc:stepId "determine-mode" ],
                _:ref_7aaedbf25622469c,
                [ a oc:WorkflowStep ;
                    dcterms:description "Update position: new_position = current_position + speed * dt" ;
                    oc:expectedOutcome "Updated position value" ;
                    oc:stepDependsOn _:ref_7aaedbf25622469c ;
                    oc:stepId "update-position" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Clamp acceleration to physical limits: max(max_decel, min(accel, max_accel))" ;
                    oc:expectedOutcome "Acceleration within vehicle physical bounds" ;
                    oc:stepId "clamp-accel" ],
                _:ref_c70382b45b822285 ;
