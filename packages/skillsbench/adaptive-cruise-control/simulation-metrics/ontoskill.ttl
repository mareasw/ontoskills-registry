    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/skills/author/skillsbench-adaptive-cruise-control/simulation-metrics" ;
    oc:contentHash "a2daddc45bcf28ce5f3e0745f824542377c2c9c02bb0499336188664e404653d" ;
    oc:dependsOnSkill oc:skill_ontoskills_csv_processing ;
    oc:differentia "Computes control system performance metrics (rise time, overshoot, steady-state error, settling time) from time-series simulation data" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasCategory "development" ;
    oc:hasDescription "Use this skill when calculating control system performance metrics such as rise time, overshoot percentage, steady-state error, or settling time for evaluating simulation results." ;
    oc:hasName "simulation-metrics" ;
    oc:hasSection [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """def settling_time(times, values, target, tolerance=0.02):
    \"\"\"Time to settle within tolerance of target.\"\"\"
    band = target * tolerance
    lower, upper = target - band, target + band

    settled_at = None
    for t, v in zip(times, values):
        if v < lower or v > upper:
            settled_at = None
        elif settled_at is None:
            settled_at = t

    return settled_at
""" ;
                            oc:codeLanguage "python" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 59-73" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Time to stay within tolerance band of target." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Settling Time" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """times = [row['time'] for row in results]
values = [row['value'] for row in results]
target = 30.0

print(f"Rise time: {rise_time(times, values, target)}")
print(f"Overshoot: {overshoot_percent(values, target)}%")
print(f"SS Error: {steady_state_error(values, target)}")
""" ;
                            oc:codeLanguage "python" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 77-85" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Usage" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Difference between target and final settled value." ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """def steady_state_error(values, target, final_fraction=0.1):
    \"\"\"Calculate steady-state error using final portion of data.\"\"\"
    n = len(values)
    start = int(n * (1 - final_fraction))
    final_avg = sum(values[start:]) / len(values[start:])
    return abs(target - final_avg)
""" ;
                            oc:codeLanguage "python" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 46-53" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Steady-State Error" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """def overshoot_percent(values, target):
    \"\"\"Calculate overshoot percentage.\"\"\"
    max_val = max(values)
    if max_val <= target:
        return 0.0
    return ((max_val - target) / target) * 100
""" ;
                            oc:codeLanguage "python" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 33-40" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "How much response exceeds target, as percentage." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Overshoot" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Time for system to go from 10% to 90% of target value." ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """def rise_time(times, values, target):
    \"\"\"Calculate rise time (10% to 90% of target).\"\"\"
    t10 = t90 = None

    for t, v in zip(times, values):
        if t10 is None and v >= 0.1 * target:
            t10 = t
        if t90 is None and v >= 0.9 * target:
            t90 = t
            break

    if t10 is not None and t90 is not None:
        return t90 - t10
    return None
""" ;
                            oc:codeLanguage "python" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 12-27" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Rise Time" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Control System Performance Metrics" ],
