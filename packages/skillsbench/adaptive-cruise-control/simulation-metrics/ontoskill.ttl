oc:kn_1fce09a1 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calculating settling time" ;
    oc:directiveContent "Default settling tolerance band is ±2% of target; adjust the tolerance parameter for stricter or looser criteria." ;
    oc:hasRationale "The 2% band is a standard engineering convention, but different systems may require tighter (1%) or looser (5%) bands." .

oc:kn_5f30fd97 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calculating steady-state error" ;
    oc:directiveContent "Steady-state error uses the final 10% of data points (default final_fraction=0.1) to average the settled value." ;
    oc:hasRationale "Averaging over the tail portion filters out transient oscillations and gives a representative steady-state value." .

oc:kn_62cef038 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When calculating rise time" ;
    oc:directiveContent "Rise time is measured from 10% to 90% of the target value, not from 0% to 100%." ;
    oc:hasRationale "The 10-90% convention avoids noise near the baseline and target, providing a robust and widely-accepted measure of system responsiveness." ;
    oc:severityLevel "MEDIUM" .

oc:kn_8ee3a57f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using rise_time() or settling_time()" ;
    oc:directiveContent "Rise time and settling time require monotonically increasing time arrays paired with corresponding value arrays." ;
    oc:hasRationale "These functions iterate through time-value pairs sequentially; unordered or non-sequential data produces incorrect results." ;
    oc:severityLevel "HIGH" .

oc:kn_9da92289 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When interpreting metric results" ;
    oc:directiveContent "If the system never reaches 90% of target, rise_time() returns None; if it never settles, settling_time() returns None." ;
    oc:hasRationale "Unstable or underpowered systems may fail to reach targets — None returns signal this condition rather than producing misleading numeric values." ;
    oc:severityLevel "MEDIUM" .

_:ref_3a0652ccb71e271e a oc:WorkflowStep ;
    dcterms:description "Extract time and value arrays from simulation results." ;
    oc:expectedOutcome "Two parallel arrays: times (monotonically increasing) and values (corresponding measurements)" ;
    oc:stepId "extract-data" .

