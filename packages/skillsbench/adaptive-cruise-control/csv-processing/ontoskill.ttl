oc:kn_1a19ad30 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before any CSV processing operation" ;
    oc:directiveContent "pandas must be installed (pip install pandas) and importable as pd." .

oc:kn_2baa4107 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When checking individual cell values for missing data" ;
    oc:directiveContent "Use pd.isna(row['column']) to check for NaN values, not equality comparison (row['column'] == np.nan is always False)." ;
    oc:hasRationale "NaN != NaN by IEEE 754 standard, so direct equality comparison always fails." ;
    oc:severityLevel "CRITICAL" .

oc:kn_35ad3c29 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating simulation or processing results row-by-row" ;
    oc:directiveContent "Build results incrementally by appending row dictionaries to a list, then create a DataFrame from the full list rather than repeatedly appending to a DataFrame." ;
    oc:hasRationale "Repeated DataFrame.append() or concatenation is O(n²); building a list of dicts and constructing a DataFrame once is O(n)." ;
    oc:severityLevel "MEDIUM" .

oc:kn_48dc5ed6 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When calling df.to_csv()" ;
    oc:directiveContent "Writing CSV files overwrites existing files without confirmation; ensure output paths do not collide with source data files." ;
    oc:hasRationale "Data loss can occur if output path matches an existing file that hasn't been backed up." ;
    oc:severityLevel "HIGH" .

oc:kn_9d41cbd1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reading CSV files with potentially missing data" ;
    oc:directiveContent "Always specify na_values explicitly when reading CSVs that may contain empty strings, 'NA', or 'null' as missing value markers." ;
    oc:hasRationale "Default NA detection may miss domain-specific missing value representations, leading to incorrect data types or failed comparisons." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b3fcce80 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "After loading any CSV file" ;
    oc:directiveContent "Validate CSV structure after reading by checking df.head(), df.columns.tolist(), and len(df) before processing." ;
    oc:hasRationale "Early structure validation prevents silent errors from unexpected column names or empty datasets propagating through downstream processing." ;
    oc:severityLevel "LOW" .

oc:kn_cec4070a a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Standard CSV processing workflow" ;
    oc:directiveContent "1. Import pandas as pd → 2. Read CSV with pd.read_csv() specifying na_values → 3. Validate structure with head/columns/len → 4. Process/filter data → 5. Build results list incrementally → 6. Create DataFrame from list → 7. Write output with to_csv(index=False)" ;
    oc:stepOrder 1 .

oc:kn_d73c4ac3 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building simulation results incrementally" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """results = []
for item in items:
    row = {'time': item.time, 'value': item.value}
    results.append(row)
df = pd.DataFrame(results)
df.to_csv('output.csv', index=False)""" .

oc:kn_e7e5fb4b a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reading CSV with explicit missing value handling" ;
    oc:codeLanguage "python" ;
    oc:directiveContent "df = pd.read_csv('data.csv', na_values=['', 'NA', 'null'])" .

oc:kn_eb848605 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing CSV output files" ;
    oc:directiveContent "Never write CSV with index=True unless you explicitly need the row index as a column; always use to_csv(path, index=False) to avoid unnamed index columns on re-read." ;
    oc:hasRationale "Pandas includes the DataFrame index by default, which creates a spurious unnamed column when the file is read back." ;
    oc:severityLevel "HIGH" .

