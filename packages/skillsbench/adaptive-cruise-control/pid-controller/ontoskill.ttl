                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "`Kd` = derivative gain (reacts to rate of change)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
