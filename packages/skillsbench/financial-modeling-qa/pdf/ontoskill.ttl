                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 1 ;
                                    oc:sectionTitle "Merge PDFs" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:CodeExample ;
                                            oc:blockType "code_block" ;
                                            oc:codeContent """reader = PdfReader("input.pdf")
for i, page in enumerate(reader.pages):
    writer = PdfWriter()
    writer.add_page(page)
    with open(f"page_{i+1}.pdf", "wb") as output:
        writer.write(output)
""" ;
                                            oc:codeLanguage "python" ;
                                            oc:contentOrder 1 ;
                                            oc:sourceLocation "lines 47-54" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 2 ;
                                    oc:sectionTitle "Split PDF" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:CodeExample ;
                                            oc:blockType "code_block" ;
                                            oc:codeContent """reader = PdfReader("input.pdf")
writer = PdfWriter()

page = reader.pages[0]
page.rotate(90)  # Rotate 90 degrees clockwise
writer.add_page(page)

with open("rotated.pdf", "wb") as output:
    writer.write(output)
""" ;
