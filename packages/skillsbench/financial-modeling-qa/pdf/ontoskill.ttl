oc:kn_3ffb0b67 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before executing any PDF operation" ;
    oc:directiveContent "pypdf must be installed (pip install pypdf) for all basic PDF read/write operations. pdfplumber, reportlab, pytesseract, and pdf2image are optional based on task." ;
    oc:severityLevel "HIGH" .

oc:kn_5625fb28 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Creating multi-page PDFs with styled content" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from reportlab.lib.pagesizes import letter
from reportlab.platypus import SimpleDocTemplate, Paragraph, Spacer, PageBreak
from reportlab.lib.styles import getSampleStyleSheet

doc = SimpleDocTemplate("report.pdf", pagesize=letter)
styles = getSampleStyleSheet()
story = [Paragraph("Title", styles['Title']), Spacer(1, 12), Paragraph("Body", styles['Normal'])]
doc.build(story)""" .

oc:kn_5a5f39d8 a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When Python environment is restricted or libraries cannot be installed" ;
    oc:directiveContent "If Python libraries are unavailable, use CLI tools: qpdf for merge/split/decrypt, pdftotext for text extraction, pdfimages for image extraction, pdftk for rotate/burst." ;
    oc:hasRationale "CLI tools are often pre-installed on servers and provide equivalent functionality without Python dependencies." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5fe95946 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting multiple tables from a multi-page PDF" ;
    oc:directiveContent "For table extraction at scale, convert extracted tables to pandas DataFrames and combine with pd.concat before exporting to Excel." ;
    oc:hasRationale "DataFrame normalization enables clean aggregation and downstream analysis of heterogeneous table data." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7d6eb3eb a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Standard PDF read-modify-write pattern" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from pypdf import PdfReader, PdfWriter

reader = PdfReader("input.pdf")
writer = PdfWriter()
for page in reader.pages:
    # modify page as needed
    writer.add_page(page)
with open("output.pdf", "wb") as f:
    writer.write(f)""" .

oc:kn_a756c852 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extract_text() returns empty or garbled results from a scanned document" ;
    oc:directiveContent "Scanned PDFs require OCR (pytesseract + pdf2image) rather than direct text extraction — the text is embedded as images, not characters." ;
    oc:hasRationale "Scanned PDFs contain rasterized images, not selectable text. Direct extraction methods will fail silently." ;
    oc:severityLevel "CRITICAL" .

oc:kn_c497b7d5 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting structured data or tables from PDFs" ;
    oc:directiveContent "Do not use pypdf's extract_text() for table extraction — use pdfplumber's extract_tables() instead." ;
    oc:hasRationale "pypdf's text extraction does not preserve table structure; pdfplumber is purpose-built for table detection and extraction." ;
    oc:severityLevel "HIGH" .

oc:kn_d026ebab a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When processing any PDF task" ;
    oc:directiveContent "1. Identify task type (extract text/tables, create, merge, split, OCR, watermark, encrypt). 2. Select appropriate tool from quick reference table. 3. Load PDF with PdfReader or pdfplumber.open. 4. Perform operation page-by-page. 5. Write output with PdfWriter or doc.build(). 6. Verify output file exists and is valid." ;
    oc:stepOrder 1 .

oc:kn_e33af129 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing which library to use for a PDF task" ;
    oc:directiveContent "Use pypdf for basic operations (merge, split, rotate, encrypt), pdfplumber for text and table extraction with layout preservation, and reportlab for creating new PDFs from scratch." ;
    oc:hasRationale "Each library has distinct strengths; choosing the right one avoids unnecessary complexity and improves reliability." ;
    oc:severityLevel "HIGH" .

