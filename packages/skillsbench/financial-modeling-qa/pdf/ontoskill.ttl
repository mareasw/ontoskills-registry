oc:kn_10d74a3c a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Extracting and structuring tables from PDF" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """import pdfplumber

with pdfplumber.open("document.pdf") as pdf:
    for page in pdf.pages:
        tables = page.extract_tables()
        for table in tables:
            if table:
                df = pd.DataFrame(table[1:], columns=table[0])""" .

