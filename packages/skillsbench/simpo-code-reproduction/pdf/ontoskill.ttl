oc:kn_1ffa2c07 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing automated PDF workflows" ;
    oc:directiveContent "Read-only operations (text extraction, metadata reading, table extraction) are safe to re-run. Write operations create new files each time and should use consistent output paths for idempotent behavior." ;
    oc:hasRationale "Idempotent workflows are safer to re-run on failure without creating duplicate or conflicting output." .

oc:kn_60aae0f2 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When filling PDF forms" ;
    oc:directiveContent "For PDF form filling, refer to forms.md for dedicated instructions rather than using pypdf's basic capabilities." ;
    oc:hasRationale "Form filling has specific requirements around field types and validation that need dedicated guidance." .

oc:kn_9c0208ab a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When performing any PDF write operation" ;
    oc:directiveContent "PDF operations create new files on disk (merged, split, watermarked, encrypted copies). Original files are never modified in place by pypdf or pdfplumber." ;
    oc:hasRationale "Understanding that originals are preserved prevents accidental data loss and helps plan output file paths." .

oc:kn_d0addfa5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting text from scanned or image-based PDFs" ;
    oc:directiveContent "Scanned PDFs require OCR (pytesseract + pdf2image) — standard text extraction will return empty or garbage results for image-based content." ;
    oc:hasRationale "Scanned PDFs contain images, not text layers; OCR is the only way to extract readable text." ;
    oc:severityLevel "CRITICAL" .

oc:kn_d8d7bd56 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting structured content like tables from PDFs" ;
    oc:directiveContent "Do not use pypdf's extract_text() for structured data extraction when tables are present. Use pdfplumber's extract_tables() instead." ;
    oc:hasRationale "pypdf's text extraction does not preserve table layout; pdfplumber provides structured row/column data." ;
    oc:severityLevel "HIGH" .

oc:kn_dd20b51b a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting a PDF processing approach" ;
    oc:directiveContent "Use pypdf for basic operations (merge, split, rotate, encrypt), pdfplumber for text and table extraction with layout preservation, and reportlab for PDF creation. Choose the right library for the task." ;
    oc:hasRationale "Each library has distinct strengths; using the wrong one leads to poor results or unnecessary complexity." ;
    oc:severityLevel "HIGH" .

