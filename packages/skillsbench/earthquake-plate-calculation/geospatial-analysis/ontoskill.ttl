oc:kn_056dfdc7 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When filtering a GeoDataFrame and then adding new columns" ;
    oc:directiveContent "Use .copy() when creating filtered DataFrames that will be modified (e.g., adding distance columns). Without .copy(), SettingWithCopyWarning may occur or data may be corrupted." ;
    oc:hasRationale "Filtered DataFrames are views by default; modifying them can produce unpredictable results or raise warnings." ;
    oc:severityLevel "MEDIUM" .

oc:kn_1740a48c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When optimizing geospatial workflows" ;
    oc:directiveContent "Filter data before projecting to a metric CRS. Project once, not inside loops. Combine geometries with .unary_union before batch distance calculations." ;
    oc:hasRationale "Projection is expensive; filtering first reduces data volume. Combining geometries before .distance() avoids N×M point-by-point comparisons." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5ad8f4da a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When calculating distances from many points to a boundary composed of multiple segments" ;
    oc:directiveContent "Use .unary_union to combine multiple geometries into a single geometry before calling .distance(). This transforms O(N×M) distance calculations into O(N) calculations." ;
    oc:hasRationale "Calling .distance() once against a unified geometry is dramatically faster than iterating over each boundary segment individually." ;
    oc:severityLevel "MEDIUM" .

oc:kn_84087c7b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing any geospatial computation" ;
    oc:directiveContent "Never implement manual Haversine formulas, point-in-polygon loops, or iterate through boundary points manually. Use geopandas built-in methods (.distance(), .within(), .unary_union) instead." ;
    oc:hasRationale "Manual implementations are slower, more error-prone, and less accurate than geopandas methods which handle edge cases like antimeridian crossings." ;
    oc:severityLevel "HIGH" .

oc:kn_db26aa97 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before any distance calculation on geospatial data" ;
    oc:directiveContent "Never calculate distances directly in geographic coordinates (EPSG:4326). Always project to a metric coordinate system (e.g., EPSG:4087) first." ;
    oc:hasRationale "EPSG:4326 returns degrees, not meters. Treating degrees as equal distances is geometrically incorrect because longitude degrees shrink toward the poles." ;
    oc:severityLevel "CRITICAL" .

