@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

oc:skill_hello a oc:ExecutableSkill,
        oc:Skill ;
    oc:differentia "A minimal demo skill that responds with a friendly greeting." ;
    oc:hasPayload oc:payload_hello ;
    oc:impartsKnowledge oc:kn_hello_standard ;
    oc:nature "Greeting demo" ;
    oc:resolvesIntent "greet the user",
        "say hello" ;
    dcterms:identifier "hello" ;
    prov:wasDerivedFrom "registry/packages/marea.greeting/hello" .

oc:payload_hello a oc:ExecutionPayload ;
    oc:code "echo \"ciao io sto bene e tu?\"" ;
    oc:executor "shell" ;
    oc:timeout 5000 .

oc:kn_hello_standard a oc:Standard ;
    oc:appliesToContext "When a simple demo response is needed" ;
    oc:directiveContent "Respond exactly with the canonical greeting payload." ;
    oc:hasRationale "This keeps the demo deterministic and easy to validate." ;
    oc:severityLevel "LOW" .
