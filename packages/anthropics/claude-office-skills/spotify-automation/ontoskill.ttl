@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_office_skills_spotify_automation a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "spotify-automation" ;
    skos:broader "Automation skill" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/spotify-automation" ;
    oc:contentHash "83f37ea0a74dd8344af4ffa6c1351e38ff86296412e2eb14481740f0bde22741" ;
    oc:differentia "that controls Spotify music playback, manages playlists, discovers music, and analyzes audio features via the Spotify API" ;
    oc:handlesFailure oc:NetworkTimeout,
        oc:PermissionDenied,
        oc:RateLimitExceeded ;
    oc:hasAllowedTool "spotify_analysis",
        "spotify_playback",
        "spotify_playlist",
        "spotify_search" ;
    oc:hasArgumentHint "playback command, playlist configuration, or search query" ;
    oc:hasCategory "media" ;
    oc:hasDescription "Automate Spotify music playback, playlist management, and audio analysis workflows" ;
    oc:hasName "spotify-automation" ;
    oc:hasRequirement oc:req_52942ee3,
        oc:req_6db916c9,
        oc:req_e7309319 ;
    oc:impartsKnowledge oc:kn_3cb7729b,
        oc:kn_8d5adfdb,
        oc:kn_978918cf,
        oc:kn_c6155b3b,
        oc:kn_df308e16 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:APIKeySet,
        oc:NetworkAvailable,
        oc:SpotifyAuthenticated ;
    oc:resolvesIntent "analyze audio features",
        "automate music workflows",
        "control spotify playback",
        "create smart playlists",
        "discover music on spotify",
        "manage spotify playlists" ;
    oc:yieldsState oc:AudioFeaturesExtracted,
        oc:PlaybackControlled,
        oc:PlaylistUpdated,
        oc:RecommendationsGenerated .

oc:kn_3cb7729b a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When authenticating with the Spotify API and requesting permissions" ;
    oc:directiveContent "Request only the minimum necessary OAuth scopes (user-read-playback-state, user-modify-playback-state, playlist-modify-private, etc.) and obtain explicit user consent." ;
    oc:hasRationale "Over-scoped tokens increase security risk if compromised; users may reject authorization requests that ask for excessive permissions" ;
    oc:severityLevel "MEDIUM" .

oc:kn_8d5adfdb a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When referencing specific tracks in playlist operations or playback commands" ;
    oc:directiveContent "Use Spotify URIs (spotify:track:xxx) rather than search-based lookups for reliable track identification when tracks are already known." ;
    oc:hasRationale "Spotify URIs are stable identifiers; search-based lookups can return wrong results due to name collisions or regional differences" .

oc:kn_978918cf a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating smart playlists or discovery workflows using the Spotify recommendations endpoint" ;
    oc:directiveContent "Use seed tracks, artists, and genres combined with target audio feature values (energy, danceability, valence, tempo) to generate high-quality recommendations." ;
    oc:hasRationale "Spotify's recommendation engine works best with 1-5 seed inputs combined with target feature ranges, producing more relevant results than pure genre-based searches" .

oc:kn_c6155b3b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building playlists or queuing tracks for playback, especially across different regional markets" ;
    oc:directiveContent "Never assume tracks are universally available; always handle unavailable tracks gracefully with fallback logic." ;
    oc:hasRationale "Track availability varies by market and can change over time; hard failures on unavailable tracks break playback workflows" ;
    oc:severityLevel "HIGH" .

oc:kn_df308e16 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When making any Spotify API calls, especially bulk operations like adding multiple tracks or fetching audio features for many songs" ;
    oc:directiveContent "Respect Spotify API rate limits and implement proper caching for frequently accessed data to avoid hitting request throttles." ;
    oc:hasRationale "Spotify enforces rate limits that can cause request failures; caching reduces redundant API calls and improves performance" ;
    oc:severityLevel "HIGH" .

oc:req_52942ee3 a oc:RequirementAPI ;
    oc:isOptional false ;
    oc:requirementValue "Spotify Web API with appropriate OAuth scopes" .

oc:req_6db916c9 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Spotify URI format (spotify:track:xxx, spotify:playlist:xxx)" .

oc:req_e7309319 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "media-mcp server with spotify_playback, spotify_playlist, spotify_search, spotify_analysis tools" .

