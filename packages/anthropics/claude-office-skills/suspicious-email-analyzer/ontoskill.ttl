@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_office_skills_suspicious_email_analyzer a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "suspicious-email-analyzer" ;
    skos:broader "Security analysis framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/suspicious-email-analyzer" ;
    oc:contentHash "c5a8677a5099b3cb0ab4380a673a8e95b25f2670dcf63059594776e0e3935075" ;
    oc:differentia "Detects phishing, scam indicators, and security threats in email content through structured threat assessment with red flag checklists and action guidelines" ;
    oc:handlesFailure oc:InsufficientEmailData,
        oc:InvalidInput ;
    oc:hasArgumentHint "email content including sender address, subject line, body text, and any links" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Analyze emails for phishing, scam indicators, and security threats" ;
    oc:hasName "suspicious-email-analyzer" ;
    oc:impartsKnowledge oc:kn_21844ebd,
        oc:kn_3b7982c9,
        oc:kn_41ba1adb,
        oc:kn_58763bd1,
        oc:kn_8a75d57c ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EmailContentProvided ;
    oc:resolvesIntent "analyze email for phishing",
        "assess email authenticity",
        "check email for security threats",
        "detect scam indicators in email",
        "identify suspicious links" ;
    oc:yieldsState oc:ThreatAssessmentComplete .

oc:kn_21844ebd a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When user reports having interacted with a suspicious email" ;
    oc:directiveContent "If the user has already clicked a suspicious link, immediately recommend: disconnect from internet, change passwords, enable 2FA, run antivirus scan, report to IT, and consider credit monitoring if financial info was shared." ;
    oc:hasRationale "Quick containment actions minimize damage from potential credential compromise or malware infection." ;
    oc:severityLevel "CRITICAL" .

oc:kn_3b7982c9 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When analyzing any email flagged as potentially suspicious" ;
    oc:directiveContent "Never click links in suspicious emails during analysis; instruct users not to interact with any links, attachments, or reply-to addresses in the email being analyzed." ;
    oc:hasRationale "Clicking phishing links can trigger malware downloads, confirm active email addresses to attackers, or compromise credentials." ;
    oc:severityLevel "CRITICAL" .

oc:kn_41ba1adb a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing email security analysis" ;
    oc:directiveContent "Assess threat level using multiple indicator categories: sender analysis, content analysis, link analysis, and technical headers — no single indicator should determine the verdict alone." ;
    oc:hasRationale "Sophisticated phishing may pass some checks while failing others; a multi-dimensional approach reduces false negatives and false positives." .

oc:kn_58763bd1 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When outputting analysis results" ;
    oc:directiveContent "Always provide a structured threat assessment report with: threat level (HIGH/MEDIUM/LOW/SAFE), confidence percentage, verdict, sender analysis, content analysis, link analysis, and recommended actions." ;
    oc:hasRationale "Consistent structured output ensures recipients can quickly understand the risk level and take appropriate action without ambiguity." .

oc:kn_8a75d57c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always — this is a fundamental limitation of the skill" ;
    oc:directiveContent "Cannot access actual email headers, verify real-time domain reputation, or analyze live links without user providing them. Human judgment is essential for the final decision." ;
    oc:hasRationale "The skill operates as a text-based analysis framework without access to external verification services, DNS lookups, or live URL inspection." ;
    oc:severityLevel "HIGH" .

