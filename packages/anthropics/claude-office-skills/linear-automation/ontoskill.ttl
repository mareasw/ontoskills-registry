        oc:Skill ;
    dcterms:identifier "linear-automation" ;
    skos:broader "project management automation" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/linear-automation" ;
    oc:contentHash "4bf51e65fae79eab17e3ac43f496699140317bb2a67e2168e0a631d77ae120f3" ;
    oc:differentia "that manages Linear issue tracking, cycle planning, roadmap management, and engineering workflows via MCP server integration" ;
