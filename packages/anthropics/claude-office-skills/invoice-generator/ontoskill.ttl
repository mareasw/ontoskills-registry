@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_office_skills_invoice_generator a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "invoice-generator" ;
    skos:broader "document generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/invoice-generator" ;
    oc:contentHash "45220449554631901cbab0619566761f1109294b6b9fc0bfa1e5e67750cc8892" ;
    oc:dependsOnSkill oc:skill_office_mcp ;
    oc:differentia "that produces professional invoices with tax calculations and multi-currency support for freelancers and small businesses" ;
    oc:extends oc:skill_invoice_template ;
    oc:handlesFailure oc:InvalidInput,
        oc:TemplateNotFound ;
    oc:hasAllowedTool "create_docx",
        "create_xlsx",
        "docx_to_pdf",
        "fill_docx_template" ;
    oc:hasArgumentHint "client_info, line_items, currency, tax_rate, payment_terms" ;
    oc:hasCategory "finance" ;
    oc:hasDescription "Create professional invoices with proper formatting for freelancers and small businesses. Supports multiple currencies and tax calculations." ;
    oc:hasName "invoice-generator" ;
    oc:hasRequirement oc:req_58d218f4,
        oc:req_934e28f0 ;
    oc:impartsKnowledge oc:kn_1d166133,
        oc:kn_40c93a57,
        oc:kn_6dfd6d27,
        oc:kn_7866d545,
        oc:kn_7dfe5322 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "calculate invoice taxes",
        "create invoice",
        "create invoice with VAT or GST",
        "generate professional invoice" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_1d166133 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating or assigning invoice numbers" ;
    oc:directiveContent "Never reuse invoice numbers and always keep them sequential; gaps may raise audit questions." ;
    oc:hasRationale "Sequential numbering is legally required in many jurisdictions (especially EU) and prevents accounting confusion or fraud suspicion." ;
    oc:severityLevel "HIGH" .

oc:kn_40c93a57 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When output format is requested" ;
    oc:directiveContent "This skill generates text/markdown invoices by default, not PDFs directly. PDF generation requires the office-mcp server's docx_to_pdf tool." ;
    oc:hasRationale "Users may expect PDF output; the skill's primary output is formatted text that must be explicitly converted using MCP tools." ;
    oc:severityLevel "LOW" .

oc:kn_6dfd6d27 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When constructing any invoice output" ;
    oc:directiveContent "Always include a due date, specific line-item descriptions (not vague terms like 'consulting'), payment instructions, and tax info where applicable." ;
    oc:hasRationale "These elements reduce payment delays, disputes, and compliance issues — the most common invoice mistakes are missing due dates and vague descriptions." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7866d545 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating invoices with tax components" ;
    oc:directiveContent "Tax calculations generated by this skill are estimates only — always recommend the user verify with a qualified accountant." ;
    oc:hasRationale "Tax regulations vary widely by jurisdiction and change frequently; incorrect tax amounts can have legal consequences." ;
    oc:severityLevel "HIGH" .

oc:kn_7dfe5322 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating invoices for EU B2B cross-border transactions" ;
    oc:directiveContent "For B2B cross-border EU services, apply reverse charge mechanism and include 'Reverse Charge - VAT to be paid by recipient' on the invoice." ;
    oc:hasRationale "EU VAT rules require reverse charge for cross-border B2B services; omitting it can lead to double taxation or non-compliance." ;
    oc:severityLevel "MEDIUM" .

oc:req_58d218f4 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "office-mcp MCP server with create_docx, fill_docx_template, docx_to_pdf tools" .

oc:req_934e28f0 a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "Tax regulations for target region (US, EU, China, Australia)" .

