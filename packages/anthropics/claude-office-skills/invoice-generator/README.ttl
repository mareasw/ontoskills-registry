oc:skill_anthropics_claude_office_skills_invoice_generator_readme a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "readme" ;
    skos:broader "Invoice generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/invoice-generator" ;
    oc:contentHash "66b9353e71b730482ea182883f23c24d6f4b1d7b491c5bf6b742be8c385d62f4" ;
    oc:differentia "Creates professional invoices with tax calculations and multi-currency support for freelancers and small businesses" ;
    oc:extends oc:skill_anthropics_claude_office_skills_invoice_generator ;
    oc:hasArgumentHint "invoice details (hours, rate, client, payment terms)" ;
    oc:hasCategory "document" ;
    oc:impartsKnowledge oc:kn_2d20adf4,
        oc:kn_2e5d9c0b,
        oc:kn_8ffee0bd,
        oc:kn_c4eeba10 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:resolvesIntent "calculate invoice taxes",
        "create invoice",
        "create invoice in English or Chinese",
        "create invoice in multiple currencies",
        "generate professional invoice" .

oc:kn_2d20adf4 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "After invoice generation" ;
    oc:directiveContent "A successful invoice generation produces a complete, formatted invoice ready to copy into the user's preferred tool." ;
    oc:hasRationale "The output should be immediately usable without further formatting or manual adjustment." .

oc:kn_2e5d9c0b a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating invoices for international clients" ;
    oc:directiveContent "Support multiple currencies and bilingual output (English and Chinese) to accommodate diverse client bases." ;
    oc:hasRationale "Freelancers and small businesses often work across borders and need invoices in the client's preferred language and currency." .

oc:kn_8ffee0bd a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When generating any invoice" ;
    oc:directiveContent "Include proper tax calculations (VAT, GST, sales tax) on every generated invoice." ;
    oc:hasRationale "Accurate tax handling ensures compliance and prevents financial discrepancies for both the freelancer and client." ;
    oc:severityLevel "HIGH" .

oc:kn_c4eeba10 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When generating any invoice" ;
    oc:directiveContent "Always include payment terms (e.g., Net 30) and clear payment instructions on generated invoices." ;
    oc:hasRationale "Clear payment terms reduce disputes and accelerate payment collection." .

