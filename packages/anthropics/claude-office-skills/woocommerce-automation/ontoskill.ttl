@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_office_skills_woocommerce_automation a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "woocommerce-automation" ;
    skos:broader "E-commerce automation skill" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/woocommerce-automation" ;
    oc:contentHash "1045041b270a947ba001c813009f23a02774ac6422cc57a5455f66a7ac16e82d" ;
    oc:differentia "Automates WooCommerce store operations including order processing, inventory sync, customer segmentation, and marketing workflows via the WooCommerce REST API and ecommerce-mcp server" ;
    oc:handlesFailure oc:InvalidInput,
        oc:NetworkTimeout,
        oc:PermissionDenied ;
    oc:hasAllowedTool "woo_coupons",
        "woo_customers",
        "woo_orders",
        "woo_products" ;
    oc:hasArgumentHint "woocommerce operation type (orders, inventory, customers, coupons, marketing) with relevant parameters" ;
    oc:hasCategory "automation" ;
    oc:hasDescription "Automate WooCommerce e-commerce operations including orders, inventory, customers, and marketing" ;
    oc:hasName "woocommerce-automation" ;
    oc:impartsKnowledge oc:kn_0ef22a55,
        oc:kn_402c79b1,
        oc:kn_48a016f6,
        oc:kn_8927f99a,
        oc:kn_9accdcca,
        oc:kn_c7436a26 ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:APIKeySet,
        oc:NetworkAvailable ;
    oc:resolvesIntent "automate woocommerce email campaigns",
        "automate woocommerce orders",
        "create woocommerce coupons and promotions",
        "generate sales and inventory reports",
        "manage woocommerce customers and segments",
        "recover abandoned carts",
        "sync woocommerce inventory" ;
    oc:yieldsState oc:CouponsCreated,
        oc:InventorySynced,
        oc:OrdersProcessed .

oc:kn_0ef22a55 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When running bulk product update operations" ;
    oc:directiveContent "Bulk product operations (price increases, sale promotions, shipping class updates) apply immediately to all matching products without preview or undo; always verify filter criteria before execution." ;
    oc:hasRationale "Incorrectly scoped bulk operations (e.g., applying a 25% discount to all products instead of a tagged subset) can cause immediate revenue loss that requires manual reversal." ;
    oc:severityLevel "CRITICAL" .

oc:kn_402c79b1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When handling zero-inventory product updates" ;
    oc:directiveContent "Never set stock status to outofstock without also enabling back-in-stock notification forms, as hiding products entirely destroys SEO rankings and removes recovery opportunities." ;
    oc:hasRationale "Maintaining product pages with back-in-stock forms preserves search engine indexing and captures demand signals for reorder decisions." ;
    oc:severityLevel "MEDIUM" .

oc:kn_48a016f6 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring inventory synchronization workflows" ;
    oc:directiveContent "Inventory sync frequency must balance real-time accuracy against API rate limits; recommended intervals are every 15 minutes for warehouse API sources and every 4 hours for FTP supplier feeds." ;
    oc:hasRationale "Overly aggressive sync intervals can exhaust WooCommerce API rate limits while infrequent syncs cause overselling and stock discrepancies." ;
    oc:severityLevel "HIGH" .

oc:kn_8927f99a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring abandoned cart recovery automations" ;
    oc:directiveContent "Cart recovery sequences should follow a 3-touch escalation pattern: 1 hour (reminder), 24 hours (gentle nudge), 72 hours (discount offer). Only introduce discount codes at the final touch." ;
    oc:hasRationale "Escalating from non-discount to discount preserves margin while maximizing recovery; too-early discounts train customers to abandon carts strategically." ;
    oc:severityLevel "HIGH" .

oc:kn_9accdcca a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating customer segmentation rules" ;
    oc:directiveContent "Design customer segments using compound criteria (total spent AND order count AND recency) rather than single dimensions to enable truly personalized marketing." ;
    oc:hasRationale "Multi-dimensional segmentation produces more actionable cohorts—e.g., VIP customers defined by spend >= $1000 AND orders >= 5 are higher-value targets than spend-only segments." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c7436a26 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When designing order management automations" ;
    oc:directiveContent "Order processing should follow a strict pipeline: receive → validate (payment, inventory, fraud) → process (confirm, reserve stock, notify) → fulfill (pick, pack, ship, track) → complete (deliver, follow-up). Each stage must complete before the next begins." ;
    oc:hasRationale "A linear pipeline with validation gates prevents stock reservation failures, payment fraud, and customer communication gaps." ;
    oc:severityLevel "CRITICAL" .

