oc:skill_anthropics_claude_office_skills_ai_agent_builder a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "ai-agent-builder" ;
    skos:broader "AI agent design framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/ai-agent-builder" ;
    oc:contentHash "5667d5447dc680a3add3bcf9b9fdbda3f993dc4a0bb9ebcb1f5db8aa0c30b347" ;
    oc:differentia "that provides architecture patterns for building agents with tools, memory, multi-step reasoning, and platform integrations across ChatGPT, Claude, and Gemini" ;
    oc:extends oc:skill_n8n_workflow ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "agent description or use case (e.g., 'appointment scheduling agent', 'customer support bot')" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Build AI agents with tools, memory, and multi-step reasoning - ChatGPT, Claude, Gemini integration patterns" ;
    oc:hasName "ai-agent-builder" ;
    oc:impartsKnowledge oc:kn_91714ef7,
        oc:kn_9aa890a6,
        oc:kn_b1f0c099,
        oc:kn_bd8c7079,
        oc:kn_d42c4f26 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady,
        oc:NetworkAvailable ;
    oc:resolvesIntent "build AI agents with tools and memory",
        "create multi-step reasoning agents",
        "design AI agent architecture",
        "design conversation flows for AI agents",
        "implement tool calling patterns for AI agents",
        "integrate AI agents with Slack, Telegram, and web platforms" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_91714ef7 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining system prompts and escalation triggers for any agent" ;
    oc:directiveContent "Never allow an agent to fabricate information when it lacks sufficient data. Always include an escalation or fallback mechanism (e.g., 'I don't know' or human handoff)." ;
    oc:hasRationale "Agents that hallucinate erode user trust and can cause real-world harm, especially in customer-facing or decision-support contexts" ;
    oc:severityLevel "CRITICAL" .

oc:kn_9aa890a6 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building agents with conversation memory or long context" ;
    oc:directiveContent "Manage the context window budget explicitly: allocate tokens across system prompt, tools, memory, current query, and response. For an 8K token budget, typical allocation is 1000 system prompt, 1000 tools, 4000 memory, 1000 query, 1000 response." ;
    oc:hasRationale "Exceeding context window limits causes truncation, loss of important context, and degraded agent performance" ;
    oc:severityLevel "HIGH" .

oc:kn_b1f0c099 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any new AI agent" ;
    oc:directiveContent "Every AI agent should be composed of four core components: Input, Agent (LLM), Tools (Functions), Memory (Context), and Knowledge (RAG). Design agents by selecting which components are needed for the use case." ;
    oc:hasRationale "Decomposing agents into core components enables modular design, easier debugging, and clearer separation of concerns" ;
    oc:severityLevel "HIGH" .

oc:kn_bd8c7079 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting an agent architecture for a use case" ;
    oc:directiveContent "Match agent type complexity to task complexity: reactive agents for simple Q&A, conversational agents for chatbots, tool-using agents for data lookup, reasoning agents for complex tasks, and multi-agent systems for complex workflows." ;
    oc:hasRationale "Over-engineering simple tasks wastes resources while under-engineering complex tasks produces unreliable results" .

oc:kn_d42c4f26 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When building agents that must perform multi-step reasoning or research tasks" ;
    oc:directiveContent "Use the ReAct pattern (Thought → Action → Observation → Thought) for agents that need multi-step reasoning, or a Planning pattern (Plan → Execute steps → Synthesize) for complex decomposable tasks." ;
    oc:hasRationale "Structured reasoning patterns prevent agents from jumping to conclusions and ensure systematic task completion with observable intermediate steps" .

