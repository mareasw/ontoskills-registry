        oc:CardsCreated .

oc:kn_3fc61806 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When configuring board automation to reduce manual overhead" ;
    oc:directiveContent "Use Butler automation rules to handle repetitive actions: auto-assign on card move, due date reminders, completion cleanup, and scheduled archiving of old completed cards." ;
    oc:hasRationale "Automating repetitive card management tasks reduces human error and ensures consistent workflow enforcement" ;
    oc:severityLevel "MEDIUM" .

oc:kn_7f7a2069 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When generating board analytics and reports" ;
    oc:directiveContent "Track board metrics including velocity (cards per sprint), cycle time (average days to complete), and burndown progress. Archive completed cards weekly to maintain board performance." ;
    oc:hasRationale "Regular metric tracking enables continuous improvement and early detection of workflow problems" ;
    oc:severityLevel "LOW" .

oc:kn_9a858cd9 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When defining card movement rules and entry/exit criteria" ;
    oc:directiveContent "Always require due dates and labels before a card exits the backlog/To Do list, and require an assignee before moving to In Progress. Use checklists to break down complex tasks." ;
    oc:hasRationale "Cards without due dates, labels, or assignees create ambiguity and make progress tracking unreliable" ;
    oc:severityLevel "MEDIUM" .

oc:kn_ad2fc9cd a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up In Progress or Code Review lists" ;
    oc:directiveContent "Enforce WIP (Work In Progress) limits on active lists (e.g., 3-5 cards max) to prevent bottlenecks and context switching overhead." ;
    oc:hasRationale "Unlimited WIP leads to multitasking, longer cycle times, and reduced throughput" ;
    oc:severityLevel "HIGH" .

oc:kn_e7c8f244 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing or configuring any Trello board" ;
    oc:directiveContent "Limit boards to 5-7 lists maximum to maintain clarity and usability. Use consistent color coding for labels across all boards." ;
    oc:hasRationale "Too many lists create visual clutter and reduce board effectiveness; consistent labels enable quick visual scanning" ;
    oc:severityLevel "MEDIUM" .

