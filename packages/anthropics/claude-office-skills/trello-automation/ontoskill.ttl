        oc:Skill ;
    dcterms:identifier "trello-automation" ;
    skos:broader "Project management automation skill" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/trello-automation" ;
    oc:contentHash "5b1cb11261a8bf2b640d6e417f92db1aa376877893bde643ea27df2bfb7a8887" ;
    oc:differentia "Automates Trello board management, card workflows, Butler automation rules, power-ups, and team collaboration via kanban-style board operations" ;
    oc:handlesFailure oc:InvalidInput,
        oc:NetworkTimeout,
        oc:PermissionDenied ;
    oc:hasArgumentHint "board configuration, card details, automation rules, or reporting request" ;
    oc:hasCategory "automation" ;
    oc:hasDescription "Automate Trello board management, card workflows, power-ups, and team collaboration" ;
    oc:hasName "trello-automation" ;
    oc:hasRequirement oc:req_28695b21,
        oc:req_2c939e2a,
        oc:req_4807ef8c,
