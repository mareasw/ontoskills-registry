    oc:requiresState oc:APIKeySet,
        oc:NetworkAvailable ;
    oc:resolvesIntent "automate Trello board management",
        "configure Trello board templates for sprints or content calendars",
        "create and manage Trello cards and lists",
        "generate Trello board analytics and reports",
        "integrate Trello with Slack and power-ups",
        "set up Butler automation rules for Trello" ;
    oc:yieldsState oc:AutomationConfigured,
