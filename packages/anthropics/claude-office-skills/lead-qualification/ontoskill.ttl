@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_office_skills_lead_qualification a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "lead-qualification" ;
    skos:broader "Sales qualification framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/lead-qualification" ;
    oc:contentHash "81f3bc16bffb5a91a7feb59c983fb28bac563b901b5393e93c59d74921868712" ;
    oc:differentia "Scores and qualifies leads using structured frameworks (BANT, MEDDIC, GPCTBA/C&I) with fit and engagement scoring models to prioritize sales efforts" ;
    oc:extends oc:skill_xlsx_manipulation ;
    oc:handlesFailure oc:InsufficientData,
        oc:InvalidInput ;
    oc:hasAllowedTool "analyze_spreadsheet",
        "create_xlsx",
        "read_xlsx" ;
    oc:hasArgumentHint "lead information (company name, contact details, qualification data)" ;
    oc:hasCategory "sales" ;
    oc:hasDescription "Score and qualify leads based on criteria and fit" ;
    oc:hasName "lead-qualification" ;
    oc:impartsKnowledge oc:kn_1a2c0992,
        oc:kn_3106c29d,
        oc:kn_56b8b192,
        oc:kn_9ae2448e,
        oc:kn_d907d0c1 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady,
        oc:LeadDataAvailable ;
    oc:resolvesIntent "evaluate leads against qualification criteria",
        "generate lead qualification reports",
        "identify deal-breakers and green flags in leads",
        "prioritize sales pipeline",
        "score and qualify leads" ;
    oc:yieldsState oc:LeadQualified,
        oc:LeadScored .

oc:kn_1a2c0992 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building or applying a lead scoring model" ;
    oc:directiveContent "Combine both fit scoring (demographics: industry, company size, revenue, geography, contact role) and engagement scoring (behavioral: website visits, email opens, event participation) for a complete lead picture." ;
    oc:hasRationale "Demographic fit alone misses buying signals; behavioral engagement alone misses ideal customer profile alignment. Both dimensions are needed for accurate prioritization." ;
    oc:severityLevel "MEDIUM" .

oc:kn_3106c29d a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When qualifying any new lead or re-qualifying an existing one" ;
    oc:directiveContent "Use structured frameworks (BANT, MEDDIC, or GPCTBA/C&I) to systematically evaluate leads rather than relying on gut feeling." ;
    oc:hasRationale "Structured frameworks ensure consistent, comparable qualification across all leads and prevent overlooked criteria." ;
    oc:severityLevel "HIGH" .

oc:kn_56b8b192 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Throughout the sales cycle, especially after significant time gaps or status changes" ;
    oc:directiveContent "Re-qualify leads regularly as situations change over time. Ask open-ended questions, verify information rather than assuming, and know when to walk away from unqualified leads." ;
    oc:hasRationale "Lead conditions evolve — budget cycles change, decision-makers leave, priorities shift. Periodic re-qualification prevents wasted effort on stale opportunities." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9ae2448e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, as inherent limitations of this skill" ;
    oc:directiveContent "Cannot access CRM data directly, cannot verify provided information, and scoring criteria must be defined by the user. Qualification is guidance, not a guarantee." ;
    oc:hasRationale "The skill operates on user-provided data and structured templates; it cannot independently validate lead claims or pull external CRM records." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d907d0c1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "During any lead qualification process" ;
    oc:directiveContent "Avoid qualifying too quickly, ignoring red flags, assuming budget equals ability to buy, or failing to identify all stakeholders." ;
    oc:hasRationale "Premature or incomplete qualification wastes sales resources on poor-fit leads and misses critical deal risks." ;
    oc:severityLevel "HIGH" .

