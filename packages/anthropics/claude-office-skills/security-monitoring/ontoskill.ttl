oc:skill_anthropics_claude_office_skills_security_monitoring a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "security-monitoring" ;
    skos:broader "Security operations automation framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/security-monitoring" ;
    oc:contentHash "6673110f368ec7b40c627fbedbb384c5c81e42c1618acebf5b47280030b2873f" ;
    oc:dependsOnSkill oc:skill_devops_automation ;
    oc:differentia "that integrates SIEM querying, rule-based threat detection, incident response playbooks, and compliance monitoring into a unified workflow engine" ;
    oc:handlesFailure oc:AlertRuleInvalid,
        oc:InsufficientPermissions,
        oc:LogSourceUnavailable,
        oc:SIEMConnectionFailed ;
    oc:hasArgumentHint "security query, alert rule, incident data, or compliance framework check" ;
    oc:hasCategory "security" ;
    oc:hasDescription "Automate security monitoring, threat detection, incident response, and compliance workflows" ;
    oc:hasName "security-monitoring" ;
    oc:hasPackageName "security-monitoring" ;
    oc:impartsKnowledge oc:kn_2def4d66,
        oc:kn_398e8f39,
        oc:kn_6f186d58,
        oc:kn_8a7160bf,
        oc:kn_def59795,
        oc:kn_e1c3cdc4,
        oc:kn_ebf2ea9e,
        oc:kn_f753a38f ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:LogSourcesConfigured,
        oc:NetworkAvailable,
        oc:SystemAuthenticated ;
    oc:resolvesIntent "analyze security logs",
        "check compliance status",
        "create security alerts",
        "detect anomalies in security logs",
        "generate security reports",
        "monitor security threats",
        "respond to security incidents" ;
    oc:yieldsState oc:AlertsCreated,
        oc:ComplianceChecked,
