        oc:ThreatsDetected .

oc:kn_2def4d66 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring any security monitoring stack" ;
    oc:directiveContent "Implement defense in depth with multiple detection layers — rule-based detection, ML anomaly detection, correlation rules, and threat intelligence feeds should all be active simultaneously." ;
    oc:hasRationale "Single-layer detection misses threats that cross detection boundaries; layered detection increases true positive rate and reduces blind spots." ;
    oc:severityLevel "HIGH" .

oc:kn_398e8f39 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When responding to any security incident" ;
    oc:directiveContent "Follow the structured incident response lifecycle: Detection → Triage → Containment → Investigation → Eradication → Recovery → Post-Incident Review. Never skip containment to jump to eradication." ;
    oc:hasRationale "Skipping containment allows active threats to spread; the structured lifecycle ensures evidence preservation, threat neutralization, and organizational learning." ;
    oc:severityLevel "CRITICAL" .

oc:kn_6f186d58 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring alert management" ;
    oc:directiveContent "Enable alert deduplication using a 1-hour window keyed on rule_id, source.ip, and destination.ip to prevent alert storms from correlated events." ;
    oc:hasRationale "Without deduplication, a single attack can generate hundreds of identical alerts, overwhelming analysts and obscuring other threats." ;
    oc:severityLevel "HIGH" .

oc:kn_8a7160bf a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating or managing security alerts" ;
    oc:directiveContent "Never treat all alerts with equal urgency. Alerts must be classified by severity (critical/high/medium/low) with tiered response SLAs: critical within 15 minutes, high within 1 hour, medium within 4 hours, low within 24 hours." ;
    oc:hasRationale "Alert fatigue from undifferentiated alerts causes real threats to be missed; tiered response ensures critical incidents get immediate attention." ;
    oc:severityLevel "CRITICAL" .

oc:kn_def59795 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When measuring security operations effectiveness" ;
    oc:directiveContent "Track MTTD (Mean Time to Detect) and MTTR (Mean Time to Respond) as primary operational KPIs. Benchmark targets: MTTD under 4 hours, MTTR under 2 hours, SLA compliance above 95%." ;
    oc:hasRationale "MTTD and MTTR are industry-standard metrics that directly measure the effectiveness of detection and response capabilities; they enable continuous improvement." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e1c3cdc4 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When setting up security monitoring infrastructure" ;
    oc:directiveContent "Log everything — maintain comprehensive audit trails across all data sources including firewall logs, endpoint logs, cloud logs, network traffic, and application logs. Feed all sources into a centralized SIEM or security data lake." ;
    oc:hasRationale "Incomplete logging creates blind spots where attackers can operate undetected; comprehensive logs are foundational to detection, investigation, and compliance." ;
    oc:severityLevel "HIGH" .

oc:kn_ebf2ea9e a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When responding to ransomware detection alerts" ;
    oc:directiveContent "For ransomware incidents: immediately isolate the affected endpoint, disable the associated account, capture a memory image for forensic evidence, then notify stakeholders before creating the incident ticket." ;
    oc:hasRationale "Ransomware spreads laterally within minutes; immediate containment stops propagation while evidence preservation enables investigation and potential decryption." ;
    oc:severityLevel "CRITICAL" .

oc:kn_f753a38f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running compliance monitoring workflows" ;
    oc:directiveContent "Compliance checks must map directly to framework requirements (PCI-DSS, HIPAA, SOC2) with verifiable queries and evidence collection. Check coverage must be continuously monitored with percentage-based dashboards." ;
    oc:hasRationale "Compliance gaps discovered during audits carry legal and financial penalties; continuous monitoring with quantified coverage prevents surprise findings." ;
    oc:severityLevel "HIGH" .

