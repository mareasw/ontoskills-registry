        oc:Skill ;
    dcterms:identifier "readme" ;
    skos:broader "Resume optimization skill" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/resume-tailor" ;
    oc:contentHash "2b9add5ab2019845243e425db10834309b7757f13563bc0ba3e05e98b3e1ca3a" ;
    oc:differentia "that tailors resumes for specific job applications with ATS-friendly formatting, keyword matching, and industry-specific guidance" ;
