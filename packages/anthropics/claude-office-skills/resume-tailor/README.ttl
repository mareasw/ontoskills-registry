        oc:kn_99e40ec6,
        oc:kn_a4e61458,
        oc:kn_ab364f78,
        oc:kn_af2efce9,
        oc:kn_becaa95e,
        oc:kn_c8f2cb15 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:JobDescriptionProvided,
        oc:ResumeProvided ;
    oc:resolvesIntent "analyze job description for resume keywords",
        "optimize resume for ATS systems",
        "quantify resume achievements",
        "reframe experience for career change",
        "tailor resume for job application" ;
    oc:yieldsState oc:KeywordAnalysisComplete,
        oc:ResumeOptimized,
        oc:TailoredResumeGenerated .

oc:kn_652e2e07 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining resume length" ;
    oc:directiveContent "Keep resume length proportional to experience: 1 page for 0-5 years, 1-2 pages for 5-15 years, 2 pages max for 15+ years or executive roles." ;
    oc:hasRationale "Recruiters spend an average of 6-7 seconds on initial resume scan. Appropriate length ensures density of relevant information without overwhelming the reviewer." ;
    oc:severityLevel "MEDIUM" .

oc:kn_99e40ec6 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When formatting resume sections" ;
    oc:directiveContent "Use standard section headers (Experience, Skills, Education, Summary) instead of creative alternatives like 'My Journey' or 'What I Bring'." ;
    oc:hasRationale "ATS systems expect standard section headers for parsing. Non-standard headers may cause sections to be misclassified or ignored entirely." ;
    oc:severityLevel "HIGH" .

oc:kn_a4e61458 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "After generating a tailored resume" ;
    oc:directiveContent "Resume tailoring will produce multiple versions of the resume. Users should maintain a 'base' resume and create tailored variants for each application type." ;
    oc:hasRationale "Maintaining multiple versions organized by role type prevents accidental submission of wrong tailoring and speeds up future applications." ;
    oc:severityLevel "LOW" .

oc:kn_ab364f78 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When tailoring any resume" ;
    oc:directiveContent "Never fabricate experience or qualifications the candidate does not have. Only reorganize, reframe, and optimize existing truthful content." ;
    oc:hasRationale "Fabricated claims are unethical, potentially illegal, and will be caught during background checks or interviews, permanently damaging credibility." ;
    oc:severityLevel "CRITICAL" .

oc:kn_af2efce9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or improving achievement bullets" ;
    oc:directiveContent "Transform weak bullet points using the formula: [Power Verb] + [What] + [Quantified Result] + [How/Context]." ;
    oc:hasRationale "Quantified achievements with strong action verbs demonstrate impact concretely and stand out to both ATS keyword scanners and human reviewers scanning quickly." ;
    oc:severityLevel "MEDIUM" .

oc:kn_becaa95e a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "When providing tailored resume output" ;
    oc:directiveContent "This skill cannot verify the truthfulness of user-provided experience, know internal company culture, or guarantee ATS passage across all systems." ;
    oc:hasRationale "ATS systems vary by vendor and configuration. The skill optimizes for common patterns but cannot account for proprietary filtering logic or company-specific culture preferences." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c8f2cb15 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When optimizing for ATS compatibility" ;
    oc:directiveContent "Use exact keywords from the job posting rather than synonyms or creative alternatives. ATS systems match literally, not semantically." ;
    oc:hasRationale "ATS systems rank candidates by keyword match percentage using literal string matching. Creative synonyms like 'people leader' won't match when the system scans for 'manager'." ;
    oc:severityLevel "HIGH" .

