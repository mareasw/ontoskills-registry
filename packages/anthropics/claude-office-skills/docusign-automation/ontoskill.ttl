@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_office_skills_docusign_automation a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "docusign-automation" ;
    skos:broader "E-signature workflow automation system" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/docusign-automation" ;
    oc:contentHash "661a637460f0e353b4dd84607e2343081b2147bc9d36e31fd48dcd18295bdf8a" ;
    oc:dependsOnSkill oc:skill_contract_review ;
    oc:differentia "Orchestrates DocuSign envelope creation, template management, conditional routing, bulk sending, and real-time status tracking with CRM integrations" ;
    oc:handlesFailure oc:EnvelopeDeclined,
        oc:EnvelopeVoided,
        oc:NetworkTimeout,
        oc:PermissionDenied ;
    oc:hasAllowedTool "docusign_envelope",
        "docusign_signing",
        "docusign_template",
        "docusign_webhook" ;
    oc:hasArgumentHint "document or signing request details (envelope config, template ID, signer info, workflow rules)" ;
    oc:hasCategory "automation" ;
    oc:hasDescription "Automate document signing workflows, envelope management, and e-signature processes" ;
    oc:hasName "docusign-automation" ;
    oc:impartsKnowledge oc:kn_0f555684,
        oc:kn_4c6856ff,
        oc:kn_8df65ef2,
        oc:kn_ad3a748e,
        oc:kn_ae1a9b36,
        oc:kn_bee7626a,
        oc:kn_dcfa1d63,
        oc:kn_e25c3548 ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:APIKeySet,
        oc:DocumentCreated,
        oc:NetworkAvailable ;
    oc:resolvesIntent "automate contract signing workflow",
        "bulk send documents for signature",
        "create docusign envelope",
        "manage signing templates",
        "send document for signature",
        "set up signing webhooks",
        "track envelope status" ;
    oc:yieldsState oc:DocumentSigned,
        oc:EnvelopeCompleted,
        oc:EnvelopeSent .

oc:kn_0f555684 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating envelopes for recurring document types" ;
    oc:directiveContent "Always use templates to standardize common document types (NDAs, employment agreements, MSAs) rather than creating ad-hoc envelopes each time." ;
    oc:hasRationale "Templates ensure consistency in signing fields, routing order, and compliance requirements across the organization." ;
    oc:severityLevel "HIGH" .

oc:kn_4c6856ff a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before creating or sending any envelope" ;
    oc:directiveContent "Verify that all signer email addresses are valid, all required template roles are filled, and anchor strings exist in the document before sending." ;
    oc:hasRationale "Missing or incorrect recipient information causes delivery failures and delays, while missing anchor strings cause signature placement errors." ;
    oc:severityLevel "HIGH" .

oc:kn_8df65ef2 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating new envelopes" ;
    oc:directiveContent "Never send envelopes without expiration dates or reminders configured, as this leads to stale unsigned documents accumulating indefinitely." ;
    oc:hasRationale "Without expiration and reminders, envelopes can linger indefinitely, creating compliance gaps and lost business momentum." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ad3a748e a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When an envelope needs to be cancelled or corrected" ;
    oc:directiveContent "Voiding an envelope is irreversible — always confirm the void reason and check that no signatures have been applied before voiding." ;
    oc:hasRationale "Once voided, the envelope cannot be recovered and all prior signatures are invalidated, potentially requiring full re-execution." ;
    oc:severityLevel "CRITICAL" .

oc:kn_ae1a9b36 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When setting up contract signing workflows with approval requirements" ;
    oc:directiveContent "Implement conditional routing based on contract attributes (value > $100K requires VP approval, international contracts require Legal Review) to automate approval hierarchies." ;
    oc:hasRationale "Conditional routing eliminates manual routing decisions and ensures proper authorization without slowing down low-risk documents." ;
    oc:severityLevel "HIGH" .

oc:kn_bee7626a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring signer tabs and field placement" ;
    oc:directiveContent "Use anchor strings (e.g., /sig1/, /date1/) in document text to auto-place signature tabs rather than absolute positioning." ;
    oc:hasRationale "Anchor-based placement is resilient to document changes and works across different document versions without manual repositioning." ;
    oc:severityLevel "HIGH" .

oc:kn_dcfa1d63 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring envelope reminder and expiration settings" ;
    oc:directiveContent "Set reminder_delay of 2 days and reminder_frequency of 2 days with expiration_days of 30 as sensible defaults for envelope settings." ;
    oc:hasRationale "These defaults balance urgency with signer patience, reducing stale envelopes while avoiding spam." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e25c3548 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "For every envelope lifecycle event (created, sent, viewed, signed, completed)" ;
    oc:directiveContent "Maintain complete audit trails with timestamps, user identification, and IP addresses for all envelope events to ensure legal enforceability and compliance." ;
    oc:hasRationale "E-signature legal enforceability under ESIGN Act and UETA requires comprehensive audit trails documenting who signed, when, and from where." ;
    oc:severityLevel "CRITICAL" .

