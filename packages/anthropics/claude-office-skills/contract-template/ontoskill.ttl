oc:skill_anthropics_claude_office_skills_contract_template a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "contract-template" ;
    skos:broader "template generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/contract-template" ;
    oc:contentHash "79a4341f5fda87cc62c63eb4ae0d5a86eb15623faeac41a41b3bed1141935d68" ;
    oc:dependsOnSkill oc:skill_office_mcp ;
    oc:differentia "creates legally enforceable machine-readable contract templates using the Accord Project framework with embedded data models, conditional logic, and executable business rules" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasAllowedTool "create_docx",
        "fill_docx_template" ;
    oc:hasArgumentHint "contract type and terms description" ;
    oc:hasCategory "document" ;
    oc:hasDescription ">" ;
    oc:hasName "contract-template" ;
    oc:impartsKnowledge oc:kn_2bb1968a,
        oc:kn_adb5ab06,
        oc:kn_c28ec916,
        oc:kn_ca3af67b,
        oc:kn_ed2e6492 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "build service agreement template",
        "create contract template",
        "create rental agreement template",
        "design contract with variable terms and logic",
        "generate NDA template" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_2bb1968a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When modeling contracts with optional provisions like penalty clauses or exclusion lists" ;
    oc:directiveContent "Use optional fields in the Concerto model for conditional clauses (e.g., latePenalty optional Boolean) and pair them with {{#if}} blocks in the template for clean conditional rendering" ;
    oc:hasRationale "This pattern keeps the data model clean while allowing rich conditional logic without polluting the default template output" ;
    oc:severityLevel "MEDIUM" .

oc:kn_adb5ab06 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing template grammar in TemplateMark format" ;
    oc:directiveContent "Template variables use [{variableName}] syntax with optional format directives like [{date as \"MMMM DD, YYYY\"}]. Conditional sections use {{#if condition}}...{{/if}} Handlebars-style blocks" ;
    oc:hasRationale "Correct syntax is required for the Accord Project Cicero engine to parse and bind variables to the data model" ;
    oc:severityLevel "HIGH" .

oc:kn_c28ec916 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any contract template" ;
    oc:directiveContent "Accord Project templates must follow a three-part structure: TemplateMark grammar (natural language with variables), Concerto data model (typed schema), and Ergo business logic (executable clauses)" ;
    oc:hasRationale "This tripartite structure ensures contracts are simultaneously human-readable, machine-parseable, and legally executable" ;
    oc:severityLevel "CRITICAL" .

oc:kn_ca3af67b a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "Before delivering any generated contract to a user for real-world use" ;
    oc:directiveContent "Generated contract templates are starting points and must be reviewed by qualified legal counsel before use. The Accord Project framework provides structure but does not guarantee legal enforceability in all jurisdictions" ;
    oc:hasRationale "Legal compliance varies by jurisdiction and context; AI-generated templates cannot replace professional legal review" ;
    oc:severityLevel "CRITICAL" .

oc:kn_ed2e6492 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing contract templates for reuse" ;
    oc:directiveContent "Do not hardcode contract terms directly into templates. All variable terms must be parameterized through the Concerto data model and bound via template variables" ;
    oc:hasRationale "Hardcoded values defeat the purpose of smart contract templates and prevent automated drafting with different data sets" ;
    oc:severityLevel "HIGH" .

