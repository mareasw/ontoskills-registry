@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_office_skills_pptx_manipulation a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "pptx-manipulation" ;
    skos:broader "Programmatic presentation builder" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/pptx-manipulation" ;
    oc:contentHash "4cade165fe6a3b4da07783c9cc24f193c0704f26092706c49b68e887ca819776" ;
    oc:dependsOnSkill oc:skill_office_mcp ;
    oc:differentia "Uses python-pptx library to create, edit, and manipulate PowerPoint (.pptx) files with text, shapes, images, charts, and tables" ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput,
        oc:PermissionDenied ;
    oc:hasArgumentHint "description of presentation to create or modify, optionally with data/images" ;
    oc:hasCategory "document" ;
    oc:hasDescription ">" ;
    oc:hasName "pptx-manipulation" ;
    oc:hasPackageName "python-pptx" ;
    oc:hasRequirement oc:req_7e9ca2f5,
        oc:req_bf19032f,
        oc:req_e18dc245 ;
    oc:impartsKnowledge oc:kn_6ca66047,
        oc:kn_877ad233,
        oc:kn_9ae44224,
        oc:kn_a8ed27d9,
        oc:kn_d0338537 ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:EnvironmentReady,
        oc:ToolInstalled ;
    oc:resolvesIntent "add charts to slides",
        "add slides with charts and tables",
        "create data-driven reports as presentations",
        "create pitch decks",
        "create powerpoint presentation",
        "edit pptx file",
        "extract text from presentation",
        "generate slides from data" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_6ca66047 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before generating presentation code" ;
    oc:directiveContent "Plan the slide structure and layout before writing python-pptx code — decide which layout index each slide uses and what content goes where" ;
    oc:hasRationale "Slide layout indices vary by template; planning ahead prevents placeholder index errors and mismatched layouts" ;
    oc:severityLevel "MEDIUM" .

oc:kn_877ad233 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before executing any pptx generation script" ;
    oc:directiveContent "Verify that python-pptx is installed (pip install python-pptx) and that any referenced image files exist before running presentation generation code" ;
    oc:hasRationale "Missing dependencies or image file references will cause runtime errors that corrupt or prevent file generation" ;
    oc:severityLevel "HIGH" .

oc:kn_9ae44224 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When users request features beyond basic slide content" ;
    oc:directiveContent "python-pptx cannot render complex animations, has limited SmartArt support, cannot embed video via API, and is limited to standard Office chart types" ;
    oc:hasRationale "These are hard limitations of the python-pptx library; attempting unsupported features will fail silently or produce broken files" ;
    oc:severityLevel "HIGH" .

oc:kn_a8ed27d9 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When working with non-default or custom PowerPoint templates" ;
    oc:directiveContent "Do not assume slide layout indices are universal — layout index 0 may not always be the Title layout across different templates" ;
    oc:hasRationale "Custom templates may reorder or replace layouts, causing content to appear on wrong slide types" ;
    oc:severityLevel "MEDIUM" .

oc:kn_d0338537 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating presentations that need to match organizational branding" ;
    oc:directiveContent "Use a .pptx template file as the starting point for consistent branding across generated presentations" ;
    oc:hasRationale "Templates with predefined slide masters ensure visual consistency and save time on formatting each slide individually" ;
    oc:severityLevel "HIGH" .

oc:req_7e9ca2f5 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "python" .

oc:req_bf19032f a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "python-pptx API (Presentation, shapes, charts, tables, formatting)" .

oc:req_e18dc245 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "python-pptx" .

