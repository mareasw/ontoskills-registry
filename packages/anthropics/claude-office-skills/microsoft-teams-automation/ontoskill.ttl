oc:skill_anthropics_claude_office_skills_microsoft_teams_automation a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "microsoft-teams-automation" ;
    skos:broader "Automation skill" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/microsoft-teams-automation" ;
    oc:contentHash "2e73cbf463c8d233338ca0be77ccfb9e5be40f02a3f46f0f8ce9738f10cfe67c" ;
    oc:differentia "automates Microsoft Teams messaging, meetings, channels, and workflow integrations via Microsoft Graph API and MCP tools" ;
    oc:handlesFailure oc:InvalidInput,
        oc:NetworkTimeout,
        oc:PermissionDenied ;
    oc:hasAllowedTool "teams_channel",
        "teams_meeting",
        "teams_message",
        "teams_webhook" ;
    oc:hasArgumentHint "message content, meeting details, channel configuration, or webhook payload" ;
    oc:hasCategory "automation" ;
    oc:hasDescription "Automate Microsoft Teams messaging, meetings, channels, and workflow integrations" ;
    oc:hasName "microsoft-teams-automation" ;
    oc:hasRequirement oc:req_57a6b35e,
        oc:req_9c0cdc28,
        oc:req_f3b175d2 ;
    oc:impartsKnowledge oc:kn_089217e0,
        oc:kn_470edd96,
        oc:kn_51bb3c9e,
        oc:kn_a1e5daa4,
        oc:kn_d9f58e71 ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:NetworkAvailable,
        oc:SystemAuthenticated ;
    oc:resolvesIntent "automate CI/CD notifications via Teams",
        "build Teams approval workflows",
        "configure Teams bot commands",
        "create Teams channels",
        "schedule Teams meetings",
        "send Teams messages",
        "send webhook notifications to Teams" ;
    oc:yieldsState oc:ChannelUpdated,
        oc:MeetingScheduled,
        oc:MessageSent .

oc:kn_089217e0 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing between webhook and bot integration patterns for Teams automation" ;
    oc:directiveContent "Use incoming webhooks for one-way notification patterns (e.g., CI/CD alerts) and bot frameworks for two-way interactive workflows (e.g., approval flows with responses)." ;
    oc:hasRationale "Webhooks are simpler and sufficient for fire-and-forget notifications; bots are needed when the workflow requires processing user responses or multi-step interactions." ;
    oc:severityLevel "MEDIUM" .

oc:kn_470edd96 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When sending follow-up messages or automated responses in channels" ;
    oc:directiveContent "Reply in threads rather than posting top-level messages when continuing a conversation, to preserve context and reduce channel noise." ;
    oc:hasRationale "Threading keeps conversations organized and makes it easier for team members to track context and find information." ;
    oc:severityLevel "LOW" .

oc:kn_51bb3c9e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When sending messages that require user interaction such as approvals, form submissions, or status updates" ;
    oc:directiveContent "Use Adaptive Cards for rich interactive content instead of plain text or HTML messages when users need to take actions or submit data." ;
    oc:hasRationale "Adaptive Cards provide a consistent, platform-native interactive experience across Teams desktop, web, and mobile clients." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a1e5daa4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When sending messages, scheduling meetings, or making any Teams API calls" ;
    oc:directiveContent "Respect Microsoft Graph API rate limits when sending messages or making API calls to avoid throttling and service disruption." ;
    oc:hasRationale "Exceeding rate limits causes request failures and can temporarily block the integration from functioning." ;
    oc:severityLevel "HIGH" .

oc:kn_d9f58e71 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When setting up or configuring the MCP server and API authentication" ;
    oc:directiveContent "Request minimal permission scopes (least privilege) when configuring Microsoft Graph API access for Teams automation." ;
    oc:hasRationale "Overly broad permissions increase the blast radius of any credential compromise and violate security best practices." ;
    oc:severityLevel "HIGH" .

oc:req_57a6b35e a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "microsoft-mcp MCP server" .

oc:req_9c0cdc28 a oc:RequirementAPI ;
    oc:isOptional false ;
    oc:requirementValue "Microsoft Graph API access" .

oc:req_f3b175d2 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Microsoft Teams channel structure and permissions model" .

