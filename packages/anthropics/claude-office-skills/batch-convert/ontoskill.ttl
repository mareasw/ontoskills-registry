@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_office_skills_batch_convert a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "batch-convert" ;
    skos:broader "Document converter" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/batch-convert" ;
    oc:contentHash "510e37534436d730c5f38b74bbe08b20b41cddb99a1f8628bf01d37f5f33925b" ;
    oc:dependsOnSkill oc:skill_office_mcp ;
    oc:differentia "that batch-processes files between multiple formats (DOCX, PDF, MD, HTML, XLSX, PPTX) using a unified parallel pipeline" ;
    oc:handlesFailure oc:ConversionError,
        oc:FileNotFound,
        oc:InsufficientDiskSpace,
        oc:ToolNotInstalled ;
    oc:hasAllowedTool "Bash",
        "Glob",
        "Read",
        "Write" ;
    oc:hasArgumentHint "source path, target format, [output directory]" ;
    oc:hasCategory "document" ;
    oc:hasDescription "Batch convert documents between multiple formats using a unified pipeline" ;
    oc:hasName "batch-convert" ;
    oc:impartsKnowledge oc:kn_03a50d6e,
        oc:kn_3fbb1b68,
        oc:kn_419a5ea2,
        oc:kn_6675f8e7,
        oc:kn_97f995b4,
        oc:kn_a32f38c1,
        oc:kn_dae1cc23 ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:FileExists,
        oc:ToolInstalled ;
    oc:resolvesIntent "batch convert PDFs to Word documents",
        "convert documents between formats in bulk",
        "convert entire folders of files to a target format",
        "export markdown files to PDF and HTML",
        "migrate legacy documents to modern formats" ;
    oc:yieldsState oc:BatchConversionComplete,
        oc:FileConverted .

oc:kn_03a50d6e a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before any batch conversion operation" ;
    oc:directiveContent "Always test conversion on a small sample of files before running batch processing on hundreds of files." ;
    oc:hasRationale "Testing a sample catches format incompatibilities and quality issues early, preventing wasted time on large failed batches." ;
    oc:severityLevel "HIGH" .

oc:kn_3fbb1b68 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When running batch conversions with LibreOffice-based converters" ;
    oc:directiveContent "Batch conversion creates output files in a 'converted' subdirectory by default, and uses LibreOffice headless mode which may conflict with running LibreOffice instances." ;
    oc:hasRationale "LibreOffice headless mode cannot run alongside an open LibreOffice instance; concurrent sessions may corrupt output or fail." ;
    oc:severityLevel "MEDIUM" .

oc:kn_419a5ea2 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting documents with rich formatting" ;
    oc:directiveContent "Do not assume complex formatting (tables, images, embedded objects) will be preserved perfectly across conversions. Complex documents may lose formatting fidelity." ;
    oc:hasRationale "Conversion tools like markitdown and Pandoc prioritize content over layout; complex styling, embedded charts, and intricate formatting may degrade or be lost entirely." ;
    oc:severityLevel "MEDIUM" .

oc:kn_6675f8e7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing large batches of files" ;
    oc:directiveContent "Use parallel processing (ThreadPoolExecutor with max_workers=4 by default) for batch operations but reduce workers if encountering resource contention." ;
    oc:hasRationale "Parallel processing significantly speeds up batch conversions, but too many workers can cause memory pressure or tool contention (especially LibreOffice)." ;
    oc:severityLevel "LOW" .

oc:kn_97f995b4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting source and target formats" ;
    oc:directiveContent "Not all format combinations are supported. The supported matrix is: DOCX→{PDF,MD,HTML}, PDF→{DOCX,MD,HTML}, MD→{DOCX,PDF,HTML,PPTX}, HTML→{DOCX,PDF,MD}, XLSX→{PDF,MD,HTML}, PPTX→{PDF,MD,HTML}." ;
    oc:hasRationale "Requesting an unsupported conversion pair will raise a ValueError and halt processing for that file." ;
    oc:severityLevel "HIGH" .

oc:kn_a32f38c1 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After completing a batch conversion" ;
    oc:directiveContent "Spot-check converted files after batch processing to verify output quality and completeness." ;
    oc:hasRationale "Automated conversion may succeed technically but produce degraded output; manual verification catches quality issues before distribution." ;
    oc:severityLevel "MEDIUM" .

oc:kn_dae1cc23 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting any conversion batch" ;
    oc:directiveContent "Verify that required external tools (Pandoc, LibreOffice, Marp) are installed before attempting conversions that depend on them." ;
    oc:hasRationale "Conversions will fail silently or with confusing errors if the underlying tools (Pandoc for MD, LibreOffice for Office→PDF, Marp for MD→PPTX) are missing." ;
    oc:severityLevel "CRITICAL" .

