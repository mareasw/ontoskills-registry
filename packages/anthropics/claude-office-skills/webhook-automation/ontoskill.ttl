@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_office_skills_webhook_automation a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "webhook-automation" ;
    skos:broader "Integration automation" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/webhook-automation" ;
    oc:contentHash "289e38ec0cc775d5f54186493a34f65ec57f81364a04d89ec28e07670f2c1fef" ;
    oc:differentia "builds and manages webhook-based real-time event processing pipelines with signature verification, payload transformation, retry logic, and multi-service orchestration" ;
    oc:handlesFailure oc:InvalidInput,
        oc:NetworkTimeout,
        oc:PermissionDenied ;
    oc:hasArgumentHint "webhook configuration or integration type (e.g., 'Stripe webhook', 'GitHub webhook', 'event routing rules')" ;
    oc:hasCategory "automation" ;
    oc:hasDescription "Build and manage webhook-based integrations for real-time event processing and API connections" ;
    oc:hasName "webhook-automation" ;
    oc:impartsKnowledge oc:kn_6dd06958,
        oc:kn_76a7d22b,
        oc:kn_c29d0a07,
        oc:kn_c586f4e7,
        oc:kn_c5b22727,
        oc:kn_e5c45505 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:APIKeySet,
        oc:NetworkAvailable ;
    oc:resolvesIntent "create webhook endpoint",
        "debug webhooks",
        "implement webhook retry and error handling",
        "process webhook events",
        "route events to handlers",
        "set up webhook integrations with Stripe/GitHub/Slack",
        "transform webhook payloads",
        "verify webhook signatures" ;
    oc:yieldsState oc:EventProcessed,
        oc:IntegrationConfigured,
        oc:WebhookEndpointCreated .

oc:kn_6dd06958 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When receiving incoming webhooks from any external service" ;
    oc:directiveContent "Always verify webhook signatures using HMAC-SHA256 with timing-safe comparison before processing any payload. Never trust unverified webhook data." ;
    oc:hasRationale "Without signature verification, anyone can send forged payloads to your endpoint, enabling data corruption, unauthorized actions, or injection attacks" ;
    oc:severityLevel "CRITICAL" .

oc:kn_76a7d22b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When logging webhook payloads for debugging or audit purposes" ;
    oc:directiveContent "Never put sensitive data (secrets, tokens, PII) in webhook URLs or log payloads without masking. Always mask secrets in debug logs." ;
    oc:hasRationale "Webhook URLs and logs can be exposed in monitoring dashboards, error trackers, or version control, leaking credentials and violating compliance requirements" ;
    oc:severityLevel "HIGH" .

oc:kn_c29d0a07 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "On every incoming webhook request before handler execution" ;
    oc:directiveContent "Before processing any webhook: verify signature, validate payload schema against expected format, check timestamp freshness, and optionally verify source IP against known allowlists." ;
    oc:hasRationale "These checks prevent replay attacks, malformed payload errors, and unauthorized sources from triggering business logic" ;
    oc:severityLevel "HIGH" .

oc:kn_c586f4e7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building any webhook handler endpoint" ;
    oc:directiveContent "Return HTTP 200 immediately upon receiving a webhook, then process the event asynchronously. This prevents timeout-related retries from the source system." ;
    oc:hasRationale "Source systems (Stripe, GitHub, etc.) will retry delivery if they don't receive a timely acknowledgment, causing duplicate processing" ;
    oc:severityLevel "HIGH" .

oc:kn_c5b22727 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing webhook event handler logic" ;
    oc:directiveContent "Design all webhook handlers to be idempotent — processing the same event multiple times must produce the same result. Use event IDs for deduplication." ;
    oc:hasRationale "Webhook delivery is at-least-once, not exactly-once. Source systems retry on failure, and network issues can cause duplicate deliveries" ;
    oc:severityLevel "CRITICAL" .

oc:kn_e5c45505 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring error handling and retry strategies for webhook processing" ;
    oc:directiveContent "Implement exponential backoff retry with a dead letter queue for failed webhook processing. Configure max 5 attempts with backoff multiplier of 2, initial delay 1s, max delay 60s." ;
    oc:hasRationale "Transient failures (timeouts, rate limits, 502/503 errors) are common. Without retries and dead letter queues, events are silently lost" ;
    oc:severityLevel "HIGH" .

