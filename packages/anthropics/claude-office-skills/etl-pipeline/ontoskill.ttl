oc:skill_anthropics_claude_office_skills_etl_pipeline a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "etl-pipeline" ;
    skos:broader "Data pipeline automation framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/etl-pipeline" ;
    oc:contentHash "c5f44f367844b670f0ef35eda5944db57bcaf273cfa4b34d201b1f64c1e30d6f" ;
    oc:dependsOnSkill oc:skill_database_sync ;
    oc:differentia "that designs and orchestrates Extract, Transform, Load workflows across multiple database and API sources into analytics warehouses with quality validation and monitoring" ;
    oc:extends oc:skill_data_pipeline ;
    oc:handlesFailure oc:ExtractionFailed,
        oc:LoadFailed,
        oc:QualityCheckFailed,
        oc:TransformationError ;
    oc:hasArgumentHint "source configuration, transformation rules, target schema, and schedule" ;
    oc:hasCategory "data-pipeline" ;
    oc:hasDescription "Design and automate Extract, Transform, Load data pipelines for data integration and analytics" ;
    oc:hasName "etl-pipeline" ;
    oc:hasRequirement oc:req_02d52cb2,
        oc:req_38a821c7,
        oc:req_4c5364a8,
        oc:req_6a8ef22a,
        oc:req_81586938,
