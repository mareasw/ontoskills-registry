oc:skill_anthropics_claude_office_skills_intercom_automation a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "intercom-automation" ;
    skos:broader "Customer messaging automation system" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/intercom-automation" ;
    oc:contentHash "50cf79bec7883a6756a035efef616f2636c53c2374ca3f59f8561506d72d01f4" ;
    oc:differentia "that orchestrates Intercom support workflows, user segmentation, messaging campaigns, product tours, and conversation routing through event-driven rules" ;
    oc:handlesFailure oc:InvalidInput,
        oc:NetworkTimeout,
        oc:PermissionDenied ;
    oc:hasAlias "customer-messaging-automation",
        "intercom",
        "intercom-workflows" ;
    oc:hasAllowedTool "intercom_articles",
        "intercom_conversation",
        "intercom_message",
        "intercom_user" ;
    oc:hasArgumentHint "automation type (messaging, segmentation, routing, tours, campaigns) and target user/segment criteria" ;
    oc:hasCategory "support" ;
    oc:hasDescription "Automate Intercom customer messaging, support workflows, user engagement, and product tours" ;
    oc:hasName "intercom-automation" ;
    oc:hasRequirement oc:req_19d63218,
        oc:req_5d7a74ad,
        oc:req_7cf15025,
        oc:req_80c02437 ;
    oc:impartsKnowledge oc:kn_07403d57,
        oc:kn_0afd71b4,
        oc:kn_17933b27,
        oc:kn_2c5a3a1d,
        oc:kn_b69d42e8,
        oc:kn_f77caf5f ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:APIKeySet,
        oc:NetworkAvailable ;
    oc:resolvesIntent "automate intercom customer messaging",
        "build product tours",
        "configure conversation routing rules",
        "create user segments in intercom",
        "design onboarding campaigns",
        "generate support metrics and engagement reports",
        "set up bot response flows",
        "sync intercom with CRM and Slack" ;
    oc:yieldsState oc:AutomationConfigured,
        oc:MessagesSent,
        oc:UserSegmentsCreated .

oc:kn_07403d57 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When setting up integration workflows with Slack, Salesforce, or Jira" ;
    oc:directiveContent "Intercom automations can trigger downstream actions in connected systems (Slack notifications, CRM lead creation, Jira ticket creation). Be aware of cascading effects when configuring routing rules." ;
    oc:hasRationale "Unintended cascading automations can create noise in integrated systems, generate duplicate records, or spam notification channels." ;
    oc:severityLevel "HIGH" .

oc:kn_0afd71b4 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing multi-step onboarding campaigns or drip sequences" ;
    oc:directiveContent "Never over-message users. Respect frequency limits and avoid sending multiple messages across channels within short time windows." ;
    oc:hasRationale "Message fatigue leads to higher unsubscribe rates, lower engagement, and damaged brand perception." ;
    oc:severityLevel "HIGH" .

oc:kn_17933b27 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining custom user attributes and segmentation rules" ;
    oc:directiveContent "Dynamic health scores and lifecycle stages must be computed from verifiable user activity data (sessions, features used, subscription status). Do not use stale or inferred attributes." ;
    oc:hasRationale "Inaccurate segmentation sends wrong messages to wrong users, undermining automation credibility and potentially triggering churn." ;
    oc:severityLevel "MEDIUM" .

oc:kn_2c5a3a1d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring any messaging campaign or automation rule" ;
    oc:directiveContent "Always personalize messages using user attributes (first_name, company_name, etc.) and respect user timezone when scheduling sends." ;
    oc:hasRationale "Personalized, well-timed messages dramatically improve open rates and user engagement while reducing annoyance." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b69d42e8 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring bot responses and conversation routing rules" ;
    oc:directiveContent "Know when to escalate from bot to human agent. Use intent classification to auto-resolve simple queries (greeting, pricing, password reset) but route complex or emotional issues to human support." ;
    oc:hasRationale "Bot-only resolution targets ~30% of conversations. Forcing bots on complex issues degrades customer satisfaction and increases resolution time." ;
    oc:severityLevel "HIGH" .

oc:kn_f77caf5f a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "After launching any messaging campaign or product tour" ;
    oc:directiveContent "A/B test message content and track engagement metrics (open rate target: 40%, CTR target: 10%, tour completion target: 60%) to continuously optimize campaigns." ;
    oc:hasRationale "Data-driven iteration is essential for improving automation effectiveness; static campaigns degrade over time as user expectations evolve." ;
    oc:severityLevel "MEDIUM" .

oc:req_19d63218 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "CRM integration mapping (Salesforce/Salesforce fields)" .

oc:req_5d7a74ad a oc:RequirementAPI ;
    oc:isOptional false ;
    oc:requirementValue "Intercom API access token" .

oc:req_7cf15025 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Intercom workspace configuration and segment definitions" .

oc:req_80c02437 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "helpdesk-mcp server with intercom_message, intercom_user, intercom_conversation, intercom_articles tools" .

