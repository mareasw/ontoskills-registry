@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_office_skills_weather_automation a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "weather-automation" ;
    skos:broader "Automation skill" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/weather-automation" ;
    oc:contentHash "0f5da7ff2f2b16e5049fef903b609c1348ce762aeac57a4f22e759cd0fc3fd69" ;
    oc:differentia "automates weather-based workflows, forecasts, alerts, and location-aware notifications using weather MCP server tools" ;
    oc:handlesFailure oc:APIKeySet,
        oc:LocationNotFound,
        oc:NetworkTimeout ;
    oc:hasAllowedTool "weather_alerts",
        "weather_current",
        "weather_forecast",
        "weather_historical" ;
    oc:hasArgumentHint "location and optional date range or alert configuration" ;
    oc:hasCategory "automation" ;
    oc:hasDescription "Automate weather-based workflows, forecasts, alerts, and location-aware notifications" ;
    oc:hasName "weather-automation" ;
    oc:hasRequirement oc:req_1c90e0cb,
        oc:req_993a9c59 ;
    oc:impartsKnowledge oc:kn_376e49b7,
        oc:kn_7bc8e08e,
        oc:kn_ca54433c,
        oc:kn_df4cd449,
        oc:kn_e524ecda ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:APIKeySet,
        oc:NetworkAvailable ;
    oc:resolvesIntent "automate weather-triggered workflows",
        "get current weather conditions for a location",
        "integrate weather data with calendar and smart home systems",
        "retrieve weather forecasts",
        "set up weather alerts and notifications" ;
    oc:yieldsState oc:AlertConfigured,
        oc:NotificationSent,
        oc:WeatherDataRetrieved .

oc:kn_376e49b7 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring weather alert rules" ;
    oc:directiveContent "Set sensible alert thresholds based on impact severity — lower thresholds for safety-critical conditions (freeze, severe storms), higher thresholds for convenience alerts (rain, heat)." ;
    oc:hasRationale "Over-alerting causes notification fatigue; under-alerting misses critical conditions. Thresholds should match the consequence severity." ;
    oc:severityLevel "HIGH" .

oc:kn_7bc8e08e a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When formatting weather data output for users" ;
    oc:directiveContent "Support both metric and imperial units for temperature, wind speed, and other measurements." ;
    oc:hasRationale "Users expect measurements in their familiar unit system; failure to support both causes confusion." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ca54433c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When weather data informs safety-critical actions like freeze protection or severe weather response" ;
    oc:directiveContent "Use reliable weather data sources and cross-reference when accuracy is critical for safety decisions." ;
    oc:hasRationale "Weather data accuracy varies by provider and region; safety decisions require higher confidence than convenience queries." ;
    oc:severityLevel "HIGH" .

oc:kn_df4cd449 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When making repeated weather queries for the same location" ;
    oc:directiveContent "Cache frequent weather API requests to avoid rate limiting and reduce latency." ;
    oc:hasRationale "Weather data changes infrequently (every 15-30 min) and API calls have rate limits and latency costs." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e524ecda a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When querying weather data for any location" ;
    oc:directiveContent "Location must be specified either as a city name string or lat/lon coordinates; both formats should be supported." ;
    oc:hasRationale "Users may have location data in different formats; supporting both ensures flexibility and avoids geocoding errors." ;
    oc:severityLevel "MEDIUM" .

oc:req_1c90e0cb a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Location formats (city name or lat/lon coordinates)" .

oc:req_993a9c59 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "weather-mcp MCP server" .

