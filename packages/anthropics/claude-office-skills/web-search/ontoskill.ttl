@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_office_skills_web_search a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "web-search" ;
    skos:broader "Search strategy framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/web-search" ;
    oc:contentHash "d80ca9497d0f9984dfd411b5dd2a081bcd1a3d32f1e0fbb9784fd023cf17b31d" ;
    oc:differentia "formulates optimized web search queries with operators, evaluates sources via the CRAAP test, and synthesizes findings across multiple search engines and reliability tiers" ;
    oc:handlesFailure oc:InvalidInput,
        oc:NetworkTimeout ;
    oc:hasArgumentHint "topic or information need description" ;
    oc:hasCategory "research" ;
    oc:hasDescription "Formulate effective web search queries, analyze search results, and synthesize findings. Optimize search strategies for different types of information needs." ;
    oc:hasName "web-search" ;
    oc:hasPackageName "web-search" ;
    oc:impartsKnowledge oc:kn_a9ea28ba,
        oc:kn_ee80b343,
        oc:kn_f5ff74b1,
        oc:kn_f9976b69,
        oc:kn_fa8430c1 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:NetworkAvailable ;
    oc:resolvesIntent "evaluate source reliability",
        "find information on the web",
        "formulate web search queries",
        "optimize search strategy",
        "synthesize search results" ;
    oc:yieldsState oc:SearchStrategyGenerated .

oc:kn_a9ea28ba a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always — this is a guidance-only skill, not a search execution tool" ;
    oc:directiveContent "This skill cannot execute actual web searches, access real-time results, or access paywalled content. It generates strategies that must be executed externally." ;
    oc:hasRationale "Agents must not misrepresent capability; users need external tools (browser, MCP servers) to execute the generated queries." ;
    oc:severityLevel "CRITICAL" .

oc:kn_ee80b343 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When synthesizing information from search results" ;
    oc:directiveContent "Cross-reference findings across multiple sources and search engines. Never rely on a single source for critical claims." ;
    oc:hasRationale "Single-source reliance introduces bias and error; triangulation improves accuracy and confidence." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f5ff74b1 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formulating any web search strategy" ;
    oc:directiveContent "Start broad, then narrow queries iteratively. Use synonym variations and question-based formulations to cover the information space." ;
    oc:hasRationale "Iterative narrowing maximizes recall in early passes and precision in later passes, reducing missed results." ;
    oc:severityLevel "HIGH" .

oc:kn_f9976b69 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating any search result or source" ;
    oc:directiveContent "Apply the CRAAP test (Currency, Relevance, Authority, Accuracy, Purpose) to evaluate every source. Tier sources from peer-reviewed (Tier 1) down to anonymous/content farms (Tier 5)." ;
    oc:hasRationale "Source reliability varies enormously; without systematic evaluation, misinformation propagates into downstream analysis." ;
    oc:severityLevel "HIGH" .

oc:kn_fa8430c1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When searching for statistics, news, or any rapidly-evolving topic" ;
    oc:directiveContent "Do not ignore date filtering on time-sensitive topics. Information expires and outdated results can be actively misleading." ;
    oc:hasRationale "Search engines surface older high-authority pages; without date filtering, stale data may be presented as current." ;
    oc:severityLevel "MEDIUM" .

