@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_office_skills_skill_name_readme a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "readme" ;
    skos:broader "Template scaffold" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/skill-name" ;
    oc:contentHash "68d729cdbdd1edc9b43d233a1fa554b1c8bd7c2a3bc9151cc8809aed5172bc31" ;
    oc:differentia "that provides boilerplate structure and guidelines for creating new Claude Office Skills" ;
    oc:extends oc:skill_anthropics_claude_office_skills_skill_name ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "new-skill-name (kebab-case)" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_34faa65d,
        oc:kn_4fa2741f,
        oc:kn_bad7129e,
        oc:kn_cc3155b5 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "create new skill",
        "learn skill authoring conventions",
        "scaffold a skill" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_34faa65d a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "After drafting a new skill but before submitting a PR" ;
    oc:directiveContent "Before submitting a skill, test it by pasting SKILL.md content into a new Claude conversation with a sample document, verifying output, and testing edge cases." ;
    oc:hasRationale "Manual testing catches gaps in instructions, missing context, and edge cases that authors overlook during creation" ;
    oc:severityLevel "MEDIUM" .

oc:kn_4fa2741f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When authoring SKILL.md content" ;
    oc:directiveContent "Skills must solve one clear problem, embed domain expertise (not just instructions), include real-world examples, and clearly state limitations." ;
    oc:hasRationale "Skills that are focused, knowledge-rich, and transparent about limits produce better AI behavior than vague multi-purpose instructions" ;
    oc:severityLevel "HIGH" .

oc:kn_bad7129e a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When starting skill creation" ;
    oc:directiveContent "When creating a new skill, copy the entire _template folder, rename to kebab-case skill name, edit SKILL.md with skill-specific content, and delete or replace the README." ;
    oc:hasRationale "Following the template ensures all skills have consistent structure (metadata, overview, domain knowledge, examples, limitations)" ;
    oc:severityLevel "MEDIUM" .

oc:kn_cc3155b5 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When naming a new skill directory" ;
    oc:directiveContent "Use lowercase with hyphens for skill directory names (kebab-case), e.g., 'expense-report', 'job-description'. Avoid generic names like 'helper' or 'assistant'." ;
    oc:hasRationale "Consistent naming enables discoverability, routing, and prevents ambiguity in skill identification" ;
    oc:severityLevel "MEDIUM" .

