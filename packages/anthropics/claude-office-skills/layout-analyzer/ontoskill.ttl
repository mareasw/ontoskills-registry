@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_office_skills_layout_analyzer a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "layout-analyzer" ;
    skos:broader "Document layout analysis tool" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/layout-analyzer" ;
    oc:contentHash "6f50507d32926253c90170bc64268364ea6f7e64cb317b18df2dddeb422102d8" ;
    oc:dependsOnSkill oc:skill_office_mcp ;
    oc:differentia "Uses surya OCR library to detect text blocks, tables, figures, headings, and determine reading order in complex document images and PDFs" ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput ;
    oc:hasArgumentHint "document image or PDF file path" ;
    oc:hasCategory "document" ;
    oc:hasDescription ">" ;
    oc:hasName "layout-analyzer" ;
    oc:hasPackageName "surya-ocr" ;
    oc:impartsKnowledge oc:kn_4048c5f2,
        oc:kn_5d6cf751,
        oc:kn_6602f661,
        oc:kn_6d9cac28,
        oc:kn_8d24bd6b,
        oc:kn_b8faca73,
        oc:kn_f64240a7 ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:FileExists,
        oc:ToolInstalled ;
    oc:resolvesIntent "analyze document layout",
        "detect layout elements in documents",
        "determine reading order of document pages",
        "extract document structure",
        "identify tables and figures in documents" ;
    oc:yieldsState oc:DocumentStructureAnalyzed .

oc:kn_4048c5f2 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When analyzing large or multi-page PDF documents" ;
    oc:directiveContent "Process multi-page PDFs page-by-page for layout analysis, not as a batch when memory is constrained" ;
    oc:hasRationale "Batch processing of many pages can exhaust GPU memory; individual page processing allows memory management" ;
    oc:severityLevel "MEDIUM" .

oc:kn_5d6cf751 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "Before analyzing any document image" ;
    oc:directiveContent "Use high-quality images (150+ DPI) for best layout detection results" ;
    oc:hasRationale "Low-resolution images cause missed text regions and inaccurate bounding boxes, degrading detection quality" ;
    oc:severityLevel "HIGH" .

oc:kn_6602f661 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When full document understanding is needed beyond just structural layout" ;
    oc:directiveContent "Combine layout analysis with OCR to get text content within detected layout regions" ;
    oc:hasRationale "Layout analysis identifies WHERE elements are; OCR provides WHAT text they contain — both are needed for complete extraction" ;
    oc:severityLevel "LOW" .

oc:kn_6d9cac28 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When analyzing documents with handwriting, fine print, or deeply nested structures" ;
    oc:directiveContent "Handwritten text layout detection may be inaccurate; very small text regions may be missed; complex nested layouts are challenging" ;
    oc:hasRationale "Surya's models are trained primarily on printed documents with standard layouts — edge cases degrade performance" ;
    oc:severityLevel "MEDIUM" .

oc:kn_8d24bd6b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "After receiving layout analysis results" ;
    oc:directiveContent "Always validate results by checking confidence scores on detected layout elements" ;
    oc:hasRationale "Low confidence scores indicate uncertain detections that may need manual verification or different preprocessing" ;
    oc:severityLevel "MEDIUM" .

oc:kn_b8faca73 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When processing multiple documents or large PDFs" ;
    oc:directiveContent "GPU is recommended for batch processing of document layout analysis" ;
    oc:hasRationale "Surya uses deep learning models that benefit significantly from GPU acceleration for inference" ;
    oc:severityLevel "LOW" .

oc:kn_f64240a7 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When analyzing scanned or photographed documents" ;
    oc:directiveContent "Preprocess documents by deskewing rotated pages before layout analysis" ;
    oc:hasRationale "Rotation and skew distort bounding box detection and reading order determination" ;
    oc:severityLevel "MEDIUM" .

