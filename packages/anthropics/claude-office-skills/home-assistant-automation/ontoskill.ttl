@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_office_skills_home_assistant_automation a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "home-assistant-automation" ;
    skos:broader "Smart home automation skill" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/home-assistant-automation" ;
    oc:contentHash "8daba109efe0206615302aa10d2759fc95e1ee9f17155500459f834c3b9670ef" ;
    oc:differentia "that controls IoT devices, creates automation workflows, manages scenes, and monitors states via Home Assistant MCP integration" ;
    oc:handlesFailure oc:DeviceNotFound,
        oc:NetworkTimeout,
        oc:PermissionDenied ;
    oc:hasAllowedTool "ha_automation",
        "ha_scene",
        "ha_service_call",
        "ha_state_get" ;
    oc:hasArgumentHint "device commands, automation triggers, or scene configurations" ;
    oc:hasCategory "automation" ;
    oc:hasDescription "Automate smart home devices and create intelligent home automation workflows with Home Assistant" ;
    oc:hasName "home-assistant-automation" ;
    oc:impartsKnowledge oc:kn_54948e0e,
        oc:kn_9a344fea,
        oc:kn_aaf4189d,
        oc:kn_c510b600,
        oc:kn_d8d2cd12 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:APIKeySet,
        oc:NetworkAvailable ;
    oc:resolvesIntent "automate smart home devices",
        "control lights climate and media devices",
        "create home automation workflows",
        "monitor home energy and security",
        "set up home scenes and routines" ;
    oc:yieldsState oc:AutomationCreated,
        oc:DeviceStateChanged .

oc:kn_54948e0e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring notification actions in automations" ;
    oc:directiveContent "Do not over-notify users with automation alerts. Keep notifications meaningful and actionable." ;
    oc:hasRationale "Excessive notifications lead to alert fatigue, causing users to ignore or disable important security and status notifications." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9a344fea a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before deploying any new automation or scene configuration" ;
    oc:directiveContent "Test automations thoroughly before relying on them and maintain regular configuration backups." ;
    oc:hasRationale "Untested automations can cause unexpected device behavior (e.g., unlocking doors, changing thermostat settings) that impacts safety and comfort." ;
    oc:severityLevel "HIGH" .

oc:kn_aaf4189d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any automation workflow" ;
    oc:directiveContent "Always add appropriate conditions to automations to prevent unintended triggers." ;
    oc:hasRationale "Without conditions, automations can fire at inappropriate times (e.g., turning on lights when no one is home, triggering security alerts falsely)." ;
    oc:severityLevel "HIGH" .

oc:kn_c510b600 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building multi-step automation actions" ;
    oc:directiveContent "Use delay actions between sequential device commands to allow devices to process state changes, and leverage transitions for lighting changes." ;
    oc:hasRationale "Rapid sequential commands can overwhelm device protocols (Zigbee, Z-Wave) causing missed commands or desynchronized states." ;
    oc:severityLevel "LOW" .

oc:kn_d8d2cd12 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When setting up or modifying any Home Assistant configuration" ;
    oc:directiveContent "Use consistent entity naming conventions across all devices and organize devices into logical groups." ;
    oc:hasRationale "Consistent naming ensures maintainability and prevents confusion when referencing entities in automations and scenes." ;
    oc:severityLevel "MEDIUM" .

