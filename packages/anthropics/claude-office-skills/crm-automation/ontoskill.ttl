oc:skill_anthropics_claude_office_skills_crm_automation a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "crm-automation" ;
    skos:broader "workflow automation framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/crm-automation" ;
    oc:contentHash "d5369a99336f5e2ddc488ecd8f3e20f3f6b6930b812981d9eff43693e9ec9ce5" ;
    oc:dependsOnSkill oc:skill_lead_routing ;
    oc:differentia "orchestrates CRM operations across HubSpot, Salesforce, and Pipedrive with lead scoring, deal tracking, pipeline management, and multi-CRM synchronization" ;
    oc:handlesFailure oc:APIRateLimited,
        oc:InvalidInput,
        oc:NetworkTimeout,
        oc:PermissionDenied ;
    oc:hasArgumentHint "CRM platform (hubspot|salesforce|pipedrive) and workflow type (lead-capture|deal-tracking|sync|scoring|sequence|report)" ;
    oc:hasCategory "automation" ;
    oc:hasDescription "CRM workflow automation for HubSpot, Salesforce, Pipedrive - lead management, deal tracking, and multi-CRM synchronization" ;
    oc:hasName "crm-automation" ;
    oc:hasPackageName "crm-automation" ;
    oc:hasRequirement oc:req_05a79562,
        oc:req_79fbb476,
        oc:req_80bcc3df,
        oc:req_83487594,
        oc:req_9fa8d574,
        oc:req_ed12f443,
        oc:req_eea13786 ;
    oc:impartsKnowledge oc:kn_015cfbce,
        oc:kn_07550fe9,
        oc:kn_6fce9ffa,
        oc:kn_949da8ac,
        oc:kn_ac928e0a,
        oc:kn_d9a24a49,
        oc:kn_dbf142f2,
        oc:kn_ef17b8f6,
        oc:kn_f85726bd ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:APIKeySet,
        oc:NetworkAvailable ;
    oc:resolvesIntent "automate CRM workflows",
        "capture and enrich leads",
        "create automated sales sequences",
        "generate sales pipeline reports",
        "score and route leads",
        "synchronize data across CRMs",
        "track deal stages" ;
    oc:yieldsState oc:CRMContactCreated,
