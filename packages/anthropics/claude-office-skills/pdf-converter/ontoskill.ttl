@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_office_skills_pdf_converter a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "pdf-converter" ;
    skos:broader "Document format converter" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/pdf-converter" ;
    oc:contentHash "50df6483e2bd2054ecb981000ee8628d4f727b64a4a411a1625bf8c00757fcbf" ;
    oc:differentia "that provides guidance for converting PDF files to and from Word, Excel, PowerPoint, images, text, HTML, and Markdown formats while preserving formatting quality" ;
    oc:extends oc:skill_office_mcp ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput,
        oc:PermissionDenied ;
    oc:hasArgumentHint "source file path and target format (e.g., 'report.pdf to docx', 'presentation.pptx to pdf')" ;
    oc:hasCategory "document" ;
    oc:hasDescription "Convert PDF files to and from Word, Excel, Image, and other formats" ;
    oc:hasName "pdf-converter" ;
    oc:hasRequirement oc:req_1988e119,
        oc:req_41e714c9,
        oc:req_708f1eff,
        oc:req_82bf9fff,
        oc:req_e10b2d63 ;
    oc:impartsKnowledge oc:kn_05c50ab1,
        oc:kn_3c586df3,
        oc:kn_737f0af6,
        oc:kn_c99495ed,
        oc:kn_ce5f954f ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:FileExists,
        oc:ToolInstalled ;
    oc:resolvesIntent "batch convert PDFs",
        "convert PDF to Excel",
        "convert PDF to Word",
        "convert PDF to images",
        "convert documents to PDF",
        "extract images from PDF" ;
    oc:yieldsState oc:DocumentConverted .

oc:kn_05c50ab1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the source PDF is scanned or image-based" ;
    oc:directiveContent "Never convert scanned PDFs directly without OCR preprocessing — text will not be selectable and conversion will fail or produce image-based output." ;
    oc:hasRationale "Scanned PDFs contain images of text, not actual text data. Without OCR, the conversion engine has no text to extract, resulting in poor or unusable output." ;
    oc:severityLevel "HIGH" .

oc:kn_3c586df3 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always — this is an advisory skill" ;
    oc:directiveContent "This skill provides guidance and tool recommendations only — it cannot perform actual file conversion itself. MCP tools (pdf_to_docx, docx_to_pdf, html_to_pdf) or external tools are required for execution." ;
    oc:hasRationale "The skill explicitly states it 'cannot perform actual file conversion' and only provides guidance; the agent must use appropriate tools to execute conversions." ;
    oc:severityLevel "CRITICAL" .

oc:kn_737f0af6 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting PDF pages to images" ;
    oc:directiveContent "Use 300 DPI for print-quality image exports, 150 DPI for email/web, and 72 DPI for screen viewing. Choose PNG for text/graphics, JPG for photos/smaller files." ;
    oc:hasRationale "Resolution and format selection directly impact both output quality and file size; matching DPI to use case prevents unnecessarily large files or poor-quality output." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c99495ed a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After completing any conversion operation" ;
    oc:directiveContent "After every conversion, verify: all text present and readable, formatting approximately preserved, images included and clear, tables properly structured, links functional, and page count matches." ;
    oc:hasRationale "Some formatting loss is inherent in PDF conversion; a post-conversion quality check catches issues like broken tables, missing fonts, or lost images before the output is used." ;
    oc:severityLevel "HIGH" .

oc:kn_ce5f954f a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before any PDF conversion operation" ;
    oc:directiveContent "Check source PDF type before conversion: native PDFs yield best results, scanned PDFs require OCR first, image-based PDFs have limited accuracy." ;
    oc:hasRationale "Conversion quality depends entirely on how the source PDF was created; applying the wrong method to a scanned PDF wastes time and produces garbage output." ;
    oc:severityLevel "HIGH" .

oc:req_1988e119 a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "html_to_pdf" .

oc:req_41e714c9 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "office-mcp MCP server" .

oc:req_708f1eff a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Understanding of PDF types (native vs scanned vs image-based)" .

oc:req_82bf9fff a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "docx_to_pdf" .

oc:req_e10b2d63 a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "pdf_to_docx" .

