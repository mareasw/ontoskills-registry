    oc:requirementValue "pdf2docx Python library" .

oc:req_d2bd96eb a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "PDF document structure" .

oc:req_d87817a6 a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "pdf2image" .

