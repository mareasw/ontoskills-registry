@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_office_skills_applicant_screening a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "applicant-screening" ;
    skos:broader "Candidate evaluation framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/applicant-screening" ;
    oc:contentHash "85551c8e739819ef7f105e200796942fd881a82f8e5978ec9a6d1b3a854d09b7" ;
    oc:differentia "that screens job applications against weighted requirement matrices, scores candidates on a 100-point rubric, and produces structured ranking reports with tiered interview recommendations" ;
    oc:extends oc:skill_office_mcp ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput ;
    oc:hasAllowedTool "analyze_document_structure",
        "extract_text_from_docx",
        "extract_text_from_pdf" ;
    oc:hasArgumentHint "resume(s) and job requirements or position title" ;
    oc:hasCategory "hr" ;
    oc:hasDescription "Screen job applications against requirements and score candidates" ;
    oc:hasName "applicant-screening" ;
    oc:impartsKnowledge oc:kn_3760994b,
        oc:kn_47ee95c9,
        oc:kn_507e31e7,
        oc:kn_c5b15d32,
        oc:kn_d6761afd ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DocumentCreated ;
    oc:resolvesIntent "batch screen multiple applicants",
        "evaluate resumes against job criteria",
        "identify top candidates for interviews",
        "score and rank candidates for a position",
        "screen job applications against requirements" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_3760994b a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning any screening session" ;
    oc:directiveContent "Before screening, ensure the requirements matrix is complete with must-have/nice-to-have separation, weights totaling 100%, explicit disqualifiers, and a clear position level (entry/mid/senior/lead)." ;
    oc:hasRationale "Incomplete or ambiguous requirements produce inconsistent scores that cannot be meaningfully compared across candidates." .

oc:kn_47ee95c9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When presenting or acting on screening results" ;
    oc:directiveContent "Scoring is guidance, not absolute — human judgment is essential for final decisions. This skill cannot verify employment history, fully assess cultural fit, or evaluate soft skills." ;
    oc:hasRationale "Automated scoring provides structure but cannot capture the full complexity of candidate evaluation; over-reliance on scores leads to missed talent from non-traditional backgrounds." ;
    oc:severityLevel "HIGH" .

oc:kn_507e31e7 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scoring individual candidates" ;
    oc:directiveContent "Score each criterion separately before forming an overall impression — this counters halo effect and confirmation bias. Use diverse interview panels to counter affinity bias." ;
    oc:hasRationale "Sequential criterion-by-criterion evaluation prevents a single strong impression from unduly influencing the overall assessment." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c5b15d32 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up any screening framework" ;
    oc:directiveContent "Use a weighted requirements matrix separating must-have (required) from nice-to-have (preferred) qualifications, with explicit disqualifiers, to ensure consistent and objective candidate evaluation." ;
    oc:hasRationale "Separating requirements by necessity and weighting them prevents subjective holistic impressions and enables defensible, comparable scoring across candidates." ;
    oc:severityLevel "HIGH" .

oc:kn_d6761afd a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating any candidate application" ;
    oc:directiveContent "Never allow protected characteristics (name, gender, age, ethnicity) to influence scoring; always focus exclusively on job-related criteria and document all decisions." ;
    oc:hasRationale "Bias in screening creates legal liability, violates fair hiring practices, and produces worse hiring outcomes by filtering out qualified candidates." ;
    oc:severityLevel "CRITICAL" .

