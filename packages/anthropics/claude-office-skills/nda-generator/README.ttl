@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_office_skills_nda_generator_readme a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "readme" ;
    skos:broader "document generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/nda-generator" ;
    oc:contentHash "7bddc371d1b5a8b2db0f19ac8887036f3d2db00ce10603dabeff53f9242b2185" ;
    oc:differentia "that creates professional Non-Disclosure Agreements customized for various business contexts including investor meetings, partnerships, contractor engagements, and employment scenarios" ;
    oc:extends oc:skill_anthropics_claude_office_skills_nda_generator ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasAllowedTool "create_docx",
        "docx_to_pdf",
        "fill_docx_template" ;
    oc:hasArgumentHint "situation description (e.g., 'NDA for investor meeting sharing business plan and financial projections')" ;
    oc:hasCategory "legal" ;
    oc:hasPackageName "nda-generator" ;
    oc:hasRequirement oc:req_00941dea,
        oc:req_3cf9815f,
        oc:req_82bf9fff ;
    oc:impartsKnowledge oc:kn_2aeae895,
        oc:kn_3bbd221d,
        oc:kn_4d09dae0,
        oc:kn_9b5bcbe5,
        oc:kn_a31ef159,
        oc:kn_d74c50de,
        oc:kn_ec7f986d,
        oc:kn_f98e2213 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "create mutual NDA",
        "create non-disclosure agreement",
        "create one-way NDA",
        "draft confidentiality agreement",
        "generate NDA",
        "generate contractor NDA",
        "generate investor NDA",
        "generate partnership NDA" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_2aeae895 a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting governing law clause" ;
    oc:directiveContent "Jurisdiction selection significantly impacts enforceability. Default to Delaware (business-friendly) or the state/country where the primary party operates unless user specifies otherwise." ;
    oc:hasRationale "Jurisdiction determines which laws apply and where disputes are resolved — incorrect selection can render the NDA ineffective" ;
    oc:severityLevel "MEDIUM" .

oc:kn_3bbd221d a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When drafting the exclusions clause" ;
    oc:directiveContent "Always include the five standard NDA exclusions: already public information, already known to recipient, independently developed, received from third party without restriction, and required by law to disclose." ;
    oc:hasRationale "Standard exclusions protect both parties from unfair claims and are expected in any enforceable NDA" ;
    oc:severityLevel "HIGH" .

oc:kn_4d09dae0 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, when presenting any generated NDA" ;
    oc:directiveContent "This skill generates templates, not legal advice. Enforceability varies by jurisdiction and complex situations require attorney review." ;
    oc:hasRationale "NDAs are legal instruments whose enforceability depends on jurisdiction-specific law; generated templates carry no guarantee of legal validity" ;
    oc:severityLevel "CRITICAL" .

oc:kn_9b5bcbe5 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting confidentiality duration clauses" ;
    oc:directiveContent "Choose confidentiality duration based on information type: trade secrets require indefinite protection ('as long as they remain trade secrets'), while general business info typically uses 2-5 years." ;
    oc:hasRationale "Duration must balance protection needs with reasonableness — courts will not enforce unreasonably long periods for non-trade-secret information" ;
    oc:severityLevel "MEDIUM" .

oc:kn_a31ef159 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining NDA structure for a given scenario" ;
    oc:directiveContent "Match the NDA type to the situation: use one-way (unilateral) when only one party discloses (investor pitches, hiring), and mutual (bilateral) when both parties share information (partnerships, M&A, joint ventures)." ;
    oc:hasRationale "Using the wrong NDA type either over-protects or under-protects one party, creating unnecessary risk or friction" ;
    oc:severityLevel "HIGH" .

oc:kn_d74c50de a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before generating any NDA" ;
    oc:directiveContent "Before generating an NDA, confirm: context (investor, contractor, partnership), parties and roles, type of information to protect, one-way vs mutual direction, and preferred jurisdiction." ;
    oc:hasRationale "Missing key parameters result in generic NDAs that may not adequately protect the specific situation" ;
    oc:severityLevel "MEDIUM" .

oc:kn_ec7f986d a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When generating an NDA for investor meetings" ;
    oc:directiveContent "Many investors will not sign NDAs. Consider what information you are comfortable sharing without one before requesting an investor NDA." ;
    oc:hasRationale "Requesting NDAs from investors can signal naivety and may prevent productive conversations; the information shared should be calibrated accordingly" ;
    oc:severityLevel "MEDIUM" .

oc:kn_f98e2213 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting any NDA clause" ;
    oc:directiveContent "Avoid overly broad definitions of confidential information, unreasonable durations (e.g. 10 years), missing standard exclusions, and no purpose limitation — these render NDAs unenforceable." ;
    oc:hasRationale "Courts routinely invalidate NDAs with overly broad scope or unreasonable terms, which defeats the purpose of the agreement" ;
    oc:severityLevel "HIGH" .

oc:req_00941dea a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "create_docx" .

oc:req_3cf9815f a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "fill_docx_template" .

oc:req_82bf9fff a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "docx_to_pdf" .

