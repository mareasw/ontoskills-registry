oc:skill_anthropics_claude_office_skills_smart_ocr a oc:ExecutableSkill,
        oc:Skill ;
    dcterms:identifier "smart-ocr" ;
    skos:broader "OCR engine integration" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/smart-ocr" ;
    oc:contentHash "8f176a44fed147fc0dceba463aa12a6f8edc652865eae8594e47b9507ea4e4a4" ;
    oc:differentia "extracts text from images and scanned documents using PaddleOCR with multilingual support" ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput,
        oc:PermissionDenied ;
    oc:hasAlias "image-to-text",
        "ocr",
        "text-extraction" ;
    oc:hasAllowedTool "extract_text_from_pdf" ;
    oc:hasArgumentHint "image or PDF file path, with optional language code" ;
    oc:hasCategory "document" ;
    oc:hasDescription ">" ;
    oc:hasName "smart-ocr" ;
    oc:hasPackageName "smart-ocr" ;
