        oc:kn_6126087c,
        oc:kn_69cd4e98,
        oc:kn_72097929,
        oc:kn_7dfa5cbb,
        oc:kn_8f5c43ff ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:FileExists,
        oc:ToolInstalled ;
    oc:resolvesIntent "extract multilingual text from images",
        "extract text from images",
        "ocr scanned documents",
        "ocr scanned pdf files",
        "read text from photos and screenshots" ;
    oc:yieldsState oc:TextExtracted .

oc:kn_0b38b0f6 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When initializing OCR engine for any document" ;
    oc:directiveContent "Always specify the correct language code when initializing PaddleOCR to achieve best recognition accuracy." ;
    oc:hasRationale "Language-specific models produce far more accurate results than auto-detection for known-language documents" ;
    oc:severityLevel "MEDIUM" .

oc:kn_6126087c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing OCR output for downstream use" ;
    oc:directiveContent "Do not blindly trust OCR results with low confidence scores. Filter out results below a reasonable confidence threshold." ;
    oc:hasRationale "Low-confidence extractions introduce noise and errors that propagate into any downstream processing or analysis" ;
    oc:severityLevel "HIGH" .

oc:kn_69cd4e98 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When processing more than one image at a time" ;
    oc:directiveContent "Use ThreadPoolExecutor with configurable max_workers for batch OCR processing of multiple images to parallelize work." ;
    oc:hasRationale "OCR is CPU/GPU-intensive; parallelizing across images significantly reduces total processing time for batch workloads" ;
    oc:severityLevel "LOW" .

oc:kn_72097929 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assessing OCR suitability for a given document" ;
    oc:directiveContent "Handwritten text accuracy varies significantly, very small text may not be detected, and complex backgrounds reduce accuracy. GPU is recommended for production workloads." ;
    oc:hasRationale "These are fundamental limitations of PaddleOCR that affect output quality and should inform expectations" ;
    oc:severityLevel "HIGH" .

oc:kn_7dfa5cbb a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing low-quality or noisy images for OCR" ;
    oc:directiveContent "Preprocess images before OCR by converting to grayscale, enhancing contrast, and applying sharpening to improve extraction accuracy." ;
    oc:hasRationale "Preprocessing significantly improves OCR accuracy on suboptimal source material by reducing noise and enhancing text contrast" ;
    oc:severityLevel "MEDIUM" .

oc:kn_8f5c43ff a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reconstructing readable text from OCR bounding box results" ;
    oc:directiveContent "Sort extracted text by spatial position (top-to-bottom, left-to-right) and group into logical lines using a Y-coordinate threshold to reconstruct document layout." ;
    oc:hasRationale "OCR engines return text in detection order, not reading order. Position-based sorting is essential for coherent text reconstruction" ;
    oc:severityLevel "MEDIUM" .

oc:payload_8f176a44fed147fc a oc:ExecutionPayload ;
    oc:code """from paddleocr import PaddleOCR
ocr = PaddleOCR(use_angle_cls=True, lang='en')
result = ocr.ocr('image.png', cls=True)""" ;
    oc:executor "python" ;
    oc:timeout 60 .

