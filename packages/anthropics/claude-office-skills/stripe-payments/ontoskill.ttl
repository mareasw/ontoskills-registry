        oc:skill_saas_metrics,
        oc:skill_subscription_management ;
    oc:differentia "automates Stripe payment processing, subscription lifecycle management, invoicing, dunning, fraud prevention, and revenue analytics" ;
    oc:handlesFailure oc:InvalidInput,
        oc:NetworkTimeout,
        oc:PaymentFailed,
        oc:PermissionDenied ;
    oc:hasAlias "billing",
        "payments",
        "stripe",
        "stripe-automation" ;
    oc:hasAllowedTool "stripe_charges",
        "stripe_customers",
        "stripe_invoices",
        "stripe_subscriptions" ;
    oc:hasArgumentHint "payment or subscription operation (e.g., 'create subscription', 'process payment', 'issue refund', 'dunning report')" ;
    oc:hasCategory "finance" ;
    oc:hasDescription "Automate Stripe payment processing, subscription management, invoicing, and financial reporting" ;
    oc:hasName "stripe-payments" ;
    oc:hasPackageName "stripe-payments" ;
