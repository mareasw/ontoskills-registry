oc:kn_0eb96e30 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When integrating checkout or payment collection flows" ;
    oc:directiveContent "Always use Stripe Elements (Payment Element, Card Element) for collecting card details rather than handling raw card data" ;
    oc:hasRationale "Using Stripe Elements ensures PCI DSS compliance by keeping sensitive card data off your servers" ;
    oc:severityLevel "CRITICAL" .

oc:kn_18be836a a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When designing webhook event handlers" ;
    oc:directiveContent "Webhook handlers trigger downstream actions (order fulfillment, CRM updates, email sends, access provisioning) that are not easily reversible" ;
    oc:hasRationale "Understanding the cascade of side effects from payment events is critical for designing idempotent and resilient handlers" ;
    oc:severityLevel "MEDIUM" .

oc:kn_a1cc363b a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When processing any payment or charge" ;
    oc:directiveContent "Always use idempotency keys when creating charges or payment intents to prevent duplicate transactions" ;
    oc:hasRationale "Duplicate charges create customer disputes, refund processing overhead, and compliance issues" ;
    oc:severityLevel "CRITICAL" .

oc:kn_b56e321e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building payment confirmation flows" ;
    oc:directiveContent "Never rely solely on redirect URLs to confirm payment success; always verify via webhook events" ;
    oc:hasRationale "Redirects can be spoofed or missed; webhooks provide reliable, verifiable payment state changes" ;
    oc:severityLevel "HIGH" .

oc:kn_bdc265b2 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring failed payment recovery workflows" ;
    oc:directiveContent "Implement a multi-step dunning sequence (0, 3, 7, 14, 30 days) with escalating communication channels (email → SMS → final notice → cancellation)" ;
    oc:hasRationale "Progressive dunning recovers a significant portion of failed payments before requiring cancellation, protecting revenue" ;
    oc:severityLevel "MEDIUM" .

oc:kn_cc8b4c9f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before any production deployment of payment flows" ;
    oc:directiveContent "Always validate workflows in Stripe test mode before deploying to production, using test cards and webhook endpoints" ;
    oc:hasRationale "Payment bugs in production can cause real financial harm; test mode catches integration errors safely" ;
    oc:severityLevel "HIGH" .

oc:kn_ed674e9e a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When setting up fraud prevention" ;
    oc:directiveContent "Configure Stripe Radar rules to block highest-risk transactions, review elevated-risk ones, and flag velocity anomalies like card/IP country mismatches" ;
    oc:hasRationale "Payment fraud results in chargebacks, dispute fees, and potential account termination by Stripe" ;
    oc:severityLevel "HIGH" .

oc:kn_fa9bd48f a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When upgrading or downgrading subscription plans" ;
    oc:directiveContent "Subscription proration behavior must be explicitly configured (create_prorations vs none) to avoid unexpected mid-cycle charges or credits" ;
    oc:hasRationale "Default proration behavior may not align with business expectations, leading to billing surprises and customer complaints" ;
    oc:severityLevel "MEDIUM" .

