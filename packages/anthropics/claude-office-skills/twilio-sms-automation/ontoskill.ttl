    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/twilio-sms-automation" ;
    oc:contentHash "e8a0abab0de906fad83d83e57965db127880e3a4d4ea064c6a094a4788d247f5" ;
    oc:differentia "Automates SMS, voice, and verification workflows using Twilio APIs with message templates, two-way messaging, bulk campaigns, and compliance management" ;
