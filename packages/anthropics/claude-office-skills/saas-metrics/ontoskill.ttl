    oc:nature "Concept" ;
    oc:requiresState oc:DataAvailable ;
    oc:resolvesIntent "analyze MRR and ARR",
        "analyze SaaS segmentation",
        "build cohort analysis",
        "calculate SaaS metrics",
        "compute unit economics LTV CAC",
        "forecast SaaS revenue",
        "generate investor metrics report",
        "measure churn and retention" ;
    oc:yieldsState oc:MetricsComputed,
