        oc:Skill ;
    dcterms:identifier "saas-metrics" ;
    skos:broader "SaaS business metrics analysis framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/saas-metrics" ;
    oc:contentHash "ffec547c893333a927c1b78411abe73d11a44b888ca6460bca3ca50a01e9a04e" ;
    oc:differentia "provides structured calculation templates, benchmarks, cohort analysis, and investor reporting for MRR, ARR, Churn, LTV, CAC, and unit economics" ;
    oc:extends oc:skill_financial_modeling ;
    oc:handlesFailure oc:InsufficientData,
        oc:InvalidInput ;
    oc:hasArgumentHint "company metrics data or request for specific SaaS metric calculation" ;
    oc:hasCategory "finance" ;
    oc:hasDescription "SaaS business metrics analysis - MRR, ARR, Churn, LTV, CAC, cohort analysis, and investor reporting" ;
    oc:hasName "saas-metrics" ;
    oc:impartsKnowledge oc:kn_4e58f72c,
        oc:kn_6df197d0,
        oc:kn_960b227c,
        oc:kn_a34d62ac,
        oc:kn_edfef732 ;
