oc:skill_anthropics_claude_office_skills_zendesk_automation a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "zendesk-automation" ;
    skos:broader "Customer support automation framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/zendesk-automation" ;
    oc:contentHash "9203028843ba813461d32c78814ff25bb23f861e5c21a70ddfedbfd315e9863c" ;
    oc:dependsOnSkill oc:skill_slack_workflows ;
    oc:differentia "Provides Zendesk-specific ticket triage, routing, SLA management, auto-response, sentiment analysis, and analytics workflows for helpdesk operations" ;
    oc:handlesFailure oc:InvalidInput,
        oc:NetworkTimeout,
        oc:PermissionDenied ;
    oc:hasArgumentHint "ticket data, routing rules, or SLA configuration" ;
    oc:hasCategory "automation" ;
    oc:hasDescription "Automate customer support workflows with Zendesk ticket management, routing, and analytics" ;
    oc:hasName "zendesk-automation" ;
    oc:hasPackageName "zendesk-automation" ;
    oc:impartsKnowledge oc:kn_0b548971,
        oc:kn_1a745283,
        oc:kn_2be35b91,
        oc:kn_852049bf,
        oc:kn_ca707ff4 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:APIKeySet,
        oc:EnvironmentReady ;
    oc:resolvesIntent "analyze support metrics and agent performance",
        "automate zendesk ticket triage and routing",
        "configure zendesk macros and bulk operations",
        "generate auto-responses for common support issues",
        "integrate zendesk with slack and jira",
        "manage SLA policies and monitor breaches" ;
    oc:yieldsState oc:SLAPoliciesConfigured,
        oc:SupportMetricsReported,
        oc:TicketsTriaged .

oc:kn_0b548971 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing bulk operations or escalations" ;
    oc:directiveContent "Never close stale tickets without adding a comment explaining the auto-closure and inviting the customer to reopen. Never escalate tickets without adding internal notes documenting the reason." ;
    oc:hasRationale "Silent ticket closures damage customer trust and generate complaints. Undocumented escalations lose context and slow resolution." ;
    oc:severityLevel "HIGH" .

oc:kn_1a745283 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring or evaluating SLA policies" ;
    oc:directiveContent "SLA targets must be differentiated by customer tier (Enterprise, Business, Standard) and priority level (urgent, high, normal). Enterprise critical issues require 15-minute first reply and 4-hour resolution." ;
    oc:hasRationale "Tiered SLAs reflect contractual obligations and ensure high-value customers receive priority attention." ;
    oc:severityLevel "CRITICAL" .

oc:kn_2be35b91 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating auto-responses or applying macros" ;
    oc:directiveContent "Personalize templated auto-responses and macro outputs rather than sending generic messages. Use customer name, order details, and contextual variables in responses." ;
    oc:hasRationale "Personalized responses improve CSAT scores and reduce follow-up tickets while maintaining automation efficiency." ;
    oc:severityLevel "MEDIUM" .

oc:kn_852049bf a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When AI-powered sentiment analysis or intent detection triggers actions" ;
    oc:directiveContent "Negative sentiment detection automatically increases ticket priority (+1), tags the ticket, and notifies the team lead. Cancellation intent detection routes to the retention team at high priority." ;
    oc:hasRationale "Automated priority escalation for negative sentiment prevents churn, while cancellation routing to retention specialists maximizes save rates." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ca707ff4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing incoming Zendesk tickets" ;
    oc:directiveContent "Route tickets through a structured triage pipeline: AI analysis (intent, sentiment, urgency) → categorization (type, product, skill needed) → routing & assignment (team, agent, priority) → auto-response if applicable." ;
    oc:hasRationale "Structured triage ensures consistent handling, reduces manual effort, and prevents tickets from falling through cracks." ;
    oc:severityLevel "HIGH" .

