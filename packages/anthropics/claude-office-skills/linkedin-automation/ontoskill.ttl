oc:kn_019f1459 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before executing any LinkedIn automation workflow" ;
    oc:directiveContent "Verify the social-mcp server is connected with valid LinkedIn credentials and that daily outreach limits have not been exceeded before initiating any campaign." ;
    oc:hasRationale "LinkedIn enforces strict daily limits on connections and messages; exceeding these triggers rate limits or account suspension." ;
    oc:severityLevel "HIGH" .

oc:kn_1783f31b a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When managing LinkedIn lead lists and prioritizing outreach" ;
    oc:directiveContent "Score leads on a composite of profile completeness, engagement behavior, and ICP fit before initiating outreach — hot leads (>75) get immediate follow-up, warm (50-75) get nurtured, cold (<50) are deprioritized." ;
    oc:hasRationale "Tiered lead scoring prevents wasting outreach quota on low-fit prospects and focuses effort on high-conversion opportunities." ;
    oc:severityLevel "MEDIUM" .

oc:kn_331e54ff a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When executing any automated LinkedIn action" ;
    oc:directiveContent "All outreach actions (connection requests, messages, comments) create permanent LinkedIn activity traces tied to the authenticated account and may affect account reputation scores." ;
    oc:hasRationale "LinkedIn monitors automated behavior patterns; excessive or poorly-timed automation can lead to account restrictions or bans." ;
    oc:severityLevel "CRITICAL" .

oc:kn_55652ac1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating LinkedIn post content" ;
    oc:directiveContent "Post content must use strong hooks on the first line — the first 210 characters determine whether the post is truncated in feeds." ;
    oc:hasRationale "LinkedIn's feed algorithm truncates posts after ~210 characters; the hook determines whether users click 'see more', directly impacting engagement rates." ;
    oc:severityLevel "MEDIUM" .

oc:kn_683e36fc a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scheduling LinkedIn content for individuals or company pages" ;
    oc:directiveContent "Optimal posting frequency is 3-5 times per week, targeting Tuesday through Thursday at 08:00, 12:00, or 17:30." ;
    oc:hasRationale "B2B audiences are most active mid-week during business hours; consistency signals algorithm favorability." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7df597e0 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing LinkedIn outreach or message sequences" ;
    oc:directiveContent "Lead outreach sequences must include wait periods (2-5 days between messages) and value-add steps before any ask." ;
    oc:hasRationale "LinkedIn's Terms of Service penalize aggressive outreach; staged sequences with delays build trust and reduce connection rejection rates." ;
    oc:severityLevel "HIGH" .

oc:kn_964adf65 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When automating engagement or comment responses on LinkedIn" ;
    oc:directiveContent "Never use generic or copy-pasted comments for engagement — LinkedIn's algorithm and users penalize inauthentic interaction." ;
    oc:hasRationale "Generic comments damage credibility and can trigger LinkedIn's spam detection, potentially resulting in account restrictions." ;
    oc:severityLevel "HIGH" .

