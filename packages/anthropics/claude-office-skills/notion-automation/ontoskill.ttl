oc:skill_anthropics_claude_office_skills_notion_automation a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "notion-automation" ;
    skos:broader "Automation skill" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/notion-automation" ;
    oc:contentHash "e002e983d48203c872ebfc9093c2757303b8c74c96f0d96ace67ff28b27b974d" ;
    oc:differentia "Automates Notion database workflows with cross-platform integrations, templates, triggers, and bidirectional sync patterns" ;
    oc:handlesFailure oc:APIKeySet,
        oc:NetworkTimeout,
        oc:PermissionDenied ;
    oc:hasArgumentHint "workflow description or Notion database name (e.g., \"set up content calendar automation\", \"sync Notion with Slack tasks\")" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Notion database automation - sync, templates, workflows, and cross-platform integrations" ;
    oc:hasName "notion-automation" ;
    oc:impartsKnowledge oc:kn_5e979f5b,
        oc:kn_67e671b2,
        oc:kn_849e74ce,
