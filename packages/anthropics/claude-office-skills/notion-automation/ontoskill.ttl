        oc:kn_d1c6da10,
        oc:kn_e6a4955b,
        oc:kn_e7736111,
        oc:kn_f0195826 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:APIKeySet,
        oc:NetworkAvailable,
        oc:SystemAuthenticated ;
    oc:resolvesIntent "automate notion databases",
        "build cross-platform integrations with notion",
        "configure bidirectional calendar sync with notion",
        "create notion pages from forms or triggers",
        "create notion workflow automations",
        "generate email digests from notion data",
        "set up notion database templates",
