@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_office_skills_office_to_md a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "office-to-md" ;
    skos:broader "format converter" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/office-to-md" ;
    oc:contentHash "45527f6cea8286219e710d4a2340344d7c4f9430665cb62c282d00ab6f379ed2" ;
    oc:differentia "that transforms Office documents (DOCX, XLSX, PPTX, PDF, HTML, images) into Markdown using Microsoft's markitdown library" ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput ;
    oc:hasAllowedTool "Bash" ;
    oc:hasArgumentHint "file-path to Office document (DOCX, XLSX, PPTX, PDF, HTML, images)" ;
    oc:hasCategory "document" ;
    oc:hasDescription ">" ;
    oc:hasName "office-to-md" ;
    oc:hasRequirement oc:req_0fa5fa1a,
        oc:req_310092fb,
        oc:req_4eb6a902,
        oc:req_fd962409 ;
    oc:impartsKnowledge oc:kn_13cd0498,
        oc:kn_3a6d20d5,
        oc:kn_7b3a3cc6,
        oc:kn_e4ec9c6a,
        oc:kn_e5550f3a ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:FileExists,
        oc:ToolInstalled ;
    oc:resolvesIntent "batch convert Office files to Markdown",
        "convert Excel spreadsheets to Markdown tables",
        "convert PowerPoint presentations to Markdown notes",
        "convert Word documents to Markdown",
        "create AI-ready document corpus from Office files",
        "extract text from PDFs as Markdown" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_13cd0498 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting documents containing images (JPG, PNG, or embedded images in Office files)" ;
    oc:directiveContent "Images are not embedded in output Markdown; use a vision model (LLM client) for image description when image content matters." ;
    oc:hasRationale "Markdown cannot embed binary images; markitdown can optionally use an LLM to describe images" ;
    oc:severityLevel "MEDIUM" .

oc:kn_3a6d20d5 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When setting up the markitdown tool for the first time" ;
    oc:directiveContent "Use pip install markitdown[all] for full feature support including image OCR and audio transcription, or install specific extras as needed." ;
    oc:hasRationale "Base installation only covers core document formats; optional dependencies enable image and audio processing" ;
    oc:severityLevel "LOW" .

oc:kn_7b3a3cc6 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "After any conversion operation" ;
    oc:directiveContent "Always review and validate converted Markdown output for accuracy before using it in production or sharing with stakeholders." ;
    oc:hasRationale "Conversion fidelity varies by document complexity; manual review catches formatting artifacts or data loss" ;
    oc:severityLevel "HIGH" .

oc:kn_e4ec9c6a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running bulk conversion of multiple Office documents" ;
    oc:directiveContent "For batch conversions, process files with error handling per-file so a single failure does not stop the entire batch." ;
    oc:hasRationale "Individual file errors (corrupt files, unsupported formats) should not prevent processing of remaining files" ;
    oc:severityLevel "HIGH" .

oc:kn_e5550f3a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting any Office document, especially Word docs with complex layouts" ;
    oc:directiveContent "Do not assume complex formatting is perfectly preserved; tables with merged cells, track changes, and comments may be lost or simplified during conversion." ;
    oc:hasRationale "markitdown simplifies complex formatting to Markdown equivalents, which cannot represent all Office features" ;
    oc:severityLevel "MEDIUM" .

oc:req_0fa5fa1a a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "office-mcp MCP server (docx_to_md tool)" .

oc:req_310092fb a oc:RequirementAPI ;
    oc:isOptional true ;
    oc:requirementValue "anthropic client (optional, for image/audio processing with vision model)" .

oc:req_4eb6a902 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "Python 3.x" .

oc:req_fd962409 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "markitdown (pip install markitdown)" .

