@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_office_skills_email_classifier a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "email-classifier" ;
    skos:broader "Classification framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/email-classifier" ;
    oc:contentHash "54c269836b40931539b0b2c4fced15820f69b3327b463d18972fa9a426327353" ;
    oc:differentia "that categorizes emails by type, priority, and required action using structured taxonomies and custom rules" ;
    oc:handlesFailure oc:InsufficientContext,
        oc:InvalidInput ;
    oc:hasArgumentHint "email content or list of emails to classify" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Automatically categorize emails by type, priority, and required action" ;
    oc:hasName "email-classifier" ;
    oc:impartsKnowledge oc:kn_0cd1a99d,
        oc:kn_25b71dee,
        oc:kn_630b387b,
        oc:kn_98836ced,
        oc:kn_c0ab8ce6 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EmailContentProvided ;
    oc:resolvesIntent "batch process multiple emails with sorting",
        "classify emails by category and priority",
        "create custom email classification rules",
        "detect spam and phishing indicators",
        "organize inbox by urgency and action required" ;
    oc:yieldsState oc:EmailsClassified,
        oc:PriorityAssigned .

oc:kn_0cd1a99d a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When classifying any email" ;
    oc:directiveContent "Use the 6-category primary classification system: Action Required, FYI, Waiting, Delegated, Archive, Delete — each email must map to exactly one primary category." ;
    oc:hasRationale "A consistent primary taxonomy ensures predictable inbox organization and prevents misclassification." ;
    oc:severityLevel "HIGH" .

oc:kn_25b71dee a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating emails for spam or phishing indicators" ;
    oc:directiveContent "Do not assume the skill can detect phishing with certainty — always flag suspicious emails for human review rather than making a definitive safe/unsafe judgment." ;
    oc:hasRationale "Phishing detection is probabilistic and the skill cannot access email headers or sender authentication data, so false negatives are possible." ;
    oc:severityLevel "CRITICAL" .

oc:kn_630b387b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When batch-processing a set of classified emails" ;
    oc:directiveContent "Process emails in priority order: Urgent first, then High, then quick wins under 2 minutes, before moving to Normal and Low priority items." ;
    oc:hasRationale "Tackling urgent and time-sensitive items first minimizes risk of missed deadlines, while quick wins reduce backlog volume efficiently." ;
    oc:severityLevel "MEDIUM" .

oc:kn_98836ced a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up or refining the classification system" ;
    oc:directiveContent "Allow users to define custom VIP senders, auto-archive rules, auto-delegate targets, and red-flag keywords to tailor classification to their specific workflow." ;
    oc:hasRationale "Generic classification rules cannot capture organizational hierarchies, key client relationships, or team-specific delegation patterns that determine true priority." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c0ab8ce6 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When classifying emails from long or ongoing threads" ;
    oc:directiveContent "Classification accuracy degrades without thread context — the skill only sees the content provided and cannot access email accounts, prior messages, or conversation history." ;
    oc:hasRationale "Missing thread context can lead to misclassification of follow-up emails as FYI when they actually require action based on prior commitments." ;
    oc:severityLevel "HIGH" .

