@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_office_skills_ai_slides a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "ai-slides" ;
    skos:broader "Presentation generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/ai-slides" ;
    oc:contentHash "67c0bdaceba1cd3bc6831b7ef3aee6770a46c28f7401c026c57e88dfb0227fdb" ;
    oc:dependsOnSkill oc:skill_office_mcp ;
    oc:differentia "Generates complete presentations from a topic or outline using AI-powered content generation with Marp markdown formatting" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasAllowedTool "add_slide",
        "create_pptx" ;
    oc:hasArgumentHint "topic or outline, audience, slide count (e.g., 'Create a 10-slide presentation about machine learning for executives')" ;
    oc:hasCategory "document" ;
    oc:hasDescription "Generate complete presentations with AI - from outline to polished slides" ;
    oc:hasName "ai-slides" ;
    oc:impartsKnowledge oc:kn_0a55936b,
        oc:kn_4e2c1d9d,
        oc:kn_4fee7bbf,
        oc:kn_731ca162,
        oc:kn_7579ff84 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "build training slides",
        "create presentation from topic",
        "create slide deck from outline",
        "generate pitch deck",
        "make quarterly review presentation" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_0a55936b a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When authoring slide content" ;
    oc:directiveContent "Apply the 6x6 rule: maximum 6 bullets per slide, approximately 6 words per bullet. Keep one idea per slide to maintain focus." ;
    oc:hasRationale "Overloaded slides cause cognitive overload and reduce comprehension. The 6x6 rule ensures readability and audience focus on the speaker." ;
    oc:severityLevel "MEDIUM" .

oc:kn_4e2c1d9d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any presentation" ;
    oc:directiveContent "Follow the standard presentation structure: title slide, agenda, introduction (with hook), 3-5 main content sections (60% of slides), conclusion with key takeaways, and closing with Q&A prompt." ;
    oc:hasRationale "Proven presentation structure maximizes audience engagement and information retention by providing clear narrative flow from opening hook through closing call-to-action." ;
    oc:severityLevel "HIGH" .

oc:kn_4fee7bbf a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When expanding sections into slide content" ;
    oc:directiveContent "Tailor content complexity, examples, and terminology to the specified audience. Always include visual suggestions (images, diagrams, tables) for content-heavy slides." ;
    oc:hasRationale "Audience-appropriate content ensures the presentation resonates, while visuals compensate for text density and improve recall." ;
    oc:severityLevel "MEDIUM" .

oc:kn_731ca162 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When regenerating or iterating on presentations" ;
    oc:directiveContent "Generating a presentation from the same topic and parameters should produce equivalent structural output (title, agenda, content, summary, closing), though prose may vary." ;
    oc:hasRationale "Consistent structural output allows users to iterate on content without losing presentation architecture." ;
    oc:severityLevel "LOW" .

oc:kn_7579ff84 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When using MCP tool integration" ;
    oc:directiveContent "This skill outputs Marp-formatted markdown which can be converted to PPTX via MCP tools (create_pptx, add_slide). The skill does not directly create binary files." ;
    oc:hasRationale "Understanding the output format is essential for proper tool chain usage — Marp markdown serves as the intermediate representation before final PPTX generation." ;
    oc:severityLevel "MEDIUM" .

