oc:skill_anthropics_claude_office_skills_apple_shortcuts_integration a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "apple-shortcuts-integration" ;
    skos:broader "Apple ecosystem integration skill" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/apple-shortcuts-integration" ;
    oc:contentHash "55d5027698c2da00f9256c5ae47b65255460a53cfefbaf0ef5ab19ed0cb9745c" ;
    oc:dependsOnSkill oc:skill_calendar_automation ;
    oc:differentia "creates and triggers Apple Shortcuts, manages Reminders, Notes, and Calendar events via the apple-mcp MCP server for iOS/macOS automation and cross-platform workflows" ;
    oc:handlesFailure oc:InvalidInput,
        oc:NetworkTimeout,
        oc:PermissionDenied,
        oc:ShortcutNotFound ;
    oc:hasArgumentHint "shortcut name or action (e.g., 'run Morning Routine', 'create reminder', 'create note')" ;
    oc:hasCategory "automation" ;
    oc:hasDescription "Create and trigger Apple Shortcuts for iOS/macOS automation and cross-platform workflows" ;
    oc:hasName "apple-shortcuts-integration" ;
    oc:hasRequirement oc:req_2566f713,
        oc:req_5fb72c3a,
        oc:req_7f7e4516,
        oc:req_8aea7e8b,
        oc:req_96f3a6cb,
        oc:req_b8b3e596 ;
    oc:impartsKnowledge oc:kn_56382969,
        oc:kn_9b2f17df,
        oc:kn_9eac74af,
        oc:kn_a5bc6398,
        oc:kn_dc2c057b ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:NetworkAvailable,
        oc:SystemAuthenticated ;
    oc:resolvesIntent "automate iOS and macOS workflows",
        "create Apple Notes",
        "create Apple Reminders",
        "manage Calendar events",
        "run Apple Shortcuts",
        "sync data across Apple and third-party apps" ;
    oc:yieldsState oc:CalendarEventCreated,
        oc:NoteCreated,
        oc:ReminderCreated,
        oc:ShortcutExecuted .

oc:kn_56382969 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "Before deploying shortcuts to production workflows" ;
    oc:directiveContent "Shortcuts must be tested on all target devices (iPhone, iPad, Mac) as behavior can differ across platforms." ;
    oc:hasRationale "Apple Shortcuts runtime behavior varies across iOS, iPadOS, and macOS; actions available on one platform may not exist on another." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9b2f17df a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When creating shortcuts that handle personal data (notes, reminders, calendar events)" ;
    oc:directiveContent "Minimize data exposure in shortcuts — only pass necessary information and avoid logging sensitive content." ;
    oc:hasRationale "Shortcuts may sync across iCloud and multiple devices, increasing the attack surface for personal data." ;
    oc:severityLevel "HIGH" .

oc:kn_9eac74af a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building or chaining Apple Shortcuts workflows" ;
    oc:directiveContent "Design shortcuts with graceful failure handling — catch errors and provide meaningful feedback rather than silently failing." ;
    oc:hasRationale "Apple Shortcuts can fail across device boundaries; graceful handling ensures users know what happened." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a5bc6398 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating or referencing Apple Shortcuts" ;
    oc:directiveContent "Use clear, descriptive shortcut names that convey purpose at a glance." ;
    oc:hasRationale "Descriptive naming prevents confusion when managing many shortcuts across iOS and macOS devices." ;
    oc:severityLevel "MEDIUM" .

oc:kn_dc2c057b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running shortcuts with dynamic input" ;
    oc:directiveContent "Always validate inputs before passing them to shortcuts, especially text parameters and date/time values." ;
    oc:hasRationale "Invalid inputs can cause silent failures or unexpected behavior in the Apple Shortcuts runtime." ;
    oc:severityLevel "HIGH" .

oc:req_2566f713 a oc:RequirementAPI ;
    oc:isOptional false ;
    oc:requirementValue "apple-mcp MCP server" .

oc:req_5fb72c3a a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Apple Shortcuts naming conventions and structure" .

