@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_brand_brand_guidelines_starter a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "brand-guidelines-starter" ;
    skos:broader "brand guidelines document" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/nextlevel-builder/ui-ux-pro-max-skill/ckm-brand" ;
    oc:contentHash "d157a57b15f0b458c79636d11de42f3c89f03d8c0bbea1bdd3cf1c3542b2140d" ;
    oc:differentia "provides a comprehensive starter template with color palette, typography, logo rules, voice & tone, imagery, and design component specs for bootstrapping new brand identities" ;
    oc:extends oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_brand ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "[brand-name]" ;
    oc:hasCategory "document" ;
    oc:hasPackageName "nextlevel-builder" ;
    oc:impartsKnowledge oc:kn_1784f2b2,
        oc:kn_1b35a5c2,
        oc:kn_2ef7c7d5,
        oc:kn_449da5a7,
        oc:kn_78939c19 ;
    oc:isUserInvocable true ;
    oc:nature "template" ;
    oc:requiresState oc:DirectoryWritable ;
    oc:resolvesIntent "bootstrap brand identity",
        "create brand guidelines",
        "establish visual style guide",
        "generate brand specification document" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_1784f2b2 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any brand-aligned content or reviewing copy for tone consistency" ;
    oc:directiveContent "Use the brand voice chart as the primary decision filter: content should be professional (not stuffy), helpful (not patronizing), clear (not vague), and confident (not arrogant). Adjust tone by context—engaging for marketing, instructional for docs, calm for errors, brief for success." ;
    oc:hasRationale "The voice chart provides concrete guardrails that prevent tone drift while allowing contextual flexibility." ;
    oc:severityLevel "HIGH" .

oc:kn_1b35a5c2 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating or validating color choices in any brand context" ;
    oc:directiveContent "Always enforce WCAG 2.1 AA contrast ratios for all interactive elements and text/background combinations; primary blue on white must achieve at least 4.6:1." ;
    oc:hasRationale "Accessibility compliance is non-negotiable for brand credibility and legal compliance; poor contrast excludes users with visual impairments." ;
    oc:severityLevel "CRITICAL" .

oc:kn_2ef7c7d5 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When building UI components or designing layouts under this brand" ;
    oc:directiveContent "Use the defined spacing scale (4px/8px/16px/24px/32px/48px) and border radius tokens (buttons 8px, cards 12px, inputs 8px, modals 16px, pills 9999px) consistently across all design components." ;
    oc:hasRationale "Consistent spacing and radius tokens create visual harmony and a cohesive brand experience across all touchpoints." ;
    oc:severityLevel "MEDIUM" .

oc:kn_449da5a7 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any branded copy, marketing materials, or UI text" ;
    oc:directiveContent "Never use prohibited terms (revolutionary, best-in-class, seamless, synergy, leverage) in any branded content; use simple direct alternatives like 'use' instead of 'leverage'." ;
    oc:hasRationale "Overused and vague terms undermine brand credibility and make copy sound generic rather than differentiated." ;
    oc:severityLevel "MEDIUM" .

oc:kn_78939c19 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When rendering or placing the brand logo in any asset" ;
    oc:directiveContent "Logo must never be rotated, skewed, recolored outside the approved palette, given shadows/effects, cropped, or placed on busy backgrounds without sufficient contrast." ;
    oc:hasRationale "Logo misuse degrades brand recognition and violates the integrity of the visual identity system." ;
    oc:severityLevel "HIGH" .

