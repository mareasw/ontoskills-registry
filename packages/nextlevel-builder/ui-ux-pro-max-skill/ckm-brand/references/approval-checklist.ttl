@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_brand_approval_checklist a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "approval-checklist" ;
    skos:broader "Quality assurance checklist" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/nextlevel-builder/ui-ux-pro-max-skill/ckm-brand" ;
    oc:contentHash "4bf8549687f53a7b9684005b4b87de93c26f018e00609b4c506a5812abd13d20" ;
    oc:differentia "that governs the systematic review and approval of marketing assets against brand, accessibility, content, technical, and legal compliance standards" ;
    oc:extends oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_brand ;
    oc:handlesFailure oc:AccessibilityNonCompliant,
        oc:BrandViolationDetected,
        oc:LegalIssueFound ;
    oc:hasArgumentHint "asset-path or asset description to review" ;
    oc:hasCategory "marketing" ;
    oc:impartsKnowledge oc:kn_4ce70610,
        oc:kn_66d56408,
        oc:kn_886c5aa6,
        oc:kn_ad2925e1,
        oc:kn_d781b5e7 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:AssetReadyForReview,
        oc:BrandGuidelinesAvailable ;
    oc:resolvesIntent "audit visual elements against brand guidelines",
        "check accessibility standards for marketing materials",
        "review marketing assets for approval",
        "sign off on creative assets before publication",
        "validate brand compliance of creative assets" ;
    oc:yieldsState oc:AssetApproved,
        oc:AssetArchived,
        oc:AssetReviewed .

oc:kn_4ce70610 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning any asset review process" ;
    oc:directiveContent "Before detailed review, confirm the asset serves its stated purpose, targets the correct audience, has no obvious errors, and aligns with campaign goals." ;
    oc:hasRationale "Quick triage prevents wasting time on assets that fundamentally miss the mark before investing in detailed compliance checking" ;
    oc:severityLevel "HIGH" .

oc:kn_66d56408 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When automated validation is available for the asset type" ;
    oc:directiveContent "Use the validate-asset.cjs script for automated checking of color palette compliance, minimum dimensions, file format/size, naming conventions, and basic metadata before manual review." ;
    oc:hasRationale "Automated pre-screening catches mechanical issues faster and frees human reviewers to focus on subjective quality criteria" ;
    oc:severityLevel "MEDIUM" .

oc:kn_886c5aa6 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing color compliance of any marketing asset" ;
    oc:directiveContent "Apply the 60/30/10 ratio for primary/secondary/accent brand colors to maintain visual hierarchy and brand consistency across all assets." ;
    oc:hasRationale "Consistent color ratios ensure brand recognition and visual coherence across all touchpoints" ;
    oc:severityLevel "HIGH" .

oc:kn_ad2925e1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "During legal and compliance review of marketing assets" ;
    oc:directiveContent "Never approve assets with unlicensed stock imagery, uncleared audio, trademark violations, or missing required regulatory disclosures." ;
    oc:hasRationale "IP and regulatory violations can result in costly litigation, brand damage, and mandatory asset takedowns" ;
    oc:severityLevel "CRITICAL" .

oc:kn_d781b5e7 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, during visual accessibility review of any asset" ;
    oc:directiveContent "Text contrast ratio must be at least 4.5:1 (AA standard) for normal text and 3:1 for large text. Color must never be the sole indicator of meaning." ;
    oc:hasRationale "WCAG AA compliance is a legal and ethical requirement; failing it excludes users with visual impairments and creates liability" ;
    oc:severityLevel "CRITICAL" .

