@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_brand_messaging_framework a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "messaging-framework" ;
    skos:broader "brand messaging template" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/nextlevel-builder/ui-ux-pro-max-skill/ckm-brand" ;
    oc:contentHash "24b2500a72867b55dd10f4bf359178b0eb347fddd852659ce47b69d9f597d4e6" ;
    oc:differentia "structures brand communication from mission through proof points with audience-specific messaging and pitch scaffolds" ;
    oc:extends oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_brand ;
    oc:handlesFailure oc:InconsistentMessaging,
        oc:InsufficientBrandInput ;
    oc:hasArgumentHint "brand name, target audience, product/service description" ;
    oc:hasCategory "marketing" ;
    oc:hasRequirement oc:req_c40ededd ;
    oc:impartsKnowledge oc:kn_1883a010,
        oc:kn_a6e07f31,
        oc:kn_c4cb9fc6,
        oc:kn_cc272234,
        oc:kn_d18abd40 ;
    oc:isUserInvocable true ;
    oc:nature "concept" ;
    oc:requiresState oc:BrandIdentityDefined ;
    oc:resolvesIntent "craft value proposition",
        "create messaging framework",
        "define brand positioning",
        "develop elevator pitches",
        "map messages to audience segments" ;
    oc:yieldsState oc:MessagingFrameworkCreated .

oc:kn_1883a010 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When finalizing any message or statement in the framework" ;
    oc:directiveContent "Validate every key message against the 5-point test: clear (no jargon), differentiated (competitors can't say it), credible (provable), compelling (audience cares), consistent (aligns with brand)." ;
    oc:hasRationale "Messages that fail any of these five checks will either confuse, underwhelm, lack trust, miss relevance, or dilute brand identity." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a6e07f31 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When defining messaging for multi-segment brands" ;
    oc:directiveContent "Map distinct messages, pain points, and calls-to-action to each audience segment rather than using a single universal message." ;
    oc:hasRationale "Different audience segments have different pain points and motivations; segment-specific messaging dramatically increases conversion and resonance." ;
    oc:severityLevel "HIGH" .

oc:kn_c4cb9fc6 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting positioning or value proposition statements" ;
    oc:directiveContent "Never write a positioning statement that competitors could truthfully claim about themselves — always include a unique differentiator." ;
    oc:hasRationale "Generic positioning fails to give prospects a reason to choose your brand over alternatives, making marketing spend inefficient." ;
    oc:severityLevel "CRITICAL" .

oc:kn_cc272234 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating or auditing any brand messaging framework" ;
    oc:directiveContent "Build the messaging framework top-down: Mission → Vision → Value Proposition → Positioning → Key Messages → Proof Points, ensuring each layer logically supports the one above." ;
    oc:hasRationale "A hierarchical structure ensures internal consistency — every key message traces back to the mission, preventing mixed or contradictory brand signals." ;
    oc:severityLevel "HIGH" .

oc:kn_d18abd40 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When crafting the core value proposition statement" ;
    oc:directiveContent "Always anchor the value proposition with the template structure: target customer → need → category → key benefit → competitor contrast → unique differentiator." ;
    oc:hasRationale "This six-part structure ensures the value proposition is complete and doesn't omit critical competitive context that drives purchase decisions." ;
    oc:severityLevel "MEDIUM" .

oc:req_c40ededd a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Brand voice and identity (from parent skill)" .

