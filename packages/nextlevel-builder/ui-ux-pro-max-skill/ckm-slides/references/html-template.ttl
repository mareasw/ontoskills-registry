@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_slides_html_template a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "html-template" ;
    skos:broader "HTML slide template" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/nextlevel-builder/ui-ux-pro-max-skill/ckm-slides" ;
    oc:contentHash "fd5b051a37365fc6059c75bb388ec6f64daf1bd9ae938b287b6d762dc83c0c35" ;
    oc:differentia "provides the complete base HTML structure with 16:9 responsive layout, Chart.js integration, CSS animation classes, keyboard navigation, and design token support for generating self-contained presentation decks" ;
    oc:extends oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_slides ;
    oc:handlesFailure oc:TemplateRenderingError ;
    oc:hasAllowedTool "Write" ;
    oc:hasArgumentHint "presentation-title, token-values, slide-content" ;
    oc:hasCategory "document" ;
    oc:impartsKnowledge oc:kn_0debed67,
        oc:kn_3fa99876,
        oc:kn_7f5cc7b0,
        oc:kn_dcc5c51c,
        oc:kn_f7b313f9 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DesignTokensReady ;
    oc:resolvesIntent "add charts to slides",
        "animate slide content",
        "apply design tokens to presentation",
        "build responsive presentation deck",
        "create html slide template" ;
    oc:yieldsState oc:SlideTemplateGenerated .

oc:kn_0debed67 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When authoring any slide within the deck" ;
    oc:directiveContent "Always wrap slide content in a .slide-content inner container to enforce safe-area constraints and prevent overflow beyond the 16:9 viewport." ;
    oc:hasRationale "The .slide wrapper uses position:absolute with overflow:hidden; without the inner .slide-content wrapper, text and elements can bleed outside the visible slide area." ;
    oc:severityLevel "HIGH" .

oc:kn_3fa99876 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When programmatically navigating slides via nextSlide/prevSlide or direct showSlide calls" ;
    oc:directiveContent "The showSlide() function clamps to valid range (1–total), so calling it with out-of-bounds indices is safe and idempotent — it will simply stay on the first or last slide." ;
    oc:hasRationale "Boundary clamping prevents runtime errors from invalid slide indices and ensures repeated navigation calls at edges are no-ops." ;
    oc:severityLevel "LOW" .

oc:kn_7f5cc7b0 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When styling any element within the slide template" ;
    oc:directiveContent "Never set fixed pixel dimensions on slide elements — use clamp(), min(), vw/vh units, and media query breakpoints for all typography and spacing." ;
    oc:hasRationale "Fixed dimensions break the responsive scaling across desktop (16:9 locked), tablet (768px), and mobile (480px) breakpoints, causing content overflow or illegible text." ;
    oc:severityLevel "HIGH" .

oc:kn_dcc5c51c a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When adding interactive elements (links, buttons, chart tooltips) inside slides" ;
    oc:directiveContent "The click-to-advance listener fires on ANY click not originating from .nav-controls, which means interactive chart elements and links inside slides will also advance the slide." ;
    oc:hasRationale "The global click listener checks only for .nav-controls ancestry; interactive content needs stopPropagation() or the click handler must be adjusted to avoid unintended navigation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f7b313f9 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When embedding Chart.js charts in any slide" ;
    oc:directiveContent "Chart.js charts must use responsive:true and maintainAspectRatio:false with clamped container dimensions (e.g., width: min(80%, 600px); height: clamp(200px, 40vh, 350px))." ;
    oc:hasRationale "Without explicit constraints, Chart.js will attempt to fill the entire slide area or collapse to zero height, breaking layout on different viewport sizes." ;
    oc:severityLevel "MEDIUM" .

