@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_slides_create a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "create" ;
    skos:broader "Presentation creation command" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/nextlevel-builder/ui-ux-pro-max-skill/ckm-slides" ;
    oc:contentHash "792d647a5d4f87d765cf417f7ac54dd0b2fc4d229cc23ea9df56282d4c1ee086" ;
    oc:differentia "Generates persuasive HTML slides using design tokens, Chart.js, and the slide knowledge database by invoking the parent slides skill" ;
    oc:extends oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_slides ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "Task description for the slides to create (topic, purpose, audience)" ;
    oc:hasCategory "document" ;
    oc:impartsKnowledge oc:kn_6719cac3,
        oc:kn_6e0a04cc,
        oc:kn_aadd38d3,
        oc:kn_c30cd9ab,
        oc:kn_fb828983 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "build persuasive slide deck",
        "create HTML presentation",
        "generate slides with charts" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_6719cac3 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any presentation" ;
    oc:directiveContent "Slides must be generated as HTML with embedded design tokens for consistent visual styling across all slides." ;
    oc:hasRationale "HTML-based slides with design tokens ensure cross-platform compatibility and maintain visual consistency with the broader design system." ;
    oc:severityLevel "HIGH" .

oc:kn_6e0a04cc a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "Before beginning slide generation" ;
    oc:directiveContent "Always query the slide knowledge database for relevant patterns, templates, and copywriting formulas before generating content." ;
    oc:hasRationale "The knowledge database contains proven strategic frameworks and contextual patterns that improve slide persuasiveness and effectiveness." ;
    oc:severityLevel "MEDIUM" .

oc:kn_aadd38d3 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before executing any slide creation task" ;
    oc:directiveContent "Verify that the parent slides skill is available and the design token system is initialized before attempting creation." ;
    oc:hasRationale "This sub-skill delegates to the parent slides skill; if it is not available, the creation will fail silently or produce incomplete output." ;
    oc:severityLevel "CRITICAL" .

oc:kn_c30cd9ab a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When slides contain data, metrics, or quantitative comparisons" ;
    oc:directiveContent "Leverage Chart.js for data visualization slides rather than static images or tables." ;
    oc:hasRationale "Chart.js provides interactive, responsive, and visually appealing data representations that enhance audience engagement." ;
    oc:severityLevel "MEDIUM" .

oc:kn_fb828983 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When receiving a slide creation request" ;
    oc:directiveContent "The $ARGUMENTS task parameter must clearly specify the slide topic, purpose, and target audience for meaningful output." ;
    oc:hasRationale "Vague or missing task descriptions lead to generic, unfocused presentations that fail to persuade or inform the intended audience." ;
    oc:severityLevel "HIGH" .

