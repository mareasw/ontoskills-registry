@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_design_system_tailwind_integration a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "tailwind-integration" ;
    skos:broader "Configuration mapping layer" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/nextlevel-builder/ui-ux-pro-max-skill/ckm-design-system" ;
    oc:contentHash "6d01092db1479dbd2060567b4232bb2b4bc16e89730ab07e1f87a3e7f5c406b9" ;
    oc:differentia "Bridges design system tokens to Tailwind CSS utility classes via CSS custom properties and HSL color format" ;
    oc:extends oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_design_system ;
    oc:handlesFailure oc:InvalidConfigSyntax,
        oc:TokenMappingError ;
    oc:hasAllowedTool "Bash",
        "Edit",
        "Read",
        "Write" ;
    oc:hasArgumentHint "design-token-config" ;
    oc:hasCategory "development" ;
    oc:hasRequirement oc:req_4fb4e4c6,
        oc:req_887dcae8,
        oc:req_aa26ad85,
        oc:req_fa76c1bc ;
    oc:impartsKnowledge oc:kn_3343833c,
        oc:kn_4e0d9ae5,
        oc:kn_5b42771e,
        oc:kn_ad0e5572,
        oc:kn_eb8c6d81 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DesignTokensDefined,
        oc:TailwindInstalled ;
    oc:resolvesIntent "configure tailwind css with design tokens",
        "create component classes from design tokens",
        "integrate shadcn/ui with custom design tokens",
        "map design system colors to tailwind utilities",
        "set up dark mode with css variables" ;
    oc:yieldsState oc:DarkModeReady,
        oc:DesignTokensMapped,
        oc:TailwindConfigured .

oc:kn_3343833c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining semantic color tokens for components" ;
    oc:directiveContent "CSS variable names must follow the shadcn/ui naming convention (e.g., --background, --foreground, --primary, --primary-foreground) to maintain compatibility." ;
    oc:hasRationale "shadcn/ui components expect these exact variable names; deviation breaks automatic theming of all shadcn components." ;
    oc:severityLevel "HIGH" .

oc:kn_4e0d9ae5 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When setting up CSS variables in the base layer" ;
    oc:directiveContent "Define both :root (light) and .dark class variants for every semantic color token to ensure complete dark mode coverage." ;
    oc:hasRationale "Incomplete dark mode token sets cause fallback to light values, creating visual inconsistencies in dark mode." ;
    oc:severityLevel "HIGH" .

oc:kn_5b42771e a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When architecting the design system integration" ;
    oc:directiveContent "Structure the token-to-Tailwind mapping as a three-layer pipeline: primitives (raw HSL values) → semantic tokens (CSS variables in :root/.dark) → Tailwind config (hsl(var(--token)) references)." ;
    oc:hasRationale "Three-layer separation allows each layer to change independently — swap primitives without touching components, update semantics without touching Tailwind config." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ad0e5572 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining color tokens as CSS custom properties for Tailwind consumption" ;
    oc:directiveContent "Use space-separated HSL values (e.g., '217 91% 60%') without the hsl() function in CSS variables so Tailwind's opacity modifiers (e.g., bg-primary/50) work correctly." ;
    oc:hasRationale "Tailwind's opacity modifier syntax requires the raw HSL values so it can compose 'hsl(X Y% Z% / opacity)' at runtime — wrapping in hsl() in the variable breaks this capability." ;
    oc:severityLevel "CRITICAL" .

oc:kn_eb8c6d81 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When re-applying or updating the configuration" ;
    oc:directiveContent "The Tailwind config and CSS variable setup is idempotent — re-running with the same tokens produces identical output. However, overwriting globals.css may lose manual additions." ;
    oc:hasRationale "Safe to re-generate config files, but globals.css should be merged rather than replaced to preserve any project-specific additions." ;
    oc:severityLevel "MEDIUM" .

oc:req_4fb4e4c6 a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "shadcn/ui" .

oc:req_887dcae8 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "Tailwind CSS" .

oc:req_aa26ad85 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "HSL Color Format" .

oc:req_fa76c1bc a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "CSS Custom Properties (CSS Variables)" .

