oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_design_system_token_architecture a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "token-architecture" ;
    skos:broader "Design token system" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/nextlevel-builder/ui-ux-pro-max-skill/ckm-design-system" ;
    oc:contentHash "925f4049c4c4313d9fd5df98cdfd52004112aca49fba1664ad85e76bc9dce4d3" ;
    oc:differentia "organizes design values into a three-layer hierarchy (primitive → semantic → component) enabling themeable, scalable styling" ;
    oc:extends oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_design_system ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "optional: target component names or theme mode (light/dark)" ;
    oc:hasCategory "development" ;
    oc:hasRequirement oc:req_6ceecdd5,
        oc:req_e133ab90,
        oc:req_fa76c1bc ;
    oc:impartsKnowledge oc:kn_0a1ec082,
        oc:kn_501b1ab9,
        oc:kn_608f443c,
        oc:kn_80ca53af,
        oc:kn_b3b71075,
        oc:kn_c2e9e24c ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "create design token architecture",
        "define dark mode token overrides",
        "implement themeable design tokens",
        "migrate flat tokens to three-layer system",
        "organize css custom properties into layers" ;
    oc:yieldsState oc:DesignTokensReady,
        oc:TokenArchitectureDefined .

oc:kn_0a1ec082 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When loading or merging token files" ;
    oc:directiveContent "Token definitions are idempotent: redeclaring the same token with the same value produces no change. However, redeclaring with different values silently overrides." ;
    oc:hasRationale "CSS custom property cascade means load order matters for overrides; last definition wins, which is used intentionally for theme layers." ;
    oc:severityLevel "MEDIUM" .

oc:kn_501b1ab9 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When migrating existing design systems or reviewing token definitions" ;
    oc:directiveContent "Never use flat tokens like --button-primary-bg: #2563EB that combine component, semantic, and primitive concerns into a single token. Migrate to three-layer references." ;
    oc:hasRationale "Flat tokens couple values to specific contexts, making theming impossible and creating duplication across the system." ;
    oc:severityLevel "HIGH" .

oc:kn_608f443c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When authoring token CSS for any layer above primitives" ;
    oc:directiveContent "Component tokens MUST reference semantic tokens, semantic tokens MUST reference primitive tokens. Never hardcode raw values in semantic or component layers." ;
    oc:hasRationale "Breaking the reference chain destroys the theming capability and defeats the purpose of the layered architecture." ;
    oc:severityLevel "CRITICAL" .

oc:kn_80ca53af a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When naming any new design token" ;
    oc:directiveContent "Follow the naming convention: --{category}-{item}-{variant}-{state}. Use consistent categories: color, space, font-size, radius, shadow, duration." ;
    oc:hasRationale "Consistent naming enables discoverability, automated tooling, and predictable token resolution across the design system." ;
    oc:severityLevel "HIGH" .

oc:kn_b3b71075 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing dark mode or any alternate theme" ;
    oc:directiveContent "Implement dark mode by overriding only semantic tokens in a .dark selector. Primitive tokens remain unchanged across themes." ;
    oc:hasRationale "Overriding at the semantic layer means all component tokens automatically adapt without individual changes, keeping theme files minimal and maintainable." ;
    oc:severityLevel "HIGH" .

oc:kn_c2e9e24c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining any new design token or building a token architecture" ;
    oc:directiveContent "Always use three token layers: primitive (raw values), semantic (purpose-based aliases), and component (per-component overrides). Never skip layers or cross-reference primitive tokens directly from components." ;
    oc:hasRationale "Three-layer separation enables theme switching at the semantic layer and per-component customization without affecting foundational values or other components." ;
    oc:severityLevel "CRITICAL" .

oc:req_6ceecdd5 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Design token concepts and naming conventions" .

oc:req_e133ab90 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "W3C Design Tokens Community Group (DTCG) format" .

oc:req_fa76c1bc a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "CSS Custom Properties (CSS Variables)" .

