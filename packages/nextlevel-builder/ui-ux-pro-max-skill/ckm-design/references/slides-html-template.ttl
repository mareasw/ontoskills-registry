@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_design_slides_html_template a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "slides-html-template" ;
    skos:broader "HTML presentation scaffold" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/nextlevel-builder/ui-ux-pro-max-skill/ckm-design" ;
    oc:contentHash "fd5b051a37365fc6059c75bb388ec6f64daf1bd9ae938b287b6d762dc83c0c35" ;
    oc:differentia "provides a complete single-file HTML slide deck with 16:9 responsive layout, keyboard/click navigation, Chart.js integration, CSS animation classes, and design token variables" ;
    oc:extends oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_design ;
    oc:handlesFailure oc:AspectRatioViolation,
        oc:ContentOverflow ;
    oc:hasArgumentHint "slide content (titles, text, data)" ;
    oc:hasCategory "document" ;
    oc:hasRequirement oc:req_1498ecbe,
        oc:req_723d1f2d,
        oc:req_fe503288 ;
    oc:impartsKnowledge oc:kn_288d7c31,
        oc:kn_2c8a8886,
        oc:kn_5870dac5,
        oc:kn_c9334823,
        oc:kn_f453c952 ;
    oc:isUserInvocable false ;
    oc:nature "template" ;
    oc:requiresState oc:DesignTokensReady ;
    oc:resolvesIntent "build interactive slide deck with charts",
        "create HTML presentation slides",
        "design data-driven slides with Chart.js",
        "generate responsive presentation with navigation" ;
    oc:yieldsState oc:SlideDeckGenerated .

oc:kn_288d7c31 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before finalizing any presentation" ;
    oc:directiveContent "Verify the slide counter total matches the actual number of .slide elements in the DOM, and update document.getElementById('total') if slides are added or removed." ;
    oc:hasRationale "Mismatched counters confuse navigation and break the progress bar calculation." ;
    oc:severityLevel "HIGH" .

oc:kn_2c8a8886 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When styling slide text and layout elements" ;
    oc:directiveContent "Never hardcode slide dimensions in pixels; use clamp() and viewport units (vw/vh) for all typography and spacing to maintain responsive behavior." ;
    oc:hasRationale "Fixed pixel values break the 16:9 letterbox approach and produce inconsistent results across screen sizes." ;
    oc:severityLevel "HIGH" .

oc:kn_5870dac5 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding content to any slide" ;
    oc:directiveContent "Always use the .slide-content wrapper inside each .slide to constrain content within the safe area and prevent overflow." ;
    oc:hasRationale "Without the inner wrapper, content can overflow the slide boundaries and break the presentation layout." ;
    oc:severityLevel "HIGH" .

oc:kn_c9334823 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When embedding Chart.js charts in slides" ;
    oc:directiveContent "Chart.js canvases must use responsive:true and maintainAspectRatio:false, wrapped in a container with clamped dimensions (e.g., width: min(80%, 600px); height: clamp(200px, 40vh, 350px))." ;
    oc:hasRationale "Without these settings, charts either overflow the slide or fail to resize correctly within the fixed 16:9 viewport." ;
    oc:severityLevel "CRITICAL" .

oc:kn_f453c952 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building list-heavy or multi-element slides" ;
    oc:directiveContent "Use .animate-stagger on parent containers to sequentially reveal child elements with incremental delays, rather than animating each child individually." ;
    oc:hasRationale "Stagger animation provides visual pacing that aids audience comprehension and avoids manual delay management." ;
    oc:severityLevel "MEDIUM" .

oc:req_1498ecbe a oc:RequirementAPI ;
    oc:isOptional true ;
    oc:requirementValue "cdn.jsdelivr.net/npm/chart.js@4.4.1" .

oc:req_723d1f2d a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "CSS clamp() and viewport units for responsive design" .

oc:req_fe503288 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "CSS custom properties (design tokens)" .

