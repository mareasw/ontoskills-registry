oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_design_logo_color_psychology a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "logo-color-psychology" ;
    skos:broader "color psychology reference guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/nextlevel-builder/ui-ux-pro-max-skill/ckm-design" ;
    oc:contentHash "3fd0e93e24c3b2ea7f3be778e8f2d03b1c62c7c6eab3ade478c8fca332bff287" ;
    oc:differentia "maps logo color choices to emotional associations, industry conventions, accessibility standards, and harmony principles for brand design decisions" ;
    oc:extends oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_design ;
    oc:hasArgumentHint "industry or color-context descriptor" ;
    oc:hasCategory "design" ;
    oc:impartsKnowledge oc:kn_23172dc9,
        oc:kn_381c6da1,
        oc:kn_c025ca4c,
        oc:kn_c45db72f,
        oc:kn_ca109978 ;
    oc:isUserInvocable true ;
    oc:nature "concept" ;
    oc:resolvesIntent "apply color psychology to design",
        "choose logo colors",
        "create accessible color palettes",
        "evaluate color meanings for branding",
        "select brand colors by industry" .

oc:kn_23172dc9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When constructing multi-color logo palettes beyond a single primary" ;
    oc:directiveContent "Use monochromatic palettes for safe cohesion, complementary for high contrast vibrancy, analogous for natural harmony, or triadic for balanced dynamism." ;
    oc:hasRationale "Color harmony theory ensures palette cohesion; violating these principles produces visually jarring or amateur results." ;
    oc:severityLevel "MEDIUM" .

oc:kn_381c6da1 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing any logo or brand primary color" ;
    oc:directiveContent "Select logo primary colors based on the psychological association that aligns with the brand's desired perception: blue for trust, red for energy, green for growth, purple for creativity, orange for friendliness, black for sophistication, yellow for optimism." ;
    oc:hasRationale "Color psychology is the foundational driver of subconscious brand perception and directly influences user trust and emotional engagement." ;
    oc:severityLevel "HIGH" .

oc:kn_c025ca4c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When finalizing any logo or brand color palette for production" ;
    oc:directiveContent "Maintain a minimum contrast ratio of 4.5:1 (WCAG AA), avoid red-green only indicators, test designs in grayscale, and account for ~8% colorblind prevalence in males." ;
    oc:hasRationale "Accessibility failures exclude users, create legal risk, and damage brand reputation for inclusivity." ;
    oc:severityLevel "CRITICAL" .

oc:kn_c45db72f a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When selecting secondary and accent colors to complement a chosen primary" ;
    oc:directiveContent "Reference industry-standard color pairings: blue with white/gold/gray, red with white/black/gold, green with white/brown/blue, black with white/gold/silver, purple with gold/white/pink." ;
    oc:hasRationale "Proven pairings leverage established visual norms and reduce the risk of aesthetic dissonance in brand materials." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ca109978 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting colors for industry-specific logo design" ;
    oc:directiveContent "Avoid red in healthcare (blood connotation), blue in food (appetite suppressant), brown/beige in tech, neon in fashion unless intentional, and dark/muted colors for children's brands." ;
    oc:hasRationale "Cultural and psychological color-industry mismatches can subvert brand messaging and create negative subconscious associations." ;
    oc:severityLevel "CRITICAL" .

