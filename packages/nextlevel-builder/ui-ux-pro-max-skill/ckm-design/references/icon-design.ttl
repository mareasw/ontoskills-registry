@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_design_icon_design a oc:ExecutableSkill,
        oc:Skill ;
    dcterms:identifier "icon-design" ;
    skos:broader "icon generation utility" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/nextlevel-builder/ui-ux-pro-max-skill/ckm-design" ;
    oc:contentHash "39281931d070918b4e51ecd71054da99493cabe06a07dfa8f1f682e48637c83f" ;
    oc:differentia "uses Gemini 3.1 Pro Preview AI to produce SVG icons across 15 styles and 12 categories with batch and multi-size export" ;
    oc:extends oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_design ;
    oc:handlesFailure oc:InvalidInput,
        oc:PermissionDenied ;
    oc:hasAllowedTool "Bash" ;
    oc:hasArgumentHint "--prompt \"icon description\" --style <style> [--batch N] [--sizes \"16,24,32,48\"]" ;
    oc:hasCategory "design" ;
    oc:hasPayload oc:payload_39281931d070918b ;
    oc:hasRequirement oc:req_39b25607,
        oc:req_3fcf652e,
        oc:req_b6956f54 ;
    oc:impartsKnowledge oc:kn_65260a57,
        oc:kn_7126f25d,
        oc:kn_7d4b4309,
        oc:kn_d4105049,
        oc:kn_d457c21a,
        oc:kn_e761680d ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:APIKeySet,
        oc:ToolInstalled ;
    oc:resolvesIntent "batch generate icon variations",
        "create icon in specific style",
        "export icons at multiple sizes",
        "generate svg icon",
        "list available icon styles and categories" ;
    oc:yieldsState oc:FileCreated .

oc:kn_65260a57 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, during SVG generation and optimization" ;
    oc:directiveContent "SVG output must contain minimal path nodes with no embedded fonts or raster images. Use stroke-linecap='round' and stroke-linejoin='round' for outlined styles." ;
    oc:hasRationale "Excessive path nodes increase file size; embedded fonts/rasters break scalability. Round line caps/joins produce polished, professional outlines." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7126f25d a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When generating SVG icons for production use" ;
    oc:directiveContent "Always include a <title> element in every SVG icon for screen reader accessibility." ;
    oc:hasRationale "Screen readers rely on <title> to describe icons to visually impaired users, ensuring WCAG compliance." ;
    oc:severityLevel "HIGH" .

oc:kn_7d4b4309 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When generating any SVG icon" ;
    oc:directiveContent "Use viewBox 0 0 24 24 as the standard SVG coordinate system, and use currentColor for fills/strokes to enable CSS inheritance." ;
    oc:hasRationale "Standard viewBox ensures consistent sizing across icon sets; currentColor allows icons to inherit text color and maintain theme consistency." ;
    oc:severityLevel "HIGH" .

oc:kn_d4105049 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the user does not specify a style or asks for a recommendation" ;
    oc:directiveContent "Choose icon style based on use context: outlined for UI/web, filled for mobile/nav, duotone for marketing, thin for luxury brands, bold for headers/heroes." ;
    oc:hasRationale "Each of the 15 styles has visual weight and aesthetic properties that suit different contexts — matching style to context improves design coherence." ;
    oc:severityLevel "LOW" .

oc:kn_d457c21a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "After generating an icon, before delivering to user" ;
    oc:directiveContent "Design icons at 24px base size, then test rendered output at both 16px and 48px to verify clarity and legibility." ;
    oc:hasRationale "Icons that look good at 24px may lose detail at 16px or reveal imperfections at 48px. Multi-size validation catches these issues early." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e761680d a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before running generate.py" ;
    oc:directiveContent "Verify GEMINI_API_KEY is set and google-genai package is installed before attempting icon generation." ;
    oc:hasRationale "The script requires the Gemini API for SVG generation and will fail without proper credentials and dependencies." ;
    oc:severityLevel "CRITICAL" .

oc:payload_39281931d070918b a oc:ExecutionPayload ;
    oc:code "python3 ~/.claude/skills/design/scripts/icon/generate.py --prompt \"{prompt}\" --style {style}" ;
    oc:executor "python" ;
    oc:timeout 30000 .

oc:req_39b25607 a oc:RequirementEnvVar ;
    oc:isOptional false ;
    oc:requirementValue "GEMINI_API_KEY" .

oc:req_3fcf652e a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "python3" .

oc:req_b6956f54 a oc:RequirementAPI ;
    oc:isOptional false ;
    oc:requirementValue "google-genai" .

