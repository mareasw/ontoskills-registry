oc:kn_0097dd91 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When implementing themes and color systems" ;
    oc:directiveContent "Always maintain WCAG AA color contrast ratios (4.5:1 for normal text, 3:1 for large text) and use semantic color names (destructive, muted, foreground) rather than literal colors." ;
    oc:hasRationale "Semantic naming decouples visual design from intent, making theme changes consistent and ensuring accessibility compliance across light and dark modes." ;
    oc:severityLevel "HIGH" .

oc:kn_0f920d59 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building any UI with shadcn/ui components" ;
    oc:directiveContent "Always build complex UIs from simple, composable primitives using shadcn/ui's copy-paste component model, composing Card, Button, Dialog etc. rather than creating monolithic custom components." ;
    oc:hasRationale "Composable primitives ensure accessibility (Radix UI primitives), maintainability, and consistent behavior across the application." ;
    oc:severityLevel "HIGH" .

oc:kn_33959584 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating responsive layouts" ;
    oc:directiveContent "Start with mobile styles as the base, then layer responsive variants using Tailwind's breakpoint prefixes (sm:, md:, lg:, xl:) — never design desktop-first and scale down." ;
    oc:hasRationale "Mobile-first approach ensures progressive enhancement, smaller base CSS, and forces prioritization of essential content for smaller viewports." ;
    oc:severityLevel "MEDIUM" .

oc:kn_413db61a a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running automation scripts" ;
    oc:directiveContent "The shadcn_add.py script checks for already-installed components and refuses to overwrite by default — use --overwrite flag for force reinstallation. Tailwind config generation is fully idempotent." ;
    oc:hasRationale "Preventing accidental overwrites protects custom component customizations while ensuring config generation is safe to re-run." ;
    oc:severityLevel "MEDIUM" .

oc:kn_60444a66 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When setting up shadcn/ui in CI/CD or automated environments" ;
    oc:directiveContent "The shadcn/ui CLI requires an interactive terminal for init; when automating, pre-create components.json or use the Python wrapper script which handles non-interactive installation." ;
    oc:hasRationale "The init command prompts for framework, TypeScript, paths, and theme preferences which blocks automated pipelines." ;
    oc:severityLevel "LOW" .

oc:kn_84fc144d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating canvas-based visual designs and posters" ;
    oc:directiveContent "In canvas-based visual designs, aim for 90% visual / 10% text maximum — text should be rare, powerful gestures integrated into visual architecture, not paragraphs." ;
    oc:hasRationale "Museum-quality visual communication relies on spatial relationships, color fields, and geometric precision rather than textual explanation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_88efb4de a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When customizing shadcn/ui theme colors" ;
    oc:directiveContent "All themed colors must be defined as HSL CSS variables (without hsl() wrapper) in both :root and .dark selectors to support runtime theme switching and dark mode." ;
    oc:hasRationale "HSL variables enable opacity control via hsl(var(--primary) / 0.5) and ensure consistent dark mode implementation across all components." ;
    oc:severityLevel "HIGH" .

oc:kn_8cd58241 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before installing shadcn/ui components" ;
    oc:directiveContent "Verify components.json exists and Node.js/npm is available before attempting to add shadcn/ui components via the CLI or automation scripts." ;
    oc:hasRationale "shadcn requires initialization (npx shadcn@latest init) to set up paths, aliases, and theme configuration before components can be added." ;
    oc:severityLevel "HIGH" .

oc:kn_b73bfae9 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When styling components with Tailwind CSS" ;
    oc:directiveContent "Never use dynamic Tailwind class names constructed at runtime (e.g., template literals with variable class names) — use complete class names or the class-variance-authority (cva) pattern instead." ;
    oc:hasRationale "Tailwind's build-time CSS purging cannot detect dynamically constructed class names, causing them to be removed from the production stylesheet." ;
    oc:severityLevel "CRITICAL" .

oc:kn_da1d10b4 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When shadcn add commands fail" ;
    oc:directiveContent "If a component installation fails, check if components.json exists, verify Node.js is installed (npx available), and use --overwrite flag to reinstall corrupted components." ;
    oc:hasRationale "Most component installation failures stem from missing initialization, Node.js unavailability, or conflicting existing component files." ;
    oc:severityLevel "MEDIUM" .

oc:payload_6407be6c171aaa21 a oc:ExecutionPayload ;
    oc:code "npx shadcn@latest add {component} || python scripts/shadcn_add.py {component}" ;
    oc:executor "shell" ;
    oc:timeout 120 .

