oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_ui_styling_tailwind_customization a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "tailwind-customization" ;
    skos:broader "Tailwind CSS configuration guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/nextlevel-builder/ui-ux-pro-max-skill/ckm-ui-styling" ;
    oc:contentHash "4c5adeed6263a274f74f6eb2c816ca420fd6ef4f35683582988bacd404799afe" ;
    oc:differentia "covers the @theme directive, custom utilities, plugins, layer organization, and dark mode for building tailored design systems with Tailwind v4" ;
    oc:extends oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_ui_styling ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "tailwind customization target (e.g., \"colors\", \"typography\", \"full config\")" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_4bede7cb,
        oc:kn_7761d36d,
        oc:kn_86f0d274,
        oc:kn_9bee8031,
        oc:kn_b78d1c8e,
        oc:kn_df49075c ;
    oc:isUserInvocable true ;
    oc:nature "Reference" ;
    oc:requiresState oc:ToolInstalled ;
    oc:resolvesIntent "configure tailwind design tokens and color palettes",
        "create custom tailwind utilities and plugins",
        "customize tailwind css theme",
        "organize tailwind css layers and components",
        "set up dark mode in tailwind" ;
    oc:yieldsState oc:EnvironmentReady .

oc:kn_4bede7cb a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining custom color palettes in @theme" ;
    oc:directiveContent "Use oklch() color space for custom color definitions in @theme blocks to ensure perceptual uniformity across lightness values." ;
    oc:hasRationale "oklch provides perceptually uniform color scales, unlike hsl or hex which can have inconsistent perceived brightness across the scale." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7761d36d a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When structuring Tailwind CSS in a project" ;
    oc:directiveContent "Organize CSS into three layers: base (element resets), components (reusable patterns), and utilities (single-purpose helpers), keeping them separate." ;
    oc:hasRationale "Layer organization ensures correct CSS specificity cascading and makes it clear where new styles belong, preventing specificity conflicts." ;
    oc:severityLevel "MEDIUM" .

oc:kn_86f0d274 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before building for production with Tailwind" ;
    oc:directiveContent "Verify that the content configuration in tailwind.config includes all file paths where Tailwind classes are used, including component libraries and dynamic class sources." ;
    oc:hasRationale "Missing content paths cause Tailwind to purge classes it thinks are unused, breaking styles in production with no warning." ;
    oc:severityLevel "CRITICAL" .

oc:kn_9bee8031 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating reusable CSS classes with Tailwind" ;
    oc:directiveContent "Avoid overusing @apply to extract components; use it only for truly repeated patterns across many files." ;
    oc:hasRationale "Excessive @apply defeats the utility-first philosophy of Tailwind, making styles harder to trace and maintain. Component extraction should be done in React/Vue components, not CSS." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b78d1c8e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When naming custom colors and tokens in @theme" ;
    oc:directiveContent "Use semantic naming for custom design tokens (e.g., 'primary', 'success', 'brand') rather than literal color names (e.g., 'blue', 'red')." ;
    oc:hasRationale "Semantic names decouple the design intent from the specific color value, making theme changes and dark mode support straightforward." ;
    oc:severityLevel "HIGH" .

oc:kn_df49075c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When customizing Tailwind CSS themes" ;
    oc:directiveContent "Prefer the CSS-based @theme directive over tailwind.config.js for simple customizations like colors, fonts, spacing, and shadows." ;
    oc:hasRationale "The @theme directive is the modern Tailwind v4 approach and keeps customization co-located with CSS, reducing config file complexity." ;
    oc:severityLevel "HIGH" .

