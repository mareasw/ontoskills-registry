oc:skill_remotion_dev_skills_remotion_best_practices_timing a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "timing" ;
    skos:broader "Animation timing and interpolation reference" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/remotion-dev/skills/remotion-best-practices" ;
    oc:contentHash "3bc19fff4fea55b16a68003d2723178e12bb60e61d0149c3d1bbb23c7389e8fe" ;
    oc:dependsOnSkill oc:skill_remotion_best_practices ;
    oc:differentia "covering linear interpolation, spring physics, and easing curves in Remotion" ;
    oc:extends oc:skill_remotion_dev_skills_remotion_best_practices ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "animation-type (spring | interpolate | easing)" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_7a77bf39,
        oc:kn_a0aecb7f,
        oc:kn_d08bc1a5,
        oc:kn_d0cda051,
        oc:kn_daf68b50 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "animate values over time in Remotion",
        "apply easing curves to interpolations",
        "combine spring and interpolate for complex animations",
        "control animation timing with delay and duration",
        "create spring animations with natural motion" ;
    oc:yieldsState oc:AnimationConfigured .

oc:kn_7a77bf39 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using the interpolate() function in Remotion" ;
    oc:directiveContent "Never use interpolate without setting extrapolateLeft and extrapolateRight to 'clamp' unless you intentionally want values outside the target range." ;
    oc:hasRationale "By default, interpolate does not clamp values, so values can exceed the output range before/after the input range, causing unexpected visual behavior like negative opacity or extreme scales." ;
    oc:severityLevel "HIGH" .

oc:kn_a0aecb7f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating elements that animate in and then animate out" ;
    oc:directiveContent "For entrance-and-exit animations, use two springs: one for the entrance (immediate) and one for the exit (delayed to near the end of the clip), then subtract the exit from the entrance." ;
    oc:hasRationale "Springs return plain numbers, enabling arithmetic composition. Subtracting a delayed exit spring from an entrance spring creates smooth in-out transitions with physically natural timing on both ends." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d08bc1a5 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When creating complex animations beyond simple scale/opacity" ;
    oc:directiveContent "Combine spring() output with interpolate() to map spring progress (0-1) to arbitrary value ranges like rotation degrees, pixel offsets, or color values." ;
    oc:hasRationale "spring() returns values from 0 to 1, which alone limits expressiveness. Chaining with interpolate() unlocks mapping spring physics to any visual property." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d0cda051 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring spring animations" ;
    oc:directiveContent "Use { damping: 200 } for smooth, natural motion without bounce. Use lower damping values (8-20) only when deliberate bouncy/playful character is desired." ;
    oc:hasRationale "The default spring config (mass:1, damping:10, stiffness:100) produces noticeable bounce that is often undesirable for UI elements and subtle reveals. Damping 200 eliminates bounce for professional-looking animations." ;
    oc:severityLevel "MEDIUM" .

oc:kn_daf68b50 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When precise animation timing is required" ;
    oc:directiveContent "A spring animation's duration is determined by its physical properties (mass, damping, stiffness). To force a specific duration, use the durationInFrames parameter to stretch the animation." ;
    oc:hasRationale "Unlike interpolate which has a fixed input range, springs settle naturally based on physics. If the composition requires the spring to complete within a specific frame budget, durationInFrames must be explicitly set." ;
    oc:severityLevel "LOW" .

