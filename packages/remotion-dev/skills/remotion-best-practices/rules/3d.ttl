    dcterms:identifier "3d" ;
    skos:broader "Guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/remotion-dev/skills/remotion-best-practices" ;
    oc:contentHash "42cef6d68fb4a266ab495d35df0c60e03672b0d85c043f9b567f6aa7ff00dd0d" ;
    oc:dependsOnSkill oc:skill_remotion_best_practices ;
    oc:differentia "that governs 3D content integration in Remotion using Three.js and React Three Fiber with deterministic frame-driven animation" ;
    oc:extends oc:skill_remotion_dev_skills_remotion_best_practices ;
    oc:handlesFailure oc:InvalidInput,
        oc:PackageNotInstalled ;
    oc:hasAlias "3d-remotion",
        "react-three-fiber",
        "three",
        "threejs" ;
