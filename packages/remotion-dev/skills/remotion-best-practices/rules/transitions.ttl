@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_remotion_dev_skills_remotion_best_practices_transitions a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "transitions" ;
    skos:broader "Remotion video composition pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/remotion-dev/skills/remotion-best-practices" ;
    oc:contentHash "f6b0ca21322d68ab516345e8d57a2039c48654c98604b673913382c854e79d86" ;
    oc:differentia "uses TransitionSeries to add scene transitions (fade, slide, wipe) and overlays between video segments with controlled timing" ;
    oc:extends oc:skill_remotion_dev_skills_remotion_best_practices ;
    oc:handlesFailure oc:DurationMismatch,
        oc:InvalidTransitionPlacement ;
    oc:hasAllowedTool "Bash" ;
    oc:hasArgumentHint "scene components and transition configuration" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_4899f4d0,
        oc:kn_6cb2973d,
        oc:kn_786eeb0a,
        oc:kn_7fe23d77,
        oc:kn_d0f45e1c ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:RemotionProjectInitialized,
        oc:RemotionTransitionsInstalled ;
    oc:resolvesIntent "add overlays to video cut points",
        "add transitions between video scenes",
        "calculate composition duration with transitions",
        "configure transition timing and presentation",
        "create scene transitions in Remotion" ;
    oc:yieldsState oc:CompositionDurationCalculated,
        oc:TransitionsConfigured .

oc:kn_4899f4d0 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When mixing transitions and overlays in the same TransitionSeries" ;
    oc:directiveContent "An overlay cannot be adjacent to a transition or another overlay within a TransitionSeries. Overlays must be surrounded by Sequences." ;
    oc:hasRationale "Adjacency constraints prevent conflicting rendering behaviors at the same cut point, ensuring predictable compositing results." ;
    oc:severityLevel "CRITICAL" .

oc:kn_6cb2973d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing and configuring transition timing" ;
    oc:directiveContent "Use springTiming for organic, natural-feeling motion and linearTiming for consistent, predictable speed. Spring timing without explicit durationInFrames requires fps to calculate settled duration." ;
    oc:hasRationale "The timing function controls the perceptual quality of transitions; matching timing to the desired feel (organic vs mechanical) produces better results." ;
    oc:severityLevel "MEDIUM" .

oc:kn_786eeb0a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calculating total composition duration with transitions and overlays" ;
    oc:directiveContent "Transitions overlap adjacent scenes, shortening the total timeline by the transition duration. Overlays do NOT affect total duration." ;
    oc:hasRationale "Accurate duration calculation is essential for frame-precise video output. Failing to account for transition overlap will produce compositions of incorrect length." ;
    oc:severityLevel "HIGH" .

oc:kn_7fe23d77 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before adding any transitions or overlays to a Remotion project" ;
    oc:directiveContent "Install the @remotion/transitions package before using TransitionSeries: `npx remotion add @remotion/transitions`." ;
    oc:hasRationale "TransitionSeries and related APIs are not included in the core Remotion package and must be installed separately." ;
    oc:severityLevel "CRITICAL" .

oc:kn_d0f45e1c a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When styling and positioning content inside TransitionSeries.Sequence children" ;
    oc:directiveContent "TransitionSeries children are absolutely positioned. This affects layout behavior of scene content." ;
    oc:hasRationale "Absolute positioning means child elements will not flow relative to each other; developers must use explicit positioning or flex/grid layouts within scenes." ;
    oc:severityLevel "MEDIUM" .

