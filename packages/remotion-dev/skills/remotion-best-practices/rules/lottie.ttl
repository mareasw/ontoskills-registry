@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_remotion_dev_skills_remotion_best_practices_lottie a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "lottie" ;
    skos:broader "Animation integration guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/remotion-dev/skills/remotion-best-practices" ;
    oc:contentHash "6dd0a845f5cea9c0f3d2465b5678a16076f5778ad1a628abbf387dba0b929cbb" ;
    oc:dependsOnSkill oc:skill_remotion_best_practices ;
    oc:differentia "enables embedding Lottie JSON animations in Remotion React components using @remotion/lottie with proper async loading patterns" ;
    oc:extends oc:skill_remotion_dev_skills_remotion_best_practices ;
    oc:handlesFailure oc:AssetLoadFailed,
        oc:PackageNotInstalled ;
    oc:hasArgumentHint "lottie JSON URL or file path" ;
    oc:hasCategory "development" ;
    oc:hasRequirement oc:req_51719b42,
        oc:req_66276a66,
        oc:req_8092d633 ;
    oc:impartsKnowledge oc:kn_472a37da,
        oc:kn_874abeb6,
        oc:kn_a77d05a4,
        oc:kn_e2064aec,
        oc:kn_e485e646 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "display lottie file in video",
        "embed lottie animation in remotion",
        "style lottie animation in remotion" ;
    oc:yieldsState oc:LottieAnimationEmbedded .

oc:kn_472a37da a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before the async fetch resolves and animationData state is populated" ;
    oc:directiveContent "Always return null (or a placeholder) while animationData is null to avoid passing undefined data to the Lottie component." ;
    oc:hasRationale "Passing null/undefined animationData to the Lottie component will cause a runtime crash." ;
    oc:severityLevel "HIGH" .

oc:kn_874abeb6 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When sizing or positioning Lottie animations within a Remotion composition" ;
    oc:directiveContent "Use the style prop on the Lottie component to control dimensions and layout (e.g., style={{ width: 400, height: 400 }})." ;
    oc:hasRationale "Lottie animations may not have intrinsic dimensions that match the video frame; explicit sizing ensures correct visual output." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a77d05a4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Whenever loading Lottie animations asynchronously via fetch or dynamic import" ;
    oc:directiveContent "Always wrap async Lottie asset fetching with delayRender() and continueRender() to prevent Remotion from rendering before the animation data is loaded." ;
    oc:hasRationale "Remotion renders frames synchronously; without delayRender, it will render a blank frame before the Lottie JSON has finished loading, producing incomplete output." ;
    oc:severityLevel "CRITICAL" .

oc:kn_e2064aec a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When fetching external Lottie JSON assets that may fail due to network errors or invalid URLs" ;
    oc:directiveContent "Use cancelRender(err) in the fetch .catch() handler to gracefully fail the entire render if the Lottie asset cannot be loaded." ;
    oc:hasRationale "Silently swallowing fetch errors would produce a render with missing animation content; cancelRender ensures the failure is surfaced immediately." ;
    oc:severityLevel "HIGH" .

oc:kn_e485e646 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before adding any Lottie animation to a Remotion project" ;
    oc:directiveContent "Ensure @remotion/lottie is installed before attempting to import or use Lottie components. Install via 'npx remotion add @remotion/lottie' (or equivalent for your package manager)." ;
    oc:hasRationale "Without the package installed, imports will fail at compile time, blocking the entire composition." ;
    oc:severityLevel "CRITICAL" .

oc:req_51719b42 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "@remotion/lottie" .

oc:req_66276a66 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Remotion delayRender/continueRender pattern" .

oc:req_8092d633 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "React hooks (useState, useEffect)" .

