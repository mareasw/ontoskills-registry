oc:skill_remotion_dev_skills_remotion_best_practices_transparent_videos a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "transparent-videos" ;
    skos:broader "Video rendering configuration" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/remotion-dev/skills/remotion-best-practices" ;
    oc:contentHash "394ccda476e084522d544471fee92d7c65672e2cbaf2201a785c3dd5c74f31a4" ;
    oc:dependsOnSkill oc:skill_remotion_best_practices ;
    oc:differentia "produces alpha-channel-enabled video output via ProRes or VP9/WebM codecs in Remotion" ;
    oc:extends oc:skill_remotion_dev_skills_remotion_best_practices ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasAllowedTool "Bash" ;
    oc:hasArgumentHint "composition-id output-path [--codec=prores|vp9]" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_28ae96cb,
        oc:kn_3d8bdd9d,
        oc:kn_cc7c0f71,
        oc:kn_e44bf0cb,
        oc:kn_f1146f0d ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "create ProRes 4444 video",
        "create transparent WebM video",
        "export video with alpha channel",
        "render transparent video" ;
    oc:yieldsState oc:VideoRendered .

oc:kn_28ae96cb a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When rendering transparent video for web playback" ;
    oc:directiveContent "Use VP9/WebM (codec=vp9, pixel-format=yuva420p) when the transparent video will be played directly in a web browser." ;
    oc:hasRationale "WebM with VP9 is natively supported in browsers with alpha channel transparency, while ProRes is not." ;
    oc:severityLevel "HIGH" .

oc:kn_3d8bdd9d a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "After modifying remotion.config.ts for transparent rendering in Studio" ;
    oc:directiveContent "Changing remotion.config.ts for Studio transparency defaults requires restarting Studio to take effect." ;
    oc:hasRationale "Studio reads config on startup; config changes are not hot-reloaded, so a restart is required for transparency settings to apply." ;
    oc:severityLevel "MEDIUM" .

oc:kn_cc7c0f71 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring per-composition export defaults" ;
    oc:directiveContent "Use calculateMetadata on the Composition component to set transparent rendering defaults, rather than relying solely on CLI flags or remotion.config.ts." ;
    oc:hasRationale "calculateMetadata binds transparency settings to the composition definition itself, making the project portable and reducing misconfiguration risk across team members." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e44bf0cb a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When rendering transparent video for post-production workflows" ;
    oc:directiveContent "Use ProRes 4444 (codec=prores, pixel-format=yuva444p10le, prores-profile=4444) when the transparent video will be imported into video editing software like Premiere or Final Cut." ;
    oc:hasRationale "ProRes 4444 is the industry-standard lossless format with alpha channel support, ensuring maximum quality in NLE environments." ;
    oc:severityLevel "HIGH" .

oc:kn_f1146f0d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When rendering any transparent video" ;
    oc:directiveContent "Always set --image-format=png when rendering transparent videos, regardless of codec choice." ;
    oc:hasRationale "PNG frames preserve the alpha channel during the intermediate rendering stage; JPEG and other lossy formats discard alpha information." ;
    oc:severityLevel "CRITICAL" .

