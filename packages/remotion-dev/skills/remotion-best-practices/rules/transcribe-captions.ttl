@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_remotion_dev_skills_remotion_best_practices_transcribe_captions a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "transcribe-captions" ;
    skos:broader "Audio transcription pipeline" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/remotion-dev/skills/remotion-best-practices" ;
    oc:contentHash "ad1a62af35fe176b37ac4d98f796451ca66bcc9983207a9710ec3eca6e847738" ;
    oc:differentia "Uses Whisper.cpp via Remotion's install-whisper-cpp package to generate timestamped captions for video projects" ;
    oc:extends oc:skill_remotion_dev_skills_remotion_best_practices ;
    oc:handlesFailure oc:FileNotFound,
        oc:NetworkTimeout ;
    oc:hasAllowedTool "bash",
        "node" ;
    oc:hasArgumentHint "path-to-audio-wav-file" ;
    oc:hasCategory "development" ;
    oc:hasRequirement oc:req_5d493341,
        oc:req_6e9d9e56,
        oc:req_8f2ef958,
        oc:req_a9de7bd3 ;
    oc:impartsKnowledge oc:kn_2ad2d729,
        oc:kn_3fd278f4,
        oc:kn_6ab62adb,
        oc:kn_7e117d5f,
        oc:kn_a2015dcb ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:FileExists,
        oc:ToolInstalled ;
    oc:resolvesIntent "convert speech to text for remotion videos",
        "create caption JSON files from audio clips",
        "generate captions from audio",
        "transcribe audio to captions" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_2ad2d729 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "During first-time setup and model download" ;
    oc:directiveContent "installWhisperCpp() downloads and compiles Whisper.cpp to the specified directory. downloadWhisperModel() downloads a model file which can be several hundred megabytes." ;
    oc:hasRationale "These operations consume significant disk space and network bandwidth. The whisper.cpp directory and model files should be cached to avoid repeated downloads." ;
    oc:severityLevel "LOW" .

oc:kn_3fd278f4 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "After receiving transcription output from transcribe()" ;
    oc:directiveContent "Always apply the toCaptions() postprocessing step on the raw whisperCppOutput to get properly formatted caption data." ;
    oc:hasRationale "Raw Whisper.cpp output contains token-level timestamps that need Remotion's recommended postprocessing to produce usable, well-segmented captions." ;
    oc:severityLevel "HIGH" .

oc:kn_6ab62adb a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When working with multiple video clips that need captions" ;
    oc:directiveContent "Transcribe each clip individually and create separate JSON files rather than transcribing a single long merged audio file." ;
    oc:hasRationale "Individual clip transcription produces more accurate timestamps and allows independent caption management per clip in the Remotion timeline." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7e117d5f a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When selecting a Whisper model for transcription" ;
    oc:directiveContent "The 'medium.en' model provides good balance of accuracy and speed for English transcription. Download time and disk usage scale with model size (tiny < base < small < medium < large)." ;
    oc:hasRationale "Larger models improve accuracy but significantly increase download time, memory usage, and transcription duration." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a2015dcb a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before calling transcribe(), ensure the input audio file is in 16KHz WAV format" ;
    oc:directiveContent "Convert audio to 16KHz WAV format before transcribing. Use ffmpeg -i input.mp4 -ar 16000 output.wav to resample." ;
    oc:hasRationale "Whisper.cpp requires 16KHz WAV input; providing other formats will cause transcription failures or silent errors." ;
    oc:severityLevel "CRITICAL" .

oc:req_5d493341 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "whisper.cpp" .

oc:req_6e9d9e56 a oc:RequirementHardware ;
    oc:isOptional false ;
    oc:requirementValue "Sufficient disk space for Whisper model download" .

oc:req_8f2ef958 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "ffmpeg" .

oc:req_a9de7bd3 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "@remotion/install-whisper-cpp" .

