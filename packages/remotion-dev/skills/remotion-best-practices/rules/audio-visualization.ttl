@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_remotion_dev_skills_remotion_best_practices_audio_visualization a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "audio-visualization" ;
    skos:broader "visualization pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/remotion-dev/skills/remotion-best-practices" ;
    oc:contentHash "0f4043de86639b6390e5ab888eaa66a24a10a8bd540f1443327cb88107eae1e9" ;
    oc:dependsOnSkill oc:skill_remotion_best_practices ;
    oc:differentia "provides audio-reactive rendering techniques (spectrum bars, waveforms, bass-reactive effects) for Remotion video compositions" ;
    oc:extends oc:skill_remotion_dev_skills_remotion_best_practices ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "audio file path (e.g., staticFile('music.mp3'))" ;
    oc:hasCategory "development" ;
    oc:hasRequirement oc:req_4424b215,
        oc:req_8486a8cc,
        oc:req_85ddab78 ;
    oc:impartsKnowledge oc:kn_3eca9822,
        oc:kn_65232d34,
        oc:kn_aa768c55,
        oc:kn_d27eed74,
        oc:kn_e695f170,
        oc:kn_ee6b2b14 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "add bass-reactive effects to video",
        "build audiogram-style video",
        "create audio visualization",
        "create waveform visualization",
        "render spectrum bars from audio",
        "visualize audio frequency data" ;
    oc:yieldsState oc:AudioVisualizationRendered .

oc:kn_3eca9822 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring frequency spectrum visualization" ;
    oc:directiveContent "numberOfSamples must be a power of 2 (32, 64, 128, 256, 512, 1024) when calling visualizeAudio()" ;
    oc:hasRationale "The underlying FFT algorithm requires power-of-2 sample counts; other values will cause errors or undefined behavior" ;
    oc:severityLevel "CRITICAL" .

oc:kn_65232d34 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When rendering frequency spectrum bars or any visual representation of audio frequency data" ;
    oc:directiveContent "Apply logarithmic scaling (dB conversion) to frequency values for visually balanced spectrum displays, as low frequencies naturally dominate linear values" ;
    oc:hasRationale "Raw frequency data from FFT is linear and heavily skewed toward bass; logarithmic scaling makes mid and high frequencies visible alongside bass content" ;
    oc:severityLevel "MEDIUM" .

oc:kn_aa768c55 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before any audio visualization rendering call" ;
    oc:directiveContent "Always null-check audioData before calling visualizeAudio() or visualizeAudioWaveform() — return null from the component if audioData is not yet loaded" ;
    oc:hasRationale "useWindowedAudioData() returns null audioData during initial load; calling visualization functions with null will throw a runtime error" ;
    oc:severityLevel "HIGH" .

oc:kn_d27eed74 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calling visualizeAudio() for performance-sensitive rendering" ;
    oc:directiveContent "Use optimizeFor: 'speed' when deploying to Remotion Lambda or when using high numberOfSamples values" ;
    oc:hasRationale "Speed optimization reduces computation time per frame, which is critical for Lambda rendering costs and large sample counts" ;
    oc:severityLevel "MEDIUM" .

oc:kn_e695f170 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When composing audio visualization components inside <Sequence> with offsets" ;
    oc:directiveContent "Never call useCurrentFrame() in child components that receive audioData from a parent. Instead, pass the frame value from the parent." ;
    oc:hasRationale "Calling useCurrentFrame() separately in children inside <Sequence> produces discontinuous visualization because the frame value is offset by the Sequence, causing audio data and frame to be out of sync" ;
    oc:severityLevel "CRITICAL" .

oc:kn_ee6b2b14 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating bass-reactive or beat-synced visual effects" ;
    oc:directiveContent "Extract bass intensity by averaging the first 32 low-frequency bins from visualizeAudio() for beat-reactive animations" ;
    oc:hasRationale "The left side of the frequency array represents bass (low frequencies); averaging these bins provides a stable bass intensity value suitable for driving scale, opacity, or position animations" ;
    oc:severityLevel "LOW" .

oc:req_4424b215 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "@remotion/media-utils" .

oc:req_8486a8cc a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "Web Audio API frequency concepts" .

oc:req_85ddab78 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "React hooks and component composition" .

