@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_remotion_dev_skills_remotion_best_practices_trimming a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "trimming" ;
    skos:broader "Pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/remotion-dev/skills/remotion-best-practices" ;
    oc:contentHash "ae00948f6a903e384c7c312896adba9b50ed592f24a5a090699b7345849b36b9" ;
    oc:dependsOnSkill oc:skill_remotion_best_practices ;
    oc:differentia "Uses Sequence with negative from values and durationInFrames to trim start/end of animations in Remotion" ;
    oc:extends oc:skill_remotion_dev_skills_remotion_best_practices ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "animation component to trim" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_065b89df,
        oc:kn_60aebebf,
        oc:kn_cd1b59c3,
        oc:kn_e753b960,
        oc:kn_fb63e03c ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "clip animation duration",
        "combine trimming with delay",
        "cut beginning of animation",
        "trim animation end",
        "trim animation start" ;
    oc:yieldsState oc:AnimationTrimmed .

oc:kn_065b89df a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When tempted to add manual frame offsets inside animation logic" ;
    oc:directiveContent "Do not manually offset frame calculations inside the animation component to simulate trimming — use the Sequence's negative `from` instead." ;
    oc:hasRationale "Declarative trimming via Sequence keeps animation components pure and reusable, while manual offsets couple the animation to a specific timeline position." ;
    oc:severityLevel "MEDIUM" .

oc:kn_60aebebf a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "Always when reading frame values inside a trimmed Sequence" ;
    oc:directiveContent "When a negative `from` is used, `useCurrentFrame()` inside the child component starts at the absolute value of the offset (e.g., from={-15} means frame starts at 15)." ;
    oc:hasRationale "The animation component is unaware it has been trimmed; it simply receives a non-zero starting frame, which affects any frame-based calculations inside it." ;
    oc:severityLevel "HIGH" .

oc:kn_cd1b59c3 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When trimming the beginning of a Remotion animation" ;
    oc:directiveContent "Use a negative `from` value on `<Sequence>` to trim the start of an animation, causing `useCurrentFrame()` inside the component to start at a value greater than 0." ;
    oc:hasRationale "Negative from shifts time backwards, making the animation appear partway through its progress without modifying the animation component itself." .

oc:kn_e753b960 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When both trimming the beginning and delaying an animation's appearance" ;
    oc:directiveContent "Nest two `<Sequence>` elements to combine trimming and delaying: inner sequence with negative `from` trims the start, outer sequence with positive `from` delays the result." ;
    oc:hasRationale "Separation of concerns — one Sequence handles the trim offset, the other handles the delay — keeps the logic composable and readable." .

oc:kn_fb63e03c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When trimming the end of a Remotion animation" ;
    oc:directiveContent "Use `durationInFrames` on `<Sequence>` to unmount content after a specified number of frames, effectively trimming the end of an animation." ;
    oc:hasRationale "The component unmounts after durationInFrames elapses, cutting off any remaining animation frames cleanly." .

