@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_remotion_dev_skills_remotion_best_practices_get_video_duration a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "get-video-duration" ;
    skos:broader "Video utility" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/remotion-dev/skills/remotion-best-practices" ;
    oc:contentHash "ed594a0d73a5274483f21c30e612aba57089d5bbc5437041aa32d07a8e789fd9" ;
    oc:differentia "extracts duration in seconds from video files using Mediabunny across browser, Node.js, and Bun environments" ;
    oc:extends oc:skill_remotion_dev_skills_remotion_best_practices ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput,
        oc:NetworkTimeout ;
    oc:hasAlias "duration-of-video",
        "video-duration" ;
    oc:hasArgumentHint "src: string (URL or staticFile path to video)" ;
    oc:hasCategory "development" ;
    oc:hasRequirement oc:req_03f2bdf1,
        oc:req_887da35a ;
    oc:impartsKnowledge oc:kn_1c701db3,
        oc:kn_5320aa5d,
        oc:kn_64e0d721,
        oc:kn_95f4f790,
        oc:kn_99a77de6 ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "extract video duration in seconds",
        "get video duration",
        "measure video length" ;
    oc:yieldsState oc:VideoDurationComputed .

oc:kn_1c701db3 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "Always when initializing Input for video duration extraction" ;
    oc:directiveContent "Use UrlSource for browser environments and FileSource for Node.js/Bun environments when creating a Mediabunny Input instance." ;
    oc:hasRationale "Each environment has different file access mechanisms; using the wrong source type will cause runtime errors." ;
    oc:severityLevel "CRITICAL" .

oc:kn_5320aa5d a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When computing duration of large or remote video files" ;
    oc:directiveContent "computeDuration() may perform a full decode or partial scan of the video depending on the format, which can be I/O intensive for large files or remote URLs." ;
    oc:hasRationale "Duration computation is not always a metadata-only operation; it can consume significant bandwidth and time." ;
    oc:severityLevel "MEDIUM" .

oc:kn_64e0d721 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating a Mediabunny Input instance for duration extraction" ;
    oc:directiveContent "Always pass ALL_FORMATS to the Input constructor to ensure maximum format compatibility when extracting video duration." ;
    oc:hasRationale "Without ALL_FORMATS, certain video formats may not be recognized, causing duration extraction to fail." ;
    oc:severityLevel "MEDIUM" .

oc:kn_95f4f790 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When referencing video files from the public/ directory in Remotion projects" ;
    oc:directiveContent "Wrap public directory file paths with Remotion's staticFile() function before passing to getVideoDuration." ;
    oc:hasRationale "Remotion serves public directory assets via a special URL pattern; staticFile() generates the correct path." ;
    oc:severityLevel "HIGH" .

oc:kn_99a77de6 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring UrlSource for video duration fetching" ;
    oc:directiveContent "Set getRetryDelay to () => null in UrlSource options to disable retry behavior for cleaner error handling." ;
    oc:hasRationale "Disabling retries gives immediate feedback on network failures rather than silently retrying." ;
    oc:severityLevel "LOW" .

oc:req_03f2bdf1 a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "Remotion staticFile API for public directory assets" .

oc:req_887da35a a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "mediabunny" .

