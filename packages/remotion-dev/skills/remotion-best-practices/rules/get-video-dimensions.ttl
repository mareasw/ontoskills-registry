@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_remotion_dev_skills_remotion_best_practices_get_video_dimensions a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "get-video-dimensions" ;
    skos:broader "Video metadata extraction utility" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/remotion-dev/skills/remotion-best-practices" ;
    oc:contentHash "ed1bb6e0ae742e4bfcb18e7c50af23fc782a9d699b90d367250437c7f6da7304" ;
    oc:dependsOnSkill oc:skill_remotion_best_practices ;
    oc:differentia "Uses Mediabunny to retrieve width and height dimensions from video files across browser, Node.js, and Bun environments" ;
    oc:extends oc:skill_remotion_dev_skills_remotion_best_practices ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput ;
    oc:hasAlias "video-dimensions",
        "video-resolution",
        "video-size" ;
    oc:hasArgumentHint "src: string (URL or file path to video)" ;
    oc:hasCategory "development" ;
    oc:hasRequirement oc:req_53c8d8a4,
        oc:req_887da35a ;
    oc:impartsKnowledge oc:kn_5a502fd6,
        oc:kn_aaacd42c,
        oc:kn_dacc3bbe,
        oc:kn_dedb7ea1,
        oc:kn_defe5784 ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "get video dimensions",
        "get video resolution",
        "get video width and height",
        "read video metadata" ;
    oc:yieldsState oc:VideoDimensionsRetrieved .

oc:kn_5a502fd6 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When constructing a Mediabunny Input for video dimension extraction" ;
    oc:directiveContent "Use UrlSource for remote URLs and FileSource for local File objects; choose the correct source adapter for the input type." ;
    oc:hasRationale "Using the wrong source type will fail to read the file. UrlSource handles network requests while FileSource handles browser File objects from input or drag-drop." ;
    oc:severityLevel "HIGH" .

oc:kn_aaacd42c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When initializing a Mediabunny Input instance for dimension extraction" ;
    oc:directiveContent "Use ALL_FORMATS when creating the Input to ensure maximum compatibility with different video formats." ;
    oc:hasRationale "Specifying ALL_FORMATS ensures the library can parse any supported video container format without needing prior knowledge of the file type." ;
    oc:severityLevel "MEDIUM" .

oc:kn_dacc3bbe a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always — this is a pure metadata extraction operation" ;
    oc:directiveContent "Getting video dimensions is a read-only operation that does not modify the source file or any external state." ;
    oc:hasRationale "Safe to call repeatedly without side effects, making it suitable for pre-flight checks and validation workflows." ;
    oc:severityLevel "LOW" .

oc:kn_dedb7ea1 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reading dimensions from a video track" ;
    oc:directiveContent "Use displayWidth and displayHeight (not coded width/height) to get the actual rendered dimensions accounting for aspect ratio and rotation metadata." ;
    oc:hasRationale "Videos may have display matrices or rotation metadata that cause the coded pixel dimensions to differ from what the viewer actually sees. displayWidth/displayHeight account for these transforms." ;
    oc:severityLevel "MEDIUM" .

oc:kn_defe5784 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting video dimensions from any source" ;
    oc:directiveContent "Always check if videoTrack is null after calling getPrimaryVideoTrack() before accessing displayWidth/displayHeight, as files without video tracks will throw." ;
    oc:hasRationale "Not all media files contain video tracks; audio-only files or corrupt files will return null, causing runtime errors if unchecked." ;
    oc:severityLevel "CRITICAL" .

oc:req_53c8d8a4 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Understanding of UrlSource vs FileSource for different input types" .

oc:req_887da35a a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "mediabunny" .

