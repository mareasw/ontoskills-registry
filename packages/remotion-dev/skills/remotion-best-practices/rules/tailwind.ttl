oc:skill_remotion_dev_skills_remotion_best_practices_tailwind a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "tailwind" ;
    skos:broader "Styling integration guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/remotion-dev/skills/remotion-best-practices" ;
    oc:contentHash "6212ce72abe5eaee0eb41822b2cdf944b77ad9b082426909beb2da07151e1788" ;
    oc:differentia "governs the use of TailwindCSS utility classes within Remotion React components while prohibiting animation-related classes in favor of frame-driven animations" ;
    oc:extends oc:skill_remotion_dev_skills_remotion_best_practices ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasCategory "development" ;
    oc:hasRequirement oc:req_07478da4,
        oc:req_14549775,
        oc:req_9256e5d9 ;
    oc:impartsKnowledge oc:kn_0d09def6,
        oc:kn_1dec92d6,
        oc:kn_4605e65c,
        oc:kn_725fca88 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ToolInstalled ;
    oc:resolvesIntent "integrate tailwind with remotion video project",
        "style remotion components with tailwind",
        "use tailwindcss in remotion" ;
    oc:yieldsState oc:EnvironmentReady .

oc:kn_0d09def6 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before using any Tailwind utility classes in a Remotion project" ;
    oc:directiveContent "Verify TailwindCSS is installed and properly configured in the Remotion project before using Tailwind classes. Fetch https://www.remotion.dev/docs/tailwind for setup instructions if unsure." ;
    oc:hasRationale "TailwindCSS is not bundled with Remotion by default. Attempting to use Tailwind classes without installation will result in unstyled output or build errors." ;
    oc:severityLevel "HIGH" .

oc:kn_1dec92d6 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding motion or animation to any Remotion component" ;
    oc:directiveContent "Always animate using the useCurrentFrame() hook instead of CSS animation classes, even when TailwindCSS is available." ;
    oc:hasRationale "Frame-driven animations ensure deterministic, reproducible renders — a core requirement for programmatic video generation. CSS animations cannot be synchronized to Remotion's frame timeline." ;
    oc:severityLevel "HIGH" .

oc:kn_4605e65c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When styling any Remotion component with TailwindCSS" ;
    oc:directiveContent "Never use Tailwind's `transition-*` or `animate-*` utility classes in Remotion components." ;
    oc:hasRationale "CSS transitions and animations are time-based and non-deterministic in a video context. Remotion requires frame-precise, deterministic animation via the useCurrentFrame() hook so that video renders are reproducible and seekable." ;
    oc:severityLevel "CRITICAL" .

oc:kn_725fca88 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding how to apply styles in Remotion components" ;
    oc:directiveContent "Use TailwindCSS freely for layout, spacing, typography, and color — but treat animation as a separate concern handled exclusively by useCurrentFrame()." ;
    oc:hasRationale "TailwindCSS excels at static utility styling. Separating static styling (Tailwind) from dynamic animation (useCurrentFrame) creates a clean architecture that leverages each tool's strengths." ;
    oc:severityLevel "MEDIUM" .

oc:req_07478da4 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "useCurrentFrame() hook for animations" .

oc:req_14549775 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "TailwindCSS installed in the project" .

oc:req_9256e5d9 a oc:RequirementAPI ;
    oc:isOptional false ;
    oc:requirementValue "https://www.remotion.dev/docs/tailwind" .

