oc:skill_remotion_dev_skills_remotion_best_practices_maps a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "maps" ;
    skos:broader "Video composition component" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/remotion-dev/skills/remotion-best-practices" ;
    oc:contentHash "5a531e1c925c58c4aa019c33bf2b6c0412560af3359295ab080f33e063e01d61" ;
    oc:dependsOnSkill oc:skill_remotion_best_practices ;
    oc:differentia "renders animated Mapbox GL maps with camera movement, line drawing, and markers inside Remotion's frame-driven rendering model" ;
    oc:extends oc:skill_remotion_dev_skills_remotion_best_practices ;
    oc:handlesFailure oc:InvalidInput,
        oc:NetworkTimeout,
        oc:PermissionDenied ;
    oc:hasAllowedTool "Bash",
        "Edit",
        "Read",
        "Write" ;
    oc:hasArgumentHint "Map coordinates, route definition, animation configuration" ;
    oc:hasCategory "development" ;
    oc:hasRequirement oc:req_277253fe,
        oc:req_5137cc99,
        oc:req_524a0611,
        oc:req_75eea18d,
        oc:req_9d433922,
        oc:req_dc6b6b8e ;
    oc:impartsKnowledge oc:kn_02fe3eb5,
        oc:kn_09842174,
        oc:kn_2f0521c5,
        oc:kn_328a69ea,
        oc:kn_40cb4591,
        oc:kn_6004e015,
        oc:kn_aa9306ee,
        oc:kn_da578dbe,
        oc:kn_e9b68515,
        oc:kn_fb03208f ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:APIKeySet,
        oc:EnvironmentReady ;
    oc:resolvesIntent "add map markers and labels",
        "animate camera along a route",
        "create map animation",
        "draw animated lines on a map",
        "render map video with Mapbox" ;
    oc:yieldsState oc:MapRendered,
        oc:VideoRendered .

oc:kn_02fe3eb5 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When animating line drawing on a Mercator map projection" ;
    oc:directiveContent "Do NOT use turf's lineSliceAlong or along functions for straight lines. Use linear interpolation between coordinates instead. Only use turf functions for geodesic/great circle curved lines." ;
    oc:hasRationale "Turf uses geodesic (great circle) calculations which appear curved on a Mercator projection, producing visually incorrect straight-line animations" ;
    oc:severityLevel "HIGH" .

oc:kn_09842174 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When running npx remotion render for map-based compositions" ;
    oc:directiveContent "Always render map animations with --gl=angle and --concurrency=1 flags." ;
    oc:hasRationale "Mapbox uses WebGL which requires the ANGLE backend for headless rendering, and concurrent processes can cause GPU resource conflicts" ;
    oc:severityLevel "CRITICAL" .

oc:kn_2f0521c5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building multi-keyframe camera animation sequences" ;
    oc:directiveContent "For multi-step camera animations, set ALL properties (zoom, position, line progress) at every stage to prevent visual jumps. Always override initial values." ;
    oc:hasRationale "Partial property updates cause discontinuities between animation stages because Mapbox retains previous values for unspecified properties" ;
    oc:severityLevel "HIGH" .

oc:kn_328a69ea a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When computing interpolated position along a route using turf" ;
    oc:directiveContent "Clamp progress to a minimum value (e.g., 0.00001) to avoid empty line geometry which causes turf.js errors." ;
    oc:hasRationale "A progress value of exactly 0 produces a zero-length line which causes turf.length and turf.along to throw errors" ;
    oc:severityLevel "HIGH" .

oc:kn_40cb4591 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When animating camera position along a route" ;
    oc:directiveContent "Keep the camera oriented so north is up by default. Do not jump between camera angles unless explicitly requested." ;
    oc:hasRationale "Sudden camera rotation disorients viewers; north-up is the expected default for map animations" ;
    oc:severityLevel "MEDIUM" .

oc:kn_6004e015 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring any Mapbox map instance in a Remotion composition" ;
    oc:directiveContent "Never use Mapbox's built-in animations. Set fadeDuration to 0, interactive to false, and drive all animation through useCurrentFrame() and Remotion's interpolate()." ;
    oc:hasRationale "Remotion renders frame-by-frame; Mapbox's own animations run asynchronously and will cause inconsistent frames across renders" ;
    oc:severityLevel "CRITICAL" .

oc:kn_aa9306ee a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When initializing a Mapbox map in a Remotion component" ;
    oc:directiveContent "Use useDelayRender() to pause rendering until the map is fully loaded, and set map state to null until the 'load' event fires." ;
    oc:hasRationale "Map tiles load asynchronously; without delayRender(), Remotion would capture a blank or partially loaded map frame" ;
    oc:severityLevel "HIGH" .

oc:kn_da578dbe a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring the map style for a composition" ;
    oc:directiveContent "By default, hide ALL features from the Mapbox Standard style (roads, transit, labels, POIs, 3D objects, etc.) and only add back what is explicitly requested." ;
    oc:hasRationale "Clean map animations require a minimal basemap; clutter from default features distracts from the animated elements" ;
    oc:severityLevel "MEDIUM" .

oc:kn_e9b68515 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding markers and labels to the map" ;
    oc:directiveContent "Scale markers and labels based on composition dimensions. For 1920x1080, use at least 40px font size and circle radius of 40. Keep text-offset small relative to marker size (e.g., [0, 0.5] for radius 40)." ;
    oc:hasRationale "Map markers and text that are too small become illegible when the composition is scaled down for delivery" ;
    oc:severityLevel "MEDIUM" .

oc:kn_fb03208f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating the DOM element that hosts the Mapbox map" ;
    oc:directiveContent "The map container element MUST have explicit width, height, and position: 'absolute'. Do not add a _map.remove() cleanup function." ;
    oc:hasRationale "Without explicit dimensions and absolute positioning, Mapbox cannot correctly size its WebGL canvas. Removing the map on cleanup causes issues with Remotion's rendering lifecycle" ;
    oc:severityLevel "CRITICAL" .

oc:req_277253fe a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "mapbox-gl" .

oc:req_5137cc99 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "@types/mapbox-gl" .

oc:req_524a0611 a oc:RequirementHardware ;
    oc:isOptional false ;
    oc:requirementValue "GPU rendering with --gl=angle flag" .

oc:req_75eea18d a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "@turf/turf" .

oc:req_9d433922 a oc:RequirementEnvVar ;
    oc:isOptional false ;
    oc:requirementValue "REMOTION_MAPBOX_TOKEN" .

oc:req_dc6b6b8e a oc:RequirementAPI ;
    oc:isOptional false ;
    oc:requirementValue "Mapbox GL access token (REMOTION_MAPBOX_TOKEN)" .

