@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_remotion_dev_skills_remotion_best_practices_images a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "images" ;
    skos:broader "Component usage guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/remotion-dev/skills/remotion-best-practices" ;
    oc:contentHash "833e0a038d7c158f58b39f9bca7efafbbc4b944a54b3ae1c95e0d5973345e22c" ;
    oc:differentia "covers image embedding in Remotion using the <Img> component, staticFile references, sizing, and dynamic paths" ;
    oc:extends oc:skill_remotion_dev_skills_remotion_best_practices ;
    oc:handlesFailure oc:FileNotFound,
        oc:NetworkTimeout,
        oc:PermissionDenied ;
    oc:hasAllowedTool "Edit",
        "Read",
        "Write" ;
    oc:hasArgumentHint "image source path or URL" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_24fde471,
        oc:kn_537d2067,
        oc:kn_743cb5ec,
        oc:kn_b0244d12,
        oc:kn_decc8911 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "display local or remote images in compositions",
        "dynamically reference images based on frame or props",
        "embed images in Remotion videos",
        "get image dimensions for composition sizing" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_24fde471 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using local image assets in a Remotion project" ;
    oc:directiveContent "Place local images in the public/ folder and reference them using staticFile() rather than hardcoding paths." ;
    oc:hasRationale "staticFile() resolves paths correctly across development and production builds, ensuring consistent asset resolution during rendering." ;
    oc:severityLevel "HIGH" .

oc:kn_537d2067 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When image paths need to vary based on frame number, component props, or application state" ;
    oc:directiveContent "Use template literals with staticFile() for dynamic image paths based on useCurrentFrame(), props, or conditional logic to support image sequences, user-specific assets, and state-dependent graphics." ;
    oc:hasRationale "Dynamic paths enable frame-by-frame animations, personalized content, and responsive iconography without conditional component trees." ;
    oc:severityLevel "MEDIUM" .

oc:kn_743cb5ec a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When loading images from external URLs or displaying animated GIFs" ;
    oc:directiveContent "Remote images must have CORS enabled on the source server, and animated GIFs must use the <Gif> component from @remotion/gif instead of <Img>." ;
    oc:hasRationale "Without CORS, remote images will fail to load during server-side rendering. The <Gif> component handles frame-by-frame GIF decoding that <Img> does not support." ;
    oc:severityLevel "HIGH" .

oc:kn_b0244d12 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When embedding any image in a Remotion composition" ;
    oc:directiveContent "Never use native HTML <img>, Next.js <Image>, or CSS background-image for images in Remotion compositions. Always use the <Img> component from 'remotion'." ;
    oc:hasRationale "The <Img> component ensures images are fully loaded before rendering begins, preventing flickering and blank frames during video export." ;
    oc:severityLevel "CRITICAL" .

oc:kn_decc8911 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When composition dimensions should adapt to the source image dimensions" ;
    oc:directiveContent "Use getImageDimensions() in calculateMetadata to dynamically size the composition to match the image aspect ratio before rendering begins." ;
    oc:hasRationale "Pre-fetching dimensions avoids misaligned compositions and ensures the video output matches the source media proportions." ;
    oc:severityLevel "MEDIUM" .

