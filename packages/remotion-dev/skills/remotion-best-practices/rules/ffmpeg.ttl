@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_remotion_dev_skills_remotion_best_practices_ffmpeg a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "ffmpeg" ;
    skos:broader "Video processing utility" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/remotion-dev/skills/remotion-best-practices" ;
    oc:contentHash "1b353dfd8f81c5edca268800428e33ee4b0ad17e870f7f76969b820268e25d48" ;
    oc:dependsOnSkill oc:skill_remotion_best_practices ;
    oc:differentia "provides FFmpeg and FFprobe access within the Remotion ecosystem for video manipulation, analysis, and trimming without requiring system-level installation" ;
    oc:extends oc:skill_remotion_dev_skills_remotion_best_practices ;
    oc:handlesFailure oc:InvalidInput,
        oc:PermissionDenied ;
    oc:hasArgumentHint "ffmpeg/ffprobe command with arguments (e.g., '-i input.mp4 output.mp3')" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_26118119,
        oc:kn_397763f5,
        oc:kn_9b514e81,
        oc:kn_a75d9b72,
        oc:kn_f2928b9f ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "analyze video metadata with ffprobe",
        "convert video formats",
        "process video with ffmpeg",
        "re-encode video clips",
        "trim videos" ;
    oc:yieldsState oc:VideoMetadataExtracted,
        oc:VideoProcessed .

oc:kn_26118119 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When running FFmpeg re-encoding operations" ;
    oc:directiveContent "FFmpeg commands create new output files and consume significant CPU during re-encoding; plan resource usage accordingly." ;
    oc:hasRationale "Re-encoding is CPU-intensive and generates new files on disk, impacting both compute resources and storage." ;
    oc:severityLevel "LOW" .

oc:kn_397763f5 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding between FFmpeg CLI trimming and component-level trimming" ;
    oc:directiveContent "Prefer the <Video> component's trimBefore and trimAfter props over FFmpeg trimming when the trim is dynamic or may change later." ;
    oc:hasRationale "Component-level trimming is non-destructive and allows trim adjustments without re-encoding, saving time and preserving quality." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9b514e81 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using FFmpeg to trim/cut video clips" ;
    oc:directiveContent "Never use stream-copy (-c copy) when trimming video with FFmpeg's -ss flag; you MUST re-encode the video to avoid frozen frames at the start." ;
    oc:hasRationale "Stream-copying with -ss copies from the nearest keyframe, which causes frozen or corrupt frames at the trim point since the required reference frames before the keyframe are missing." ;
    oc:severityLevel "CRITICAL" .

oc:kn_a75d9b72 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing a trimming strategy" ;
    oc:directiveContent "FFmpeg CLI trimming is destructive and produces a new file; <Video> trim props are non-destructive and reversible." ;
    oc:hasRationale "Understanding the destructive vs non-destructive nature determines whether the operation can be safely repeated or adjusted." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f2928b9f a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "Always when running ffmpeg or ffprobe commands in a Remotion project" ;
    oc:directiveContent "Use 'bunx remotion ffmpeg' and 'bunx remotion ffprobe' instead of installing FFmpeg system-wide; Remotion bundles these tools for you." ;
    oc:hasRationale "Avoids version mismatches, installation issues, and ensures the Remotion-compatible version is used." ;
    oc:severityLevel "HIGH" .

