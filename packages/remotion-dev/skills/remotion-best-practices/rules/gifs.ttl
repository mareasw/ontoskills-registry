@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_remotion_dev_skills_remotion_best_practices_gifs a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "gifs" ;
    skos:broader "Animated image display component" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/remotion-dev/skills/remotion-best-practices" ;
    oc:contentHash "db5d84bb8da4c52c133cdc9820a5b6995db94a548df5f9838efb8d1224065787" ;
    oc:dependsOnSkill oc:skill_remotion_best_practices ;
    oc:differentia "Synchronizes GIF, APNG, AVIF, and WebP animations with Remotion's video timeline" ;
    oc:extends oc:skill_remotion_dev_skills_remotion_best_practices ;
    oc:handlesFailure oc:CORSBlocked,
        oc:FileNotFound ;
    oc:hasAllowedTool "@remotion/gif",
        "remotion" ;
    oc:hasArgumentHint "image-source-path or URL" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_26099bdb,
        oc:kn_27329bd1,
        oc:kn_3e2644c6,
        oc:kn_4a6d126d,
        oc:kn_62d47fab ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:EnvironmentReady,
        oc:RemotionProjectInitialized ;
    oc:resolvesIntent "control animated image playback speed and looping",
        "display animated GIFs in video",
        "embed animated images in Remotion compositions",
        "get GIF duration for composition timing" ;
    oc:yieldsState oc:AnimatedImageRendered .

oc:kn_26099bdb a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When composing videos with animated image assets" ;
    oc:directiveContent "Never use animated images without setting composition duration to match. Use getGifDurationInSeconds() in calculateMetadata to sync composition length with the animation." ;
    oc:hasRationale "If the composition duration doesn't match the animation duration, the GIF will either be cut short or show a mismatch with the rest of the timeline." ;
    oc:severityLevel "HIGH" .

oc:kn_27329bd1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When rendering compositions that use <AnimatedImage>" ;
    oc:directiveContent "<AnimatedImage> is only supported in Chrome and Firefox. Use <Gif> from @remotion/gif as a fallback if <AnimatedImage> does not work." ;
    oc:hasRationale "Browser compatibility limits where <AnimatedImage> can be used; the @remotion/gif package provides a GIF-only alternative with wider support." ;
    oc:severityLevel "HIGH" .

oc:kn_3e2644c6 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When rendering compositions with animated images" ;
    oc:directiveContent "Animated images are frame-synchronized with Remotion's timeline, meaning the same frame always produces the same visual output for a given playbackRate and loopBehavior configuration." ;
    oc:hasRationale "Frame synchronization is essential for deterministic rendering, ensuring that repeated renders produce identical output." ;
    oc:severityLevel "MEDIUM" .

oc:kn_4a6d126d a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When using remote URLs as src for <AnimatedImage> or <Gif>" ;
    oc:directiveContent "Remote URLs for animated images must have CORS enabled, otherwise the image will fail to load at render time." ;
    oc:hasRationale "Without CORS headers, the browser/runtime cannot fetch the remote resource, causing silent failures during rendering." ;
    oc:severityLevel "CRITICAL" .

oc:kn_62d47fab a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing which component to use for animated images" ;
    oc:directiveContent "Prefer <AnimatedImage> over <Gif> for animated images, as it supports multiple formats (GIF, APNG, AVIF, WebP) while <Gif> only supports GIF files." ;
    oc:hasRationale "<AnimatedImage> is the modern, format-agnostic component; <Gif> exists only as a fallback for browsers that don't support <AnimatedImage>." ;
    oc:severityLevel "MEDIUM" .

