@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_remotion_dev_skills_remotion_best_practices_calculate_metadata a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "calculate-metadata" ;
    skos:broader "Remotion composition configuration function" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/remotion-dev/skills/remotion-best-practices" ;
    oc:contentHash "fc7c3f411a38020686e1295078fdf0ac9e1b889296192b5c7d4a4871edb2b662" ;
    oc:dependsOnSkill oc:skill_remotion_best_practices ;
    oc:differentia "dynamically sets duration, dimensions, props, and output settings before rendering by resolving metadata from external resources like videos and APIs" ;
    oc:extends oc:skill_remotion_dev_skills_remotion_best_practices ;
    oc:handlesFailure oc:InvalidInput,
        oc:NetworkTimeout ;
    oc:hasArgumentHint "CalculateMetadataFunction<Props> with props containing videoSrc or other resource references" ;
    oc:hasCategory "development" ;
    oc:hasRequirement oc:req_03938ee0,
        oc:req_5faf15eb,
        oc:req_b79743b9,
        oc:req_e529d240 ;
    oc:impartsKnowledge oc:kn_3e3282a4,
        oc:kn_613728ad,
        oc:kn_a780d54b,
        oc:kn_c2766754,
        oc:kn_dce9c075 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:CompositionDefined,
        oc:NetworkAvailable ;
    oc:resolvesIntent "calculate metadata for multiple video compositions",
        "match composition dimensions to video dimensions",
        "set composition duration dynamically based on video length",
        "set default output filename based on composition props",
        "transform props by fetching external data before rendering" ;
    oc:yieldsState oc:CompositionMetadataResolved .

oc:kn_3e3282a4 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When composition duration must match video playback length" ;
    oc:directiveContent "Do not hardcode durationInFrames on the <Composition> when it should depend on a video's actual length. Use calculateMetadata instead." ;
    oc:hasRationale "Hardcoded durations cause either truncated or padded output that mismatches the actual media content." ;
    oc:severityLevel "HIGH" .

oc:kn_613728ad a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a composition uses multiple sequential video sources" ;
    oc:directiveContent "Calculate total duration from multiple videos by mapping getVideoDuration over each, using Promise.all, then reducing to a sum before converting to frames." ;
    oc:hasRationale "Sequential video compositions require summing all durations rather than using a single video's length, which is a common source of incorrect frame counts." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a780d54b a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When fetching external data inside calculateMetadata" ;
    oc:directiveContent "Always pass abortSignal to fetch calls inside calculateMetadata so stale requests are cancelled when props change in Studio." ;
    oc:hasRationale "Without abortSignal, changing props in Studio triggers overlapping requests that waste resources and may resolve with stale data." ;
    oc:severityLevel "HIGH" .

oc:kn_c2766754 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing calculateMetadata functions" ;
    oc:directiveContent "All fields in the calculateMetadata return value are optional. Returned values override the corresponding <Composition> props." ;
    oc:hasRationale "Developers must understand that calculateMetadata is a partial override — unreturned fields retain their Composition-level defaults." ;
    oc:severityLevel "MEDIUM" .

oc:kn_dce9c075 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "Always — calculateMetadata is a pre-render phase with I/O side effects" ;
    oc:directiveContent "calculateMetadata runs asynchronously before rendering begins and can trigger network requests to external APIs or video file reads." ;
    oc:hasRationale "Agents must account for latency and potential failure of external calls when designing calculateMetadata logic." ;
    oc:severityLevel "LOW" .

oc:req_03938ee0 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Remotion Composition API" .

oc:req_5faf15eb a oc:RequirementAPI ;
    oc:isOptional false ;
    oc:requirementValue "remotion" .

oc:req_b79743b9 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "getVideoDimensions utility" .

oc:req_e529d240 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "getVideoDuration utility" .

