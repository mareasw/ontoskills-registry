@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_remotion_dev_skills_remotion_best_practices_measuring_text a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "measuring-text" ;
    skos:broader "Layout utility guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/remotion-dev/skills/remotion-best-practices" ;
    oc:contentHash "5cab1807b9ae9f5be3fc0e1cb0e0513a69451e31e32657d6a665573331db6807" ;
    oc:differentia "provides techniques for measuring text dimensions, fitting text to containers, and detecting overflow in Remotion video compositions" ;
    oc:extends oc:skill_remotion_dev_skills_remotion_best_practices ;
    oc:handlesFailure oc:FontNotLoaded,
        oc:TextOverflow ;
    oc:hasAllowedTool "npx" ;
    oc:hasArgumentHint "text, fontFamily, fontSize, and optionally withinWidth, maxBoxWidth, or maxLines depending on the function" ;
    oc:hasCategory "development" ;
    oc:hasRequirement oc:req_03613f8f,
        oc:req_e925f915 ;
    oc:impartsKnowledge oc:kn_3f754a73,
        oc:kn_3ffeb9be,
        oc:kn_45028366,
        oc:kn_a06ab29d,
        oc:kn_ff9f1e84 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ToolInstalled ;
    oc:resolvesIntent "calculate optimal font size for text layout",
        "check if text overflows a box",
        "fit text to a container width",
        "measure text width and height" ;
    oc:yieldsState oc:LayoutComputed,
        oc:TextMeasured .

oc:kn_3f754a73 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When measuring text for layout purposes" ;
    oc:directiveContent "Use the exact same font properties (fontFamily, fontSize, fontWeight, letterSpacing) for measurement calls and the final rendering element." ;
    oc:hasRationale "Any mismatch between measurement and rendering properties produces incorrect layout calculations, causing text to overflow or underfill containers." ;
    oc:severityLevel "HIGH" .

oc:kn_3ffeb9be a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calling measureText multiple times" ;
    oc:directiveContent "measureText() results are cached — duplicate calls with identical parameters return cached results without recomputation." ;
    oc:hasRationale "Caching improves performance in render loops; knowing this allows you to call measureText freely without worrying about redundant computation." ;
    oc:severityLevel "LOW" .

oc:kn_45028366 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calling measureText or fitText" ;
    oc:directiveContent "Use validateFontIsLoaded: true to catch font loading issues early during development." ;
    oc:hasRationale "Silently missing fonts produce wrong measurements; validation throws an explicit error that is easier to debug." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a06ab29d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When styling measured text containers" ;
    oc:directiveContent "Never use CSS border or padding on text containers when precise measurement matters. Use outline instead." ;
    oc:hasRationale "Border and padding add to the computed dimensions, creating a mismatch between measured text size and rendered text size." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ff9f1e84 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before any text measurement call" ;
    oc:directiveContent "Always load fonts before calling any measurement function (measureText, fitText, fillTextBox). Use waitUntilDone() or waitForFonts() to ensure font readiness." ;
    oc:hasRationale "Measurement results are incorrect if the font hasn't finished loading, because the browser cannot compute accurate glyph dimensions." ;
    oc:severityLevel "CRITICAL" .

oc:req_03613f8f a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "font loading in Remotion" .

oc:req_e925f915 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "@remotion/layout-utils" .

