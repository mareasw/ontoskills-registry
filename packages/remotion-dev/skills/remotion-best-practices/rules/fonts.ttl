@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_remotion_dev_skills_remotion_best_practices_fonts a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "fonts" ;
    skos:broader "Font loading reference" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/remotion-dev/skills/remotion-best-practices" ;
    oc:contentHash "1749e4cf82e8b157d4b0a26f46721152d3ef9e5e9a1686753b8bb6a1be83ddbc" ;
    oc:dependsOnSkill oc:skill_remotion_best_practices ;
    oc:differentia "provides patterns for integrating Google Fonts and local fonts into Remotion video compositions with proper loading and rendering guarantees" ;
    oc:extends oc:skill_remotion_dev_skills_remotion_best_practices ;
    oc:handlesFailure oc:FileNotFound,
        oc:NetworkTimeout ;
    oc:hasAllowedTool "Bash" ;
    oc:hasArgumentHint "font-family or font configuration" ;
    oc:hasCategory "development" ;
    oc:hasRequirement oc:req_1f77ec7c,
        oc:req_3312e6a5,
        oc:req_aad9bed4 ;
    oc:impartsKnowledge oc:kn_29f820b4,
        oc:kn_2ac06582,
        oc:kn_a4a166d7,
        oc:kn_b7a9fd34,
        oc:kn_bab375cb,
        oc:kn_c3b94957 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "configure font weights and subsets for video rendering",
        "ensure fonts are loaded before rendering",
        "load google fonts in remotion",
        "load local fonts in remotion" ;
    oc:yieldsState oc:FontLoaded .

oc:kn_29f820b4 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring component code that uses custom fonts" ;
    oc:directiveContent "Do not call loadFont() inside component render bodies or useEffect hooks — call it at the module top level or in an early import." ;
    oc:hasRationale "Calling loadFont() inside render cycles can cause repeated loading, race conditions, or fonts not being ready at render time." ;
    oc:severityLevel "CRITICAL" .

oc:kn_2ac06582 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When loading local fonts with @remotion/fonts" ;
    oc:directiveContent "Place local font files in the public/ directory and reference them via staticFile() to ensure they are bundled correctly." ;
    oc:hasRationale "The public/ directory is Remotion's convention for static assets that are served during preview and rendering." ;
    oc:severityLevel "HIGH" .

oc:kn_a4a166d7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing between Google Fonts and local fonts" ;
    oc:directiveContent "Prefer @remotion/google-fonts for web fonts as it is type-safe and automatically blocks rendering until the font is ready." ;
    oc:hasRationale "Type safety and automatic render-blocking prevent flicker or missing-font frames in video output." ;
    oc:severityLevel "HIGH" .

oc:kn_b7a9fd34 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When a font family requires multiple weights (e.g., regular 400 and bold 700)" ;
    oc:directiveContent "Load multiple font weights by calling loadFont() separately for each weight with the same family name, using Promise.all() for parallel loading." ;
    oc:hasRationale "Each weight is a separate font-face definition; parallel loading ensures all weights are available without sequential delays." ;
    oc:severityLevel "MEDIUM" .

oc:kn_bab375cb a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calling loadFont() from @remotion/google-fonts" ;
    oc:directiveContent "Specify only the needed weights and subsets when loading Google Fonts to minimize bundle and rendering overhead." ;
    oc:hasRationale "Importing all weights and subsets increases file size unnecessarily, slowing down rendering and increasing resource usage." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c3b94957 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When you need guaranteed font availability before proceeding" ;
    oc:directiveContent "Use waitUntilDone() to explicitly await font readiness when font loading timing is critical or when rendering programmatically." ;
    oc:hasRationale "Explicit waiting removes ambiguity about font availability and is especially useful in programmatic rendering pipelines." ;
    oc:severityLevel "LOW" .

oc:req_1f77ec7c a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "@remotion/fonts" .

oc:req_3312e6a5 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "CSS font-face and font-family properties" .

oc:req_aad9bed4 a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "@remotion/google-fonts" .

