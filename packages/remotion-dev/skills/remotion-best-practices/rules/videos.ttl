@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_remotion_dev_skills_remotion_best_practices_videos a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "videos" ;
    skos:broader "Media embedding component guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/remotion-dev/skills/remotion-best-practices" ;
    oc:contentHash "d9d3032a57f92c759daf0bd60b3282f6810ecc9958e9093a6b828de623b05328" ;
    oc:differentia "that teaches how to embed, trim, delay, size, control volume, speed, loop, and pitch-shift videos in Remotion compositions using the `<Video>` component from `@remotion/media`" ;
    oc:extends oc:skill_remotion_dev_skills_remotion_best_practices ;
    oc:handlesFailure oc:MediaFileNotFound,
        oc:PackageNotInstalled,
        oc:UnsupportedVideoFormat ;
    oc:hasArgumentHint "video source path or URL" ;
    oc:hasCategory "development" ;
    oc:hasRequirement oc:req_8e3216f4,
        oc:req_ac74ef7a,
        oc:req_bbe08332,
        oc:req_d97a5491 ;
    oc:impartsKnowledge oc:kn_3ff4a5ed,
        oc:kn_bcc44513,
        oc:kn_c712cb74,
        oc:kn_d0300e14,
        oc:kn_de5f5122 ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:PackageInstalled,
        oc:RemotionProjectInitialized ;
    oc:resolvesIntent "control video volume speed and pitch in remotion",
        "delay video playback in remotion",
        "embed video in remotion composition",
        "loop video in remotion",
        "trim video in remotion" ;
    oc:yieldsState oc:VideoEmbedded .

oc:kn_3ff4a5ed a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scheduling video playback timing in a composition" ;
    oc:directiveContent "Use Sequence wrapper to delay video appearance rather than manipulating trimBefore. Use trimBefore/trimAfter for cutting content, and Sequence for timeline positioning." ;
    oc:hasRationale "Separating concerns: Sequence controls when the video starts in the composition timeline, while trim controls which portion of the source video plays. Mixing these concerns leads to confusing code." ;
    oc:severityLevel "MEDIUM" .

oc:kn_bcc44513 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using the toneFrequency prop to adjust audio pitch" ;
    oc:directiveContent "Pitch shifting (toneFrequency) only works during server-side rendering, not in the Remotion Studio preview or in the <Player /> component." ;
    oc:hasRationale "Pitch shifting relies on server-side audio processing that is not available in browser-based playback. Developers must not rely on Studio preview for pitch verification." ;
    oc:severityLevel "HIGH" .

oc:kn_c712cb74 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When looping videos with dynamic volume callbacks" ;
    oc:directiveContent "Use the loopVolumeCurveBehavior prop ('repeat' or 'extend') to control volume callback frame counting across loop iterations, ensuring smooth fade effects." ;
    oc:hasRationale "Without explicit loopVolumeCurveBehavior, the volume callback may behave unexpectedly on loop boundaries — 'repeat' resets frame count per loop (good for per-loop fades), while 'extend' continues incrementing (good for gradual fade across many loops)." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d0300e14 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adjusting video speed with playbackRate" ;
    oc:directiveContent "Reverse video playback is not supported via playbackRate or any other mechanism." ;
    oc:hasRationale "Remotion's video rendering pipeline does not support reverse decoding. Use negative playbackRate values or reverse playback will silently fail or produce incorrect output." ;
    oc:severityLevel "HIGH" .

oc:kn_de5f5122 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before embedding any video in a Remotion composition" ;
    oc:directiveContent "Ensure @remotion/media is installed before using the <Video> component. Install it via `npx remotion add @remotion/media` (or the equivalent for your package manager)." ;
    oc:hasRationale "The <Video> component is exported from @remotion/media, not from the core remotion package. Without it, imports will fail." ;
    oc:severityLevel "CRITICAL" .

oc:req_8e3216f4 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "@remotion/media package" .

oc:req_ac74ef7a a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "Remotion useVideoConfig and interpolate hooks" .

oc:req_bbe08332 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "Remotion project setup" .

oc:req_d97a5491 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "React component syntax" .

