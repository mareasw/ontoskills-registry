@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_remotion_dev_skills_remotion_best_practices_light_leaks a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "light-leaks" ;
    skos:broader "Visual effect component" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/remotion-dev/skills/remotion-best-practices" ;
    oc:contentHash "17d2f136f7bf2f438274a0ade43df017c360ae31175d8367ce476415c222dfca" ;
    oc:dependsOnSkill oc:skill_remotion_best_practices ;
    oc:differentia "renders WebGL-based light leak overlay effects for scene transitions and decorative overlays in Remotion videos" ;
    oc:extends oc:skill_remotion_dev_skills_remotion_best_practices ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "props: { durationInFrames?, seed?, hueShift? }" ;
    oc:hasCategory "development" ;
    oc:hasRequirement oc:req_04f3108f,
        oc:req_694b136b ;
    oc:impartsKnowledge oc:kn_00738a92,
        oc:kn_0429095c,
        oc:kn_326638bb,
        oc:kn_36d90755,
        oc:kn_ca2562e3 ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "add light leak overlay to video",
        "create cinematic transition effects",
        "customize light leak color and pattern" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_00738a92 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When customizing light leak appearance" ;
    oc:directiveContent "Use the `seed` prop to control the pattern shape and `hueShift` to control color: 0 = yellow-orange (default), 120 = green, 240 = blue. Experiment with different seed values for varied patterns." ;
    oc:hasRationale "Seed and hueShift provide deterministic, reproducible visual variations without requiring custom WebGL shaders." .

oc:kn_0429095c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding atmospheric effects to any composition" ;
    oc:directiveContent "<LightLeak> can be used standalone outside of TransitionSeries as a decorative overlay by placing it inside an <AbsoluteFill> container alongside other content." ;
    oc:hasRationale "The component is not limited to transitions; it can serve as a creative overlay effect anywhere in a composition for visual flair." .

oc:kn_326638bb a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting durationInFrames for a LightLeak overlay" ;
    oc:directiveContent "The light leak reveals during the first half of its duration and retracts during the second half. Plan durationInFrames accordingly — shorter durations create snappier transitions, longer ones create dreamier effects." ;
    oc:hasRationale "The built-in reveal/retract symmetry means the effect is inherently timed to the midpoint, making duration the primary creative control." .

oc:kn_36d90755 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing transitions with light leaks" ;
    oc:directiveContent "Use <LightLeak> inside a <TransitionSeries.Overlay> to play over the cut point between two scenes, not as a replacement for a scene." ;
    oc:hasRationale "The overlay pattern ensures the light leak plays on top of both adjacent scenes at the transition point, creating a natural cinematic effect." .

oc:kn_ca2562e3 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before using <LightLeak>" ;
    oc:directiveContent "This component requires Remotion 4.0.415 or later. Use `npx remotion versions` to check and `npx remotion upgrade` to upgrade." ;
    oc:hasRationale "The @remotion/light-leaks package was introduced in 4.0.415 and will not work on earlier versions." ;
    oc:severityLevel "CRITICAL" .

oc:req_04f3108f a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Remotion 4.0.415+" .

oc:req_694b136b a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "@remotion/light-leaks" .

