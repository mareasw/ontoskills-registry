@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coinbase_agentic_wallet_skills_trade a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "trade" ;
    skos:broader "Token swap command" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coinbase/agentic-wallet-skills/trade" ;
    oc:contentHash "e4b3b168ab54d0ba12ce378eb64775ecc7a0ae8e5a8fae08b9ca697328a58d7d" ;
    oc:dependsOnSkill oc:skill_authenticate_wallet ;
    oc:differentia "executes atomic token trades on Base network via CDP Swap API using the awal CLI" ;
    oc:handlesFailure oc:InsufficientBalance,
        oc:InvalidInput,
        oc:LiquidityUnavailable,
        oc:NetworkTimeout ;
    oc:hasAllowedTool "Bash(npx awal@2.0.3 balance*)",
        "Bash(npx awal@2.0.3 status*)",
        "Bash(npx awal@2.0.3 trade *)" ;
    oc:hasArgumentHint "amount from to [options] — e.g. '$1' usdc eth" ;
    oc:hasCategory "finance" ;
    oc:hasDescription "Swap or trade tokens on Base network. Use when you or the user want to trade, swap, exchange, buy, sell, or convert between tokens like USDC, ETH, and WETH. Covers phrases like \"buy ETH\", \"sell ETH for USDC\", \"convert USDC to ETH\", \"get some ETH\"." ;
    oc:hasName "trade" ;
    oc:impartsKnowledge oc:kn_03516e18,
        oc:kn_46338747,
        oc:kn_4d25ff2f,
        oc:kn_72b3f302,
        oc:kn_86d052c5,
        oc:kn_aea3e36b,
        oc:kn_ca2feef7,
        oc:kn_d5543705 ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:SystemAuthenticated,
        oc:WalletFunded ;
    oc:resolvesIntent "buy tokens with USDC",
        "convert between tokens like ETH and USDC",
        "exchange tokens on Base network",
        "sell tokens for USDC",
        "swap tokens on Base",
        "trade one token for another" ;
    oc:yieldsState oc:TokenSwapCompleted .

oc:kn_03516e18 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "After executing a trade command" ;
    oc:directiveContent "A successful trade returns swap details including the amount received. Use --json flag for machine-readable output to programmatically confirm the trade completed." ;
    oc:hasRationale "Confirming the actual received amount ensures the trade executed at an acceptable rate and completed fully." ;
    oc:severityLevel "MEDIUM" .

oc:kn_46338747 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When validating trade parameters before execution" ;
    oc:directiveContent "Never attempt to swap a token to itself (e.g. usdc to usdc). The from and to tokens must always be different." ;
    oc:hasRationale "Same-token swaps are rejected by the API and indicate a user error in specifying the trade." ;
    oc:severityLevel "HIGH" .

oc:kn_4d25ff2f a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When constructing any trade command" ;
    oc:directiveContent "Always single-quote amounts that use '$' to prevent bash variable expansion (e.g. '$1.00' not $1.00). Validate all user input against strict regex patterns before passing to the shell command." ;
    oc:hasRationale "Unvalidated user input passed to shell commands enables injection attacks; unquoted $ signs get interpreted as bash variables causing incorrect amounts." ;
    oc:severityLevel "CRITICAL" .

oc:kn_72b3f302 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before executing any trade command" ;
    oc:directiveContent "Run 'npx awal@2.0.3 status' before trading to confirm wallet is authenticated and initialized. If not authenticated, refer to the authenticate-wallet skill first." ;
    oc:hasRationale "Trading requires a valid authenticated wallet session; attempting to trade without authentication will fail." ;
    oc:severityLevel "HIGH" .

oc:kn_86d052c5 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "Always — every trade execution" ;
    oc:directiveContent "Executing a trade permanently transfers tokens from the wallet on Base network. The operation is irreversible once the swap is confirmed on-chain." ;
    oc:hasRationale "On-chain transactions cannot be reversed; users must be certain before executing trades, especially large ones." ;
    oc:severityLevel "CRITICAL" .

oc:kn_aea3e36b a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When trade command returns an error" ;
    oc:directiveContent "If 'No liquidity' error occurs, try a smaller amount or a different token pair. If 'TRANSFER_FROM_FAILED' occurs, check wallet balance and token approval status." ;
    oc:hasRationale "Liquidity constraints and approval issues are common DeFi failures with straightforward remediation paths." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ca2feef7 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When specifying or interpreting trade amounts" ;
    oc:directiveContent "For known tokens (usdc=6, eth=18, weth=18), decimal handling is automatic. Large integers without a decimal point are auto-detected as atomic units. For arbitrary contract addresses, decimals are read from the token contract on-chain." ;
    oc:hasRationale "Incorrect decimal interpretation leads to trades that are orders of magnitude wrong — e.g. 500000 as 500,000 USDC instead of $0.50." ;
    oc:severityLevel "HIGH" .

oc:kn_d5543705 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before constructing any npx awal trade command" ;
    oc:directiveContent "Amount must match ^\\$?[\\d.]+$, token identifiers must be a known alias (usdc, eth, weth) or a valid 0x hex address, and slippage must be a positive integer. Reject input containing shell metacharacters (spaces, semicolons, pipes, backticks)." ;
    oc:hasRationale "Strict input validation prevents shell injection and ensures the swap API receives well-formed parameters." ;
    oc:severityLevel "CRITICAL" .

